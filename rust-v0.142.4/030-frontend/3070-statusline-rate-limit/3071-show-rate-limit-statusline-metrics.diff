+fn status_line_version_display_line(
+    cli_version: &str,
+    remote_app_server_version: Option<Option<&str>>,
+) -> Line<'static> {
+    let Some(app_server_version) = remote_app_server_version else {
+        return Line::from(cli_version.to_string().red());
+    };
+    let Some(app_server_version) = app_server_version else {
+        return Line::from(vec![
+            cli_version.to_string().dim(),
+            " ".into(),
+            "unknown".red(),
+        ]);
+    };
+    if app_server_version == "unknown" {
+        return Line::from(vec![
+            cli_version.to_string().dim(),
+            " ".into(),
+            "unknown".red(),
+        ]);
+    }
+
+    let app_server_display_version = app_server_version.trim_start_matches('v');
+    if app_server_display_version == cli_version {
+        return Line::from(cli_version.to_string().green());
+    }
+    Line::from(vec![
+        cli_version.to_string().dim(),
+        " ".into(),
+        app_server_display_version
+            .to_string()
+            .fg(app_server_version_mismatch_color(
+                cli_version,
+                app_server_display_version,
+            )),
+    ])
+}
+
+fn app_server_version_mismatch_color(cli_version: &str, app_server_version: &str) -> Color {
+    match (
+        ParsedCodexVersion::parse(cli_version),
+        ParsedCodexVersion::parse(app_server_version),
+    ) {
+        (Some(cli), Some(app_server)) if cli.is_within_one_version_of(app_server) => Color::Yellow,
+        _ => Color::Red,
+    }
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct ParsedCodexVersion {
+    major: u64,
+    minor: u64,
+    patch: u64,
+}
+
+impl ParsedCodexVersion {
+    fn parse(value: &str) -> Option<Self> {
+        let value = value.trim();
+        let value = value
+            .strip_prefix("rust-v")
+            .or_else(|| value.strip_prefix('v'))
+            .unwrap_or(value);
+        let numeric = value.split_once('-').map_or(value, |(numeric, _)| numeric);
+        let mut parts = numeric.split('.');
+        let major = parts.next()?.parse().ok()?;
+        let minor = parts.next()?.parse().ok()?;
+        let patch = parts.next()?.parse().ok()?;
+        if parts.next().is_some() {
+            return None;
+        }
+        Some(Self {
+            major,
+            minor,
+            patch,
+        })
+    }
+
+    fn is_within_one_version_of(self, other: Self) -> bool {
+        if self.major != other.major {
+            return false;
+        }
+        if self.minor == other.minor {
+            return self.patch.abs_diff(other.patch) <= 1;
+        }
+        self.minor.abs_diff(other.minor) <= 1
+    }
+}
