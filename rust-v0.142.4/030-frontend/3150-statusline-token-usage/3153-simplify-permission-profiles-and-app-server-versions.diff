+pub(super) fn permission_profile_selection_config_edits(
+    selection: &PermissionProfileSelection,
+) -> Vec<codex_app_server_protocol::ConfigEdit> {
+    let mut edits = vec![crate::config_update::replace_config_value(
+        "default_permissions",
+        serde_json::json!(selection.profile_id),
+    )];
+    if let Some(policy) = selection.approval_policy {
+        edits.push(crate::config_update::replace_config_value(
+            "approval_policy",
+            serde_json::to_value(policy)
+                .unwrap_or_else(|err| panic!("approval policy should serialize: {err}")),
+        ));
+    }
+    if let Some(reviewer) = selection.approvals_reviewer {
+        edits.push(crate::config_update::replace_config_value(
+            "approvals_reviewer",
+            serde_json::json!(reviewer.to_string()),
+        ));
+    }
+    edits
+}
+
 impl App {
+    pub(super) async fn persist_permission_profile_selection(
+        &mut self,
+        app_server: &mut AppServerSession,
+        selection: &PermissionProfileSelection,
+    ) -> bool {
+        let edits = permission_profile_selection_config_edits(selection);
+
+        let write_response = match crate::config_update::write_config_batch(
+            app_server.request_handle(),
+            edits,
+        )
+        .await
+        {
+            Ok(response) => response,
+            Err(err) => {
+                let error = crate::config_update::format_config_error(&err);
+                tracing::error!(error = %error, "failed to persist permission profile selection");
+                self.chat_widget
+                    .add_error_message(format!("Failed to save permission profile: {error}"));
+                return false;
+            }
+        };
+        if write_response.status == WriteStatus::OkOverridden {
+            let message = overridden_write_message(&write_response);
+            tracing::warn!(
+                message,
+                "permission profile config write was overridden by effective config"
+            );
+            self.chat_widget.add_error_message(format!(
+                "Permission profile was saved but not applied: {message}"
+            ));
+            return false;
+        }
+
+        true
+    }
