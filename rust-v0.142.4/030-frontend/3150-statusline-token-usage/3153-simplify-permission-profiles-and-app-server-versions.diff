+fn workspace_profile_has_only_default_writes(
+    permission_profile: &PermissionProfile,
+    cwd: &AbsolutePathBuf,
+) -> bool {
+    let PermissionProfile::Managed { file_system, .. } = permission_profile else {
+        return false;
+    };
+    let ManagedFileSystemPermissions::Restricted { entries, .. } = file_system else {
+        return false;
+    };
+    entries.iter().all(|entry| {
+        if !entry.access.can_write() {
+            return true;
+        }
+        match &entry.path {
+            FileSystemPath::Special {
+                value:
+                    FileSystemSpecialPath::ProjectRoots { subpath: None }
+                    | FileSystemSpecialPath::Tmpdir
+                    | FileSystemSpecialPath::SlashTmp,
+            } => true,
+            FileSystemPath::Path { path } => path == cwd,
+            _ => false,
+        }
+    })
