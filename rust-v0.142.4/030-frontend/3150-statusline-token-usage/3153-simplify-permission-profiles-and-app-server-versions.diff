+            output_tokens: 200,
+            reasoning_output_tokens: 200,
+            total_tokens: 1_200,
+        };
+
+        assert_eq!(
+            response_tokens_per_second(Some(&token_usage), Some(10_000)),
+            None
+        );
+    }
+
+    #[test]
