+            output_tokens: 500,
+            reasoning_output_tokens: 450,
+            total_tokens: 1_500,
+        };
+
+        assert_eq!(
+            response_tokens_per_second(Some(&token_usage), Some(10_000)),
+            Some(5.0)
+        );
+    }
+
+    #[test]
+    fn tps_is_hidden_when_visible_output_is_absent() {
+        let token_usage = TokenUsage {
+            input_tokens: 1_000,
