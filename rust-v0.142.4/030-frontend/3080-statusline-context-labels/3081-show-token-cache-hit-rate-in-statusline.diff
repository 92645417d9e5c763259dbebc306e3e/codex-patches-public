+
+    let exec = begin_exec(&mut chat, "call-1", "git switch feature/demo");
+    end_exec(
+        &mut chat, exec, /*stdout*/ "", /*stderr*/ "", /*exit_code*/ 0,
+    );
+
+    assert!(chat.status_line_branch_pending);
+}
