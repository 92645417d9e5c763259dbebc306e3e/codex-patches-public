+//! Local model-name colors for TUI personalization.
+
+#![allow(clippy::disallowed_methods)]
+
+use ratatui::style::Color;
+use ratatui::style::Style;
+
+const MODEL_COLORS: [Color; 5] = [
+    Color::Rgb(89, 169, 255),
+    Color::Rgb(45, 212, 191),
+    Color::Rgb(74, 222, 128),
+    Color::Rgb(167, 139, 250),
+    Color::Rgb(148, 163, 184),
+];
+const KNOWN_MODELS: [&str; 5] = [
+    "gpt-5.4",
+    "gpt-5.5",
+    "gpt-5.4-mini",
+    "gpt-5.3-codex",
+    "gpt-5.2",
+];
+
+pub(crate) fn model_style(model: &str) -> Style {
+    Style::default().fg(model_color(model))
+}
+
+fn model_color(model: &str) -> Color {
+    if let Some(idx) = KNOWN_MODELS
+        .iter()
+        .position(|known_model| *known_model == model)
+    {
+        return MODEL_COLORS[idx % MODEL_COLORS.len()];
+    }
+
+    let idx = model
+        .bytes()
+        .fold(0usize, |acc, byte| acc.wrapping_add(byte as usize))
+        % MODEL_COLORS.len();
+    MODEL_COLORS[idx]
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+
+    #[test]
+    fn known_models_have_stable_colors() {
+        for (idx, model) in KNOWN_MODELS.iter().enumerate() {
+            let color = MODEL_COLORS[idx % MODEL_COLORS.len()];
+            assert_eq!(model_style(model).fg, Some(color));
+        }
+    }
+
+    #[test]
+    fn known_model_colors_do_not_repeat_before_palette_wraps() {
+        let colors: std::collections::HashSet<_> = KNOWN_MODELS
+            .iter()
+            .map(|model| model_style(model).fg)
+            .collect();
+
+        assert_eq!(
+            colors.len(),
+            KNOWN_MODELS.len().min(MODEL_COLORS.len()),
+            "known model colors should not repeat before palette colors are exhausted"
+        );
+    }
+
+    #[test]
+    fn unknown_model_color_is_deterministic() {
+        assert_eq!(model_style("future-model"), model_style("future-model"));
+    }
+}
