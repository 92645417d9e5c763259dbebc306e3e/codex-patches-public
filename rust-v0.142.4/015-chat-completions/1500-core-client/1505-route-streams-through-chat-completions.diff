+#[test]
+fn responses_api_input_view_drops_reasoning_content() {
+    let input = vec![
+        ResponseItem::Reasoning {
+            id: Some("rs_1".to_string()),
+            summary: vec![ReasoningItemReasoningSummary::SummaryText {
+                text: "summary".to_string(),
+            }],
+            content: Some(vec![ReasoningItemContent::ReasoningText {
+                text: "raw reasoning".to_string(),
+            }]),
+            encrypted_content: None,
+            internal_chat_message_metadata_passthrough: None,
+        },
+        output_message("msg_1", "done"),
+    ];
+
+    let request_input = super::responses_api_input_view(input.clone());
+
+    assert_eq!(input[0], {
+        ResponseItem::Reasoning {
+            id: Some("rs_1".to_string()),
+            summary: vec![ReasoningItemReasoningSummary::SummaryText {
+                text: "summary".to_string(),
+            }],
+            content: Some(vec![ReasoningItemContent::ReasoningText {
+                text: "raw reasoning".to_string(),
+            }]),
+            encrypted_content: None,
+            internal_chat_message_metadata_passthrough: None,
+        }
+    });
+    let ResponseItem::Reasoning { content, .. } = &request_input[0] else {
+        panic!("expected reasoning item");
+    };
+    assert_eq!(content, &None);
+    assert_eq!(request_input[1], input[1]);
+}
