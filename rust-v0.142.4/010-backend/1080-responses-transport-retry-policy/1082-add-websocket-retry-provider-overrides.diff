+fn overlay_openai_provider(base: &mut ModelProviderInfo, provider: ModelProviderInfo) {
+    if !provider.name.is_empty() {
+        base.name = provider.name;
+    }
+    if provider.base_url.is_some() {
+        base.base_url = provider.base_url;
+    }
+    if provider.env_key.is_some() {
+        base.env_key = provider.env_key;
+    }
+    if provider.env_key_instructions.is_some() {
+        base.env_key_instructions = provider.env_key_instructions;
+    }
+    if provider.experimental_bearer_token.is_some() {
+        base.experimental_bearer_token = provider.experimental_bearer_token;
+    }
+    if provider.auth.is_some() {
+        base.auth = provider.auth;
+    }
+    if provider.aws.is_some() {
+        base.aws = provider.aws;
+    }
+    if provider.query_params.is_some() {
+        base.query_params = provider.query_params;
+    }
+    if provider.http_headers.is_some() {
+        base.http_headers = provider.http_headers;
+    }
+    if provider.env_http_headers.is_some() {
+        base.env_http_headers = provider.env_http_headers;
+    }
+    if provider.request_max_retries.is_some() {
+        base.request_max_retries = provider.request_max_retries;
+    }
+    if provider.stream_max_retries.is_some() {
+        base.stream_max_retries = provider.stream_max_retries;
+    }
+    if provider.stream_idle_timeout_ms.is_some() {
+        base.stream_idle_timeout_ms = provider.stream_idle_timeout_ms;
+    }
+    if provider.websocket_connect_timeout_ms.is_some() {
+        base.websocket_connect_timeout_ms = provider.websocket_connect_timeout_ms;
+    }
+    if provider.requires_openai_auth {
+        base.requires_openai_auth = true;
+    }
+    base.wire_api = provider.wire_api;
+    base.supports_websockets = provider.supports_websockets;
+}
