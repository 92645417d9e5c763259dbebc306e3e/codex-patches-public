+fn account_rate_limit_key(snapshot: &CoreRateLimitSnapshot, index: usize) -> String {
+    if let Some(limit_id) = snapshot
+        .limit_id
+        .as_deref()
+        .map(str::trim)
+        .filter(|limit_id| !limit_id.is_empty())
+    {
+        return limit_id.to_string();
+    }
+
+    if let Some(limit_name) = snapshot
+        .limit_name
+        .as_deref()
+        .map(str::trim)
+        .filter(|limit_name| !limit_name.is_empty())
+        .filter(|limit_name| !limit_name.eq_ignore_ascii_case("codex"))
+    {
+        return limit_name.to_ascii_lowercase().replace(['-', ' '], "_");
+    }
+
+    format!("unknown_{index}")
+}
