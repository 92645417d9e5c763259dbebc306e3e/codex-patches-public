+#[tokio::test]
+async fn instructions_overlay_seeds_instruction_template_as_string() {
+    let prompted = remote_model_with_prompt(
+        "prompted-cache-model",
+        "Prompted Cache Model",
+        /*priority*/ 1,
+        "upstream prompt\nwith newline",
+    );
+    let plain = remote_model(
+        "plain-cache-model",
+        "Plain Cache Model",
+        /*priority*/ 2,
+    );
+    let codex_home = tempdir().expect("temp dir");
+    let endpoint = TestModelsEndpoint::new(vec![vec![prompted.clone(), plain]]);
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint);
+
+    manager
+        .refresh_available_models(RefreshStrategy::OnlineIfUncached)
+        .await
+        .expect("refresh succeeds");
+    let _ = manager.get_remote_models().await;
+
+    let overlay = read_instructions_overlay(codex_home.path());
+    assert_eq!(
+        overlay["models"]["prompted-cache-model"]["model_messages"]["instructions_template"],
+        json!("upstream prompt\nwith newline")
+    );
+    let overlay_text = read_instructions_overlay_text(codex_home.path());
+    assert!(overlay_text.contains("\"instructions_template\": \"upstream prompt\\nwith newline\""));
+    assert!(!overlay_text.contains("\"instructions_template\": ["));
+    assert!(overlay["models"]["plain-cache-model"].is_null());
+    assert_models_contain(&manager.get_remote_models().await, &[prompted]);
+}
