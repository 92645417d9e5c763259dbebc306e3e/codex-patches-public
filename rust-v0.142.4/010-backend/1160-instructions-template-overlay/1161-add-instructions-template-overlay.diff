+use codex_protocol::openai_models::ModelInfo;
+use serde_json::Map;
+use serde_json::Value;
+use std::fs;
+use std::io;
+use std::io::ErrorKind;
+use std::path::Path;
+use std::path::PathBuf;
+use tracing::warn;
+
+pub(crate) const INSTRUCTIONS_OVERLAY_FILE: &str = "instructions.json";
+
+#[derive(Debug, Clone)]
+pub(crate) struct ModelsCacheOverlay {
+    path: PathBuf,
+}
+
+impl ModelsCacheOverlay {
+    pub(crate) fn new(path: PathBuf) -> Self {
+        Self { path }
+    }
+
+    pub(crate) fn apply(&self, mut models: Vec<ModelInfo>) -> Vec<ModelInfo> {
+        let overlay = match load_or_seed(&self.path, &models) {
+            Ok(overlay) => overlay,
+            Err(err) => {
+                warn!(
+                    path = %self.path.display(),
+                    "failed to load instructions overlay: {err}"
+                );
+                return models;
+            }
+        };
+        for model in &mut models {
+            let Some(overlay_model) = overlay_model(&overlay, &model.slug) else {
+                continue;
+            };
+            apply_overlay_model(model, overlay_model, &self.path);
+        }
+        models
+    }
+}
+
+fn load_or_seed(path: &Path, models: &[ModelInfo]) -> io::Result<Value> {
+    let mut overlay = match fs::read(path) {
+        Ok(contents) => serde_json::from_slice::<Value>(&contents)
+            .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?,
+        Err(err) if err.kind() == ErrorKind::NotFound => empty_overlay(),
+        Err(err) => return Err(err),
+    };
+    let mut changed = false;
+    let overlay_models = models_object_mut(&mut overlay)?;
+    for model in models {
+        let Some(template) = instructions_template(model) else {
+            continue;
+        };
+        changed |= seed_model_template(overlay_models, model, template);
+    }
+    if changed || !path.exists() {
+        if let Some(parent) = path.parent() {
+            fs::create_dir_all(parent)?;
+        }
+        let json = serde_json::to_vec_pretty(&overlay)
+            .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+        fs::write(path, json)?;
+    }
+    Ok(overlay)
+}
+
+fn empty_overlay() -> Value {
+    let mut root = Map::new();
+    root.insert("models".to_string(), Value::Object(Map::new()));
+    Value::Object(root)
+}
+
+fn models_object_mut(overlay: &mut Value) -> io::Result<&mut Map<String, Value>> {
+    let Some(root) = overlay.as_object_mut() else {
+        return Err(io::Error::new(
+            ErrorKind::InvalidData,
+            "instructions overlay root must be an object",
+        ));
+    };
+    let models = root
+        .entry("models")
+        .or_insert_with(|| Value::Object(Map::new()));
+    models.as_object_mut().ok_or_else(|| {
+        io::Error::new(
+            ErrorKind::InvalidData,
+            "instructions overlay `models` must be an object",
+        )
+    })
+}
+
+fn instructions_template(model: &ModelInfo) -> Option<&str> {
+    model
+        .model_messages
+        .as_ref()
+        .and_then(|messages| messages.instructions_template.as_deref())
+        .filter(|template| !template.is_empty())
+}
+
+fn seed_model_template(
+    overlay_models: &mut Map<String, Value>,
+    model: &ModelInfo,
+    template: &str,
+) -> bool {
+    let entry = overlay_models
+        .entry(model.slug.clone())
+        .or_insert_with(|| Value::Object(Map::new()));
+    let Some(entry_object) = entry.as_object_mut() else {
+        warn!(
+            model = %model.slug,
+            "instructions overlay model entry must be an object"
+        );
+        return false;
+    };
+    if template_value(entry_object).is_some() {
+        return false;
+    }
+    let messages = entry_object
+        .entry("model_messages")
+        .or_insert_with(|| Value::Object(Map::new()));
+    let Some(messages_object) = messages.as_object_mut() else {
+        warn!(
+            model = %model.slug,
+            "instructions overlay model_messages must be an object"
+        );
+        return false;
+    };
+    messages_object.insert(
+        "instructions_template".to_string(),
+        Value::String(template.to_string()),
+    );
+    true
+}
+
+fn overlay_model<'a>(overlay: &'a Value, slug: &str) -> Option<&'a Map<String, Value>> {
+    overlay
+        .get("models")
+        .and_then(Value::as_object)
+        .and_then(|models| models.get(slug))
+        .and_then(Value::as_object)
+}
+
+fn template_value(model: &Map<String, Value>) -> Option<&Value> {
+    model
+        .get("model_messages")
+        .and_then(Value::as_object)
+        .and_then(|messages| messages.get("instructions_template"))
+}
+
+fn apply_overlay_model(model: &mut ModelInfo, overlay_model: &Map<String, Value>, path: &Path) {
+    let Some(messages) = model.model_messages.as_mut() else {
+        return;
+    };
+    let Some(template) = template_value(overlay_model) else {
+        return;
+    };
+    let Some(template) = template.as_str() else {
+        warn!(
+            model = %model.slug,
+            path = %path.display(),
+            "instructions overlay instructions_template must be a string"
+        );
+        return;
+    };
+    if template.is_empty() {
+        warn!(
+            model = %model.slug,
+            path = %path.display(),
+            "instructions overlay instructions_template must not be empty"
+        );
+        return;
+    }
+    messages.instructions_template = Some(template.to_string());
+}
