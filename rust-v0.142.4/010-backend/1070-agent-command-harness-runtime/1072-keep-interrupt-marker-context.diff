+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn interrupted_guidance_does_not_invite_a_marker_reply() {
+        for guidance in [
+            TurnAborted::INTERRUPTED_GUIDANCE,
+            TurnAborted::INTERRUPTED_DEVELOPER_GUIDANCE,
+        ] {
+            assert!(guidance.contains("not a user request"));
+            assert!(guidance.contains("do not reply to this marker by itself"));
+            assert!(guidance.contains("later user message"));
+            assert!(guidance.contains("latest instruction"));
+        }
+    }
+
+    #[test]
+    fn interrupted_guidance_routes_later_steers_to_latest_instruction() {
+        let marker = TurnAborted::new(TurnAborted::INTERRUPTED_DEVELOPER_GUIDANCE);
+        let rendered_marker = marker.body();
+
+        assert!(rendered_marker.contains("This is context, not a user request"));
+        assert!(rendered_marker.contains("If a later user message is present"));
+        assert!(!rendered_marker.contains("ask the user what to do"));
+    }
+}
