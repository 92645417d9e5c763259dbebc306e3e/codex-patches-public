+struct GuardianManualApprovalEvents {
+    approval_request: ExecApprovalRequestEvent,
+    warnings: Vec<String>,
+    denial_rationales: Vec<Option<String>>,
+    statuses: Vec<GuardianAssessmentStatus>,
+}
+
+async fn enable_manual_approval_responses(session: &Arc<Session>) {
+    *session.active_turn.lock().await = Some(crate::state::ActiveTurn::default());
+}
+
+async fn receive_guardian_manual_approval(
+    rx: &async_channel::Receiver<Event>,
+    mut review: Pin<&mut impl Future<Output = ReviewDecision>>,
+) -> anyhow::Result<GuardianManualApprovalEvents> {
+    let mut warnings = Vec::new();
+    let mut denial_rationales = Vec::new();
+    let mut statuses = Vec::new();
+    loop {
+        let event = tokio::select! {
+            event = rx.recv() => event?,
+            decision = review.as_mut() => {
+                anyhow::bail!("guardian review finished before requesting manual approval: {decision:?}");
+            }
+            _ = tokio::time::sleep(Duration::from_secs(30)) => {
+                anyhow::bail!("timed out waiting for manual approval request");
+            }
+        };
+        match event.msg {
+            EventMsg::GuardianWarning(event) => warnings.push(event.message),
+            EventMsg::GuardianAssessment(event) => {
+                if event.status == GuardianAssessmentStatus::Denied {
+                    denial_rationales.push(event.rationale.clone());
+                }
+                statuses.push(event.status);
+            }
+            EventMsg::ExecApprovalRequest(event) => {
+                return Ok(GuardianManualApprovalEvents {
+                    approval_request: event,
+                    warnings,
+                    denial_rationales,
+                    statuses,
+                });
+            }
+            _ => {}
+        }
+    }
+}
