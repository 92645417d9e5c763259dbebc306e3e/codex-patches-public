+    pub(crate) async fn retry_now(&self, expected_turn_id: &str) -> CodexResult<()> {
+        let retry_now = {
+            let active = self.active_turn.lock().await;
+            let Some(active_turn) = active.as_ref() else {
+                return Err(CodexErr::InvalidRequest(
+                    "no active turn to retry".to_string(),
