+#[tokio::test]
+async fn submitted_turn_context_clears_at_terminal_lifecycle_boundaries() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(Some("gpt-5")).await;
+    let context = crate::chatwidget::input_queue::SubmittedTurnContext {
+        model: "gpt-5".to_string(),
+        reasoning_effort: Some(ReasoningEffortConfig::High),
+    };
+
+    chat.input_queue.user_turn_pending_start = true;
+    chat.input_queue.submitted_turn_context = Some(context.clone());
+    let input_state = chat
+        .capture_thread_input_state()
+        .expect("captured input state");
+    chat.input_queue.submitted_turn_context = None;
+    chat.restore_thread_input_state(Some(input_state));
+    assert_eq!(
+        chat.input_queue.submitted_turn_context.as_ref(),
+        Some(&context)
+    );
+
+    chat.on_task_complete(
+        /*last_agent_message*/ None, /*duration_ms*/ None, /*from_replay*/ false,
+    );
+    assert!(chat.input_queue.submitted_turn_context.is_none());
+
+    chat.input_queue.submitted_turn_context = Some(context);
+    chat.finalize_turn();
+    assert!(chat.input_queue.submitted_turn_context.is_none());
+}
