     // Use a hair space (U+200A) to create a subtle, near-invisible separation
     // before the text. VS16 is intentionally omitted to keep spacing tighter
@@ -217,3 +355,38 @@ pub(crate) fn new_error_event(message: String) -> PlainHistoryCell {
     let lines: Vec<Line<'static>> = vec![vec![format!("■ {message}").red()].into()];
     PlainHistoryCell { lines }
 }
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn context_compacted_event_matches_triggered_separator_style() {
+        let cell = new_context_compacted_event(Some(84_000));
+        let lines = cell.display_lines(60);
+
+        assert_eq!(lines.len(), 1);
+        assert_eq!(
+            lines[0].to_string(),
+            "─ Context compacted ■ Worked 1m 24s ────────────────────────"
+        );
+        let rendered_width: usize = lines[0]
+            .spans
+            .iter()
+            .map(ratatui::prelude::Span::width)
+            .sum();
+        assert_eq!(rendered_width, 60);
+        assert!(!lines[0].to_string().contains("Used"));
+        assert!(!lines[0].to_string().contains("tokens"));
+    }
+
+    #[test]
+    fn context_compacted_event_without_duration_omits_details() {
+        let cell = new_context_compacted_event(/*duration_ms*/ None);
+        assert_eq!(cell.raw_lines()[0].to_string(), "Context compacted");
+        assert_eq!(
+            cell.display_lines(30)[0].to_string(),
+            "─ Context compacted ──────────"
+        );
+    }
+}
