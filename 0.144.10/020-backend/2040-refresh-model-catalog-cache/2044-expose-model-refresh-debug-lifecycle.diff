+#[tokio::test]
+#[traced_test]
+async fn foreground_model_refresh_failure_uses_debug_noise() {
+    let (endpoint, mut started_rx) = ControlledModelsEndpoint::new(vec![
+        ControlledModelsFetch::error("catalog refresh failed"),
+        ControlledModelsFetch::error("etag refresh failed"),
+    ]);
+    let codex_home = tempdir().expect("temp dir");
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint.clone());
+
+    let catalog = manager
+        .raw_model_catalog(RefreshStrategy::Online, DEFAULT_HTTP_CLIENT_FACTORY)
+        .await;
+
+    expect_fetch_started(&mut started_rx, 1).await;
+    manager
+        .refresh_if_new_etag("changed-etag".to_string(), DEFAULT_HTTP_CLIENT_FACTORY)
+        .await;
+    expect_fetch_started(&mut started_rx, 2).await;
+    assert_eq!(endpoint.fetch_count(), 2);
+    assert!(
+        !catalog.models.is_empty(),
+        "foreground refresh failure should preserve bundled models"
+    );
+    logs_assert(|lines: &[&str]| {
+        for (error, message) in [
+            (
+                "catalog refresh failed",
+                "models refresh: foreground refresh failed; using current catalog",
+            ),
+            (
+                "etag refresh failed",
+                "models refresh: ETag-triggered refresh failed; keeping current catalog",
+            ),
+        ] {
+            let Some(line) = lines
+                .iter()
+                .find(|line| line.contains(error) && line.contains(message))
+            else {
+                return Err(format!("missing refresh failure debug log: {message}"));
+            };
+            if !line.contains("DEBUG") || line.contains("ERROR") {
+                return Err(format!(
+                    "refresh failure used the wrong log level: {message}"
+                ));
+            }
+            if lines
+                .iter()
+                .any(|line| line.contains("ERROR") && line.contains(error))
+            {
+                return Err(format!(
+                    "refresh failure was also logged as error: {message}"
+                ));
+            }
+        }
+        Ok(())
+    });
+}
