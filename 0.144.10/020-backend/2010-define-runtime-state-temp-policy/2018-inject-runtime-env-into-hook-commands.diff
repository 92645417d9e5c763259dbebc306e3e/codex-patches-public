+/// Builds values overlaid onto the inherited hook child environment.
+///
+/// Hook commands do not clear the host environment, so this is not a complete
+/// shell-environment-policy boundary.
+fn build_hook_runtime_env_overlay(
+    config: &Config,
+    environment: Option<&TurnEnvironment>,
+) -> HashMap<String, String> {
+    if !config.features.enabled(Feature::CodexHooks) {
+        return HashMap::new();
+    }
+    let Some(environment) = environment else {
+        return HashMap::new();
+    };
+    let Ok(cwd) = environment.cwd().to_abs_path() else {
+        return HashMap::new();
+    };
+
+    create_runtime_env(
+        &config.permissions.shell_environment_policy,
+        /*thread_id*/ None,
+        Some(cwd.as_path()),
+        config.codex_home.as_path(),
+    )
 }
 
