+fn plugin_source_env_overrides_runtime_env_overlay() {
+    let runtime_plugin_key = if cfg!(windows) {
+        "plugin_root"
+    } else {
+        "PLUGIN_ROOT"
+    };
+    let mut handlers = vec![ConfiguredHandler {
+        event_name: HookEventName::SessionStart,
+        matcher: None,
+        command: "echo hook".to_string(),
+        timeout_sec: 600,
+        status_message: None,
+        source_path: cwd().join("hooks.json"),
+        source: HookSource::Plugin,
+        display_order: 0,
+        env: HashMap::from([("PLUGIN_ROOT".to_string(), "/plugin".to_string())]),
+    }];
+    let runtime_env_overlay = HashMap::from([
+        (
+            runtime_plugin_key.to_string(),
+            "/runtime-plugin".to_string(),
+        ),
+        (
+            "PROJECT_SCRATCH_ROOT".to_string(),
+            "/runtime-scratch".to_string(),
+        ),
+    ]);
+
+    merge_runtime_env_overlay(&mut handlers, &runtime_env_overlay);
+
+    assert_eq!(
+        handlers[0].env,
+        HashMap::from([
+            ("PLUGIN_ROOT".to_string(), "/plugin".to_string()),
+            (
+                "PROJECT_SCRATCH_ROOT".to_string(),
+                "/runtime-scratch".to_string(),
+            ),
+        ])
+    );
+}
