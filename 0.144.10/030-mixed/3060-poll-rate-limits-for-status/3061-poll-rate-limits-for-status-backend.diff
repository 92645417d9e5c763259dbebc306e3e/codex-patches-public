+fn assemble_account_rate_limits(
+    snapshots: Vec<CoreRateLimitSnapshot>,
+) -> Result<
+    (
+        CoreRateLimitSnapshot,
+        HashMap<String, CoreRateLimitSnapshot>,
+    ),
+    String,
+> {
+    if snapshots.is_empty() {
+        return Err("no snapshots returned".to_string());
+    }
+
+    let keyed_snapshots = snapshots
+        .into_iter()
+        .map(|snapshot| {
+            let limit_id = account_rate_limit_key(&snapshot);
+            (limit_id, snapshot)
+        })
+        .collect::<Vec<_>>();
+    let reserved_limit_ids = keyed_snapshots
+        .iter()
+        .filter_map(|(limit_id, _)| limit_id.clone())
+        .collect::<HashSet<_>>();
+
+    let mut used_limit_ids = HashSet::new();
+    let mut first_snapshot = None;
+    let mut first_codex_snapshot = None;
+    let mut by_limit_id = HashMap::with_capacity(keyed_snapshots.len());
+    for (index, (candidate_limit_id, mut snapshot)) in keyed_snapshots.into_iter().enumerate() {
+        let limit_id = match candidate_limit_id {
+            Some(limit_id) if used_limit_ids.insert(limit_id.clone()) => limit_id,
+            _ => anonymous_rate_limit_key(index, &reserved_limit_ids, &mut used_limit_ids),
+        };
+        snapshot.limit_id = Some(limit_id.clone());
+        first_snapshot.get_or_insert_with(|| snapshot.clone());
+        if limit_id == "codex" {
+            first_codex_snapshot.get_or_insert_with(|| snapshot.clone());
+        }
+        by_limit_id.insert(limit_id, snapshot);
+    }
+
+    let primary = first_codex_snapshot
+        .or(first_snapshot)
+        .ok_or_else(|| "no snapshots returned".to_string())?;
+    Ok((primary, by_limit_id))
+}
+
+fn account_rate_limit_key(snapshot: &CoreRateLimitSnapshot) -> Option<String> {
+    if let Some(limit_id) = snapshot
+        .limit_id
+        .as_deref()
+        .filter(|limit_id| !limit_id.trim().is_empty())
+    {
+        return Some(limit_id.to_string());
+    }
+
+    snapshot
+        .limit_name
+        .as_deref()
+        .filter(|limit_name| !limit_name.trim().eq_ignore_ascii_case("codex"))
+        .and_then(derive_rate_limit_id_from_name)
+}
+
+fn derive_rate_limit_id_from_name(value: &str) -> Option<String> {
+    let value = value.trim();
+    if value.is_empty() {
+        return None;
+    }
+    Some(value.to_ascii_lowercase().replace(['-', ' '], "_"))
+}
+
+fn anonymous_rate_limit_key(
+    index: usize,
+    reserved_limit_ids: &HashSet<String>,
+    used_limit_ids: &mut HashSet<String>,
+) -> String {
+    let mut ordinal = index;
+    loop {
+        let limit_id = format!("unknown_{ordinal}");
+        if !reserved_limit_ids.contains(&limit_id) && used_limit_ids.insert(limit_id.clone()) {
+            return limit_id;
+        }
+        ordinal += 1;
+    }
+}
