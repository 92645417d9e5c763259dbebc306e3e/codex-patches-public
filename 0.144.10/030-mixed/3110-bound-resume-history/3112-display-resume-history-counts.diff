+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct ResumeHistoryLoadSummary {
+    messages: u64,
+    turns: u64,
+    app_server_turns: u64,
+    context_windows: u64,
+}
+
+fn resume_history_load_summary(turns: &[Turn]) -> Option<ResumeHistoryLoadSummary> {
+    if turns.is_empty() {
+        return None;
+    }
+
+    let mut messages = 0;
+    let mut visible_turns = 0;
+    let mut context_windows = 0;
+    for turn in turns {
+        let mut has_visible_conversation = false;
+        for item in &turn.items {
+            match item {
+                ThreadItem::UserMessage { .. } | ThreadItem::AgentMessage { .. } => {
+                    messages += 1;
+                    has_visible_conversation = true;
+                }
+                ThreadItem::ContextCompaction { .. } => {
+                    context_windows += 1;
+                }
+                _ => {}
+            }
+        }
+        if has_visible_conversation {
+            visible_turns += 1;
+        }
+    }
+
+    Some(ResumeHistoryLoadSummary {
+        messages,
+        turns: visible_turns,
+        app_server_turns: turns.len() as u64,
+        context_windows,
+    })
+}
