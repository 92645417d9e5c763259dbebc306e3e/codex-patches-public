+#[test]
+fn ascii_warning_event_uses_ascii_prefix() {
+    let cell = new_ascii_warning_event(
+        "Automatic approval review approved (risk: low, authorization: unknown): ok".to_string(),
+    );
+    let rendered = render_lines(&cell.display_lines(/*width*/ 80));
+
+    assert_eq!(
+        rendered,
+        vec!["! Automatic approval review approved (risk: low, authorization: unknown): ok"]
+    );
+}
