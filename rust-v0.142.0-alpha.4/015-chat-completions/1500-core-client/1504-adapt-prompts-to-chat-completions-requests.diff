+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+#[cfg_attr(not(test), allow(dead_code))]
+pub(crate) enum ChatToolStrictMode {
+    PreserveToolSetting,
+    Disabled,
+    Enabled,
+}
+
+pub(crate) struct ChatCompletionsRequestParts {
+    pub(crate) request: ChatCompletionsRequest,
+    pub(crate) tool_aliases: BTreeMap<String, ChatToolAlias>,
+}
+
+#[cfg_attr(not(test), allow(dead_code))]
+pub(crate) fn build_chat_completions_request(
+    prompt: &Prompt,
+    model_info: &ModelInfo,
+    effort: Option<ReasoningEffort>,
+    service_tier: Option<&str>,
+    strict_mode: ChatToolStrictMode,
+) -> Result<ChatCompletionsRequest> {
+    Ok(
+        build_chat_completions_request_parts(
+            prompt,
+            model_info,
+            effort,
+            service_tier,
+            strict_mode,
+        )?
+        .request,
+    )
+}
+
+pub(crate) fn build_chat_completions_request_parts(
+    prompt: &Prompt,
+    model_info: &ModelInfo,
+    effort: Option<ReasoningEffort>,
+    _service_tier: Option<&str>,
+    strict_mode: ChatToolStrictMode,
+) -> Result<ChatCompletionsRequestParts> {
+    let mut messages = Vec::new();
+    let effort_label = effort
+        .clone()
+        .or_else(|| model_info.default_reasoning_level.clone())
+        .map_or_else(|| "none".to_string(), |effort| effort.to_string());
+    let runtime_metadata = format!(
+        "Runtime metadata: current_model={}; reasoning_effort={}. \
+         If asked about the current model or reasoning effort, answer from this metadata.",
+        model_info.slug, effort_label
+    );
+    let ChatTools {
+        tools,
+        tool_aliases,
+    } = chat_tools_from_specs(&prompt.tools, strict_mode)?;
+    let system_content =
+        chat_completions_system_content(&prompt.base_instructions.text, &runtime_metadata);
+    messages.push(ChatMessage::System {
+        content: system_content,
+        name: None,
+    });
+    messages.extend(chat_messages_from_items_with_aliases(
+        &prompt.get_formatted_input_for_request(/*use_responses_lite*/ false),
+        &tool_aliases,
+    )?);
+
+    Ok(ChatCompletionsRequestParts {
+        request: ChatCompletionsRequest {
+            model: chat_completions_model_slug(model_info, effort.clone()).to_string(),
+            messages,
+            tools,
+            tool_choice: Some(ChatToolChoice::Mode(ChatToolChoiceMode::Auto)),
+            thinking: think(model_info, effort.clone()),
+            reasoning_effort: chat_reasoning_effort(model_info, effort),
+            response_format: prompt.output_schema.as_ref().map(|_| ChatResponseFormat {
+                r#type: ChatResponseFormatType::JsonObject,
+            }),
+            stream: true,
+            stream_options: Some(ChatStreamOptions {
+                include_usage: true,
+            }),
+        },
+        tool_aliases,
+    })
+}
+
+fn chat_completions_system_content(base_instructions: &str, runtime_metadata: &str) -> String {
+    let mut sections = Vec::new();
+    if !base_instructions.is_empty() {
+        sections.push(base_instructions.to_string());
+    }
+    sections.push(runtime_metadata.to_string());
+    sections.join("\n\n")
+}
+
+fn chat_messages_from_items_with_aliases(
+    items: &[ResponseItem],
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> Result<Vec<ChatMessage>> {
+    let mut messages = Vec::new();
+    let mut segment_start = 0;
+
+    for (index, item) in items.iter().enumerate() {
+        if let ResponseItem::Message { role, content, .. } = item
+            && role == "user"
+        {
+            let segment = &items[segment_start..index];
+            append_chat_messages_from_segment(segment, &mut messages, tool_aliases)?;
+            messages.push(chat_message_from_content(role, content, None)?);
+            segment_start = index + 1;
+        }
+    }
+
+    append_chat_messages_from_segment(&items[segment_start..], &mut messages, tool_aliases)?;
+    Ok(messages)
+}
+
+fn append_chat_messages_from_segment(
+    items: &[ResponseItem],
+    messages: &mut Vec<ChatMessage>,
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> Result<()> {
+    let has_tool_call = items.iter().any(is_supported_chat_tool_call);
+    let mut pending_reasoning_content: Option<String> = None;
+    let mut index = 0;
+
+    while index < items.len() {
+        let item = &items[index];
+        match item {
+            ResponseItem::Reasoning { content, .. } => {
+                pending_reasoning_content = reasoning_content_text(content.as_deref());
+                index += 1;
+            }
+            ResponseItem::Message { role, content, .. } if role == "assistant" => {
+                let content = Some(content_text(content)?);
+                let start = index + 1;
+                let (tool_calls, next_index) = collect_tool_calls(items, start, tool_aliases)?;
+                messages.push(ChatMessage::Assistant {
+                    content,
+                    name: None,
+                    prefix: None,
+                    reasoning_content: has_tool_call
+                        .then(|| pending_reasoning_content.take())
+                        .flatten(),
+                    tool_calls,
+                });
+                index = next_index;
+            }
+            ResponseItem::Message { role, content, .. } => {
+                pending_reasoning_content = None;
+                messages.push(chat_message_from_content(role, content, None)?);
+                index += 1;
+            }
+            ResponseItem::AgentMessage {
+                author,
+                recipient,
+                content,
+                ..
+            } => {
+                pending_reasoning_content = None;
+                messages.push(chat_message_from_agent_message(author, recipient, content)?);
+                index += 1;
+            }
+            ResponseItem::FunctionCall { .. } | ResponseItem::CustomToolCall { .. }
+                if !can_replay_chat_tool_call(item, tool_aliases) =>
+            {
+                let (content, next_index) = unsupported_history_tool_message(items, index);
+                pending_reasoning_content = None;
+                messages.push(ChatMessage::User {
+                    content,
+                    name: None,
+                });
+                index = next_index;
+            }
+            ResponseItem::FunctionCall { .. } | ResponseItem::CustomToolCall { .. } => {
+                let (tool_calls, next_index) = collect_tool_calls(items, index, tool_aliases)?;
+                messages.push(ChatMessage::Assistant {
+                    content: None,
+                    name: None,
+                    prefix: None,
+                    reasoning_content: pending_reasoning_content.take(),
+                    tool_calls,
+                });
+                index = next_index;
+            }
+            ResponseItem::FunctionCallOutput {
+                call_id, output, ..
+            } => {
+                messages.push(ChatMessage::Tool {
+                    content: function_output_text(output)?,
+                    tool_call_id: call_id.clone(),
+                });
+                index += 1;
+            }
+            ResponseItem::CustomToolCallOutput {
+                call_id, output, ..
+            } => {
+                messages.push(ChatMessage::Tool {
+                    content: function_output_text(output)?,
+                    tool_call_id: call_id.clone(),
+                });
+                index += 1;
+            }
+            ResponseItem::LocalShellCall { .. }
+            | ResponseItem::ToolSearchCall { .. }
+            | ResponseItem::ToolSearchOutput { .. }
+            | ResponseItem::WebSearchCall { .. }
+            | ResponseItem::ImageGenerationCall { .. } => {
+                pending_reasoning_content = None;
+                messages.push(ChatMessage::User {
+                    content: unsupported_history_item_message(item),
+                    name: None,
+                });
+                index += 1;
+            }
+            ResponseItem::Compaction { .. }
+            | ResponseItem::ContextCompaction { .. }
+            | ResponseItem::CompactionTrigger { .. }
+            | ResponseItem::Other => {
+                index += 1;
+            }
+        }
+    }
+
+    Ok(())
+}
+
+fn can_replay_chat_tool_call(
+    item: &ResponseItem,
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> bool {
+    match item {
+        ResponseItem::FunctionCall {
+            name, namespace, ..
+        } => maybe_chat_wire_name(namespace.as_deref(), name, tool_aliases).is_some(),
+        ResponseItem::CustomToolCall { name, .. } => name == APPLY_PATCH_TOOL_NAME,
+        _ => false,
+    }
+}
+
+fn unsupported_history_tool_message(items: &[ResponseItem], index: usize) -> (String, usize) {
+    let item = &items[index];
+    let mut next_index = index + 1;
+    let mut message = format!(
+        "Earlier in this conversation, another model used a tool that is not available in the current request: {}.",
+        history_item_name(item)
+    );
+    if let Some(output) = items.get(next_index).and_then(matching_tool_output_text) {
+        message.push_str("\nTool result:\n");
+        message.push_str(&output);
+        next_index += 1;
+    }
+    (message, next_index)
+}
+
+fn unsupported_history_item_message(item: &ResponseItem) -> String {
+    format!(
+        "Earlier in this conversation, another model produced an item that is not available in the current request: {}.",
+        history_item_name(item)
+    )
+}
+
+fn matching_tool_output_text(item: &ResponseItem) -> Option<String> {
+    match item {
+        ResponseItem::FunctionCallOutput { output, .. }
+        | ResponseItem::CustomToolCallOutput { output, .. } => output.body.to_text(),
+        _ => None,
+    }
+}
+
+fn collect_tool_calls(
+    items: &[ResponseItem],
+    mut index: usize,
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> Result<(Option<Vec<ChatToolCall>>, usize)> {
+    let mut tool_calls = Vec::new();
+
+    while index < items.len() {
+        let Some(tool_call) = chat_tool_call_from_item(&items[index], tool_aliases)? else {
+            break;
+        };
+        tool_calls.push(tool_call);
+        index += 1;
+    }
+
+    Ok(((!tool_calls.is_empty()).then_some(tool_calls), index))
+}
+
+fn chat_tool_call_from_item(
+    item: &ResponseItem,
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> Result<Option<ChatToolCall>> {
+    match item {
+        ResponseItem::FunctionCall {
+            name,
+            namespace,
+            arguments,
+            call_id,
+            ..
+        } => {
+            let Some(wire_name) = maybe_chat_wire_name(namespace.as_deref(), name, tool_aliases)
+            else {
+                return Err(CodexErr::UnsupportedOperation(format!(
+                    "Chat Completions request adapter does not support previous `{}` tool calls",
+                    display_tool_name(namespace.as_deref(), name)
+                )));
+            };
+            Ok(Some(ChatToolCall {
+                id: call_id.clone(),
+                r#type: ChatToolType::Function,
+                function: ChatFunctionCall {
+                    name: wire_name,
+                    arguments: arguments.clone(),
+                },
+            }))
+        }
+        ResponseItem::CustomToolCall {
+            name,
+            input,
+            call_id,
+            ..
+        } if name == APPLY_PATCH_TOOL_NAME => Ok(Some(ChatToolCall {
+            id: call_id.clone(),
+            r#type: ChatToolType::Function,
+            function: ChatFunctionCall {
+                name: name.clone(),
+                arguments: apply_patch_chat_arguments(input)?,
+            },
+        })),
+        ResponseItem::CustomToolCall { .. } => Err(unsupported_item(item)),
+        _ => Ok(None),
+    }
+}
+
+fn is_supported_chat_tool_call(item: &ResponseItem) -> bool {
+    match item {
+        ResponseItem::FunctionCall { .. } => true,
+        ResponseItem::CustomToolCall { name, .. } => name == APPLY_PATCH_TOOL_NAME,
+        _ => false,
+    }
+}
+
+fn chat_message_from_content(
+    role: &str,
+    content: &[ContentItem],
+    reasoning_content: Option<String>,
+) -> Result<ChatMessage> {
+    let text = content_text(content)?;
+    match role {
+        "system" | "developer" => Ok(ChatMessage::System {
+            content: text,
+            name: None,
+        }),
+        "user" => Ok(ChatMessage::User {
+            content: text,
+            name: None,
+        }),
+        "assistant" => Ok(ChatMessage::Assistant {
+            content: Some(text),
+            name: None,
+            prefix: None,
+            reasoning_content,
+            tool_calls: None,
+        }),
+        _ => Err(CodexErr::UnsupportedOperation(format!(
+            "Chat Completions does not support message role `{role}`"
+        ))),
+    }
+}
+
+fn chat_message_from_agent_message(
+    author: &str,
+    recipient: &str,
+    content: &[AgentMessageInputContent],
+) -> Result<ChatMessage> {
+    let mut parts = Vec::new();
+    for item in content {
+        match item {
+            AgentMessageInputContent::InputText { text } => parts.push(text.clone()),
+            AgentMessageInputContent::EncryptedContent { .. } => {
+                return Err(CodexErr::UnsupportedOperation(
+                    "Chat Completions request adapter does not support encrypted agent messages"
+                        .to_string(),
+                ));
+            }
+        }
+    }
+    Ok(ChatMessage::User {
+        content: format!("{author} to {recipient}: {}", parts.join("\n")),
+        name: None,
+    })
+}
+
+fn content_text(content: &[ContentItem]) -> Result<String> {
+    let mut parts = Vec::new();
+    for item in content {
+        match item {
+            ContentItem::InputText { text } | ContentItem::OutputText { text } => {
+                parts.push(text.clone());
+            }
+            ContentItem::InputImage { .. } => {
+                return Err(CodexErr::UnsupportedOperation(
+                    UNSUPPORTED_IMAGES_MESSAGE.to_string(),
+                ));
+            }
+        }
+    }
+    Ok(parts.join("\n"))
+}
+
+fn reasoning_content_text(content: Option<&[ReasoningItemContent]>) -> Option<String> {
+    let parts = content?.iter().map(reasoning_item_text).collect::<Vec<_>>();
+    (!parts.is_empty()).then(|| parts.join("\n"))
+}
+
+fn reasoning_item_text(item: &ReasoningItemContent) -> &str {
+    match item {
+        ReasoningItemContent::ReasoningText { text } => text.as_str(),
+        ReasoningItemContent::Text { text } => text.as_str(),
+    }
+}
+
+fn function_output_text(
+    output: &codex_protocol::models::FunctionCallOutputPayload,
+) -> Result<String> {
+    match &output.body {
+        FunctionCallOutputBody::Text(text) => Ok(text.clone()),
+        FunctionCallOutputBody::ContentItems(_) => output.body.to_text().ok_or_else(|| {
+            CodexErr::UnsupportedOperation(
+                "Chat Completions request adapter does not support non-text tool output"
+                    .to_string(),
+            )
+        }),
+    }
+}
+
+struct ChatTools {
+    tools: Vec<ChatTool>,
+    tool_aliases: BTreeMap<String, ChatToolAlias>,
+}
+
+fn chat_tools_from_specs(tools: &[ToolSpec], strict_mode: ChatToolStrictMode) -> Result<ChatTools> {
+    let mut chat_tools = Vec::new();
+    let mut tool_aliases = BTreeMap::new();
+    let mut used_wire_names = BTreeSet::new();
+
+    for tool in tools {
+        match tool {
+            ToolSpec::Function(function) => {
+                let wire_name = unique_wire_name(&function.name, &mut used_wire_names);
+                let tool = chat_tool_from_function(function, &wire_name, strict_mode);
+                tool_aliases.insert(wire_name, ChatToolAlias::plain(function.name.clone()));
+                chat_tools.push(tool);
+            }
+            ToolSpec::Freeform(freeform) if freeform.name == APPLY_PATCH_TOOL_NAME => {
+                let wire_name = unique_wire_name(&freeform.name, &mut used_wire_names);
+                let tool = chat_tool_from_apply_patch(&wire_name, strict_mode);
+                tool_aliases.insert(wire_name, ChatToolAlias::plain(freeform.name.clone()));
+                chat_tools.push(tool);
+            }
+            ToolSpec::Namespace(namespace) => {
+                for tool in &namespace.tools {
+                    match tool {
+                        ResponsesApiNamespaceTool::Function(function) => {
+                            let base_wire_name = flat_wire_name(&namespace.name, &function.name);
+                            let wire_name = unique_wire_name(&base_wire_name, &mut used_wire_names);
+                            let tool = chat_tool_from_function(function, &wire_name, strict_mode);
+                            tool_aliases.insert(
+                                wire_name,
+                                ChatToolAlias::namespaced(
+                                    namespace.name.clone(),
+                                    function.name.clone(),
+                                ),
+                            );
+                            chat_tools.push(tool);
+                        }
+                    }
+                }
+            }
+            ToolSpec::ToolSearch { .. }
+            | ToolSpec::ImageGeneration { .. }
+            | ToolSpec::WebSearch { .. }
+            | ToolSpec::Freeform(_) => Err(CodexErr::UnsupportedOperation(format!(
+                "Chat Completions request adapter does not support `{}` tools",
+                tool.name()
+            )))?,
+        }
+    }
+
+    Ok(ChatTools {
+        tools: chat_tools,
+        tool_aliases,
+    })
+}
+
+fn chat_tool_from_apply_patch(wire_name: &str, strict_mode: ChatToolStrictMode) -> ChatTool {
+    let mut properties = BTreeMap::new();
+    properties.insert(
+        APPLY_PATCH_CHAT_COMPLETIONS_INPUT_FIELD.to_string(),
+        JsonSchema::string(Some(
+            APPLY_PATCH_CHAT_COMPLETIONS_INPUT_DESCRIPTION.to_string(),
+        )),
+    );
+    let parameters = JsonSchema::object(
+        properties,
+        Some(vec![APPLY_PATCH_CHAT_COMPLETIONS_INPUT_FIELD.to_string()]),
+        Some(AdditionalProperties::Boolean(false)),
+    );
+
+    ChatTool {
+        r#type: ChatToolType::Function,
+        function: ChatFunctionTool {
+            name: wire_name.to_string(),
+            description: Some(APPLY_PATCH_CHAT_COMPLETIONS_DESCRIPTION.to_string()),
+            parameters: serde_json::to_value(parameters).ok(),
+            strict: Some(matches!(
+                strict_mode,
+                ChatToolStrictMode::PreserveToolSetting | ChatToolStrictMode::Enabled
+            )),
+        },
+    }
+}
+
+fn chat_tool_from_function(
+    function: &ResponsesApiTool,
+    wire_name: &str,
+    strict_mode: ChatToolStrictMode,
+) -> ChatTool {
+    let (parameters, strict) = match strict_mode {
+        ChatToolStrictMode::PreserveToolSetting => {
+            let parameters = function.parameters.clone();
+            (parameters, function.strict)
+        }
+        ChatToolStrictMode::Disabled => (function.parameters.clone(), false),
+        ChatToolStrictMode::Enabled => {
+            let parameters = deepseek_strict_parameters(&function.parameters);
+            (parameters, true)
+        }
+    };
+    let parameters = serde_json::to_value(parameters).unwrap_or_default();
+    ChatTool {
+        r#type: ChatToolType::Function,
+        function: ChatFunctionTool {
+            name: wire_name.to_string(),
+            description: Some(function.description.clone()),
+            parameters: Some(parameters),
+            strict: Some(strict),
+        },
+    }
+}
+
+fn maybe_chat_wire_name(
+    namespace: Option<&str>,
+    name: &str,
+    tool_aliases: &BTreeMap<String, ChatToolAlias>,
+) -> Option<String> {
+    tool_aliases.iter().find_map(|(wire_name, alias)| {
+        (alias.namespace.as_deref() == namespace && alias.name == name).then(|| wire_name.clone())
+    })
+}
+
+fn display_tool_name(namespace: Option<&str>, name: &str) -> String {
+    namespace
+        .map(|namespace| format!("{namespace}.{name}"))
+        .unwrap_or_else(|| name.to_string())
+}
+
+fn flat_wire_name(namespace: &str, name: &str) -> String {
+    let mut wire_name = sanitize_wire_name(namespace);
+    if !wire_name.ends_with('_') {
+        wire_name.push('_');
+    }
+    wire_name.push_str(&sanitize_wire_name(name));
+    wire_name
+}
+
+fn sanitize_wire_name(name: &str) -> String {
+    let mut sanitized = name
+        .chars()
+        .map(|ch| {
+            if ch.is_ascii_alphanumeric() || ch == '_' || ch == '-' {
+                ch
+            } else {
+                '_'
+            }
+        })
+        .collect::<String>();
+    if sanitized.is_empty() {
+        sanitized.push_str("tool");
+    }
+    sanitized
+}
+
+fn unique_wire_name(base_name: &str, used_wire_names: &mut BTreeSet<String>) -> String {
+    let base_name = sanitize_wire_name(base_name);
+    if used_wire_names.insert(base_name.clone()) {
+        return base_name;
+    }
+
+    let mut suffix = 2;
+    loop {
+        let candidate = format!("{base_name}_{suffix}");
+        if used_wire_names.insert(candidate.clone()) {
+            return candidate;
+        }
+        suffix += 1;
+    }
+}
+
+fn deepseek_strict_parameters(parameters: &JsonSchema) -> JsonSchema {
+    let mut parameters = parameters.clone();
+    let is_empty_schema = parameters.schema_type.is_none()
+        && parameters.properties.is_none()
+        && parameters.items.is_none()
+        && parameters.any_of.is_none();
+    if is_empty_schema {
+        let object_type = JsonSchemaType::Single(JsonSchemaPrimitiveType::Object);
+        parameters.schema_type = Some(object_type);
+        parameters.properties = Some(BTreeMap::new());
+    }
+    normalize_deepseek_strict_schema(&mut parameters);
+    parameters
+}
+
+fn normalize_deepseek_strict_schema(schema: &mut JsonSchema) {
+    if schema.schema_type.is_none() && schema.properties.is_some() {
+        let object_type = JsonSchemaType::Single(JsonSchemaPrimitiveType::Object);
+        schema.schema_type = Some(object_type);
+    }
+
+    if let Some(properties) = schema.properties.as_mut() {
+        for property in properties.values_mut() {
+            normalize_deepseek_strict_schema(property);
+        }
+    }
+    if let Some(items) = schema.items.as_mut() {
+        normalize_deepseek_strict_schema(items);
+    }
+    if let Some(any_of) = schema.any_of.as_mut() {
+        for variant in any_of {
+            normalize_deepseek_strict_schema(variant);
+        }
+    }
+
+    let is_object = matches!(
+        schema.schema_type,
+        Some(JsonSchemaType::Single(JsonSchemaPrimitiveType::Object))
+    );
+    if is_object {
+        let required = schema
+            .properties
+            .as_ref()
+            .map(|properties| properties.keys().cloned().collect())
+            .unwrap_or_default();
+        schema.required = Some(required);
+        schema.additional_properties = Some(AdditionalProperties::Boolean(false));
+    }
+}
+
+fn apply_patch_chat_arguments(input: &str) -> Result<String> {
+    serde_json::to_string(&serde_json::json!({
+        APPLY_PATCH_CHAT_COMPLETIONS_INPUT_FIELD: input,
+    }))
+    .map_err(|err| {
+        let message = format!("failed to encode apply_patch arguments: {err}");
+        CodexErr::UnsupportedOperation(message)
+    })
+}
+
+fn chat_completions_model_slug(model: &ModelInfo, effort: Option<ReasoningEffort>) -> String {
+    chat_completions_config::api_model_slug(model, effort)
+}
+
+fn think(model: &ModelInfo, effort: Option<ReasoningEffort>) -> Option<ChatThinking> {
+    if !supports_chat_reasoning(model) {
+        return None;
+    }
+
+    effort.or_else(|| model.default_reasoning_level.clone())?;
+    let r#type = ChatThinkingType::Enabled;
+    Some(ChatThinking { r#type })
+}
+
+fn chat_reasoning_effort(
+    model_info: &ModelInfo,
+    effort: Option<ReasoningEffort>,
+) -> Option<ChatReasoningEffort> {
+    if !supports_chat_reasoning(model_info) {
+        return None;
+    }
+    if chat_completions_config::provider_for_model(&model_info.slug)
+        == Some(chat_completions_config::ProviderId::Mimo)
+    {
+        return match effort.or_else(|| model_info.default_reasoning_level.clone()) {
+            Some(ReasoningEffort::Low | ReasoningEffort::High) | None => {
+                Some(ChatReasoningEffort::Medium)
+            }
+            Some(
+                ReasoningEffort::None
+                | ReasoningEffort::Minimal
+                | ReasoningEffort::Medium
+                | ReasoningEffort::XHigh
+                | ReasoningEffort::Custom(_),
+            ) => Some(ChatReasoningEffort::High),
+        };
+    }
+    match effort.or_else(|| model_info.default_reasoning_level.clone()) {
+        Some(
+            ReasoningEffort::None
+            | ReasoningEffort::Minimal
+            | ReasoningEffort::Low
+            | ReasoningEffort::High
+            | ReasoningEffort::Custom(_),
+        ) => Some(ChatReasoningEffort::High),
+        Some(ReasoningEffort::Medium | ReasoningEffort::XHigh) => Some(ChatReasoningEffort::Max),
+        None => None,
+    }
+}
+
+fn supports_chat_reasoning(model_info: &ModelInfo) -> bool {
+    model_info.supports_reasoning_summaries || chat_completions_config::is_model(&model_info.slug)
+}
+
+fn unsupported_item(item: &ResponseItem) -> CodexErr {
+    CodexErr::UnsupportedOperation(format!(
+        "Chat Completions request adapter does not support {}",
+        history_item_name(item)
+    ))
+}
+
+fn history_item_name(item: &ResponseItem) -> String {
+    match item {
+        ResponseItem::LocalShellCall { .. } => "local shell call",
+        ResponseItem::AgentMessage { .. } => "agent message",
+        ResponseItem::ToolSearchCall { .. } => "tool search call",
+        ResponseItem::FunctionCall { .. } => "function tool call",
+        ResponseItem::FunctionCallOutput { .. } => "function tool call output",
+        ResponseItem::CustomToolCall { .. } => "custom tool call",
+        ResponseItem::CustomToolCallOutput { .. } => "custom tool call output",
+        ResponseItem::ToolSearchOutput { .. } => "tool search output",
+        ResponseItem::WebSearchCall { .. } => "web search call",
+        ResponseItem::ImageGenerationCall { .. } => "image generation call",
+        ResponseItem::Message { .. }
+        | ResponseItem::Reasoning { .. }
+        | ResponseItem::Compaction { .. }
+        | ResponseItem::ContextCompaction { .. }
+        | ResponseItem::CompactionTrigger { .. }
+        | ResponseItem::Other => "unknown item",
+    }
+    .to_string()
+}
