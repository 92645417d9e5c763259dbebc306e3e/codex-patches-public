+fn has_consumer_side_output_guard_pipeline(tokens: &[String]) -> bool {
+    tokens.windows(4).any(|window| {
+        window[0] == "|"
+            && matches!(window[1].as_str(), "head" | "tail")
+            && matches!(window[2].as_str(), "-c" | "-n")
+            && output_cap_count(&window[3])
+    }) || tokens.windows(3).any(|window| {
+        window[0] == "|"
+            && matches!(window[1].as_str(), "head" | "tail")
+            && window[2]
+                .strip_prefix("-c")
+                .or_else(|| window[2].strip_prefix("-n"))
+                .is_some_and(output_cap_count)
+    })
+}
+
+fn output_cap_count(value: &str) -> bool {
+    !value.is_empty() && value.chars().all(|ch| ch.is_ascii_digit())
+}
+
+fn supports_guarded_shell_fallback(tokens: &[String]) -> bool {
+    has_consumer_side_output_guard_pipeline(tokens) && supports_safe_redirect_shell_fallback(tokens)
+}
+
+fn supports_safe_redirect_shell_fallback(tokens: &[String]) -> bool {
+    tokens.iter().all(|token| {
+        is_safe_output_redirect(token) || (!token.contains('>') && !token.contains('<'))
+    })
+}
