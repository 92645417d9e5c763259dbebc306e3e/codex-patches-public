+
+fn reasoning_effort_spans(effort: ReasoningEffortConfig) -> Vec<Span<'static>> {
+    let label = effort.to_string();
+    match effort {
+        ReasoningEffortConfig::Minimal | ReasoningEffortConfig::Low => {
+            vec![Span::from(label).yellow()]
+        }
+        #[allow(clippy::disallowed_methods)]
+        ReasoningEffortConfig::Medium => vec![Span::from(label).fg(Color::Rgb(255, 128, 0))],
+        ReasoningEffortConfig::High => vec![Span::from(label).red()],
+        ReasoningEffortConfig::XHigh => label
+            .chars()
+            .zip(
+                [
+                    Color::Red,
+                    Color::Yellow,
+                    Color::Green,
+                    Color::Cyan,
+                    Color::Blue,
+                    Color::Magenta,
+                ]
+                .into_iter()
+                .cycle(),
+            )
+            .map(|(ch, color)| Span::from(ch.to_string()).fg(color))
+            .collect(),
+        ReasoningEffortConfig::None | ReasoningEffortConfig::Custom(_) => {
+            vec![Span::from(label).magenta()]
+        }
+    }
 }
 
