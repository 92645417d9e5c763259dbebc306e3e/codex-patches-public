+#[test]
+fn permission_profile_selection_config_edits_include_reviewer_and_policy() {
+    let selection = PermissionProfileSelection {
+        profile_id: codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS
+            .to_string(),
+        approval_policy: Some(AskForApproval::OnRequest),
+        approvals_reviewer: Some(ApprovalsReviewer::AutoReview),
+        display_label: "Full Access + Agent Review".to_string(),
+    };
+
+    let edits = permission_profile_selection_config_edits(&selection);
+
+    assert_eq!(
+        edits
+            .iter()
+            .find(|edit| edit.key_path == "default_permissions")
+            .map(|edit| &edit.value),
+        Some(&serde_json::json!(":danger-full-access"))
+    );
+    assert_eq!(
+        edits
+            .iter()
+            .find(|edit| edit.key_path == "approval_policy")
+            .map(|edit| &edit.value),
+        Some(&serde_json::json!("on-request"))
+    );
+    assert_eq!(
+        edits
+            .iter()
+            .find(|edit| edit.key_path == "approvals_reviewer")
+            .map(|edit| &edit.value),
+        Some(&serde_json::json!("auto_review"))
+    );
+}
