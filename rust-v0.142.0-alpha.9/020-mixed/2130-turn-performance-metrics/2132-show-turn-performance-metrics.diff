+fn completed_turn_metrics_fields(
+    token_info: Option<&TokenUsageInfo>,
+    duration_ms: Option<i64>,
+    time_to_first_token_ms: Option<i64>,
+) -> Option<Vec<String>> {
+    let usage = token_info.map(|info| &info.last_token_usage);
+    let mut parts = Vec::new();
+
+    if let Some(ms) = positive_ms(time_to_first_token_ms) {
+        parts.push(format!("First {}", format_duration_ms(ms)));
+    }
+    if let Some(ms) = positive_ms(duration_ms) {
+        parts.push(format!("Total {}", format_duration_ms(ms)));
+    }
+    if let (Some(usage), Some(duration), Some(first)) = (
+        usage,
+        positive_ms(duration_ms),
+        positive_ms(time_to_first_token_ms),
+    ) {
+        let generation_ms = duration.saturating_sub(first);
+        let output_tokens = usage.output_tokens.max(0);
+        if generation_ms > 0 && output_tokens > 0 {
+            let tokens_per_second = output_tokens as f64 / (generation_ms as f64 / 1_000.0);
+            parts.push(format!("{tokens_per_second:.1} tok/s"));
+        }
+    }
+    if let Some(usage) = usage {
+        if usage.input_tokens > 0 {
+            parts.push(format!("{} in", format_tokens_compact(usage.input_tokens)));
+        }
+        if usage.output_tokens > 0 {
+            parts.push(format!(
+                "{} out",
+                format_tokens_compact(usage.output_tokens)
+            ));
+        }
+        if usage.reasoning_output_tokens > 0 {
+            parts.push(format!(
+                "{} reasoning",
+                format_tokens_compact(usage.reasoning_output_tokens)
+            ));
+        }
+        if let Some(cache_hit_rate) = usage.cache_hit_rate_percent() {
+            parts.push(format!("{cache_hit_rate:.1}% cached"));
+        }
+    }
+
+    (!parts.is_empty()).then_some(parts)
+}
+
+fn positive_ms(value: Option<i64>) -> Option<i64> {
+    value.filter(|value| *value > 0)
+}
+
+fn format_duration_ms(ms: i64) -> String {
+    if ms < 1_000 {
+        return format!("{ms}ms");
+    }
+    let seconds = ms as f64 / 1_000.0;
+    if seconds < 10.0 {
+        format!("{seconds:.2}s")
+    } else if seconds < 100.0 {
+        format!("{seconds:.1}s")
+    } else {
+        format!("{seconds:.0}s")
+    }
+}
+
