+    #[test]
+    fn details_include_latency_speed_and_last_turn_tokens() {
+        let token_info = TokenUsageInfo {
+            total_token_usage: TokenUsage::default(),
+            last_token_usage: TokenUsage {
+                input_tokens: 1_000,
+                cached_input_tokens: 500,
+                output_tokens: 200,
+                reasoning_output_tokens: 50,
+                total_tokens: 1_200,
