+#[derive(Debug)]
+pub struct TurnMetricsSeparator {
+    fields: Vec<String>,
+}
+
+impl TurnMetricsSeparator {
+    pub(crate) fn new(fields: Vec<String>) -> Self {
+        Self { fields }
+    }
+
+    fn label(&self) -> String {
+        let mut parts = Vec::with_capacity(self.fields.len() + 1);
+        parts.push("Turn metrics".to_string());
+        parts.extend(self.fields.iter().cloned());
+        parts.join(" ■ ")
+    }
+}
+
+impl HistoryCell for TurnMetricsSeparator {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        let label_text = self.label();
+        let label = format!("─ {label_text} ─");
+        let label_width = UnicodeWidthStr::width(label.as_str());
+        if label_width > width as usize {
+            let (label, _suffix, label_width) = take_prefix_by_width(&label, width as usize);
+            return vec![
+                Line::from_iter([
+                    label,
+                    "─".repeat((width as usize).saturating_sub(label_width)),
+                ])
+                .dim(),
+            ];
+        }
+
+        let mut spans = Vec::new();
+        spans.push("─ ".dim());
+        spans.push(
+            "Turn metrics"
+                .fg(Color::Yellow)
+                .add_modifier(Modifier::BOLD),
+        );
+        for field in &self.fields {
+            spans.push(" ■ ".dim());
+            spans.push(field.clone().fg(Color::Yellow));
+        }
+        spans.push(" ─".dim());
+        spans.push(
+            "─"
+                .repeat((width as usize).saturating_sub(label_width))
+                .dim(),
+        );
+        vec![Line::from(spans)]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        vec![Line::from(self.label())]
+    }
+}
