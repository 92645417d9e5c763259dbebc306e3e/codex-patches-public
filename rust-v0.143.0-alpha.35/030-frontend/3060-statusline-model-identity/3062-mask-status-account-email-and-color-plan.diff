+#[allow(clippy::disallowed_methods)]
+pub(crate) fn account_plan_style(plan: &str) -> Style {
+    match plan
+        .to_ascii_lowercase()
+        .replace([' ', '-', '_'], "")
+        .as_str()
+    {
+        "free" => Style::default().fg(Color::DarkGray),
+        "plus" => Style::default().fg(Color::Green),
+        "business" | "team" | "enterprise" => Style::default().fg(Color::Cyan),
+        "prolite" => Style::default().fg(Color::Yellow),
+        "pro" => Style::default().fg(Color::Magenta),
+        _ => Style::default().fg(Color::Blue),
+    }
+}
