+
+fn positive_ms(value: Option<i64>) -> Option<i64> {
+    value.filter(|value| *value > 0)
+}
+
+fn response_tokens_per_second(
+    usage: Option<&TokenUsage>,
+    duration_ms: Option<i64>,
+    time_to_first_token_ms: Option<i64>,
+) -> Option<f64> {
+    let usage = usage?;
+    let duration = positive_ms(duration_ms)?;
+    // TTFT is tracked in whole milliseconds. Very short visible answers can finish in the same
+    // millisecond bucket as the first visible token, which would otherwise hide TPS entirely.
+    let generation_duration = duration
+        .checked_sub(time_to_first_token_ms.unwrap_or(0))
+        .filter(|ms| *ms > 0)
+        .unwrap_or(duration);
+    let output_tokens = visible_output_tokens(usage);
+    if output_tokens == 0 {
+        return None;
+    }
+    Some(output_tokens as f64 / (generation_duration as f64 / 1_000.0))
+}
+
+fn visible_output_tokens(usage: &TokenUsage) -> i64 {
+    usage
+        .output_tokens
+        .saturating_sub(usage.reasoning_output_tokens)
+        .max(0)
+}
