+    async fn poll_account_rate_limits_until_shutdown(&self, shutdown: CancellationToken) {
+        loop {
+            self.poll_account_rate_limits_once().await;
+
+            tokio::select! {
+                _ = shutdown.cancelled() => break,
+                _ = tokio::time::sleep(ACCOUNT_RATE_LIMITS_POLL_INTERVAL) => {}
+            }
+        }
+    }
+
+    async fn poll_account_rate_limits_once(&self) {
+        if !self
+            .auth_manager
+            .auth_cached()
+            .as_ref()
+            .is_some_and(CodexAuth::uses_codex_backend)
+        {
+            self.rate_limits_cache.lock().await.take();
+            return;
+        }
+
+        if let Err(err) = self.fetch_and_cache_account_rate_limits().await {
+            tracing::debug!("failed to poll ChatGPT account rate limits: {err:?}");
+        }
+    }
+
+    fn refresh_account_rate_limits_in_background(&self) {
+        if self
+            .rate_limits_refresh_in_flight
+            .swap(true, std::sync::atomic::Ordering::AcqRel)
+        {
+            return;
+        }
+
+        let processor = self.clone();
+        tokio::spawn(async move {
+            if let Err(err) = processor.fetch_and_cache_account_rate_limits().await {
+                tracing::debug!("failed to refresh ChatGPT account rate limits: {err:?}");
+            }
+            processor
+                .rate_limits_refresh_in_flight
+                .store(false, std::sync::atomic::Ordering::Release);
+        });
+    }
+
+    fn broadcast_cached_account_rate_limits(&self) {
+        let processor = self.clone();
+        tokio::spawn(async move {
+            if let Some(cached) = processor.rate_limits_cache.lock().await.clone() {
+                processor.send_rate_limits_notifications(&cached).await;
+            }
+        });
+    }
+
+    async fn fetch_and_cache_account_rate_limits(
+        &self,
+    ) -> Result<CachedAccountRateLimits, JSONRPCErrorError> {
+        let _guard = self.rate_limits_fetch_lock.lock().await;
+        self.fetch_and_cache_account_rate_limits_inner().await
+    }
+
+    async fn read_or_fetch_account_rate_limits(
+        &self,
+    ) -> Result<CachedAccountRateLimits, JSONRPCErrorError> {
+        let _guard = self.rate_limits_fetch_lock.lock().await;
+        if let Some(cached) = self.rate_limits_cache.lock().await.clone() {
+            return Ok(cached);
+        }
+        self.fetch_and_cache_account_rate_limits_inner().await
+    }
+
+    async fn fetch_and_cache_account_rate_limits_inner(
+        &self,
+    ) -> Result<CachedAccountRateLimits, JSONRPCErrorError> {
+        let cached = self.fetch_account_rate_limits().await?;
+        let previous = {
+            let mut cache = self.rate_limits_cache.lock().await;
+            let previous = cache.clone();
+            *cache = Some(cached.clone());
+            previous
+        };
+        if previous.as_ref().map(|snapshot| &snapshot.by_limit_id) != Some(&cached.by_limit_id) {
+            self.send_rate_limits_notifications(&cached).await;
+        }
+        Ok(cached)
+    }
+
+    async fn send_rate_limits_notifications(&self, cached: &CachedAccountRateLimits) {
