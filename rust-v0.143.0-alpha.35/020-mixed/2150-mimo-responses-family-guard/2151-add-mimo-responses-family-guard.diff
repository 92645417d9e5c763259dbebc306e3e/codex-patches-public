+#[test]
+fn mimo_disabled_config_hides_models_and_provider() {
+    let parsed: MimoToml = toml::from_str("enabled = false\n").unwrap();
+    let config = mimo_config_from_toml(parsed).unwrap();
+
+    assert!(!config.enabled);
+    assert!(config.provider.is_none());
+    assert!(config.model_infos().is_empty());
+    assert!(!config.is_mimo_model("mimo-2.5"));
+}
+
+#[test]
+fn mimo_enabled_config_builds_visible_responses_models_with_capabilities() {
+    let parsed: MimoToml = toml::from_str(
+        r#"
+enabled = true
+api_key = "secret"
+base_url = "https://mimo.example/v1"
+
+[[models]]
+id = "mimo-fast-text"
+model = "mimo-upstream"
+display_name = "MiMo Fast Text"
+supports_web_search = true
+
+[[models]]
+id = "mimo-fast-image"
+model = "mimo-upstream"
+supports_image = true
+"#,
+    )
+    .unwrap();
+    let config = mimo_config_from_toml(parsed).unwrap();
+
+    assert!(config.enabled);
+    assert_eq!(
+        config.provider.as_ref().unwrap().wire_api,
+        WireApi::Responses
+    );
+    assert_eq!(
+        config.request_model_overrides().get("mimo-fast-text"),
+        Some(&"mimo-upstream".to_string())
+    );
+
+    let infos = config.model_infos();
+    let text = infos
+        .iter()
+        .find(|model| model.slug == "mimo-fast-text")
+        .unwrap();
+    assert_eq!(text.display_name, "MiMo Fast Text");
+    assert_eq!(text.input_modalities, vec![InputModality::Text]);
+    assert!(text.supports_search_tool);
+    assert_eq!(
+        text.auto_review_model_override.as_deref(),
+        Some("mimo-fast-text")
+    );
+    assert_eq!(text.multi_agent_version, Some(MultiAgentVersion::V1));
+
+    let image = infos
+        .iter()
+        .find(|model| model.slug == "mimo-fast-image")
+        .unwrap();
+    assert_eq!(
+        image.input_modalities,
+        vec![InputModality::Text, InputModality::Image]
+    );
+    assert!(!image.supports_search_tool);
+}
