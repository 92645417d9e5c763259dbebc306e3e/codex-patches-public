+async fn load_mimo_config(
+    fs: &dyn ExecutorFileSystem,
+    codex_home: &AbsolutePathBuf,
+) -> std::io::Result<MimoConfig> {
+    let path = codex_home.as_path().join("mimo.toml");
+    let abs_path = AbsolutePathBuf::try_from(path.clone())
+        .map_err(|err| std::io::Error::new(std::io::ErrorKind::InvalidInput, err.to_string()))?;
+    let path_uri = PathUri::from_abs_path(&abs_path);
+    let contents = match fs.read_file_text(&path_uri, /*sandbox*/ None).await {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(MimoConfig::default()),
+        Err(err) => {
+            return Err(std::io::Error::new(
+                err.kind(),
+                format!("failed to read MiMo config {}: {err}", path.display()),
+            ));
+        }
+    };
+    let parsed: MimoToml = toml::from_str(&contents).map_err(|err| {
+        std::io::Error::new(
+            std::io::ErrorKind::InvalidData,
+            format!("failed to parse MiMo config {}: {err}", path.display()),
+        )
+    })?;
+    mimo_config_from_toml(parsed)
+}
+
+fn mimo_config_from_toml(parsed: MimoToml) -> std::io::Result<MimoConfig> {
+    if !parsed.enabled {
+        return Ok(MimoConfig::default());
+    }
+    let api_key = parsed
+        .api_key
+        .map(|key| key.trim().to_string())
+        .filter(|key| !key.is_empty())
+        .ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::InvalidInput,
+                "mimo.toml requires api_key when enabled is true",
+            )
+        })?;
+    let base_url = parsed
+        .base_url
+        .unwrap_or_else(|| "https://api.mimo.ai/v1".to_string());
+    let models = if parsed.models.is_empty() {
+        vec![MimoModelConfig {
+            id: "mimo-2.5".to_string(),
+            upstream_model: "mimo-2.5".to_string(),
+            display_name: "MiMo 2.5".to_string(),
+            description: "MiMo Responses model.".to_string(),
+            default_reasoning_effort: ReasoningEffort::High,
+            supported_reasoning_efforts: vec![
+                ReasoningEffort::Low,
+                ReasoningEffort::Medium,
+                ReasoningEffort::High,
+            ],
+            context_window: Some(128_000),
+            auto_compact_token_limit: Some(110_000),
+            supports_image: false,
+            supports_web_search: false,
+        }]
+    } else {
+        parsed
+            .models
+            .into_iter()
+            .map(|model| {
+                let id = model.id.trim().to_string();
+                if id.is_empty() {
+                    return Err(std::io::Error::new(
+                        std::io::ErrorKind::InvalidInput,
+                        "mimo.toml model id must not be empty",
+                    ));
+                }
+                Ok(MimoModelConfig {
+                    upstream_model: model
+                        .model
+                        .map(|value| value.trim().to_string())
+                        .filter(|value| !value.is_empty())
+                        .unwrap_or_else(|| id.clone()),
+                    display_name: model.display_name.unwrap_or_else(|| id.clone()),
+                    description: model
+                        .description
+                        .unwrap_or_else(|| "MiMo Responses model.".to_string()),
+                    default_reasoning_effort: model
+                        .default_reasoning_effort
+                        .unwrap_or(ReasoningEffort::High),
+                    supported_reasoning_efforts: model.supported_reasoning_efforts.unwrap_or_else(
+                        || {
+                            vec![
+                                ReasoningEffort::Low,
+                                ReasoningEffort::Medium,
+                                ReasoningEffort::High,
+                            ]
+                        },
+                    ),
+                    context_window: model.context_window.or(Some(128_000)),
+                    auto_compact_token_limit: model.auto_compact_token_limit.or(Some(110_000)),
+                    supports_image: model.supports_image,
+                    supports_web_search: model.supports_web_search,
+                    id,
+                })
+            })
+            .collect::<std::io::Result<Vec<_>>>()?
+    };
+    Ok(MimoConfig {
+        enabled: true,
+        provider: Some(ModelProviderInfo {
+            name: "MiMo".to_string(),
+            base_url: Some(base_url),
+            env_key: None,
+            env_key_instructions: None,
+            experimental_bearer_token: Some(api_key),
+            auth: None,
+            aws: None,
+            wire_api: WireApi::Responses,
+            query_params: None,
+            http_headers: None,
+            env_http_headers: None,
+            request_max_retries: None,
+            stream_max_retries: None,
+            stream_idle_timeout_ms: None,
+            websocket_connect_timeout_ms: None,
+            requires_openai_auth: false,
+            supports_websockets: false,
+        }),
+        models,
+    })
 }
 
