+fn add_mimo_model_to_turn(turn: &mut TurnContext, model: &str) {
+    update_config(turn, |config| {
+        config.mimo = crate::config::MimoConfig {
+            enabled: true,
+            provider: None,
+            models: vec![crate::config::MimoModelConfig {
+                id: model.to_string(),
+                upstream_model: "mimo-upstream".to_string(),
+                display_name: model.to_string(),
+                description: "test MiMo model".to_string(),
+                default_reasoning_effort: ReasoningEffort::High,
+                supported_reasoning_efforts: vec![ReasoningEffort::High],
+                context_window: Some(128_000),
+                auto_compact_token_limit: Some(110_000),
+                supports_image: false,
+                supports_web_search: false,
+            }],
+        };
+    });
+    let mut preset = turn
+        .available_models
+        .first()
+        .cloned()
+        .expect("test turn should have a model preset");
+    preset.id = model.to_string();
+    preset.model = model.to_string();
+    preset.display_name = model.to_string();
+    turn.available_models.push(preset);
+}
