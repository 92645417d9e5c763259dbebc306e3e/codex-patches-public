+fn resolve_hook_command_path(source_path: &AbsolutePathBuf, command: &str) -> String {
+    let trimmed = command.trim();
+    if !is_relative_hooks_json_command(source_path, trimmed) {
+        return command.to_string();
+    }
+
+    source_path
+        .parent()
+        .map(|parent| parent.join(trimmed).display().to_string())
+        .unwrap_or_else(|| command.to_string())
+}
+
+fn is_relative_hooks_json_command(source_path: &AbsolutePathBuf, command: &str) -> bool {
+    source_path.file_name() == Some(OsStr::new("hooks.json"))
+        && !command.is_empty()
+        && !command.starts_with('~')
+        && !command.chars().any(char::is_whitespace)
+        && !Path::new(command).is_absolute()
+        && (command.contains('/') || command.contains('\\'))
+}
