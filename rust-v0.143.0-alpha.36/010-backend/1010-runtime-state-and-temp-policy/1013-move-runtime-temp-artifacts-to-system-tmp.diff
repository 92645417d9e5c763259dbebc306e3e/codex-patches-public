+#[test]
+fn maybe_wrap_shell_lc_with_snapshot_restores_runtime_temp_env() {
+    let dir = tempdir().expect("create temp dir");
+    let snapshot_path = dir.path().join("snapshot.sh");
+    std::fs::write(
+        &snapshot_path,
+        "# Snapshot file\n\
+         export TMPDIR='/snapshot/tmp'\n\
+         export CODEX_TMP='/snapshot/codex'\n\
+         export PROJECT_NAME='snapshot-project'\n\
+         export PROJECT_SCRATCH_ROOT='/snapshot/project'\n\
+         export PROJECT_WORKING_ROOT='/snapshot/working'\n\
+         export RUNTIME_TMP_ROOT='/snapshot/runtime-tmp'\n\
+         export RUNTIME_STATE_ROOT='/snapshot/runtime-state'\n",
+    )
+    .expect("write snapshot");
+    let (session_shell, shell_snapshot) =
+        shell_with_snapshot(ShellType::Bash, "/bin/bash", snapshot_path.abs());
+    let command = vec![
+        "/bin/bash".to_string(),
+        "-lc".to_string(),
+        "printf '%s|%s|%s|%s|%s|%s|%s' \"$TMPDIR\" \"$CODEX_TMP\" \"${PROJECT_NAME-unset}\" \"${PROJECT_SCRATCH_ROOT-unset}\" \"${PROJECT_WORKING_ROOT-unset}\" \"${RUNTIME_TMP_ROOT-unset}\" \"${RUNTIME_STATE_ROOT-unset}\"".to_string(),
+    ];
+    let env = HashMap::from([
+        ("TMPDIR".to_string(), "/live/tmp".to_string()),
+        (CODEX_TMP_ENV_VAR.to_string(), "/live/codex".to_string()),
+        (PROJECT_NAME_ENV_VAR.to_string(), "live-project".to_string()),
+        (
+            PROJECT_WORKING_ROOT_ENV_VAR.to_string(),
+            "/live/working".to_string(),
+        ),
+        (
+            RUNTIME_TMP_ROOT_ENV_VAR.to_string(),
+            "/live/runtime-tmp".to_string(),
+        ),
+    ]);
+    let rewritten = maybe_wrap_shell_lc_with_snapshot(
+        &command,
+        &session_shell,
+        Some(&shell_snapshot),
+        &HashMap::new(),
+        &env,
+        &RuntimePathPrepends::default(),
+    );
+    let output = Command::new(&rewritten[0])
+        .args(&rewritten[1..])
+        .env("TMPDIR", "/live/tmp")
+        .env(CODEX_TMP_ENV_VAR, "/live/codex")
+        .env(PROJECT_NAME_ENV_VAR, "live-project")
+        .env_remove(PROJECT_SCRATCH_ROOT_ENV_VAR)
+        .env(PROJECT_WORKING_ROOT_ENV_VAR, "/live/working")
+        .env(RUNTIME_TMP_ROOT_ENV_VAR, "/live/runtime-tmp")
+        .env_remove(RUNTIME_STATE_ROOT_ENV_VAR)
+        .output()
+        .expect("run rewritten command");
+
+    assert!(output.status.success(), "command failed: {output:?}");
+    assert_eq!(
+        String::from_utf8_lossy(&output.stdout),
+        "/live/tmp|/live/codex|live-project|unset|/live/working|/live/runtime-tmp|unset"
+    );
+}
