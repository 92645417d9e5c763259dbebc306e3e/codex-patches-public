+
+fn path_leaf(path: Option<&Path>, fallback: &str) -> String {
+    let Some(path) = path else {
+        return fallback.to_string();
+    };
+    let Some(name) = path.file_name() else {
+        return fallback.to_string();
+    };
+    let rendered = name.to_string_lossy();
+    if rendered.is_empty() {
+        fallback.to_string()
+    } else {
+        rendered.into_owned()
+    }
+}
