+fn inject_runtime_path_env(env: &mut HashMap<String, String>, local_cwd: Option<&Path>) {
+    for key in [
+        "TMPDIR",
+        CODEX_HOME_ENV_VAR,
+        CODEX_TMP_ENV_VAR,
+        PROJECT_SCRATCH_ROOT_ENV_VAR,
+        PROJECT_WORKING_ROOT_ENV_VAR,
+        PROJECT_NAME_ENV_VAR,
+        RUNTIME_TMP_ROOT_ENV_VAR,
+        RUNTIME_STATE_ROOT_ENV_VAR,
+    ] {
+        remove_env_var(env, key);
+    }
+
+    if let Ok(codex_home) = find_codex_home() {
+        env.insert(
+            CODEX_HOME_ENV_VAR.to_string(),
+            codex_home.to_string_lossy().into_owned(),
+        );
+    }
+
+    let Some(cwd) = local_cwd else {
+        return;
+    };
+
+    if let Ok(tmpdir) = find_system_tmp_root() {
+        env.insert("TMPDIR".to_string(), tmpdir.to_string_lossy().into_owned());
+    }
+    if let Ok(codex_tmp) = find_codex_tmp_root() {
+        env.insert(
+            CODEX_TMP_ENV_VAR.to_string(),
+            codex_tmp.to_string_lossy().into_owned(),
+        );
+    }
+    if let Ok(project_scratch_root) = find_project_scratch_root(cwd) {
+        env.insert(
+            PROJECT_SCRATCH_ROOT_ENV_VAR.to_string(),
+            project_scratch_root.to_string_lossy().into_owned(),
+        );
+    }
+    if let Ok(project_working_root) = find_project_working_root(cwd) {
+        env.insert(
+            PROJECT_WORKING_ROOT_ENV_VAR.to_string(),
+            project_working_root.to_string_lossy().into_owned(),
+        );
+    }
+    env.insert(PROJECT_NAME_ENV_VAR.to_string(), find_project_name(cwd));
+    if let Ok(runtime_tmp_root) = find_runtime_tmp_root(cwd) {
+        env.insert(
+            RUNTIME_TMP_ROOT_ENV_VAR.to_string(),
+            runtime_tmp_root.to_string_lossy().into_owned(),
+        );
+    }
+    if let Ok(runtime_state_root) = find_runtime_state_root(cwd) {
+        env.insert(
+            RUNTIME_STATE_ROOT_ENV_VAR.to_string(),
+            runtime_state_root.to_string_lossy().into_owned(),
+        );
+    }
+}
