+#[tokio::test]
+async fn instructions_overlay_missing_file_does_not_write() {
+    let prompted = remote_model_with_prompt(
+        "prompted-cache-model",
+        "Prompted Cache Model",
+        /*priority*/ 1,
+        "upstream prompt\nwith newline",
+    );
+    let codex_home = tempdir().expect("temp dir");
+    let endpoint = TestModelsEndpoint::new(vec![vec![prompted.clone()]]);
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint);
+
+    manager
+        .refresh_available_models(RefreshStrategy::OnlineIfUncached)
+        .await
+        .expect("refresh succeeds");
+    assert_models_contain(&manager.get_remote_models().await, &[prompted]);
+    assert!(!instructions_overlay_path(codex_home.path()).exists());
+}
+
+#[tokio::test]
+async fn instructions_overlay_overrides_prompt_and_reloads_file() {
+    let remote = remote_model_with_prompt(
+        "overlay-cache-model",
+        "Overlay Cache Model",
+        /*priority*/ 1,
+        "upstream prompt",
+    );
+    let codex_home = tempdir().expect("temp dir");
+    write_instructions_overlay(
+        codex_home.path(),
+        json!({
+            "models": {
+                "overlay-cache-model": {
+                    "model_messages": {
+                        "instructions_template": "local prompt one"
+                    }
+                }
+            }
+        }),
+    );
+    let endpoint = TestModelsEndpoint::new(vec![vec![remote]]);
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint);
+
+    manager
+        .refresh_available_models(RefreshStrategy::OnlineIfUncached)
+        .await
+        .expect("refresh succeeds");
+    let config = ModelsManagerConfig {
+        personality_enabled: true,
+        ..Default::default()
+    };
+    let model_info = manager.get_model_info("overlay-cache-model", &config).await;
+    assert_eq!(
+        model_info
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("local prompt one")
+    );
+    assert_eq!(model_info.display_name, "Overlay Cache Model");
+    assert_eq!(model_info.base_instructions, "base instructions");
+
+    write_instructions_overlay(
+        codex_home.path(),
+        json!({
+            "models": {
+                "overlay-cache-model": {
+                    "model_messages": {
+                        "instructions_template": "local prompt two"
+                    }
+                }
+            }
+        }),
+    );
+    let updated = manager.get_model_info("overlay-cache-model", &config).await;
+    assert_eq!(
+        updated
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("local prompt two")
+    );
+}
