+#[tokio::test]
+async fn status_line_permissions_shows_known_profile_combinations() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.config
+        .permissions
+        .approval_policy
+        .set(AskForApproval::OnRequest.to_core())
+        .expect("set approval policy");
+    chat.config
+        .permissions
+        .set_permission_profile_from_session_snapshot(PermissionProfileSnapshot::active(
+            PermissionProfile::workspace_write(),
+            ActivePermissionProfile::new(BUILT_IN_PERMISSION_PROFILE_WORKSPACE),
+        ))
+        .expect("set permission profile");
+
+    chat.config.approvals_reviewer = ApprovalsReviewer::User;
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::Permissions),
+        Some("Ask For Approval".to_string())
+    );
+
+    chat.config.approvals_reviewer = ApprovalsReviewer::AutoReview;
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::Permissions),
+        Some("Approve For Me".to_string())
+    );
+}
