+fn builtin_workspace_profile_label(
+    approval_policy: AskForApproval,
+    approvals_reviewer: ApprovalsReviewer,
+) -> Option<&'static str> {
+    match (approval_policy, approvals_reviewer) {
+        (AskForApproval::OnRequest, ApprovalsReviewer::User) => Some(ASK_FOR_APPROVAL_LABEL),
+        (AskForApproval::OnRequest, ApprovalsReviewer::AutoReview) => Some(APPROVE_FOR_ME_LABEL),
+        _ => None,
+    }
+}
+
+fn builtin_full_access_profile_label(
+    approval_policy: AskForApproval,
+    approvals_reviewer: ApprovalsReviewer,
+) -> Option<&'static str> {
+    match (approval_policy, approvals_reviewer) {
+        (AskForApproval::Never, ApprovalsReviewer::User) => Some("Full Access"),
+        (AskForApproval::OnRequest, ApprovalsReviewer::AutoReview) => {
+            Some(FULL_ACCESS_AGENT_REVIEW_LABEL)
+        }
+        (AskForApproval::Never, ApprovalsReviewer::AutoReview) => Some(YOLO_LABEL),
+        _ => None,
+    }
+}
