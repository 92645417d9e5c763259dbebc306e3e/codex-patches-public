+            /*use_theme_colors*/ false,
+        )
+        .expect("status line");
+        let model = &line.spans[0];
+
+        assert_eq!(model.content.as_ref(), "gpt-5.3-codex");
+        assert_eq!(model.style.fg, model_style("gpt-5.3-codex").fg);
+        assert_eq!(model.style.add_modifier.contains(Modifier::DIM), false);
+        assert_eq!(model.style.sub_modifier.contains(Modifier::DIM), false);
+    }
+}
