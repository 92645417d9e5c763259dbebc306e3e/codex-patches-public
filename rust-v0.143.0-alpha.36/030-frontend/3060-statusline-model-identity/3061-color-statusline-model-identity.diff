+
+    chat.submit_user_message(UserMessage::from("run with gpt-5"));
+    chat.set_model("gpt-5.4");
+    chat.set_reasoning_effort(Some(ReasoningEffortConfig::Low));
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5 high".to_string()));
+
+    handle_turn_completed(&mut chat, "turn-1", /*duration_ms*/ None);
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5.4 low".to_string()));
