+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+
+    #[allow(clippy::disallowed_methods)]
+    #[test]
+    fn reasoning_effort_status_line_uses_color_without_dim_override() {
+        let cases = [
+            (Some(ReasoningEffortConfig::Minimal), Some(Color::Yellow)),
+            (Some(ReasoningEffortConfig::Low), Some(Color::Yellow)),
+            (
+                Some(ReasoningEffortConfig::Medium),
+                Some(Color::Rgb(255, 128, 0)),
+            ),
+            (Some(ReasoningEffortConfig::High), Some(Color::Red)),
+            (Some(ReasoningEffortConfig::None), None),
+            (None, None),
+        ];
+
+        for (effort, expected_color) in cases {
+            let label = ChatWidget::status_line_reasoning_effort_label(effort.as_ref());
+            let span = ChatWidget::status_line_reasoning_effort_span(label, effort.as_ref());
+            assert_eq!(span.style.fg, expected_color, "effort: {effort:?}");
+            assert_eq!(
+                span.style.add_modifier.contains(Modifier::DIM),
+                false,
+                "effort: {effort:?}"
+            );
+            assert_eq!(
+                span.style.sub_modifier.contains(Modifier::DIM),
+                false,
+                "effort: {effort:?}"
+            );
+        }
+    }
+
+    #[test]
+    fn xhigh_reasoning_effort_status_line_is_multicolor() {
+        let line = ChatWidget::status_line_reasoning_effort_line(
+            "xhigh".to_string(),
+            Some(&ReasoningEffortConfig::XHigh),
+        );
+
+        assert_eq!(
+            line.spans
+                .iter()
+                .map(|span| span.content.as_ref())
+                .collect::<String>(),
+            "xhigh"
+        );
+        assert_eq!(line.spans.len(), 5);
+        assert!(
+            line.spans
+                .iter()
+                .all(|span| !span.style.add_modifier.contains(Modifier::DIM))
+        );
+        assert!(
+            line.spans
+                .iter()
+                .all(|span| !span.style.sub_modifier.contains(Modifier::DIM))
+        );
+        assert!(line.spans.iter().any(|span| span.style.fg.is_some()));
+    }
+
+    #[test]
+    fn fast_mode_on_status_line_is_red_without_dim_override() {
+        let line = Line::from(vec!["Fast ".into(), "on".red()]);
+        let on = &line.spans[1];
+
+        assert_eq!(on.content.as_ref(), "on");
+        assert_eq!(on.style.fg, Some(Color::Red));
+        assert_eq!(on.style.add_modifier.contains(Modifier::DIM), false);
+        assert_eq!(on.style.sub_modifier.contains(Modifier::DIM), false);
+    }
+
+    #[test]
+    #[allow(clippy::disallowed_methods)]
+    fn model_status_line_style_uses_stable_model_color_without_theme_colors() {
+        let line = status_line_from_segments(
+            [(
+                StatusLineItem::ModelName,
+                Line::from(vec![Span::styled(
+                    "gpt-5.3-codex",
+                    model_style("gpt-5.3-codex"),
