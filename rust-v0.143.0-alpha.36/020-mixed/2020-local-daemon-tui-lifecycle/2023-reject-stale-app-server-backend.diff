+#[cfg(target_os = "linux")]
+async fn linux_unix_socket_inode(socket_path: &Path) -> Result<Option<String>> {
+    let proc_net_unix = tokio::fs::read_to_string("/proc/net/unix")
+        .await
+        .context("failed to read /proc/net/unix")?;
+    let socket_path = socket_path.to_string_lossy();
+    Ok(proc_net_unix
+        .lines()
+        .find_map(|line| linux_unix_socket_inode_from_line(line, &socket_path)))
+}
+
+#[cfg(target_os = "linux")]
+fn linux_unix_socket_inode_from_line(line: &str, socket_path: &str) -> Option<String> {
+    let mut fields = line.split_whitespace();
+    let _num = fields.next()?;
+    let _ref_count = fields.next()?;
+    let _protocol = fields.next()?;
+    let _flags = fields.next()?;
+    let _type = fields.next()?;
+    let _state = fields.next()?;
+    let inode = fields.next()?;
+    let path = fields.next()?;
+    (path == socket_path).then(|| inode.to_string())
+}
+
+#[cfg(target_os = "linux")]
+async fn linux_pid_for_socket_inode(inode: &str) -> Result<Option<u32>> {
+    let socket_link = format!("socket:[{inode}]");
+    let mut proc_entries = tokio::fs::read_dir("/proc")
+        .await
+        .context("failed to read /proc")?;
+    while let Some(entry) = proc_entries
+        .next_entry()
+        .await
+        .context("failed to read /proc entry")?
+    {
+        let file_name = entry.file_name();
+        let Some(pid) = file_name.to_string_lossy().parse::<u32>().ok() else {
+            continue;
+        };
+        let fd_dir = entry.path().join("fd");
+        let Ok(mut fd_entries) = tokio::fs::read_dir(fd_dir).await else {
+            continue;
+        };
+        while let Some(fd_entry) = fd_entries
+            .next_entry()
+            .await
+            .context("failed to read /proc fd entry")?
+        {
+            let Ok(target) = tokio::fs::read_link(fd_entry.path()).await else {
+                continue;
+            };
+            if target.to_string_lossy() == socket_link {
+                return Ok(Some(pid));
+            }
+        }
+    }
+    Ok(None)
+}
