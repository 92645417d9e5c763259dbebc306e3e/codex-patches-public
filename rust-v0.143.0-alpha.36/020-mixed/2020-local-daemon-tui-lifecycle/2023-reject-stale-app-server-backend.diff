+async fn terminate_socket_owner(socket_path: &Path) -> Result<()> {
+    let inode = linux_unix_socket_inode(socket_path).await?.ok_or_else(|| {
+        anyhow!(
+            "app server is idle but no socket owner was found for {}",
+            socket_path.display()
+        )
+    })?;
+    let pid = linux_pid_for_socket_inode(&inode).await?.ok_or_else(|| {
+        anyhow!(
+            "app server is idle but no process owns socket inode {inode} for {}",
+            socket_path.display()
+        )
+    })?;
+    backend::force_terminate_pid(pid)?;
+    let _ = tokio::fs::remove_file(socket_path).await;
+    Ok(())
+}
