+async fn emit_visible_turn_error(
+    sess: &Arc<Session>,
+    turn_context: &Arc<TurnContext>,
+    err: &CodexErr,
+) {
+    let error = err.to_codex_protocol_error();
+    sess.emit_turn_error_lifecycle(turn_context.as_ref(), error)
+        .await;
+    sess.track_turn_codex_error(turn_context.as_ref(), err);
+    sess.send_event(
+        turn_context,
+        EventMsg::Error(err.to_error_event(/*message_prefix*/ None)),
+    )
+    .await;
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+enum AutoCompactPolicy {
+    Allow,
+    ErrorOnLimit,
+}
+
+fn auto_compact_policy(model_slug: &str) -> AutoCompactPolicy {
+    if model_slug == "gpt-5.3-codex-spark" {
+        AutoCompactPolicy::ErrorOnLimit
+    } else {
+        AutoCompactPolicy::Allow
+    }
+}
+
+fn ensure_auto_compact_allowed(turn_context: &TurnContext) -> CodexResult<()> {
+    match auto_compact_policy(turn_context.model_info.slug.as_str()) {
+        AutoCompactPolicy::Allow => Ok(()),
+        AutoCompactPolicy::ErrorOnLimit => Err(CodexErr::UnsupportedOperation(format!(
+            "automatic compaction is disabled for {} after reaching the model context threshold; start a new thread or split the task",
+            turn_context.model_info.slug
+        ))),
+    }
+}
