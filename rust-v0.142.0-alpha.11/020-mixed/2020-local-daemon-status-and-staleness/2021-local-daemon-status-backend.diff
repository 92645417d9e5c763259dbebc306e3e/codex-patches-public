+#[tokio::test]
+async fn initialize_reports_daemon_restart_probe_counts() -> Result<()> {
+    let server = create_mock_responses_server_sequence_unchecked(Vec::new()).await;
+    let codex_home = TempDir::new()?;
+    create_config_toml(codex_home.path(), &server.uri(), "never")?;
+
+    let (mut process, bind_addr) = spawn_websocket_server(codex_home.path()).await?;
+
+    let mut daemon_probe = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut daemon_probe, /*id*/ 1, "codex_app_server_daemon").await?;
+    let _daemon_init = read_initialize_response(&mut daemon_probe, /*id*/ 1).await?;
+    send_daemon_status_request(&mut daemon_probe, /*id*/ 101).await?;
+    let daemon_status = read_daemon_status_response(&mut daemon_probe, /*id*/ 101).await?;
+    assert_eq!(daemon_status.active_client_count, 0);
+    assert_eq!(daemon_status.running_assistant_turn_count, 0);
+
+    let mut client = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut client, /*id*/ 2, "ws_client").await?;
+    let _client_init = read_initialize_response(&mut client, /*id*/ 2).await?;
+
+    let mut second_daemon_probe = connect_websocket(bind_addr).await?;
+    send_initialize_request(
+        &mut second_daemon_probe,
+        /*id*/ 3,
+        "codex_app_server_daemon",
+    )
+    .await?;
+    let _second_daemon_init = read_initialize_response(&mut second_daemon_probe, /*id*/ 3).await?;
+    send_daemon_status_request(&mut second_daemon_probe, /*id*/ 103).await?;
+    let second_daemon_status =
+        read_daemon_status_response(&mut second_daemon_probe, /*id*/ 103).await?;
+    assert_eq!(second_daemon_status.active_client_count, 1);
+    assert_eq!(second_daemon_status.running_assistant_turn_count, 0);
+
+    client.close(None).await?;
+    let mut final_daemon_status = None;
+    for id in 4..=20 {
+        let mut final_daemon_probe = connect_websocket(bind_addr).await?;
+        send_initialize_request(&mut final_daemon_probe, id, "codex_app_server_daemon").await?;
+        let _response = read_initialize_response(&mut final_daemon_probe, id).await?;
+        let status_id = id + 100;
+        send_daemon_status_request(&mut final_daemon_probe, status_id).await?;
+        let response = read_daemon_status_response(&mut final_daemon_probe, status_id).await?;
+        if response.active_client_count == 0 {
+            final_daemon_status = Some(response);
+            break;
+        }
+        sleep(Duration::from_millis(50)).await;
+    }
+    assert_eq!(
+        final_daemon_status
+            .expect("active client count returns to zero")
+            .active_client_count,
+        0
+    );
+
+    process
+        .kill()
+        .await
+        .context("failed to stop websocket app-server process")?;
+    Ok(())
+}
