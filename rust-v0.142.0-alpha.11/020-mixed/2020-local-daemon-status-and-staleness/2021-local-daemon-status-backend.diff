+#[derive(Debug, serde::Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct DaemonStatusResponse {
+    active_client_count: usize,
+    running_assistant_turn_count: usize,
+}
+
+async fn daemon_status<S>(websocket: &mut WebSocketStream<S>) -> Result<DaemonStatusResponse>
+where
+    S: AsyncRead + AsyncWrite + Unpin,
+{
+    let request = JSONRPCMessage::Request(JSONRPCRequest {
+        id: DAEMON_STATUS_REQUEST_ID.clone(),
+        method: INTERNAL_DAEMON_STATUS_METHOD.to_string(),
+        params: None,
+        trace: None,
+    });
+    send_message(websocket, &request)
+        .await
+        .context("failed to send internal daemon status request")?;
+
+    let response = loop {
+        let message = timeout(CONTROL_SOCKET_RESPONSE_TIMEOUT, read_message(websocket))
+            .await
+            .context("timed out waiting for internal daemon status response")??;
+        if let JSONRPCMessage::Response(response) = message
+            && response.id == DAEMON_STATUS_REQUEST_ID
+        {
+            break response;
+        }
+    };
+    serde_json::from_value::<DaemonStatusResponse>(response.result)
+        .context("failed to parse internal daemon status response")
+}
