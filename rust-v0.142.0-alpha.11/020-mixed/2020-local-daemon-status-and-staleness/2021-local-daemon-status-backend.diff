+#[cfg(target_os = "linux")]
+async fn process_is_zombie(pid: u32) -> Result<bool> {
+    let stat_path = format!("/proc/{pid}/stat");
+    let stat = match fs::read_to_string(&stat_path).await {
+        Ok(stat) => stat,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(false),
+        Err(err) => return Err(err).with_context(|| format!("failed to read {stat_path}")),
+    };
+    Ok(process_stat_is_zombie(&stat))
+}
+
+#[cfg(target_os = "linux")]
+fn process_stat_is_zombie(stat: &str) -> bool {
+    let Some((_before_name, after_name)) = stat.rsplit_once(") ") else {
+        return false;
+    };
+    after_name.starts_with("Z ")
+}
+
+#[cfg(all(unix, not(target_os = "linux")))]
+async fn process_is_zombie(_pid: u32) -> Result<bool> {
+    Ok(false)
+}
