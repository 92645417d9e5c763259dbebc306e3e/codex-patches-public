+    turn.provider = create_model_provider(provider_info.clone(), turn.auth_manager.clone());
+
+    let mut config = (*turn.config).clone();
+    config.model = Some("gpt-5-codex".to_string());
+    config.model_provider =
+        built_in_model_providers(/* openai_base_url */ /*openai_base_url*/ None)["openai"].clone();
+
+    apply_spawn_agent_runtime_overrides(&mut config, &turn).expect("runtime overrides");
+
+    assert_eq!(config.model.as_deref(), Some("mimo-v2.5"));
+    assert_eq!(config.model_provider, provider_info);
