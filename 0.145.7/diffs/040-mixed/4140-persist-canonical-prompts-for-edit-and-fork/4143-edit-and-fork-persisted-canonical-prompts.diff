+#[test]
+fn select_agent_thread_rehydrates_an_existing_channel_through_bounded_resume() -> Result<()> {
+    let runtime = tokio::runtime::Builder::new_multi_thread()
+        .worker_threads(/*val*/ 1)
+        .thread_stack_size(/*val*/ 8 * 1024 * 1024)
+        .enable_all()
+        .build()?;
+
+    runtime.block_on(async {
+        let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+        let config = app.chat_widget.config_ref().clone();
+        let thread_id = ThreadId::from_string(
+            &app_test_support::create_fake_rollout(
+                config.codex_home.as_path(),
+                "2025-01-05T12-00-00",
+                "2025-01-05T12:00:00Z",
+                "bounded switch history",
+                Some(config.model_provider_id.as_str()),
+                /*git_info*/ None,
+            )
+            .expect("create source rollout"),
+        )?;
+        let stale_turn = test_turn(
+            "stale-turn",
+            TurnStatus::Completed,
+            vec![ThreadItem::UserMessage {
+                id: "stale-user".to_string(),
+                client_id: None,
+                content: vec![AppServerUserInput::Text {
+                    text: "stale local snapshot".to_string(),
+                    text_elements: Vec::new(),
+                }],
+            }],
+        );
+        app.thread_event_channels.insert(
+            thread_id,
+            ThreadEventChannel::new_with_session(
+                /*capacity*/ 4,
+                test_thread_session(thread_id, test_path_buf("/tmp/stale")),
+                vec![stale_turn],
+            ),
+        );
+        app.agent_navigation.upsert(
+            thread_id,
+            Some("Hydrated".to_string()),
+            Some("worker".to_string()),
+            /*is_closed*/ false,
+        );
+        while app_event_rx.try_recv().is_ok() {}
+
+        let mut app_server =
+            crate::start_embedded_app_server_for_picker(app.chat_widget.config_ref()).await?;
+        app_server
+            .resume_thread(app.config.clone(), thread_id, app.resume_model_settings())
+            .await?;
+        let mut tui = crate::tui::test_support::make_test_tui()?;
+        app.select_agent_thread(&mut tui, &mut app_server, thread_id)
+            .await?;
+
+        assert_eq!(app.active_thread_id, Some(thread_id));
+        let store = app
+            .thread_event_channels
+            .get(&thread_id)
+            .expect("thread channel")
+            .store
+            .lock()
+            .await;
+        assert!(
+            store.turns.iter().all(|turn| turn.id != "stale-turn"),
+            "bounded thread/resume must replace the stale local presentation: {:?}",
+            store.turns
+        );
+        drop(store);
+
+        let rendered = std::iter::from_fn(|| app_event_rx.try_recv().ok())
+            .filter_map(|event| match event {
+                AppEvent::InsertHistoryCell(cell) => {
+                    Some(lines_to_single_string(&cell.display_lines(/*width*/ 160)))
+                }
+                _ => None,
+            })
+            .collect::<Vec<_>>()
+            .join("\n");
+        assert!(rendered.contains("Loaded 1 message"), "{rendered}");
+        assert!(rendered.contains("▪ Worked "), "{rendered}");
+        Ok(())
+    })
 }
 
