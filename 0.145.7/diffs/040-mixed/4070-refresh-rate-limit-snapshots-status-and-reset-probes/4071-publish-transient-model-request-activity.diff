+#[tokio::test]
+async fn model_request_activity_keeps_request_identity_and_auth_snapshot() {
+    let (tx_event, rx_event) = async_channel::bounded(1);
+    let client = test_model_client(SessionSource::Cli).with_event_sender(tx_event);
+    let responses_metadata = test_responses_metadata_for_client(
+        &client,
+        Some("turn-activity"),
+        format!("{}:0", client.state.thread_id),
+        /*parent_thread_id*/ None,
+        TestCodexResponsesRequestKind::Turn,
+    );
+
+    client
+        .emit_model_request_started(&responses_metadata, Some(7), Some("account-a".to_string()))
+        .await;
+
