+#[tokio::test]
+async fn status_rate_limit_values_are_dimmed() {
+    let temp_home = TempDir::new().expect("temp home");
+    let config = test_config(&temp_home).await;
+    let captured_at = Local
+        .with_ymd_and_hms(2024, 7, 8, 9, 10, 11)
+        .single()
+        .expect("timestamp");
+    let snapshot = RateLimitSnapshot {
+        limit_id: None,
+        limit_name: None,
+        primary: Some(RateLimitWindow {
+            used_percent: 45,
+            window_duration_mins: Some(300),
+            resets_at: Some(reset_at_from(&captured_at, /*seconds*/ 900)),
+        }),
+        secondary: Some(RateLimitWindow {
+            used_percent: 30,
+            window_duration_mins: Some(10_080),
+            resets_at: Some(reset_at_from(&captured_at, /*seconds*/ 2_700)),
+        }),
+        credits: None,
+        individual_limit: None,
+        spend_control_reached: None,
+        plan_type: None,
+        rate_limit_reached_type: None,
+    };
+    let rate_display = rate_limit_snapshot_display(&snapshot, captured_at);
+    let usage = TokenUsage::default();
+    let model_slug = get_model_offline_for_tests(config.model.as_deref());
+    let composite = new_status_output_with_rate_limits(
+        &config,
+        /*account_display*/ None,
+        /*token_info*/ None,
+        &usage,
+        &None,
+        /*thread_name*/ None,
+        /*forked_from*/ None,
+        std::slice::from_ref(&rate_display),
+        None,
+        captured_at,
+        &model_slug,
+        /*collaboration_mode*/ None,
+        /*reasoning_effort_override*/ None,
+        /*refreshing_rate_limits*/ false,
+    );
+
+    let limit_summaries = composite
+        .display_lines(/*width*/ 80)
+        .into_iter()
+        .flat_map(|line| line.spans)
+        .filter(|span| span.content.contains("% left"))
+        .collect::<Vec<_>>();
+    assert_eq!(limit_summaries.len(), 2);
+    assert!(
+        limit_summaries
+            .iter()
+            .all(|span| span.style.add_modifier.contains(Modifier::DIM))
+    );
+}
