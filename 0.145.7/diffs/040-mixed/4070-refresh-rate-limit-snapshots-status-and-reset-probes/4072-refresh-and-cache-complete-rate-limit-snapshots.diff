diff --git a/codex-rs/app-server/src/rate_limits.rs b/codex-rs/app-server/src/rate_limits.rs
new file mode 100644
index 0000000000..9513ef41b9
--- /dev/null
+++ b/codex-rs/app-server/src/rate_limits.rs
@@ -0,0 +1,228 @@
+use std::sync::Arc;
+
+use codex_app_server_protocol::AccountRateLimitsUpdatedNotification;
+use codex_app_server_protocol::GetAccountRateLimitsResponse;
+use codex_app_server_protocol::JSONRPCErrorError;
+use codex_app_server_protocol::ServerNotification;
+use tokio::sync::Mutex;
+use tokio::sync::Notify;
+use tokio_util::sync::CancellationToken;
+use tokio_util::task::TaskTracker;
+
+use crate::outgoing_message::OutgoingMessageSender;
+use crate::request_processors::AccountRequestProcessor;
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct RateLimitIdentity {
+    pub(crate) auth_revision: u64,
+    pub(crate) account_id: Option<String>,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct RateLimitWindowPace {
+    pub(crate) primary: Option<i32>,
+    pub(crate) secondary: Option<i32>,
+}
+
+pub(crate) struct FetchedRateLimits {
+    pub(crate) identity: RateLimitIdentity,
+    pub(crate) response: GetAccountRateLimitsResponse,
+    pub(crate) pace_by_limit_id: std::collections::HashMap<String, RateLimitWindowPace>,
+}
+
+#[derive(Clone)]
+struct CachedSnapshot {
+    identity: RateLimitIdentity,
+    response: GetAccountRateLimitsResponse,
+    #[allow(dead_code)]
+    pace_by_limit_id: std::collections::HashMap<String, RateLimitWindowPace>,
+}
+
+#[derive(Default)]
+struct RefreshState {
+    cached: Option<CachedSnapshot>,
+    refreshing: bool,
+    generation: u64,
+}
+
+impl RefreshState {
+    fn begin_refresh(&mut self) -> Option<u64> {
+        if self.refreshing {
+            return None;
+        }
+        self.refreshing = true;
+        Some(self.generation)
+    }
+
+    fn finish_refresh(&mut self, generation: u64) -> bool {
+        self.refreshing = false;
+        generation == self.generation
+    }
+
+    fn invalidate(&mut self) {
+        self.cached = None;
+        self.generation = self.generation.wrapping_add(1);
+    }
+}
+
+struct Inner {
+    processor: AccountRequestProcessor,
+    outgoing: Arc<OutgoingMessageSender>,
+    state: Mutex<RefreshState>,
+    changed: Notify,
+}
+
+#[derive(Clone)]
+pub(crate) struct RateLimitManager {
+    inner: Arc<Inner>,
+    cancel: CancellationToken,
+    tasks: TaskTracker,
+}
+
+impl RateLimitManager {
+    pub(crate) fn start(
+        processor: AccountRequestProcessor,
+        outgoing: Arc<OutgoingMessageSender>,
+    ) -> Self {
+        let manager = Self {
+            inner: Arc::new(Inner {
+                processor,
+                outgoing,
+                state: Mutex::new(RefreshState::default()),
+                changed: Notify::new(),
+            }),
+            cancel: CancellationToken::new(),
+            tasks: TaskTracker::new(),
+        };
+        manager.spawn_refresh();
+        manager
+    }
+
+    pub(crate) async fn read(&self) -> Result<GetAccountRateLimitsResponse, JSONRPCErrorError> {
+        refresh(&self.inner).await
+    }
+
+    pub(crate) async fn invalidate_and_refresh(&self) {
+        let mut state = self.inner.state.lock().await;
+        state.invalidate();
+        drop(state);
+        self.spawn_refresh();
+    }
+
+    fn spawn_refresh(&self) {
+        let inner = Arc::clone(&self.inner);
+        let cancel = self.cancel.clone();
+        self.tasks.spawn(async move {
+            tokio::select! {
+                _ = cancel.cancelled() => {}
+                _ = refresh(&inner) => {}
+            }
+        });
+    }
+
+    pub(crate) fn cancel(&self) {
+        self.cancel.cancel();
+    }
+
+    pub(crate) async fn drain(&self) {
+        self.cancel();
+        self.tasks.close();
+        self.tasks.wait().await;
+    }
+}
+
+async fn refresh(inner: &Arc<Inner>) -> Result<GetAccountRateLimitsResponse, JSONRPCErrorError> {
+    loop {
+        let current_identity = inner.processor.cached_rate_limit_identity();
+        let notified = inner.changed.notified();
+        let fetch_generation = {
+            let mut state = inner.state.lock().await;
+            if let Some(cached) = &state.cached
+                && cached.identity == current_identity
+            {
+                return Ok(cached.response.clone());
+            }
+            if state
+                .cached
+                .as_ref()
+                .is_some_and(|cached| cached.identity != current_identity)
+            {
+                state.cached = None;
+            }
+            state.begin_refresh()
+        };
+        let Some(fetch_generation) = fetch_generation else {
+            notified.await;
+            continue;
+        };
+
+        let result = inner.processor.fetch_account_rate_limits().await;
+        let mut notification = None;
+        let generation_is_current;
+        let mut accepted = false;
+        {
+            let mut state = inner.state.lock().await;
+            generation_is_current = state.finish_refresh(fetch_generation);
+            if generation_is_current
+                && let Ok(fetched) = &result
+                && fetched.identity == inner.processor.cached_rate_limit_identity()
+            {
+                state.cached = Some(CachedSnapshot {
+                    identity: fetched.identity.clone(),
+                    response: fetched.response.clone(),
+                    pace_by_limit_id: fetched.pace_by_limit_id.clone(),
+                });
+                notification = Some(AccountRateLimitsUpdatedNotification {
+                    rate_limits: fetched.response.rate_limits.clone(),
+                });
+                accepted = true;
+            }
+        }
+        inner.changed.notify_waiters();
+
+        if let Some(notification) = notification {
+            inner
+                .outgoing
+                .send_server_notification(ServerNotification::AccountRateLimitsUpdated(
+                    notification,
+                ))
+                .await;
+        }
+
+        if !generation_is_current {
+            continue;
+        }
+        match result {
+            Ok(fetched) if accepted => return Ok(fetched.response),
+            Ok(_) => {
+                continue;
+            }
+            Err(err) => return Err(err),
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::RefreshState;
+
+    #[test]
+    fn invalidation_rejects_in_flight_generation_and_requires_another_fetch() {
+        let mut state = RefreshState::default();
+        let stale_generation = state.begin_refresh().expect("initial fetch");
+
+        state.invalidate();
+
+        assert!(!state.finish_refresh(stale_generation));
+        assert_eq!(state.begin_refresh(), Some(stale_generation + 1));
+    }
+
+    #[test]
+    fn concurrent_refreshes_share_one_generation() {
+        let mut state = RefreshState::default();
+        let generation = state.begin_refresh().expect("initial fetch");
+
+        assert_eq!(state.begin_refresh(), None);
+        assert!(state.finish_refresh(generation));
+    }
+}
