+fn rate_limit_paces_by_limit_id(
+    snapshots: &HashMap<String, RateLimitSnapshot>,
+    captured_at: std::time::SystemTime,
+) -> HashMap<String, RateLimitWindowPace> {
+    let captured_at = captured_at
+        .duration_since(std::time::UNIX_EPOCH)
+        .ok()
+        .and_then(|elapsed| i64::try_from(elapsed.as_secs()).ok());
+    snapshots
+        .iter()
+        .filter_map(|(limit_id, snapshot)| {
+            let captured_at = captured_at?;
+            let pace = RateLimitWindowPace {
+                primary: rate_limit_window_pace(snapshot.primary.as_ref(), captured_at),
+                secondary: rate_limit_window_pace(snapshot.secondary.as_ref(), captured_at),
+            };
+            (pace.primary.is_some() || pace.secondary.is_some()).then(|| (limit_id.clone(), pace))
+        })
+        .collect()
+}
+
+fn rate_limit_window_pace(window: Option<&RateLimitWindow>, captured_at: i64) -> Option<i32> {
+    let window = window?;
+    let duration_secs = window.window_duration_mins?.checked_mul(60)?;
+    if duration_secs <= 0 {
+        return None;
+    }
+    let started_at = window.resets_at?.checked_sub(duration_secs)?;
+    let elapsed_secs = captured_at.checked_sub(started_at)?;
+    let elapsed_percent = (elapsed_secs as f64 / duration_secs as f64 * 100.0).clamp(0.0, 100.0);
+    let used_percent = window.used_percent.clamp(0, 100) as f64;
+    Some((elapsed_percent - used_percent).round() as i32)
+}
