+#[tokio::test]
+async fn rolling_rate_limit_updates_wake_a_cache_only_snapshot_read() -> Result<()> {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let app_server = crate::start_embedded_app_server_for_picker(app.chat_widget.config_ref())
+        .await
+        .expect("embedded app server");
+
+    deliver_rolling_rate_limit_snapshot(
+        &mut app,
+        &app_server,
+        rate_limit_snapshot(
+            /*used_percent*/ 42, /*rate_limit_reached_type*/ None,
+            /*spend_control_reached*/ None,
+        ),
+    )
+    .await;
+
+    let event = tokio::time::timeout(std::time::Duration::from_secs(1), async {
+        loop {
+            if let Some(event) = app_event_rx.recv().await
+                && matches!(
+                    event,
+                    AppEvent::RateLimitsLoaded {
+                        origin: RateLimitRefreshOrigin::UpdatedWake,
+                        ..
+                    }
+                )
+            {
+                break event;
+            }
+        }
+    })
+    .await?;
+    assert!(matches!(
+        event,
+        AppEvent::RateLimitsLoaded {
+            origin: RateLimitRefreshOrigin::UpdatedWake,
+            ..
+        }
+    ));
+
+    app_server.shutdown().await?;
+    Ok(())
+}
