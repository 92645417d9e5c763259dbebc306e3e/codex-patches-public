+fn scan_legacy_model_context_from_scanner<R>(
+    scanner: &mut ReverseJsonlScanner<R>,
+    session_meta: SessionMetaLine,
+) -> io::Result<Vec<RolloutItem>>
+where
+    R: io::Read + io::Seek,
+{
+    let mut scan = ModelContextScan::default();
+    let mut at_crash_tail = true;
+    while let Some(outcome) = scanner.scan_next::<RolloutLine>()? {
+        let line = match outcome {
+            ScanOutcome::Parsed(line) => {
+                at_crash_tail = false;
+                line
+            }
+            ScanOutcome::Rejected(_) if at_crash_tail => {
+                // A process can crash while appending its final JSONL record. Only that newest
+                // malformed tail is safely ignorable; older corruption makes selection unsafe.
+                at_crash_tail = false;
+                continue;
+            }
+            ScanOutcome::Rejected(_) => {
+                return Err(io::Error::other(
+                    "bounded legacy model context unavailable after malformed JSONL record",
+                ));
+            }
+        };
+        if matches!(&line.item, RolloutItem::SessionMeta(_)) {
+            break;
+        }
+        if matches!(scan.push(line.item), ModelContextScanProgress::Complete) {
+            break;
+        }
+    }
+    let canonical_meta = session_meta.clone();
+    let mut items = scan.finish(session_meta);
+    if !matches!(items.first(), Some(RolloutItem::SessionMeta(_))) {
+        items.insert(0, RolloutItem::SessionMeta(canonical_meta));
+    }
+    Ok(items)
+}
