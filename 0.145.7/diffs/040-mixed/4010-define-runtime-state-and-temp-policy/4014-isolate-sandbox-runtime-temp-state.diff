+pub(crate) fn apply_runtime_isolation_to_bwrap_args(
+    bwrap_args: &mut BwrapArgs,
+    mounts: BwrapRuntimeMounts<'_>,
+) -> Result<()> {
+    let args = &mut bwrap_args.args;
+    let runtime_root = mounts.runtime_root;
+    for index in 0..args.len().saturating_sub(3) {
+        if args[index] == "--perms"
+            && args[index + 1] == "000"
+            && args[index + 2] == "--tmpfs"
+            && runtime_root.starts_with(Path::new(&args[index + 3]))
+        {
+            args[index + 1] = "111".to_string();
+        }
+    }
+
+    let default_insertion_index = args
+        .iter()
+        .position(|arg| arg == "--unshare-user")
+        .or_else(|| args.iter().position(|arg| arg == "--"))
+        .ok_or_else(|| {
+            CodexErr::Fatal("bubblewrap argv is missing command separator".to_string())
+        })?;
+    let mut target_insertions = args
+        .windows(2)
+        .enumerate()
+        .filter_map(|(index, window)| {
+            (window[0] == "--remount-ro" && runtime_root.starts_with(Path::new(&window[1])))
+                .then(|| (index, PathBuf::from(&window[1])))
+        })
+        .collect::<Vec<_>>();
+    if target_insertions.is_empty() {
+        target_insertions.push((default_insertion_index, PathBuf::from("/")));
+    }
+    for (insertion_index, anchor) in target_insertions.into_iter().rev() {
+        let mut target_args = Vec::new();
+        append_mount_target_parent_dir_args(&mut target_args, runtime_root, &anchor);
+        args.splice(insertion_index..insertion_index, target_args);
+    }
+
+    let insertion_index = args
+        .iter()
+        .position(|arg| arg == "--unshare-user")
+        .or_else(|| args.iter().position(|arg| arg == "--"))
+        .ok_or_else(|| {
+            CodexErr::Fatal("bubblewrap argv is missing command separator".to_string())
+        })?;
+    let mut runtime_args = vec![
+        "--perms".to_string(),
+        "700".to_string(),
+        "--tmpfs".to_string(),
+        path_to_string(runtime_root),
+    ];
+    if let Some(proxy_socket_dir) = mounts.proxy_socket_dir {
+        append_mount_target_parent_dir_args(&mut runtime_args, proxy_socket_dir, runtime_root);
+        runtime_args.extend([
+            "--ro-bind".to_string(),
+            path_to_string(proxy_socket_dir),
+            path_to_string(proxy_socket_dir),
+        ]);
+    }
+    runtime_args.extend(["--remount-ro".to_string(), path_to_string(runtime_root)]);
+    args.splice(insertion_index..insertion_index, runtime_args);
+    Ok(())
+}
