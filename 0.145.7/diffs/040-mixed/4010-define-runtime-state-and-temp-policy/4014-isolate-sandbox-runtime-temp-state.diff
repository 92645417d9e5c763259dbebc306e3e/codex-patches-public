new file mode 100644
index 0000000000..bd1b15b780
--- /dev/null
+++ b/codex-rs/linux-sandbox/src/runtime_tmp.rs
@@ -0,0 +1,34 @@
+use codex_utils_home_dir::PrivateCodexTmpDir;
+use codex_utils_home_dir::prepare_private_codex_tmp_root;
+use std::ffi::OsStr;
+use std::path::Path;
+
+const LINUX_SANDBOX_TMP_DIR: &str = "linux-sandbox";
+
+#[derive(Debug)]
+pub(crate) struct LinuxSandboxTmp {
+    root: PrivateCodexTmpDir,
+}
+
+impl LinuxSandboxTmp {
+    pub(crate) fn prepare() -> std::io::Result<Self> {
+        let root = prepare_private_codex_tmp_root()?.ensure_subdir(LINUX_SANDBOX_TMP_DIR)?;
+        root.validate()?;
+        Ok(Self { root })
+    }
+
+    pub(crate) fn as_path(&self) -> &Path {
+        self.root.as_path()
+    }
+
+    pub(crate) fn ensure_subdir(
+        &self,
+        name: impl AsRef<OsStr>,
+    ) -> std::io::Result<PrivateCodexTmpDir> {
+        self.root.ensure_subdir(name)
+    }
+
+    pub(crate) fn validate(&self) -> std::io::Result<()> {
+        self.root.validate()
+    }
+}
