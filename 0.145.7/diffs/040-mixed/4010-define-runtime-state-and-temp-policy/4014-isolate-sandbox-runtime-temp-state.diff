+#[derive(Clone, Copy, Debug)]
+pub(crate) struct BwrapRuntimeMounts<'a> {
+    runtime_root: &'a Path,
+    proxy_socket_dir: Option<&'a Path>,
+}
+
+impl<'a> BwrapRuntimeMounts<'a> {
+    pub(crate) fn new(runtime_root: &'a Path, proxy_socket_dir: Option<&'a Path>) -> Result<Self> {
+        if !runtime_root.is_absolute()
+            || !std::fs::symlink_metadata(runtime_root)
+                .is_ok_and(|metadata| metadata.file_type().is_dir())
+        {
+            return Err(CodexErr::Fatal(format!(
+                "Linux sandbox runtime root is not an absolute non-symlink directory: {}",
+                runtime_root.display()
+            )));
+        }
+        if let Some(proxy_socket_dir) = proxy_socket_dir {
+            let canonical_runtime_root = runtime_root.canonicalize().map_err(|error| {
+                CodexErr::Fatal(format!(
+                    "failed to resolve Linux sandbox runtime root {}: {error}",
+                    runtime_root.display()
+                ))
+            })?;
+            let canonical_proxy_socket_dir = proxy_socket_dir.canonicalize().map_err(|error| {
+                CodexErr::Fatal(format!(
+                    "failed to resolve Linux proxy socket directory {}: {error}",
+                    proxy_socket_dir.display()
+                ))
+            })?;
+            if proxy_socket_dir == runtime_root
+                || !proxy_socket_dir.starts_with(runtime_root)
+                || !std::fs::symlink_metadata(proxy_socket_dir)
+                    .is_ok_and(|metadata| metadata.file_type().is_dir())
+                || canonical_proxy_socket_dir == canonical_runtime_root
+                || !canonical_proxy_socket_dir.starts_with(&canonical_runtime_root)
+            {
+                return Err(CodexErr::Fatal(format!(
+                    "Linux proxy socket directory is not a strict runtime-root descendant or is missing: {}",
+                    proxy_socket_dir.display()
+                )));
+            }
+        }
+        Ok(Self {
+            runtime_root,
+            proxy_socket_dir,
+        })
+    }
+}
