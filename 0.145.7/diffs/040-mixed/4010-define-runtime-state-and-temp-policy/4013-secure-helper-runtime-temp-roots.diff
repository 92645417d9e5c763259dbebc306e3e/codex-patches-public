+use crate::find_codex_tmp_root;
+use codex_utils_absolute_path::AbsolutePathBuf;
+use std::ffi::OsStr;
+use std::io;
+use std::path::Component;
+use std::path::Path;
+use std::path::PathBuf;
+
+const PRIVATE_DIRECTORY_MODE: u32 = 0o700;
+const PERMISSION_BITS: u32 = 0o7777;
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct DirectoryIdentity {
+    device: u64,
+    inode: u64,
+}
+
+#[derive(Debug, Eq, PartialEq)]
+struct SafeAncestorChain {
+    lexical: Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>,
+    resolved: Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>,
+}
+
+impl SafeAncestorChain {
+    fn capture(path: &Path) -> io::Result<Self> {
+        Ok(Self {
+            lexical: capture_ancestor_entries(path)?,
+            resolved: capture_ancestor_entries(&std::fs::canonicalize(path)?)?,
+        })
+    }
+
+    fn validate(&self) -> io::Result<()> {
+        let path = self
+            .lexical
+            .last()
+            .map(|(path, _, _)| path.as_path())
+            .ok_or_else(|| private_directory_error("temporary directory has no ancestors"))?;
+        if &Self::capture(path)? != self {
+            return Err(private_directory_error(format!(
+                "temporary directory ancestor was replaced: {}",
+                path.display()
+            )));
+        }
+        Ok(())
+    }
+}
+
+/// A current-user-private directory beneath the supplied `$CODEX_TMP` root.
+#[derive(Debug)]
+pub struct PrivateCodexTmpDir {
+    path: AbsolutePathBuf,
+    parent_chain: SafeAncestorChain,
+    identity: DirectoryIdentity,
+}
+
+impl PrivateCodexTmpDir {
+    fn prepare(path: AbsolutePathBuf) -> io::Result<Self> {
+        use std::os::unix::fs::DirBuilderExt;
+        use std::os::unix::fs::MetadataExt;
+        use std::os::unix::fs::PermissionsExt;
+
+        let parent = path.as_path().parent().ok_or_else(|| {
+            private_directory_error(format!(
+                "private directory has no parent: {}",
+                path.as_path().display()
+            ))
+        })?;
+        let parent_chain = SafeAncestorChain::capture(parent)?;
+        let mut builder = std::fs::DirBuilder::new();
+        builder.mode(PRIVATE_DIRECTORY_MODE);
+        match builder.create(path.as_path()) {
+            Ok(()) => {}
+            Err(error) if error.kind() == io::ErrorKind::AlreadyExists => {}
+            Err(error) => return Err(error),
+        }
+        parent_chain.validate()?;
+
+        let effective_uid = unsafe { libc::geteuid() };
+        let mut metadata = private_directory_metadata(path.as_path())?;
+        if metadata.uid() != effective_uid {
+            return Err(private_directory_error(format!(
+                "private temp directory is owned by uid {}, not current uid {effective_uid}: {}",
+                metadata.uid(),
+                path.as_path().display()
+            )));
+        }
+        if metadata.mode() & 0o022 != 0 {
+            return Err(private_directory_error(format!(
+                "private temp directory is writable by other users: {}",
+                path.as_path().display()
+            )));
+        }
+        if metadata.mode() & PERMISSION_BITS != PRIVATE_DIRECTORY_MODE {
+            std::fs::set_permissions(
+                path.as_path(),
+                std::fs::Permissions::from_mode(PRIVATE_DIRECTORY_MODE),
+            )?;
+            metadata = private_directory_metadata(path.as_path())?;
+        }
+        if metadata.uid() != effective_uid
+            || metadata.mode() & PERMISSION_BITS != PRIVATE_DIRECTORY_MODE
+        {
+            return Err(private_directory_error(format!(
+                "private temp directory could not be secured: {}",
+                path.as_path().display()
+            )));
+        }
+        parent_chain.validate()?;
+
+        Ok(Self {
+            path,
+            parent_chain,
+            identity: directory_identity(&metadata),
+        })
+    }
+
+    pub fn as_path(&self) -> &Path {
+        self.path.as_path()
+    }
+
+    pub fn ensure_subdir(&self, name: impl AsRef<OsStr>) -> io::Result<Self> {
+        self.validate()?;
+        let name = name.as_ref();
+        let mut components = Path::new(name).components();
+        if !matches!(components.next(), Some(Component::Normal(_))) || components.next().is_some() {
+            return Err(io::Error::new(
+                io::ErrorKind::InvalidInput,
+                format!(
+                    "private temp subdirectory must be one path component: {}",
+                    name.to_string_lossy()
+                ),
+            ));
+        }
+        Self::prepare(self.path.join(name))
+    }
+
+    pub fn validate(&self) -> io::Result<()> {
+        use std::os::unix::fs::MetadataExt;
+
+        self.parent_chain.validate()?;
+        let metadata = private_directory_metadata(self.path.as_path())?;
+        let effective_uid = unsafe { libc::geteuid() };
+        if directory_identity(&metadata) != self.identity
+            || metadata.uid() != effective_uid
+            || metadata.mode() & PERMISSION_BITS != PRIVATE_DIRECTORY_MODE
+        {
+            return Err(private_directory_error(format!(
+                "private temp directory was replaced or made unsafe: {}",
+                self.path.as_path().display()
+            )));
+        }
+        Ok(())
+    }
+}
+
+pub fn prepare_private_codex_tmp_root() -> io::Result<PrivateCodexTmpDir> {
+    PrivateCodexTmpDir::prepare(find_codex_tmp_root()?)
+}
+
+fn capture_ancestor_entries(
+    path: &Path,
+) -> io::Result<Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>> {
+    use std::os::unix::fs::MetadataExt;
+
+    let effective_uid = unsafe { libc::geteuid() };
+    let mut entries = Vec::new();
+    for ancestor in path.ancestors().collect::<Vec<_>>().into_iter().rev() {
+        let lexical_metadata = std::fs::symlink_metadata(ancestor)?;
+        if lexical_metadata.file_type().is_symlink() {
+            let owner = lexical_metadata.uid();
+            if owner != 0 && owner != effective_uid {
+                return Err(private_directory_error(format!(
+                    "temporary directory symlink is owned by uid {owner}: {}",
+                    ancestor.display()
+                )));
+            }
+        }
+        let metadata = std::fs::metadata(ancestor)?;
+        if !metadata.is_dir() {
+            return Err(private_directory_error(format!(
+                "temporary directory ancestor is not a directory: {}",
+                ancestor.display()
+            )));
+        }
+        let owner = metadata.uid();
+        if owner != 0 && owner != effective_uid {
+            return Err(private_directory_error(format!(
+                "temporary directory ancestor is owned by uid {owner}: {}",
+                ancestor.display()
+            )));
+        }
+        let mode = metadata.mode();
+        if mode & 0o022 != 0 && mode & 0o1000 == 0 {
+            return Err(private_directory_error(format!(
+                "temporary directory ancestor is writable without the sticky bit: {}",
+                ancestor.display()
+            )));
+        }
+        entries.push((
+            ancestor.to_path_buf(),
+            directory_identity(&lexical_metadata),
+            directory_identity(&metadata),
+        ));
+    }
+    Ok(entries)
+}
+
+fn private_directory_metadata(path: &Path) -> io::Result<std::fs::Metadata> {
+    let metadata = std::fs::symlink_metadata(path)?;
+    if !metadata.file_type().is_dir() {
+        return Err(private_directory_error(format!(
+            "private temp path is not a non-symlink directory: {}",
+            path.display()
+        )));
+    }
+    Ok(metadata)
+}
+
+fn directory_identity(metadata: &std::fs::Metadata) -> DirectoryIdentity {
+    use std::os::unix::fs::MetadataExt;
+
+    DirectoryIdentity {
+        device: metadata.dev(),
+        inode: metadata.ino(),
+    }
+}
+
+fn private_directory_error(message: impl Into<String>) -> io::Error {
+    io::Error::new(io::ErrorKind::PermissionDenied, message.into())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::fs;
+    use std::os::unix::fs::MetadataExt;
+    use std::os::unix::fs::PermissionsExt;
+    use std::os::unix::fs::symlink;
+    use tempfile::TempDir;
+
+    fn absolute(path: impl Into<PathBuf>) -> AbsolutePathBuf {
+        AbsolutePathBuf::from_absolute_path(path.into()).expect("absolute path")
+    }
+
+    fn local_temp() -> io::Result<TempDir> {
+        TempDir::new_in(std::env::current_dir()?)
+    }
+
+    #[test]
+    fn private_root_accepts_sticky_parent_and_uses_mode_0700() -> io::Result<()> {
+        let root = local_temp()?;
+        let parent = root.path().join("sticky");
+        fs::create_dir(&parent)?;
+        fs::set_permissions(&parent, fs::Permissions::from_mode(0o1777))?;
+
+        let private = PrivateCodexTmpDir::prepare(absolute(parent.join("codex")))?;
+        let metadata = fs::symlink_metadata(private.as_path())?;
+
+        assert_eq!(metadata.uid(), unsafe { libc::geteuid() });
+        assert_eq!(metadata.mode() & PERMISSION_BITS, PRIVATE_DIRECTORY_MODE);
+        Ok(())
+    }
+
+    #[test]
+    fn private_root_rejects_non_sticky_writable_parent() -> io::Result<()> {
+        let root = local_temp()?;
+        let parent = root.path().join("unsafe");
+        fs::create_dir(&parent)?;
+        fs::set_permissions(&parent, fs::Permissions::from_mode(0o777))?;
+        let path = parent.join("codex");
+
+        let error = PrivateCodexTmpDir::prepare(absolute(&path)).expect_err("unsafe parent");
+
+        assert_eq!(error.kind(), io::ErrorKind::PermissionDenied);
+        assert!(!path.exists());
+        Ok(())
+    }
+
+    #[test]
+    fn private_root_rejects_symlink_root() -> io::Result<()> {
+        let root = local_temp()?;
+        let target = root.path().join("target");
+        let path = root.path().join("codex");
+        fs::create_dir(&target)?;
+        symlink(&target, &path)?;
+
+        let error = PrivateCodexTmpDir::prepare(absolute(&path)).expect_err("symlink root");
+
+        assert_eq!(error.kind(), io::ErrorKind::PermissionDenied);
+        assert_eq!(fs::read_link(path)?, target);
+        Ok(())
+    }
+
+    #[test]
+    fn private_root_detects_replacement() -> io::Result<()> {
+        let root = local_temp()?;
+        let path = root.path().join("codex");
+        let replacement = root.path().join("replacement");
+        let private = PrivateCodexTmpDir::prepare(absolute(&path))?;
+        fs::rename(&path, &replacement)?;
+        fs::create_dir(&path)?;
+
+        let error = private.validate().expect_err("replacement");
+
+        assert_eq!(error.kind(), io::ErrorKind::PermissionDenied);
+        Ok(())
+    }
+
+    #[test]
+    fn private_subdir_requires_one_component() -> io::Result<()> {
+        let root = local_temp()?;
+        let private = PrivateCodexTmpDir::prepare(absolute(root.path().join("codex")))?;
+
+        let error = private
+            .ensure_subdir("nested/child")
+            .expect_err("nested child");
+
+        assert_eq!(error.kind(), io::ErrorKind::InvalidInput);
+        Ok(())
+    }
+}
