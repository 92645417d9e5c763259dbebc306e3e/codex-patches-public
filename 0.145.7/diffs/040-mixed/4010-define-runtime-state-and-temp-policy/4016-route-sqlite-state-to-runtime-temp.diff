+#[tokio::test]
+async fn debug_clear_memories_clears_legacy_home_without_creating_current_db() -> Result<()> {
+    let root = TempDir::new()?;
+    let codex_home = root.path().join("codex-home");
+    let sqlite_home = root.path().join("runtime-sqlite");
+    std::fs::create_dir(&codex_home)?;
+    let sqlite = codex_state::SqliteConfig::new_for_testing(codex_home.abs());
+    let runtime = StateRuntime::init(codex_home.clone(), "test-provider".to_string()).await?;
+    runtime.close().await;
+
+    let legacy_memories_path = memories_db_path(&codex_home);
+    let memories_pool = sqlite.open_read_write_pool(&legacy_memories_path).await?;
+    sqlx::query(
+        r#"
+INSERT INTO stage1_outputs (
+    thread_id,
+    source_updated_at,
+    raw_memory,
+    rollout_summary,
+    generated_at,
+    rollout_slug,
+    usage_count,
+    last_usage,
+    selected_for_phase2,
+    selected_for_phase2_source_updated_at
+) VALUES ('00000000-0000-0000-0000-000000000123', 1, 'raw', 'summary', 1, NULL, 0, NULL, 0, NULL)
+        "#,
+    )
+    .execute(&memories_pool)
+    .await?;
+    memories_pool.close().await;
+    assert!(!sqlite_home.exists());
+
+    let mut cmd = codex_command(&codex_home, &sqlite_home)?;
+    cmd.args(["debug", "clear-memories"])
+        .assert()
+        .success()
+        .stdout(contains(legacy_memories_path.display().to_string()));
+
+    assert!(!sqlite_home.exists());
+    let pool = sqlite.open_read_only_pool(&legacy_memories_path).await?;
+    let count: i64 = sqlx::query_scalar("SELECT COUNT(*) FROM stage1_outputs")
+        .fetch_one(&pool)
+        .await?;
+    pool.close().await;
+    assert_eq!(count, 0);
+
+    Ok(())
+}
