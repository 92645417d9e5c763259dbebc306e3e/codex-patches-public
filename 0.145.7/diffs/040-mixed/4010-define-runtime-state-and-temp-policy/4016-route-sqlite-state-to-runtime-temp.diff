+use crate::StateRuntime;
+use crate::backup_runtime_db_for_fresh_start;
+use crate::open_thread_history_db;
+use crate::read_thread_state_audit_rows;
+use crate::sqlite_integrity_check;
+use crate::state_db_path;
+use std::path::Path;
+use std::path::PathBuf;
+use tempfile::TempDir;
+
+const CASE_ENV: &str = "CODEX_STATE_SQLITE_GUARD_CASE";
+const CUSTOM_HOME_ENV: &str = "CODEX_STATE_SQLITE_GUARD_CUSTOM_HOME";
+const TEST_NAME: &str = "sqlite_home_tests::default_sqlite_home_guard_contract";
+
+async fn assert_state_init_fails(sqlite_home: PathBuf) {
+    if let Ok(runtime) = StateRuntime::init(sqlite_home, "test-provider".to_string()).await {
+        runtime.close().await;
+        panic!("state runtime unexpectedly initialized");
+    }
+}
+
+#[tokio::test]
+async fn default_sqlite_home_guard_contract() -> anyhow::Result<()> {
+    use std::os::unix::fs::MetadataExt;
+    use std::os::unix::fs::PermissionsExt;
+    use std::os::unix::fs::symlink;
+
+    if let Ok(case) = std::env::var(CASE_ENV) {
+        let custom_home = PathBuf::from(std::env::var_os(CUSTOM_HOME_ENV).ok_or_else(|| {
+            std::io::Error::new(std::io::ErrorKind::NotFound, "missing custom home")
+        })?);
+        match case.as_str() {
+            "normal" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                let runtime =
+                    StateRuntime::init(sqlite_home.clone(), "test-provider".to_string()).await?;
+                runtime.close().await;
+                open_thread_history_db(&sqlite_home).await?.close().await;
+                let metadata = std::fs::symlink_metadata(&sqlite_home)?;
+                assert_eq!(metadata.mode() & 0o7777, 0o700);
+                assert!(state_db_path(&sqlite_home).is_file());
+            }
+            "unsafe-custom" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                assert_state_init_fails(sqlite_home.clone()).await;
+                assert!(!sqlite_home.exists());
+                let runtime =
+                    StateRuntime::init(custom_home.clone(), "test-provider".to_string()).await?;
+                runtime.close().await;
+                assert!(state_db_path(&custom_home).is_file());
+            }
+            "missing-reads" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                assert!(!StateRuntime::clear_memory_data_in_sqlite_home(&sqlite_home).await?);
+                assert!(
+                    read_thread_state_audit_rows(&state_db_path(&sqlite_home))
+                        .await
+                        .is_err()
+                );
+                assert!(
+                    sqlite_integrity_check(&state_db_path(&sqlite_home))
+                        .await
+                        .is_err()
+                );
+                assert!(!sqlite_home.exists());
+            }
+            "blocking-root" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                assert!(sqlite_home.is_file());
+                assert!(
+                    backup_runtime_db_for_fresh_start(&state_db_path(&sqlite_home))
+                        .await
+                        .is_err()
+                );
+                assert!(sqlite_home.is_file());
+            }
+            "aliases" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                let runtime =
+                    StateRuntime::init(sqlite_home.clone(), "test-provider".to_string()).await?;
+                runtime.close().await;
+                let parent = sqlite_home.parent().expect("SQLite home parent");
+                let symlink_home = parent.join("sqlite-alias");
+                symlink(&sqlite_home, &symlink_home)?;
+                assert_state_init_fails(symlink_home.clone()).await;
+                assert!(
+                    std::fs::symlink_metadata(&symlink_home)?
+                        .file_type()
+                        .is_symlink()
+                );
+
+                let nested = parent.join("nested");
+                assert_state_init_fails(nested.join("..").join("codex")).await;
+                assert!(!nested.exists());
+            }
+            "dangling-aliases" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                assert!(!sqlite_home.exists());
+                let parent = sqlite_home.parent().expect("SQLite home parent");
+                let absolute_alias = parent.join("sqlite-absolute-alias");
+                symlink(&sqlite_home, &absolute_alias)?;
+                let relative_alias = parent.join("sqlite-relative-alias");
+                symlink(Path::new("codex"), &relative_alias)?;
+                let chained_alias = parent.join("sqlite-chained-alias");
+                symlink(Path::new("sqlite-relative-alias"), &chained_alias)?;
+
+                for alias in [&absolute_alias, &relative_alias, &chained_alias] {
+                    assert_state_init_fails(alias.clone()).await;
+                    assert!(std::fs::symlink_metadata(alias)?.file_type().is_symlink());
+                }
+
+                let parent_alias = custom_home
+                    .parent()
+                    .expect("custom SQLite home parent")
+                    .join("runtime-tmp-alias");
+                symlink(parent, &parent_alias)?;
+                assert_state_init_fails(parent_alias.join("codex")).await;
+                assert!(
+                    std::fs::symlink_metadata(&parent_alias)?
+                        .file_type()
+                        .is_symlink()
+                );
+
+                let cycle_a = parent.join("sqlite-cycle-a");
+                let cycle_b = parent.join("sqlite-cycle-b");
+                symlink(Path::new("sqlite-cycle-b"), &cycle_a)?;
+                symlink(Path::new("sqlite-cycle-a"), &cycle_b)?;
+                assert_state_init_fails(cycle_a.clone()).await;
+                assert!(
+                    std::fs::symlink_metadata(&cycle_a)?
+                        .file_type()
+                        .is_symlink()
+                );
+                assert!(
+                    std::fs::symlink_metadata(&cycle_b)?
+                        .file_type()
+                        .is_symlink()
+                );
+                assert!(!sqlite_home.exists());
+            }
+            "custom-paths" => {
+                let sqlite_home = codex_utils_home_dir::find_codex_tmp_root()?.into_path_buf();
+                let custom_target = custom_home.join("existing-target");
+                std::fs::create_dir_all(&custom_target)?;
+                let custom_alias = custom_home.join("existing-alias");
+                symlink(&custom_target, &custom_alias)?;
+                let runtime = StateRuntime::init(custom_alias, "test-provider".to_string()).await?;
+                runtime.close().await;
+                assert!(state_db_path(&custom_target).is_file());
+
+                let deep_custom_home = custom_home.join("missing").join("deep");
+                let runtime =
+                    StateRuntime::init(deep_custom_home.clone(), "test-provider".to_string())
+                        .await?;
+                runtime.close().await;
+                assert!(state_db_path(&deep_custom_home).is_file());
+                assert!(!sqlite_home.exists());
+            }
+            "invalid-resolver-custom" => {
+                assert!(codex_utils_home_dir::find_codex_tmp_root().is_err());
+                let runtime =
+                    StateRuntime::init(custom_home.clone(), "test-provider".to_string()).await?;
+                runtime.close().await;
+                assert!(state_db_path(&custom_home).is_file());
+            }
+            _ => panic!("unknown SQLite guard case: {case}"),
+        }
+        return Ok(());
+    }
+
+    for case in [
+        "normal",
+        "unsafe-custom",
+        "missing-reads",
+        "blocking-root",
+        "aliases",
+        "dangling-aliases",
+        "custom-paths",
+        "invalid-resolver-custom",
+    ] {
+        let root = TempDir::new_in(std::env::current_dir()?)?;
+        let codex_tmp = root.path().join("runtime-tmp").join("codex");
+        std::fs::create_dir(codex_tmp.parent().expect("CODEX_TMP parent"))?;
+        if case == "unsafe-custom" {
+            std::fs::set_permissions(
+                codex_tmp.parent().expect("CODEX_TMP parent"),
+                std::fs::Permissions::from_mode(0o777),
+            )?;
+        }
+        if case == "blocking-root" {
+            std::fs::write(&codex_tmp, b"blocking file")?;
+        }
+        let custom_home = if case == "unsafe-custom" {
+            codex_tmp
+                .parent()
+                .expect("CODEX_TMP parent")
+                .join("custom-sqlite")
+        } else {
+            root.path().join("custom-sqlite")
+        };
+        let supplied_codex_tmp = if case == "invalid-resolver-custom" {
+            Path::new("relative-codex-tmp")
+        } else {
+            codex_tmp.as_path()
+        };
+        let output = std::process::Command::new(std::env::current_exe()?)
+            .arg("--exact")
+            .arg(TEST_NAME)
+            .arg("--test-threads=1")
+            .env(CASE_ENV, case)
+            .env(CUSTOM_HOME_ENV, &custom_home)
+            .env("CODEX_TMP", supplied_codex_tmp)
+            .output()?;
+        assert!(
+            output.status.success(),
+            "SQLite guard case {case} failed\nstdout:\n{}\nstderr:\n{}",
+            String::from_utf8_lossy(&output.stdout),
+            String::from_utf8_lossy(&output.stderr)
+        );
+    }
+
+    Ok(())
+}
