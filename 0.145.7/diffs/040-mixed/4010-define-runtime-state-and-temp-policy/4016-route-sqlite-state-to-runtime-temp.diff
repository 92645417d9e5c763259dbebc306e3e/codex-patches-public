diff --git a/codex-rs/state/src/sqlite_home.rs b/codex-rs/state/src/sqlite_home.rs
new file mode 100644
index 0000000000..d184f939d4
--- /dev/null
+++ b/codex-rs/state/src/sqlite_home.rs
@@ -0,0 +1,185 @@
+use std::future::Future;
+use std::path::Path;
+
+/// Guards only the default runtime SQLite root; explicitly configured homes
+/// continue through the upstream SQLite path unchanged.
+#[derive(Debug)]
+pub(crate) struct SqliteHomeGuard {
+    #[cfg(unix)]
+    private_root: Option<codex_utils_home_dir::PrivateCodexTmpDir>,
+}
+
+impl SqliteHomeGuard {
+    pub(crate) fn prepare(sqlite_home: &Path) -> std::io::Result<Self> {
+        #[cfg(unix)]
+        {
+            let private_root = match codex_utils_home_dir::find_codex_tmp_root() {
+                Ok(default_root) if sqlite_homes_alias(default_root.as_path(), sqlite_home)? => {
+                    if default_root.as_path() != sqlite_home {
+                        return Err(std::io::Error::new(
+                            std::io::ErrorKind::PermissionDenied,
+                            format!(
+                                "SQLite temp root must use its resolved path {}; alias {} is not allowed",
+                                default_root.as_path().display(),
+                                sqlite_home.display()
+                            ),
+                        ));
+                    }
+                    let private_root = codex_utils_home_dir::prepare_private_codex_tmp_root()?;
+                    if private_root.as_path() != sqlite_home {
+                        return Err(std::io::Error::new(
+                            std::io::ErrorKind::PermissionDenied,
+                            "SQLite temp root changed while its private guard was prepared",
+                        ));
+                    }
+                    Some(private_root)
+                }
+                Ok(_) | Err(_) => None,
+            };
+            let guard = Self { private_root };
+            guard.validate()?;
+            Ok(guard)
+        }
+        #[cfg(not(unix))]
+        {
+            let _ = sqlite_home;
+            Ok(Self {})
+        }
+    }
+
+    pub(crate) fn for_db_path(db_path: &Path) -> std::io::Result<Self> {
+        let sqlite_home = db_path.parent().ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::InvalidInput,
+                format!(
+                    "database path does not have a parent directory: {}",
+                    db_path.display()
+                ),
+            )
+        })?;
+        Self::prepare(sqlite_home)
+    }
+
+    pub(crate) fn validate(&self) -> std::io::Result<()> {
+        #[cfg(unix)]
+        if let Some(private_root) = self.private_root.as_ref() {
+            private_root.validate()?;
+        }
+        Ok(())
+    }
+
+    pub(crate) async fn run<T>(&self, operation: impl Future<Output = T>) -> std::io::Result<T> {
+        self.validate()?;
+        let output = operation.await;
+        self.validate()?;
+        Ok(output)
+    }
+}
+
+#[cfg(unix)]
+fn sqlite_homes_alias(left: &Path, right: &Path) -> std::io::Result<bool> {
+    if left == right {
+        return Ok(true);
+    }
+    if let (Some(left), Some(right)) = (
+        lexically_normalize_absolute(left),
+        lexically_normalize_absolute(right),
+    ) && left == right
+    {
+        return Ok(true);
+    }
+
+    let resolved_left = resolve_sqlite_home_symlinks(left)?;
+    let resolved_right = resolve_sqlite_home_symlinks(right)?;
+    if resolved_left == resolved_right {
+        return Ok(true);
+    }
+    if let (Some(left), Some(right)) = (
+        lexically_normalize_absolute(&resolved_left),
+        lexically_normalize_absolute(&resolved_right),
+    ) && left == right
+    {
+        return Ok(true);
+    }
+
+    match (
+        normalize_sqlite_home_for_comparison(left),
+        normalize_sqlite_home_for_comparison(right),
+    ) {
+        (Ok(left), Ok(right)) => Ok(left == right),
+        (Err(left_err), Err(right_err)) => {
+            if left_err.kind() != std::io::ErrorKind::NotFound {
+                Err(left_err)
+            } else if right_err.kind() != std::io::ErrorKind::NotFound {
+                Err(right_err)
+            } else {
+                Ok(false)
+            }
+        }
+        (Err(err), _) | (_, Err(err)) if err.kind() == std::io::ErrorKind::NotFound => Ok(false),
+        (Err(err), _) | (_, Err(err)) => Err(err),
+    }
+}
+
+#[cfg(unix)]
+fn resolve_sqlite_home_symlinks(path: &Path) -> std::io::Result<std::path::PathBuf> {
+    codex_utils_path::resolve_symlink_write_paths(path)?
+        .read_path
+        .ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::PermissionDenied,
+                format!(
+                    "SQLite home symbolic link chain could not be resolved safely: {}",
+                    path.display()
+                ),
+            )
+        })
+}
+
+#[cfg(unix)]
+fn lexically_normalize_absolute(path: &Path) -> Option<std::path::PathBuf> {
+    use std::path::Component;
+
+    if !path.is_absolute() {
+        return None;
+    }
+    let mut normalized = std::path::PathBuf::new();
+    for component in path.components() {
+        match component {
+            Component::CurDir => {}
+            Component::ParentDir => {
+                normalized.pop();
+            }
+            Component::Prefix(_) | Component::RootDir | Component::Normal(_) => {
+                normalized.push(component.as_os_str());
+            }
+        }
+    }
+    Some(normalized)
+}
+
+#[cfg(unix)]
+fn normalize_sqlite_home_for_comparison(path: &Path) -> std::io::Result<std::path::PathBuf> {
+    match std::fs::canonicalize(path) {
+        Ok(path) => Ok(path),
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => {
+            let parent = path.parent().ok_or_else(|| {
+                std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("SQLite home has no parent directory: {}", path.display()),
+                )
+            })?;
+            let file_name = path.file_name().ok_or_else(|| {
+                std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!(
+                        "SQLite home has no final path component: {}",
+                        path.display()
+                    ),
+                )
+            })?;
+            Ok(std::fs::canonicalize(parent)?.join(file_name))
+        }
+        Err(err) => Err(err),
+    }
+}
