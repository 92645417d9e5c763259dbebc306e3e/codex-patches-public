diff --git a/codex-rs/utils/home-dir/src/agent_paths.rs b/codex-rs/utils/home-dir/src/agent_paths.rs
new file mode 100644
index 0000000000..f30a614721
--- /dev/null
+++ b/codex-rs/utils/home-dir/src/agent_paths.rs
@@ -0,0 +1,82 @@
+use codex_utils_absolute_path::AbsolutePathBuf;
+use dirs::home_dir;
+use std::io;
+use std::path::Path;
+
+pub const REPOS_ROOT_ENV: &str = "REPOS_ROOT";
+pub const SKILLS_ROOT_ENV: &str = "SKILLS_ROOT";
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct AgentPathRoots {
+    pub repos_root: AbsolutePathBuf,
+    pub skills_root: AbsolutePathBuf,
+}
+
+impl AgentPathRoots {
+    pub fn ensure(&self) -> io::Result<()> {
+        std::fs::create_dir_all(self.repos_root.as_path())?;
+        std::fs::create_dir_all(self.skills_root.as_path())
+    }
+}
+
+pub fn resolve_agent_path_roots(codex_home: &Path) -> io::Result<AgentPathRoots> {
+    let user_home = home_dir()
+        .ok_or_else(|| io::Error::new(io::ErrorKind::NotFound, "could not find home directory"))?;
+    resolve_agent_path_roots_from(&user_home, codex_home)
+}
+
+fn resolve_agent_path_roots_from(
+    user_home: &Path,
+    codex_home: &Path,
+) -> io::Result<AgentPathRoots> {
+    let user_home =
+        AbsolutePathBuf::from_absolute_path(user_home.to_path_buf()).map_err(|error| {
+            io::Error::new(
+                io::ErrorKind::InvalidInput,
+                format!("invalid user home: {error}"),
+            )
+        })?;
+    let codex_home =
+        AbsolutePathBuf::from_absolute_path(codex_home.to_path_buf()).map_err(|error| {
+            io::Error::new(
+                io::ErrorKind::InvalidInput,
+                format!("invalid CODEX_HOME: {error}"),
+            )
+        })?;
+    Ok(AgentPathRoots {
+        repos_root: user_home.join("repos"),
+        skills_root: codex_home.join("skills"),
+    })
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn agent_roots_derive_from_user_and_codex_homes() {
+        let temp = tempfile::tempdir().expect("temp dir");
+        let user_home = temp.path().join("home");
+        let codex_home = temp.path().join("codex-home");
+
+        let roots = resolve_agent_path_roots_from(&user_home, &codex_home).expect("agent roots");
+
+        assert_eq!(roots.repos_root.as_path(), user_home.join("repos"));
+        assert_eq!(roots.skills_root.as_path(), codex_home.join("skills"));
+    }
+
+    #[test]
+    fn ensure_creates_both_agent_roots() {
+        let temp = tempfile::tempdir().expect("temp dir");
+        let roots = resolve_agent_path_roots_from(
+            &temp.path().join("home"),
+            &temp.path().join("codex-home"),
+        )
+        .expect("agent roots");
+
+        roots.ensure().expect("create agent roots");
+
+        assert!(roots.repos_root.as_path().is_dir());
+        assert!(roots.skills_root.as_path().is_dir());
+    }
+}
