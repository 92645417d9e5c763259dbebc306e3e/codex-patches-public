+fn summarize_search_paths<'a, I>(paths: I) -> Option<String>
+where
+    I: IntoIterator<Item = &'a String>,
+{
+    let mut paths = paths.into_iter();
+    let first = short_display_path(paths.next()?);
+    let remaining = paths.count();
+    if remaining == 0 {
+        Some(first)
+    } else {
+        Some(format!("{first} +{remaining} more"))
+    }
+}
