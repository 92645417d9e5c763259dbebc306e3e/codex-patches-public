+    let sleep = ["/bin/sleep", "/usr/bin/sleep"]
+        .into_iter()
+        .map(std::path::Path::new)
+        .find(|path| path.is_file())
+        .expect("sleep executable");
+    let temp_dir = tempfile::TempDir::new().expect("temp dir");
+    let executable = temp_dir.path().join("codex");
+    tokio::fs::copy(sleep, &executable)
+        .await
+        .expect("copy executable");
+    let expected = executable_identity(&executable)
+        .await
+        .expect("initial identity");
+    let mut child = tokio::process::Command::new(&executable)
+        .arg("30")
+        .spawn()
+        .expect("spawn copied executable");
+    let pid = child.id().expect("spawned pid");
+
+    let replacement = temp_dir.path().join("replacement");
+    tokio::fs::write(&replacement, b"replacement")
+        .await
+        .expect("write replacement");
+    tokio::fs::rename(&replacement, &executable)
+        .await
+        .expect("replace executable path");
+    let spawned = spawned_executable_identity(pid, &executable)
+        .await
+        .expect("spawned identity")
+        .expect("Linux spawned identity");
+    let current = executable_identity(&executable)
+        .await
+        .expect("replacement identity");
+    child.kill().await.expect("kill copied executable");
+
+    assert_eq!(spawned, expected);
+    assert_ne!(spawned, current);
+}
