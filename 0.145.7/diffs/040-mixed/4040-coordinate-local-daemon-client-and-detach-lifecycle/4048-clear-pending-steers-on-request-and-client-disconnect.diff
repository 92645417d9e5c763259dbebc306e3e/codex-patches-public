+#[tokio::test]
+async fn disconnect_clears_pending_steer_while_another_client_remains_subscribed() -> Result<()> {
+    let (release_tx, release_rx) = oneshot::channel();
+    let (server, mut completions) = start_streaming_sse_server(vec![vec![
+        StreamingSseChunk {
+            gate: None,
+            body: responses::sse(vec![responses::ev_response_created("resp-1")]),
+        },
+        StreamingSseChunk {
+            gate: Some(release_rx),
+            body: responses::sse(vec![
+                responses::ev_assistant_message("msg-1", "active turn complete"),
+                responses::ev_completed("resp-1"),
+            ]),
+        },
+    ]])
+    .await;
+    let response_completed = completions.remove(0);
+    let codex_home = TempDir::new()?;
+    create_config_toml(codex_home.path(), server.uri(), "never")?;
+    let (mut process, bind_addr) = spawn_websocket_server(codex_home.path()).await?;
+
+    let mut daemon = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut daemon, 1, "codex_app_server_daemon").await?;
+    read_response_for_id(&mut daemon, 1)
+        .await
+        .context("daemon initialize response")?;
+    let mut owner = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut owner, 2, "steer_owner").await?;
+    read_response_for_id(&mut owner, 2)
+        .await
+        .context("owner initialize response")?;
+    let mut survivor = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut survivor, 3, "surviving_client").await?;
+    read_response_for_id(&mut survivor, 3)
+        .await
+        .context("survivor initialize response")?;
+
+    let thread_id = start_thread(&mut owner, 4).await?;
+    send_request(
+        &mut owner,
+        "turn/start",
+        6,
+        Some(serde_json::to_value(TurnStartParams {
+            thread_id: thread_id.clone(),
+            input: vec![UserInput::Text {
+                text: "start gated turn".to_string(),
+                text_elements: Vec::new(),
+            }],
+            ..Default::default()
+        })?),
+    )
+    .await?;
+    let turn: TurnStartResponse = to_response(
+        read_response_for_id(&mut owner, 6)
+            .await
+            .context("owner turn start response")?,
+    )?;
+    timeout(DEFAULT_READ_TIMEOUT, server.wait_for_request_count(1)).await?;
+    send_request(
+        &mut survivor,
+        "thread/resume",
+        5,
+        Some(json!({ "threadId": thread_id.clone() })),
+    )
+    .await?;
+    read_response_for_id(&mut survivor, 5)
+        .await
+        .context("survivor thread resume response")?;
+    send_request(
+        &mut owner,
+        "turn/steer",
+        7,
+        Some(serde_json::to_value(TurnSteerParams {
+            thread_id: thread_id.clone(),
+            input: vec![UserInput::Text {
+                text: "clear on disconnect".to_string(),
+                text_elements: Vec::new(),
+            }],
+            expected_turn_id: turn.turn.id.clone(),
+            client_user_message_id: Some("disconnect-steer".to_string()),
+            responsesapi_client_metadata: None,
+            additional_context: None,
+        })?),
+    )
+    .await?;
+    let _: TurnSteerResponse = to_response(
+        read_response_for_id(&mut owner, 7)
+            .await
+            .context("owner turn steer response")?,
+    )?;
+    owner.close(None).await?;
+    drop(owner);
+
+    timeout(DEFAULT_READ_TIMEOUT, async {
+        for id in 100.. {
+            send_daemon_status_request(&mut daemon, id).await?;
+            if read_daemon_status_response(&mut daemon, id)
+                .await?
+                .active_client_count
+                == 1
+            {
+                return Ok::<(), anyhow::Error>(());
+            }
+            sleep(Duration::from_millis(25)).await;
+        }
+        unreachable!()
+    })
+    .await??;
+    send_request(
+        &mut survivor,
+        "turn/clearPendingSteers",
+        8,
+        Some(serde_json::to_value(TurnClearPendingSteersParams {
+            thread_id,
+            expected_turn_id: turn.turn.id,
+        })?),
+    )
+    .await?;
+    let cleared: TurnClearPendingSteersResponse = to_response(
+        read_response_for_id(&mut survivor, 8)
+            .await
+            .context("survivor pending-steer clear response")?,
+    )?;
+    assert_eq!(cleared.cleared_count, 0);
+    release_tx.send(()).expect("response gate should be live");
+    timeout(DEFAULT_READ_TIMEOUT, response_completed).await??;
+    sleep(Duration::from_millis(100)).await;
+    assert_eq!(server.requests().await.len(), 1);
+
+    process.kill().await?;
+    server.shutdown().await;
+    Ok(())
+}
