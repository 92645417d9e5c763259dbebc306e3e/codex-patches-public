+
+impl PendingTurnStartGuard {
+    pub(crate) async fn started(mut self, turn_id: &str) {
+        self.manager
+            .resolve_pending_turn_start(&self.thread_id, self.token, Some(turn_id))
+            .await;
+        self.resolved = true;
+    }
+
+    pub(crate) async fn rollback(mut self) {
+        self.manager
+            .resolve_pending_turn_start(&self.thread_id, self.token, None)
+            .await;
+        self.resolved = true;
+    }
+}
+
+impl Drop for PendingTurnStartGuard {
+    fn drop(&mut self) {
+        if self.resolved {
+            return;
+        }
+        let manager = self.manager.clone();
+        let thread_id = self.thread_id.clone();
+        let token = self.token;
+        self.handle.spawn(async move {
+            manager
+                .resolve_pending_turn_start(&thread_id, token, None)
+                .await;
+        });
+    }
 }
 
