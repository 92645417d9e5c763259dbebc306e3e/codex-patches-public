+#[tokio::test]
+async fn prompt_assistant_is_root_only_and_keeps_source_visible_until_atomic_completion() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let thread_id = ThreadId::new();
+    chat.thread_id = Some(thread_id);
+    chat.bottom_pane
+        .set_composer_text("rough source".to_string(), Vec::new(), Vec::new());
+
+    chat.set_prompt_assistant_root_thread(false);
+    chat.open_prompt_assistant();
+    assert!(rx.try_recv().is_err());
+    assert_eq!(chat.bottom_pane.composer_text(), "rough source");
+    assert!(chat.bottom_pane.composer_input_enabled());
+
+    chat.set_prompt_assistant_root_thread(true);
+    chat.open_prompt_assistant();
+    let params = match rx.try_recv().expect("rewrite request") {
+        AppEvent::PromptAssistantRewrite(params) => params,
+        other => panic!("unexpected event: {other:?}"),
+    };
+    assert_eq!(params.thread_id, thread_id.to_string());
+    assert_eq!(params.input, "rough source");
+    assert_eq!(chat.bottom_pane.composer_text(), "rough source");
+    assert!(!chat.bottom_pane.composer_input_enabled());
+
+    chat.prompt_assistant_rewrite_finished(
+        thread_id.to_string(),
+        Ok(codex_app_server_protocol::PromptAssistantRewriteResponse {
+            outcome: codex_app_server_protocol::PromptAssistantOutcome::Ready,
+            candidate: Some("# Goal\n\n- Revised source.".to_string()),
+            reason: None,
+            effective_model: params.model,
+            effective_reasoning_effort: params.reasoning_effort,
+            fallback_from_model: None,
+            usage: None,
+        }),
+    );
+    assert_eq!(
+        chat.bottom_pane.composer_text(),
+        "# Goal\n\n- Revised source."
+    );
+    assert!(chat.bottom_pane.composer_input_enabled());
+}
+
+#[tokio::test]
+async fn prompt_assistant_failure_preserves_source() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let thread_id = ThreadId::new();
+    chat.thread_id = Some(thread_id);
+    let source = "Organize this request while preserving its constraints.".to_string();
+    chat.bottom_pane
+        .set_composer_text(source.clone(), Vec::new(), Vec::new());
+
+    chat.open_prompt_assistant();
+    let params = match rx.try_recv().expect("rewrite request") {
+        AppEvent::PromptAssistantRewrite(params) => params,
+        other => panic!("unexpected event: {other:?}"),
+    };
+    assert_eq!(params.input, source.as_str());
+    chat.prompt_assistant_rewrite_finished(
+        thread_id.to_string(),
+        Err(
+            "promptAssistant/rewrite failed: Prompt Assistant cannot run while the parent turn is active (code -32602)"
+                .to_string(),
+        ),
+    );
+
+    assert_eq!(chat.bottom_pane.composer_text(), source);
+    assert!(chat.bottom_pane.composer_input_enabled());
+    let rendered = drain_insert_history(&mut rx)
+        .into_iter()
+        .flatten()
+        .map(|line| line.to_string())
+        .collect::<Vec<_>>()
+        .join("\n");
+    assert!(rendered.contains("Prompt Assistant failed: promptAssistant/rewrite failed:"));
+    assert!(rendered.contains("cannot run while the parent turn is active"));
+}
