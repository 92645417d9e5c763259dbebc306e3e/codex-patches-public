+    let thread_id = ThreadId::new();
+    chat.thread_id = Some(thread_id);
+
+    chat.handle_server_notification(
+        ServerNotification::Error(ErrorNotification {
+            error: AppServerTurnError {
+                message: "Reconnecting... 2/30".to_string(),
+                codex_error_info: Some(CodexErrorInfo::Other),
+                additional_details: None,
+            },
+            will_retry: true,
+            retry_info: Some(codex_app_server_protocol::StreamRetryInfo {
+                retry_count: 2,
+                retry_limit: 30,
+                retry_delay_ms: 5_000,
+            }),
+            thread_id: thread_id.to_string(),
+            turn_id: "turn-1".to_string(),
+        }),
+        /*replay_kind*/ None,
+    );
+    drain_insert_history(&mut rx);
+
+    let retry_key = KeyEvent::new(KeyCode::Char('x'), KeyModifiers::CONTROL);
+    chat.handle_key_event(retry_key);
+    chat.handle_key_event(retry_key);
+
+    match rx.try_recv() {
+        Ok(AppEvent::RetryCurrentStream {
+            thread_id: event_thread_id,
+            turn_id,
+        }) => {
+            assert_eq!(event_thread_id, thread_id);
+            assert_eq!(turn_id, "turn-1");
+        }
+        other => panic!("expected RetryCurrentStream event, got {other:?}"),
+    }
+    assert!(
+        !std::iter::from_fn(|| rx.try_recv().ok())
+            .any(|event| matches!(event, AppEvent::RetryCurrentStream { .. }))
+    );
+    let status = chat
+        .bottom_pane
+        .status_widget()
+        .expect("status indicator should be visible");
+    assert_eq!(
+        status.header(),
+        "Reconnecting... 2/30 ▪ resetting retry budget"
+    );
+}
