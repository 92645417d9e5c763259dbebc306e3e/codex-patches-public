+            header,
+            content,
+            cwd: cwd.to_path_buf(),
+            item_head,
+            reasoning_item_id: reasoning_item_id
+                .strip_prefix("rs_")
+                .filter(|item_id| !item_id.is_empty())
+                .map(ToOwned::to_owned),
+            reasoning_output_tokens,
+        }
+    }
+
+    fn lines(&self, width: u16) -> Vec<Line<'static>> {
+        let mut lines = Vec::new();
+        append_markdown(
+            &self.content,
+            crate::width::usable_content_width_u16(width, /*reserved_cols*/ 2),
+            Some(self.cwd.as_path()),
+            &mut lines,
+        );
+        let summary_style = Style::default().dim().italic();
+        let mut summary_lines = lines
+            .into_iter()
+            .map(|mut line| {
+                line.spans = line
+                    .spans
+                    .into_iter()
+                    .map(|span| span.patch_style(summary_style))
+                    .collect();
+                line
+            })
+            .collect::<Vec<_>>();
+        if !self.header.is_empty() {
+            let header = self
+                .header
+                .strip_prefix("**")
+                .and_then(|header| header.strip_suffix("**"))
+                .unwrap_or(self.header.as_str())
+                .to_string();
+            let header_style = if header == "No reasoning summary" {
+                Style::default().fg(Color::DarkGray)
+            } else {
+                summary_style.add_modifier(Modifier::BOLD)
+            };
+            summary_lines.insert(0, Line::from(Span::styled(header, header_style)));
+        }
+        let mut metadata = Vec::new();
+        if let Some(item_id) = self.reasoning_item_id.as_deref() {
+            metadata.push(Span::styled(
+                item_id.to_string(),
+                Style::default().fg(Color::DarkGray),
+            ));
+        }
+        if let Some(tokens) = self.reasoning_output_tokens {
+            if !metadata.is_empty() {
+                metadata.push(Span::styled(" ▪ ", Style::default().dim()));
+            }
+            metadata.push(Span::styled(
+                format!(
+                    "{} tokens",
+                    codex_protocol::num_format::format_with_separators(tokens)
+                ),
+                Style::default().fg(Color::Yellow),
+            ));
+        }
+        if !metadata.is_empty() {
+            if let Some(first_line) = summary_lines.first_mut() {
+                first_line
+                    .spans
+                    .push(Span::styled(" ▪ ", Style::default().dim()));
+                first_line.spans.extend(metadata);
+            } else {
+                summary_lines.push(Line::from(metadata));
+            }
+        }
+
+        adaptive_wrap_lines(
+            &summary_lines,
+            RtOptions::new(width as usize)
+                .initial_indent(if self.item_head {
+                    "▪ ".dim().into()
+                } else {
+                    "  ".into()
+                })
+                .subsequent_indent("  ".into()),
+        )
+    }
+}
