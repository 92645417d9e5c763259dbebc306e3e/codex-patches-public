+pub(crate) fn new_atomic_reasoning_summary_blocks(
+    reasoning_parts: Vec<String>,
+    cwd: &Path,
+    reasoning_item_id: String,
+    reasoning_output_tokens: Option<i64>,
+) -> Vec<Box<dyn HistoryCell>> {
+    new_atomic_reasoning_response_blocks(
+        vec![(reasoning_item_id, reasoning_parts)],
+        cwd,
+        reasoning_output_tokens,
+    )
+}
+
+pub(crate) fn new_atomic_reasoning_response_blocks(
+    reasoning_items: Vec<(String, Vec<String>)>,
+    cwd: &Path,
+    reasoning_output_tokens: Option<i64>,
+) -> Vec<Box<dyn HistoryCell>> {
+    let mut response_usage = reasoning_output_tokens;
+    let mut cells: Vec<Box<dyn HistoryCell>> = Vec::new();
+    for (reasoning_item_id, reasoning_parts) in reasoning_items {
+        let mut blocks = split_atomic_reasoning_summary_parts(&reasoning_parts);
+        if blocks.is_empty() {
+            blocks.push(("No reasoning summary".to_string(), String::new()));
+        }
+        for (index, (header, content)) in blocks.into_iter().enumerate() {
+            let atomic_head = index == 0;
+            cells.push(Box::new(LiveAtomicReasoningCell::new(
+                header,
+                content,
+                cwd,
+                atomic_head
+                    .then(|| reasoning_item_id.clone())
+                    .unwrap_or_default(),
+                atomic_head.then(|| response_usage.take()).flatten(),
+                atomic_head,
+            )));
+        }
+    }
+    cells
+}
+
+fn split_atomic_reasoning_summary_parts(reasoning_parts: &[String]) -> Vec<(String, String)> {
+    let mut leading_empty_part_header = None;
+    let mut blocks = Vec::with_capacity(reasoning_parts.len());
+
+    for part in reasoning_parts {
+        let part = part.trim();
+        if part.is_empty() {
+            continue;
+        }
+        let header_end = part.strip_prefix("**").and_then(|after_open| {
+            after_open
+                .find("**")
+                .and_then(|close| (close > 0).then_some(close + 4))
+        });
+        let body = header_end.map_or(part, |header_end| &part[header_end..]);
+        if body.trim() == "<!-- -->" {
+            if blocks.is_empty()
+                && leading_empty_part_header.is_none()
+                && let Some(header_end) = header_end
+            {
+                leading_empty_part_header = Some(part[..header_end].to_string());
+            }
+            continue;
+        }
+        blocks.push(split_reasoning_summary_parts(&[part.to_string()]));
+    }
+
+    if blocks.is_empty()
+        && let Some(header) = leading_empty_part_header
+    {
+        blocks.push((header, String::new()));
+    }
+    blocks
+}
