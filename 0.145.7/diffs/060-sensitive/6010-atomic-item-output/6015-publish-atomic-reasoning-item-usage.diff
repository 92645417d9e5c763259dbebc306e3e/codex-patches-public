+        summary_text: Vec::new(),
+        raw_content: Vec::new(),
+        reasoning_output_tokens: None,
+    })];
+
+    assert!(!attach_reasoning_output_tokens_to_response_tail(
+        &mut item,
+        Some(0)
+    ));
+
+    let TurnItem::Reasoning(reasoning) = &item[0] else {
+        panic!("expected reasoning item");
+    };
+    assert_eq!(reasoning.reasoning_output_tokens, None);
+}
