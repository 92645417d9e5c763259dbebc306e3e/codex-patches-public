+fn attach_reasoning_output_tokens_to_response_tail(
+    reasoning_items: &mut [TurnItem],
+    reasoning_output_tokens: Option<i64>,
+) -> bool {
+    let Some(reasoning_output_tokens) = reasoning_output_tokens.filter(|tokens| *tokens > 0) else {
+        return false;
+    };
+    let Some(TurnItem::Reasoning(reasoning)) = reasoning_items.last_mut() else {
+        return false;
+    };
+    reasoning.reasoning_output_tokens = Some(reasoning_output_tokens);
+    true
+}
