+#[test]
+fn response_reasoning_usage_is_owned_only_by_the_final_item() {
+    let reasoning_item = |id: &str| {
+        TurnItem::Reasoning(codex_protocol::items::ReasoningItem {
+            id: id.to_string(),
+            summary_text: Vec::new(),
+            raw_content: Vec::new(),
+            reasoning_output_tokens: None,
+        })
+    };
+    let mut items = vec![reasoning_item("rs-a"), reasoning_item("rs-b")];
+
+    assert!(attach_reasoning_output_tokens_to_response_tail(
+        &mut items,
+        Some(516)
+    ));
+
+    let tokens = items
+        .iter()
+        .map(|item| match item {
+            TurnItem::Reasoning(reasoning) => reasoning.reasoning_output_tokens,
+            _ => None,
+        })
+        .collect::<Vec<_>>();
+    assert_eq!(tokens, vec![None, Some(516)]);
+}
