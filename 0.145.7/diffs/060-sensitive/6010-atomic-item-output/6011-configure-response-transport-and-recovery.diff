+#[tokio::test]
+async fn startup_prewarm_abort_waits_for_session_drop_before_returning() {
+    struct DropSignal {
+        client_session: Option<crate::client::ModelClientSession>,
+        dropped: Arc<std::sync::atomic::AtomicBool>,
+    }
+
+    impl Drop for DropSignal {
+        fn drop(&mut self) {
+            drop(self.client_session.take());
+            self.dropped
+                .store(true, std::sync::atomic::Ordering::SeqCst);
+        }
+    }
+
+    let (sess, _tc, _rx) = make_session_and_context_with_rx().await;
+    let model_client = sess.services.model_client.clone();
+    let dropped = Arc::new(std::sync::atomic::AtomicBool::new(false));
+    let task_dropped = Arc::clone(&dropped);
+    let (started_tx, started_rx) = tokio::sync::oneshot::channel();
+    let task = tokio::spawn(async move {
+        let mut drop_signal = DropSignal {
+            client_session: Some(model_client.new_session()),
+            dropped: task_dropped,
+        };
+        started_tx.send(()).expect("drop signal task should start");
+        std::future::pending::<()>().await;
+        Ok(drop_signal
+            .client_session
+            .take()
+            .expect("pending task should retain its client session"))
+    });
+    started_rx.await.expect("drop signal task should start");
+
+    tokio::time::timeout(
+        std::time::Duration::from_secs(1),
+        crate::session_startup_prewarm::SessionStartupPrewarmHandle::new(
+            task,
+            std::time::Instant::now(),
+            crate::client::WEBSOCKET_CONNECT_TIMEOUT,
+        )
+        .abort(&sess.services.model_client),
+    )
+    .await
+    .expect("startup prewarm abort should not hang");
+
+    assert!(
+        dropped.load(std::sync::atomic::Ordering::SeqCst),
+        "startup prewarm abort returned before its client session was dropped"
+    );
+}
