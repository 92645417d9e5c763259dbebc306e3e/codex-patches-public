+            msg,
+            EventMsg::Warning(WarningEvent { message })
+                if message.contains("next 30-minute boundary")
+        )
+    })
+    .await;
+    let EventMsg::Warning(WarningEvent { message }) = warning else {
+        unreachable!();
+    };
+    assert!(message.contains("Account quota limit reached"));
+
+    codex.submit(Op::Interrupt).await?;
+    let aborted = wait_for_event(&codex, |msg| matches!(msg, EventMsg::TurnAborted(_))).await;
+    let EventMsg::TurnAborted(aborted) = aborted else {
+        unreachable!();
+    };
+    assert_eq!(aborted.reason, TurnAbortReason::Interrupted);
+    assert_eq!(responses_mock.requests().len(), 1);
+
+    Ok(())
+}
