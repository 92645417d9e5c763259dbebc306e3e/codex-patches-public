+    pub(super) fn request_performance_line_at(
+        &self,
+        item: StatusLineItem,
+        now: Instant,
+    ) -> Option<Line<'static>> {
+        let metric = match item {
+            StatusLineItem::RequestTtfb => self.request_performance.ttfb,
+            StatusLineItem::RequestTps => self.request_performance.tps,
+            _ => return None,
+        }?;
+        let text = match item {
+            StatusLineItem::RequestTtfb => format_request_ttfb(metric.value)?,
+            StatusLineItem::RequestTps if metric.value.is_finite() && metric.value > 0.0 => {
+                format!("TPS {:.1}", metric.value)
+            }
+            StatusLineItem::RequestTps => return None,
+            _ => unreachable!(),
+        };
+        let stale =
+            now.saturating_duration_since(metric.observed_at) >= REQUEST_PERFORMANCE_FRESH_DURATION;
+        let style = if stale {
+            Style::default()
+                .fg(Color::DarkGray)
+                .add_modifier(Modifier::DIM)
+        } else {
+            Style::default()
+        };
+        Some(Line::from(Span::styled(text, style)))
+    }
