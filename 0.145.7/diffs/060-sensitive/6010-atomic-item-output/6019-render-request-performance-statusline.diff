+#[tokio::test]
+async fn request_performance_values_merge_and_age_independently() {
+    let (mut chat, _rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let first_observed_at = Instant::now();
+    assert!(chat.merge_request_performance_at(Some(0.125), None, first_observed_at,));
+    assert!(
+        chat.request_performance_line_at(StatusLineItem::RequestTtfb, first_observed_at)
+            .is_some()
+    );
+    assert!(
+        chat.request_performance_line_at(StatusLineItem::RequestTps, first_observed_at)
+            .is_none()
+    );
+
+    let tps_observed_at = first_observed_at + Duration::from_secs(3);
+    assert!(chat.merge_request_performance_at(None, Some(42.5), tps_observed_at));
+    let stale_ttfb = chat
+        .request_performance_line_at(
+            StatusLineItem::RequestTtfb,
+            first_observed_at + Duration::from_secs(6),
+        )
+        .expect("TTFB should remain visible after becoming stale");
+    let fresh_tps = chat
+        .request_performance_line_at(
+            StatusLineItem::RequestTps,
+            first_observed_at + Duration::from_secs(6),
+        )
+        .expect("TPS should be fresh on its own lifecycle");
+    assert_eq!(stale_ttfb.spans[0].style.fg, Some(Color::DarkGray));
+    assert_ne!(fresh_tps.spans[0].style.fg, Some(Color::DarkGray));
+}
