+    pub(super) fn merge_request_performance_at(
+        &mut self,
+        ttfb: Option<f64>,
+        tps: Option<f64>,
+        observed_at: Instant,
+    ) -> bool {
+        if ttfb.is_none() && tps.is_none() {
+            return false;
+        }
+        if let Some(ttfb) = ttfb {
+            self.request_performance.ttfb = Some(ObservedRequestPerformanceValue {
+                value: ttfb,
+                observed_at,
+            });
+        }
+        if let Some(tps) = tps {
+            self.request_performance.tps = Some(ObservedRequestPerformanceValue {
+                value: tps,
+                observed_at,
+            });
+        }
+        self.schedule_request_performance_freshness_refresh_at(observed_at);
+        true
+    }
+
+    fn schedule_request_performance_freshness_refresh_at(&mut self, now: Instant) {
+        let next_refresh_at = [self.request_performance.ttfb, self.request_performance.tps]
+            .into_iter()
+            .flatten()
+            .filter_map(|metric| {
+                metric
+                    .observed_at
+                    .checked_add(REQUEST_PERFORMANCE_FRESH_DURATION)
+            })
+            .filter(|deadline| *deadline > now)
+            .min();
+        self.request_performance.next_freshness_refresh_at = next_refresh_at;
+        if let Some(next_refresh_at) = next_refresh_at {
+            self.frame_requester
+                .schedule_frame_in(next_refresh_at.saturating_duration_since(now));
+        }
+    }
+
+    pub(super) fn request_performance_freshness_due_at(&mut self, now: Instant) -> bool {
+        let Some(next_refresh_at) = self.request_performance.next_freshness_refresh_at else {
+            return false;
+        };
+        if now < next_refresh_at {
+            self.frame_requester
+                .schedule_frame_in(next_refresh_at.saturating_duration_since(now));
+            return false;
+        }
+        self.schedule_request_performance_freshness_refresh_at(now);
+        true
+    }
