+pub(crate) fn notify_action_required(
+    session_id: &str,
+    turn_id: Option<&str>,
+    working_dir: &Path,
+    title: &str,
+    body: &str,
+) {
+    let Some(request) = action_required_request(
+        session_id,
+        turn_id,
+        working_dir,
+        title,
+        body,
+        chrono::Utc::now(),
+    ) else {
+        return;
+    };
+    notify_completion(request);
+}
+
+fn action_required_request(
+    session_id: &str,
+    turn_id: Option<&str>,
+    working_dir: &Path,
+    title: &str,
+    body: &str,
+    created_at: chrono::DateTime<chrono::Utc>,
+) -> Option<CompletionRequest> {
+    Some(CompletionRequest::new(
+        Uuid::parse_str(session_id).ok()?.to_string(),
+        turn_id.map(stable_turn_id).unwrap_or(1),
+        "NeedsInput".to_string(),
+        0,
+        working_dir.display().to_string(),
+        title.to_string(),
+        body.to_string(),
+        created_at.to_rfc3339_opts(chrono::SecondsFormat::Secs, true),
+    ))
+}
+
+pub(crate) fn stable_turn_id(turn_id: &str) -> u64 {
+    if let Some(turn_id) = trailing_positive_number(turn_id) {
+        return turn_id;
+    }
+
+    let mut hasher = DefaultHasher::new();
+    turn_id.hash(&mut hasher);
+    (hasher.finish() % (i64::MAX as u64)).max(1)
+}
+
+fn trailing_positive_number(value: &str) -> Option<u64> {
+    let digits = value
+        .chars()
+        .rev()
+        .take_while(|character| character.is_ascii_digit())
+        .collect::<Vec<_>>();
+    if digits.is_empty() {
+        return None;
+    }
+
+    digits
+        .into_iter()
+        .rev()
+        .collect::<String>()
+        .parse::<u64>()
+        .ok()
+        .filter(|number| *number > 0)
+}
