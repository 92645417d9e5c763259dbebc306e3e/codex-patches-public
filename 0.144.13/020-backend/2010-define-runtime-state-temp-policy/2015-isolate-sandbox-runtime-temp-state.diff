+fn synthetic_mount_registry_lock_serializes_callers() {
+    let registry = test_synthetic_mount_registry_root();
+    let registry_path = registry.path().to_path_buf();
+    let (first_entered_tx, first_entered_rx) = std::sync::mpsc::channel();
+    let (release_tx, release_rx) = std::sync::mpsc::channel();
+    let first = std::thread::spawn(move || {
+        with_synthetic_mount_registry_lock(&registry_path, || {
+            first_entered_tx.send(()).expect("signal first entered");
+            release_rx.recv().expect("wait for release");
+        });
+    });
+    let first_entered = first_entered_rx.recv_timeout(std::time::Duration::from_secs(1));
+
+    let registry_path = registry.path().to_path_buf();
+    let (second_ready_tx, second_ready_rx) = std::sync::mpsc::channel();
+    let (second_entered_tx, second_entered_rx) = std::sync::mpsc::channel();
+    let second = std::thread::spawn(move || {
+        second_ready_tx.send(()).expect("signal second ready");
+        with_synthetic_mount_registry_lock(&registry_path, || {
+            second_entered_tx.send(()).expect("signal second entered");
+        });
+    });
+    let second_ready = second_ready_rx.recv_timeout(std::time::Duration::from_secs(1));
+    let second_entered_early = second_entered_rx
+        .recv_timeout(std::time::Duration::from_millis(50))
+        .is_ok();
+
+    let release = release_tx.send(());
+    let second_entered_after_release = if second_entered_early {
+        Ok(())
+    } else {
+        second_entered_rx.recv_timeout(std::time::Duration::from_secs(1))
+    };
+    let first_join = first.join();
+    let second_join = second.join();
+
+    first_entered.expect("first caller should acquire lock");
+    second_ready.expect("second caller should reach the lock attempt");
+    assert!(!second_entered_early, "second caller acquired lock early");
+    release.expect("release first caller");
+    second_entered_after_release.expect("second caller should acquire after release");
+    first_join.expect("first caller");
+    second_join.expect("second caller");
 }
 
