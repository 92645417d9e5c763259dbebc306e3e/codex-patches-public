+pub(crate) fn append_linux_sandbox_runtime_mounts(
+    args: &mut Vec<String>,
+    runtime_root: &Path,
+    proxy_socket_dir: Option<&Path>,
+) -> Result<()> {
+    if !runtime_root.is_absolute() || !runtime_root.is_dir() {
+        return Err(CodexErr::Fatal(format!(
+            "Linux sandbox runtime root is not an absolute directory: {}",
+            runtime_root.display()
+        )));
+    }
+    if let Some(proxy_socket_dir) = proxy_socket_dir
+        && (proxy_socket_dir == runtime_root
+            || !proxy_socket_dir.starts_with(runtime_root)
+            || !proxy_socket_dir.is_dir())
+    {
+        return Err(CodexErr::Fatal(format!(
+            "Linux proxy socket directory is not a strict runtime-root descendant or is missing: {}",
+            proxy_socket_dir.display()
+        )));
+    }
+
+    let insertion_index = args
+        .iter()
+        .position(|arg| arg == "--unshare-user")
+        .or_else(|| args.iter().position(|arg| arg == "--"))
+        .ok_or_else(|| {
+            CodexErr::Fatal("bubblewrap argv is missing command separator".to_string())
+        })?;
+    let mut runtime_args = Vec::new();
+    append_mount_target_parent_dir_args(&mut runtime_args, runtime_root, Path::new("/"));
+    runtime_args.extend([
+        "--perms".to_string(),
+        "700".to_string(),
+        "--tmpfs".to_string(),
+        path_to_string(runtime_root),
+    ]);
+
+    if let Some(proxy_socket_dir) = proxy_socket_dir {
+        append_mount_target_parent_dir_args(&mut runtime_args, proxy_socket_dir, runtime_root);
+        runtime_args.extend([
+            "--ro-bind".to_string(),
+            path_to_string(proxy_socket_dir),
+            path_to_string(proxy_socket_dir),
+        ]);
+    }
+
+    runtime_args.extend(["--remount-ro".to_string(), path_to_string(runtime_root)]);
+    args.splice(insertion_index..insertion_index, runtime_args);
+    Ok(())
+}
