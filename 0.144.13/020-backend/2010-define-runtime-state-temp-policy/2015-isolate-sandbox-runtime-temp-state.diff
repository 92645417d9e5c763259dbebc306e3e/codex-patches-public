+fn write_synthetic_mount_marker(path: &Path, contents: &[u8]) -> std::io::Result<()> {
+    let mut file = OpenOptions::new()
+        .read(true)
+        .write(true)
+        .create(true)
+        .truncate(false)
+        .mode(0o600)
+        .custom_flags(libc::O_CLOEXEC | libc::O_NOFOLLOW)
+        .open(path)?;
+    validate_synthetic_mount_registry_file(&file, path)?;
+    file.set_len(0)?;
+    file.write_all(contents)
+}
+
+fn validate_synthetic_mount_registry_dir(path: &Path) -> std::io::Result<()> {
+    let metadata = fs::symlink_metadata(path)?;
+    let effective_uid = unsafe { libc::geteuid() };
+    if !metadata.file_type().is_dir()
+        || metadata.uid() != effective_uid
+        || metadata.mode() & 0o7777 != 0o700
+    {
+        return Err(std::io::Error::new(
+            std::io::ErrorKind::PermissionDenied,
+            format!(
+                "expected a non-symlink 0700 directory owned by uid {effective_uid}: {}",
+                path.display()
+            ),
+        ));
+    }
+    Ok(())
+}
+
+fn validate_synthetic_mount_registry_file(file: &File, path: &Path) -> std::io::Result<()> {
+    let effective_uid = unsafe { libc::geteuid() };
+    let mut metadata = file.metadata()?;
+    if !metadata.file_type().is_file()
+        || metadata.uid() != effective_uid
+        || metadata.mode() & 0o022 != 0
+    {
+        return Err(std::io::Error::new(
+            std::io::ErrorKind::PermissionDenied,
+            format!(
+                "expected a non-symlink private file owned by uid {effective_uid}: {}",
+                path.display()
+            ),
+        ));
+    }
+    if metadata.mode() & 0o7777 != 0o600 {
+        file.set_permissions(fs::Permissions::from_mode(0o600))?;
+        metadata = file.metadata()?;
+    }
+    if metadata.uid() != effective_uid || metadata.mode() & 0o7777 != 0o600 {
+        return Err(std::io::Error::new(
+            std::io::ErrorKind::PermissionDenied,
+            format!("could not secure registry file: {}", path.display()),
+        ));
+    }
+    Ok(())
+}
