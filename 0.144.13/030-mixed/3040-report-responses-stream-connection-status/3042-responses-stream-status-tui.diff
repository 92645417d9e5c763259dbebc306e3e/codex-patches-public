+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.on_task_started();
+    chat.on_agent_message_delta("partial answer\n".to_string());
+    chat.on_commit_tick();
+    chat.on_agent_reasoning_delta("**Partial reasoning**".to_string());
+
+    handle_stream_error(&mut chat, "Reconnecting... 1/30", None);
+
+    assert!(chat.stream_controller.is_none());
+    assert!(chat.reasoning_buffer.is_empty());
+    assert!(chat.reasoning_summary_parts.is_empty());
+    assert!(!chat.has_active_stream_tail());
+    assert!(
+        std::iter::from_fn(|| rx.try_recv().ok())
+            .any(|event| matches!(event, AppEvent::DiscardIncompleteAgentMessage)),
+        "retry should remove provisional stream cells from transcript"
+    );
+
+    chat.on_agent_message_delta("retry answer\n".to_string());
+    assert!(chat.stream_controller.as_ref().is_some_and(|controller| {
+        !controller
+            .current_tail_lines()
+            .iter()
+            .any(|line| line.line.to_string().contains("partial answer"))
+    }));
+}
