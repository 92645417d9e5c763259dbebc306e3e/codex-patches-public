diff --git a/codex-rs/tui/src/status/permissions.rs b/codex-rs/tui/src/status/permissions.rs
new file mode 100644
index 0000000000..4e45139a82
--- /dev/null
+++ b/codex-rs/tui/src/status/permissions.rs
@@ -0,0 +1,246 @@
+use crate::legacy_core::config::Config;
+use codex_app_server_protocol::AskForApproval;
+use codex_protocol::config_types::ApprovalsReviewer;
+use codex_protocol::models::ActivePermissionProfile;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_READ_ONLY;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_WORKSPACE;
+use codex_protocol::models::PermissionProfile;
+use codex_utils_absolute_path::AbsolutePathBuf;
+use codex_utils_sandbox_summary::summarize_permission_profile;
+
+const ASK_FOR_APPROVAL_LABEL: &str = "Ask For Approval";
+const GUARDIAN_REVIEW_LABEL: &str = "Guardian Review";
+
+pub(crate) fn effective_permissions_label(config: &Config) -> String {
+    let permission_profile = config.permissions.effective_permission_profile();
+    let approval_policy = AskForApproval::from(config.permissions.approval_policy.value());
+    let approval_fallback = config.permissions.approval_policy.value().to_string();
+    let workspace_roots = config.effective_workspace_roots();
+    let sandbox = sandbox_label(&permission_profile, &config.cwd, workspace_roots.as_slice());
+    let workspace_root_suffix = workspace_root_suffix(workspace_roots.as_slice(), &config.cwd);
+
+    effective_permissions_label_from_parts(
+        config.permissions.active_permission_profile().as_ref(),
+        &permission_profile,
+        approval_policy,
+        config.approvals_reviewer,
+        &sandbox,
+        &approval_fallback,
+        workspace_root_suffix.as_deref(),
+    )
+}
+
+pub(crate) fn approval_mode_label(config: &Config) -> String {
+    approval_label(
+        AskForApproval::from(config.permissions.approval_policy.value()),
+        config.approvals_reviewer,
+        &config.permissions.approval_policy.value().to_string(),
+    )
+}
+
+fn effective_permissions_label_from_parts(
+    active_permission_profile: Option<&ActivePermissionProfile>,
+    permission_profile: &PermissionProfile,
+    approval_policy: AskForApproval,
+    approvals_reviewer: ApprovalsReviewer,
+    sandbox: &str,
+    approval_fallback: &str,
+    workspace_root_suffix: Option<&str>,
+) -> String {
+    let approval = approval_label(approval_policy, approvals_reviewer, approval_fallback);
+    let active_id = active_permission_profile.map(|active| active.id.as_str());
+
+    if permission_profile == &PermissionProfile::Disabled
+        && active_id.is_none_or(|id| id.starts_with(':'))
+    {
+        return full_access_label(approval_policy, approvals_reviewer, &approval);
+    }
+
+    match active_id {
+        Some(BUILT_IN_PERMISSION_PROFILE_READ_ONLY) => {
+            let sandbox = if sandbox == "read-only with network access" {
+                "Read Only with network access"
+            } else {
+                "Read Only"
+            };
+            if approval_policy == AskForApproval::OnRequest {
+                return match approvals_reviewer {
+                    ApprovalsReviewer::AutoReview => {
+                        format!("{sandbox} + {GUARDIAN_REVIEW_LABEL}")
+                    }
+                    ApprovalsReviewer::User
+                        if sandbox == "Read Only"
+                            && permission_profile == &PermissionProfile::read_only() =>
+                    {
+                        "Read Only".to_string()
+                    }
+                    ApprovalsReviewer::User => format!("{sandbox} ({approval})"),
+                };
+            }
+            return format!("{sandbox} ({approval})");
+        }
+        Some(BUILT_IN_PERMISSION_PROFILE_WORKSPACE) if sandbox.starts_with("workspace") => {
+            let sandbox = decorate_workspace_sandbox_label(sandbox, workspace_root_suffix);
+            let sandbox = workspace_display_label(&sandbox);
+            if approval_policy == AskForApproval::OnRequest {
+                return match approvals_reviewer {
+                    ApprovalsReviewer::AutoReview => {
+                        format!("{sandbox} + {GUARDIAN_REVIEW_LABEL}")
+                    }
+                    ApprovalsReviewer::User
+                        if sandbox == "Workspace"
+                            && permission_profile == &PermissionProfile::workspace_write()
+                            && workspace_root_suffix.is_none() =>
+                    {
+                        ASK_FOR_APPROVAL_LABEL.to_string()
+                    }
+                    ApprovalsReviewer::User => format!("{sandbox} ({approval})"),
+                };
+            }
+            return format!("{sandbox} ({approval})");
+        }
+        Some(BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS) => {}
+        Some(id) => {
+            let sandbox = decorate_workspace_sandbox_label(sandbox, workspace_root_suffix);
+            return format!("Profile {id} ({sandbox}, {approval})");
+        }
+        None => {}
+    }
+
+    if sandbox == "read-only" {
+        return format!("Read Only ({approval})");
+    }
+    if approval_policy == AskForApproval::OnRequest && sandbox == "workspace" {
+        let sandbox = decorate_workspace_sandbox_label(sandbox, workspace_root_suffix);
+        let sandbox = workspace_display_label(&sandbox);
+        return match approvals_reviewer {
+            ApprovalsReviewer::AutoReview => {
+                format!("{sandbox} + {GUARDIAN_REVIEW_LABEL}")
+            }
+            ApprovalsReviewer::User => format!("{sandbox} ({approval})"),
+        };
+    }
+
+    let sandbox = decorate_workspace_sandbox_label(sandbox, workspace_root_suffix);
+    format!("Custom ({sandbox}, {approval})")
+}
+
+fn full_access_label(
+    approval_policy: AskForApproval,
+    approvals_reviewer: ApprovalsReviewer,
+    approval: &str,
+) -> String {
+    match (approval_policy, approvals_reviewer) {
+        (AskForApproval::Never, _) => "Full Access".to_string(),
+        (AskForApproval::OnRequest, ApprovalsReviewer::AutoReview) => {
+            "Full Access + Guardian Review".to_string()
+        }
+        _ => format!("No Sandbox ({approval})"),
+    }
+}
+
+fn approval_label(
+    approval_policy: AskForApproval,
+    approvals_reviewer: ApprovalsReviewer,
+    fallback: &str,
+) -> String {
+    if approval_policy == AskForApproval::OnRequest {
+        return match approvals_reviewer {
+            ApprovalsReviewer::AutoReview => GUARDIAN_REVIEW_LABEL.to_string(),
+            ApprovalsReviewer::User => ASK_FOR_APPROVAL_LABEL.to_string(),
+        };
+    }
+
+    fallback.to_string()
+}
+
+fn sandbox_label(
+    permission_profile: &PermissionProfile,
+    cwd: &AbsolutePathBuf,
+    workspace_roots: &[AbsolutePathBuf],
+) -> String {
+    let summary = summarize_permission_profile(permission_profile, cwd, workspace_roots);
+    if let Some(details) = summary.strip_prefix("read-only") {
+        if details.contains("(network access enabled)") {
+            return "read-only with network access".to_string();
+        }
+        return "read-only".to_string();
+    }
+    if let Some(details) = summary.strip_prefix("workspace-write") {
+        if details.contains("(network access enabled)") {
+            return "workspace with network access".to_string();
+        }
+        return "workspace".to_string();
+    }
+    if summary == "custom permissions (network access enabled)" {
+        return "custom permissions with network access".to_string();
+    }
+    summary
+}
+
+fn workspace_root_suffix(
+    workspace_roots: &[AbsolutePathBuf],
+    cwd: &AbsolutePathBuf,
+) -> Option<String> {
+    let extra_roots = workspace_roots
+        .iter()
+        .filter(|root| *root != cwd)
+        .map(|root| root.to_string_lossy().to_string())
+        .collect::<Vec<_>>();
+    if extra_roots.is_empty() {
+        None
+    } else {
+        Some(format!(" [{}]", extra_roots.join(", ")))
+    }
+}
+
+fn decorate_workspace_sandbox_label(sandbox: &str, workspace_root_suffix: Option<&str>) -> String {
+    match workspace_root_suffix {
+        Some(suffix) if sandbox.starts_with("workspace") => format!("{sandbox}{suffix}"),
+        _ => sandbox.to_string(),
+    }
+}
+
+fn workspace_display_label(sandbox: &str) -> String {
+    sandbox.replacen("workspace", "Workspace", 1)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn full_access_permission_matrix_preserves_active_review_semantics() {
+        let cases = [
+            (
+                AskForApproval::Never,
+                ApprovalsReviewer::User,
+                "Full Access",
+            ),
+            (
+                AskForApproval::Never,
+                ApprovalsReviewer::AutoReview,
+                "Full Access",
+            ),
+            (
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+                "No Sandbox (Ask For Approval)",
+            ),
+            (
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::AutoReview,
+                "Full Access + Guardian Review",
+            ),
+        ];
+
+        for (approval_policy, approvals_reviewer, expected) in cases {
+            let approval = approval_label(approval_policy, approvals_reviewer, "fallback");
+            assert_eq!(
+                full_access_label(approval_policy, approvals_reviewer, &approval),
+                expected
+            );
+        }
+    }
+}
