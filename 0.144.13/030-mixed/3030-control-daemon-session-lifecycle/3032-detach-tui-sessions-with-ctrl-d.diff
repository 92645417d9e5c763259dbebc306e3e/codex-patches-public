+#[tokio::test]
+async fn detach_exit_falls_back_to_shutdown_first_for_embedded_app_server() {
+    let (mut app, _app_event_rx, mut op_rx) = Box::pin(make_test_app_with_channels()).await;
+    let thread_id = ThreadId::new();
+    app.active_thread_id = Some(thread_id);
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    let control = Box::pin(app.handle_exit_mode(&mut app_server, ExitMode::Detach)).await;
+
+    assert_eq!(app.pending_shutdown_exit_thread_id, None);
+    assert!(matches!(
+        control,
+        AppRunControl::Exit(ExitReason::UserRequested)
+    ));
+    assert!(
+        op_rx.try_recv().is_err(),
+        "embedded detach fallback should use app-server shutdown, not Op::Shutdown"
+    );
+}
+
+#[tokio::test]
+async fn detach_exit_leaves_local_daemon_thread_running() {
+    let (mut app, _app_event_rx, mut op_rx) = Box::pin(make_test_app_with_channels()).await;
+    let thread_id = ThreadId::new();
+    app.active_thread_id = Some(thread_id);
+    app.app_server_target = crate::AppServerTarget::LocalDaemon {
+        endpoint: crate::RemoteAppServerEndpoint::UnixSocket {
+            socket_path: test_absolute_path("/tmp/codex-test.sock"),
+        },
+    };
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    let control = Box::pin(app.handle_exit_mode(&mut app_server, ExitMode::Detach)).await;
+
+    assert_eq!(app.pending_shutdown_exit_thread_id, None);
+    assert!(matches!(control, AppRunControl::Exit(ExitReason::Detached)));
+    assert!(
+        op_rx.try_recv().is_err(),
+        "detaching from a separate app-server should not submit shutdown"
+    );
+}
+
+#[tokio::test]
+async fn detach_exit_discards_pending_local_steer_state() {
+    let (mut app, _app_event_rx, _op_rx) = Box::pin(make_test_app_with_channels()).await;
+    app.chat_widget
+        .queue_pending_steer_for_test("pending steer");
+    assert!(app.chat_widget.has_pending_steers());
+    app.app_server_target = crate::AppServerTarget::LocalDaemon {
+        endpoint: crate::RemoteAppServerEndpoint::UnixSocket {
+            socket_path: test_absolute_path("/tmp/codex-test.sock"),
+        },
+    };
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    let control = Box::pin(app.handle_exit_mode(&mut app_server, ExitMode::Detach)).await;
+
+    assert!(matches!(control, AppRunControl::Exit(ExitReason::Detached)));
+    assert!(!app.chat_widget.has_pending_steers());
+}
