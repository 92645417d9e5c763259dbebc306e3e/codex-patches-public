+#[test]
+fn streaming_agent_tail_channels_keep_blank_rows_framed_without_closing() {
+    for channel in [
+        AgentMessageChannel::Commentary,
+        AgentMessageChannel::FinalAnswer,
+    ] {
+        let cell = StreamingAgentTailCell::new_with_channel(
+            vec![HyperlinkLine::from("first"), HyperlinkLine::from("")],
+            /*is_first_line*/ true,
+            channel,
+        );
+
+        let lines = cell.display_lines(/*width*/ 20);
+        assert_eq!(lines.len(), 3, "channel: {channel:?}");
+        assert_eq!(lines[2].width(), 20, "channel: {channel:?}");
+        assert_eq!(
+            lines[2].style.bg,
+            user_input_style().bg,
+            "channel: {channel:?}"
+        );
+        assert!(
+            lines[2]
+                .spans
+                .iter()
+                .all(|span| !span.content.contains('─')),
+            "streaming tail closed before completion for {channel:?}"
+        );
+    }
+}
+
+#[test]
+fn completed_agent_channels_and_user_input_close_the_surface() {
+    for channel in [
+        AgentMessageChannel::Commentary,
+        AgentMessageChannel::FinalAnswer,
+    ] {
+        let cell = AgentMarkdownCell::new_with_channel(
+            "first\n\nsecond".to_string(),
+            &test_cwd(),
+            channel,
+        );
+        let lines = cell.display_lines(/*width*/ 20);
+        assert!(
+            lines
+                .last()
+                .is_some_and(|line| line.spans.iter().any(|span| span.content.contains('─'))),
+            "completed surface stayed open for {channel:?}"
+        );
+    }
+
+    let user = UserHistoryCell {
+        message: "input".to_string(),
+        text_elements: Vec::new(),
+        local_image_paths: Vec::new(),
+        remote_image_urls: Vec::new(),
+    };
+    assert!(
+        user.display_lines(/*width*/ 20)
+            .last()
+            .is_some_and(|line| line.spans.iter().any(|span| span.content.contains('─')))
+    );
 }
 
