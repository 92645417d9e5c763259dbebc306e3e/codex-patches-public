+            return (
+                GuardianReviewOutcome::Error(GuardianReviewError::prompt_build(err)),
+                GuardianReviewAnalyticsResult::without_session(),
+            );
+        }
+    };
+    run_guardian_review_session_with_retry_config(
+        session,
+        turn,
+        session_config,
+        request,
+        retry_reason,
+        schema,
+        external_cancel,
+        max_attempts,
+    )
+    .await
+}
