+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn guardian_review_timeout_routes_to_manual_approval() -> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let (_gate_tx, gate_rx) = oneshot::channel();
+    let (server, _completions) = start_streaming_sse_server(vec![vec![
+        StreamingSseChunk {
+            gate: None,
+            body: sse(vec![ev_response_created("resp-guardian-timeout")]),
+        },
+        StreamingSseChunk {
+            gate: Some(gate_rx),
+            body: String::new(),
+        },
+    ]])
+    .await;
+    let (session, turn, rx) = guardian_test_session_turn_rx_with_base_url(server.uri()).await;
+    seed_guardian_parent_history(&session, &turn).await;
+    enable_manual_approval_responses(&session).await;
+
+    let review = review_approval_request_with_timeout_for_test(
+        &session,
+        &turn,
+        "review-shell-guardian-timeout".to_string(),
+        guardian_shell_request("shell-guardian-timeout"),
+        /*retry_reason*/ None,
+        Duration::from_millis(50),
+    );
+    tokio::pin!(review);
+
+    let approval_events = receive_guardian_manual_approval(&rx, review.as_mut()).await?;
+    let approval_request = approval_events.approval_request;
+    assert_eq!(
+        approval_request.available_decisions,
+        Some(vec![ReviewDecision::Approved, ReviewDecision::Abort])
+    );
+    assert!(
+        approval_request
+            .reason
+            .as_deref()
+            .is_some_and(|reason| reason.contains("timed out while evaluating")),
+        "approval request should include timeout rationale: {approval_request:?}"
+    );
+    assert!(
+        approval_events
+            .statuses
+            .contains(&GuardianAssessmentStatus::TimedOut)
+    );
+    session
+        .notify_approval(
+            &approval_request.effective_approval_id(),
+            ReviewDecision::Abort,
+        )
+        .await;
+
+    assert_eq!(review.await, ReviewDecision::Abort);
+    server.shutdown().await;
+    Ok(())
+}
