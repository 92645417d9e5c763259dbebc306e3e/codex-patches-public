+async fn expect_guardian_network_fallback(
+    test: &TestCodex,
+    expected_host: Option<&str>,
+    expected_protocol: NetworkApprovalProtocol,
+) -> Result<ExecApprovalRequestEvent> {
+    let event = wait_for_event_with_timeout(
+        &test.codex,
+        |event| {
+            matches!(
+                event,
+                EventMsg::ExecApprovalRequest(_) | EventMsg::TurnComplete(_)
+            )
+        },
+        Duration::from_secs(30),
+    )
+    .await;
+    match event {
+        EventMsg::ExecApprovalRequest(approval) => {
+            let network_context = approval
+                .network_approval_context
+                .as_ref()
+                .context("expected Guardian network context")?;
+            assert_eq!(network_context.protocol, expected_protocol);
+            if let Some(expected_host) = expected_host {
+                assert_eq!(network_context.host, expected_host);
+            }
+            assert_eq!(approval.environment_id, None);
+            assert_eq!(
+                approval.available_decisions,
+                Some(vec![ReviewDecision::Approved, ReviewDecision::Abort])
+            );
+            Ok(approval)
+        }
+        EventMsg::TurnComplete(_) => {
+            panic!("expected Guardian manual fallback before completion");
+        }
+        other => panic!("unexpected event: {other:?}"),
+    }
+}
