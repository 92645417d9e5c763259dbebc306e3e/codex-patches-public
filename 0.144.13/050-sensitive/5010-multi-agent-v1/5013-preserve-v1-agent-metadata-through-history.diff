+#[test]
+fn legacy_history_persists_completed_collab_agent_tool_calls() {
+    for tool in [CollabAgentTool::SpawnAgent, CollabAgentTool::CloseAgent] {
+        let item = completed_collab_tool_call(tool);
+        let (persisted, measurement) = measure_and_filter_rollout_items(
+            std::slice::from_ref(&item),
+            ThreadHistoryMode::Legacy,
+        );
+
+        assert_eq!(
+            serde_json::to_value(persisted).expect("serialize persisted items"),
+            serde_json::to_value([item]).expect("serialize expected items")
+        );
+        assert_eq!(
+            measurement.items[0].decision,
+            super::PersistenceDecision::Kept
+        );
+    }
+}
+
+#[test]
+fn legacy_history_keeps_v2_wait_collab_items_transient() {
+    let item = completed_collab_tool_call(CollabAgentTool::Wait);
+
+    let (persisted, measurement) =
+        measure_and_filter_rollout_items(std::slice::from_ref(&item), ThreadHistoryMode::Legacy);
+
+    assert!(persisted.is_empty());
+    assert_eq!(
+        measurement.items[0].decision,
+        super::PersistenceDecision::Dropped
+    );
+}
