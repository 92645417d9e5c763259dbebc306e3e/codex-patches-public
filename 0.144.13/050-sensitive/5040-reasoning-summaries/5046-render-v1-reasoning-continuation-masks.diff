+#[tokio::test]
+async fn replayed_v1_continuation_items_show_masks_and_commentary_instruction() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let marker = "Continue the same turn from the preserved reasoning chain. Unaccepted replies and tool calls have not taken effect; request any still-needed tool again.";
+    chat.on_agent_reasoning_delta("**First reasoning part**".to_string());
+    chat.on_agent_reasoning_final(Some("rs_hidden".to_string()), true, Some(516));
+
+    for (id, text, notice, hidden) in [
+        (
+            "hidden-output",
+            "[Hidden assistant output]",
+            Some(codex_protocol::items::ContinuationNoticeKind::HiddenAssistantOutput),
+            true,
+        ),
+        (
+            "skipped-tool",
+            "[Skipped tool execution]",
+            Some(codex_protocol::items::ContinuationNoticeKind::SkippedToolExecution),
+            true,
+        ),
+        (
+            "skipped-tool-2",
+            "[Skipped tool execution]",
+            Some(codex_protocol::items::ContinuationNoticeKind::SkippedToolExecution),
+            true,
+        ),
+        ("continuation-instruction", marker, None, false),
+    ] {
+        chat.replay_thread_item(
+            AppServerThreadItem::AgentMessage {
+                id: id.to_string(),
+                text: text.to_string(),
+                phase: Some(MessagePhase::Commentary),
+                memory_citation: None,
+                continuation_notice: notice,
+                continuation_hidden: hidden,
+                continuation_instruction: id == "continuation-instruction",
+            },
+            "turn-1".to_string(),
+            ReplayKind::ThreadSnapshot,
+        );
+    }
+    chat.on_agent_reasoning_delta("**Completed reasoning**".to_string());
+    chat.on_agent_reasoning_final(Some("rs_final".to_string()), false, Some(7));
+
+    let rendered = drain_insert_history(&mut rx)
+        .into_iter()
+        .flatten()
+        .flat_map(|line| line.spans)
+        .map(|span| span.content.into_owned())
+        .collect::<Vec<_>>()
+        .join("\n");
+    assert!(rendered.contains("[Hidden assistant output]"));
+    assert!(rendered.contains("[Skipped tool execution]"));
+    assert!(rendered.contains("+1 more"));
+    assert!(
+        rendered
+            .split_whitespace()
+            .collect::<Vec<_>>()
+            .join(" ")
+            .contains(marker),
+        "the visible commentary instruction may wrap but must retain its complete text",
+    );
+}
