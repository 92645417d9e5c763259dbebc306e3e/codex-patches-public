+#[tokio::test]
+async fn replayed_v1_reasoning_chain_renders_once_with_response_usage() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let _ = drain_insert_history(&mut rx);
+
+    chat.replay_thread_item(
+        AppServerThreadItem::Reasoning {
+            id: "rs_opaque-a".to_string(),
+            summary: vec!["**First**\n\none".to_string()],
+            content: Vec::new(),
+            response_id: Some("resp-1".to_string()),
+            reasoning_output_tokens: None,
+            continued: true,
+        },
+        "turn-1".to_string(),
+        ReplayKind::ThreadSnapshot,
+    );
+    assert!(rx.try_recv().is_err());
+
+    chat.replay_thread_item(
+        AppServerThreadItem::Reasoning {
+            id: "rs_opaque-b".to_string(),
+            summary: vec!["**Second**\n\ntwo".to_string()],
+            content: Vec::new(),
+            response_id: Some("resp-1".to_string()),
+            reasoning_output_tokens: Some(37),
+            continued: false,
+        },
+        "turn-1".to_string(),
+        ReplayKind::ThreadSnapshot,
+    );
+
+    let rendered = match rx.try_recv() {
+        Ok(AppEvent::InsertHistoryCell(cell)) => {
+            lines_to_single_string(&cell.transcript_lines(/*width*/ 80))
+        }
+        other => panic!("expected InsertHistoryCell, got {other:?}"),
+    };
+    assert!(rendered.contains("one"));
+    assert!(rendered.contains("two"));
+    assert_eq!(rendered.matches("opaque-a").count(), 1);
+    assert_eq!(rendered.matches("opaque-b").count(), 1);
+    assert!(!rendered.contains("rs_opaque"));
+    assert_eq!(rendered.matches("37 tokens").count(), 1);
+}
+
+#[tokio::test]
+async fn reasoning_usage_distinguishes_missing_from_zero() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let _ = drain_insert_history(&mut rx);
+
+    for (id, tokens) in [("missing", None), ("zero", Some(0))] {
+        chat.replay_thread_item(
+            AppServerThreadItem::Reasoning {
+                id: id.to_string(),
+                summary: vec![format!("**{id}**\n\n{id}")],
+                content: Vec::new(),
+                response_id: Some(format!("resp-{id}")),
+                reasoning_output_tokens: tokens,
+                continued: false,
+            },
+            "turn-1".to_string(),
+            ReplayKind::ThreadSnapshot,
+        );
+    }
+
+    let missing = match rx.try_recv() {
+        Ok(AppEvent::InsertHistoryCell(cell)) => {
+            lines_to_single_string(&cell.transcript_lines(/*width*/ 80))
+        }
+        other => panic!("expected missing-usage history cell, got {other:?}"),
+    };
+    let zero = match rx.try_recv() {
+        Ok(AppEvent::InsertHistoryCell(cell)) => {
+            lines_to_single_string(&cell.transcript_lines(/*width*/ 80))
+        }
+        other => panic!("expected zero-usage history cell, got {other:?}"),
+    };
+    assert!(!missing.contains("tokens"));
+    assert!(zero.contains("0 tokens"));
+}
+
+#[tokio::test]
+async fn empty_v1_reasoning_chain_renders_one_placeholder() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let _ = drain_insert_history(&mut rx);
+
+    for (id, continued, tokens) in [("rs_empty-a", true, None), ("rs_empty-b", false, Some(23))] {
+        chat.replay_thread_item(
+            AppServerThreadItem::Reasoning {
+                id: id.to_string(),
+                summary: Vec::new(),
+                content: Vec::new(),
+                response_id: Some("resp-empty".to_string()),
+                reasoning_output_tokens: tokens,
+                continued,
+            },
+            "turn-1".to_string(),
+            ReplayKind::ThreadSnapshot,
+        );
+    }
+
+    let rendered = match rx.try_recv() {
+        Ok(AppEvent::InsertHistoryCell(cell)) => {
+            lines_to_single_string(&cell.transcript_lines(/*width*/ 80))
+        }
+        other => panic!("expected placeholder history cell, got {other:?}"),
+    };
+    assert_eq!(rendered.matches("[No reasoning summary]").count(), 1);
+    assert_eq!(rendered.matches("empty-a").count(), 1);
+    assert_eq!(rendered.matches("empty-b").count(), 1);
+    assert_eq!(rendered.matches("23 tokens").count(), 1);
+}
