+#[tokio::test]
+async fn live_v2_app_server_collab_wait_uses_status_without_history() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let _ = chat.config.features.enable(Feature::MultiAgentV2);
+    chat.bottom_pane.set_task_running(/*running*/ true);
+    let sender_thread_id = ThreadId::new();
+    let wait_item = |status, receiver_count| AppServerThreadItem::CollabAgentToolCall {
+        id: "wait-v2".to_string(),
+        tool: AppServerCollabAgentTool::Wait,
+        status,
+        sender_thread_id: sender_thread_id.to_string(),
+        receiver_thread_ids: (0..receiver_count)
+            .map(|index| format!("agent-{index}"))
+            .collect(),
+        prompt: None,
+        model: None,
+        reasoning_effort: None,
+        agents_states: HashMap::new(),
+    };
+
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 0,
+            item: wait_item(AppServerCollabAgentToolCallStatus::InProgress, 0),
+        }),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(
+        chat.status_state.current_status.header,
+        "Waiting for agents"
+    );
+    assert_chatwidget_snapshot!(
+        "v2_collab_wait_status",
+        render_bottom_popup(&chat, /*width*/ 80)
+    );
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 0,
+            item: wait_item(AppServerCollabAgentToolCallStatus::Completed, 0),
+        }),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    for (receiver_count, expected) in [(1, "Waiting for 1 agent"), (3, "Waiting for 3 agents")] {
+        chat.handle_server_notification(
+            ServerNotification::ItemStarted(ItemStartedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                started_at_ms: 0,
+                item: wait_item(
+                    AppServerCollabAgentToolCallStatus::InProgress,
+                    receiver_count,
+                ),
+            }),
+            /*replay_kind*/ None,
+        );
+        assert_eq!(chat.status_state.current_status.header, expected);
+        chat.handle_server_notification(
+            ServerNotification::ItemCompleted(ItemCompletedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                completed_at_ms: 0,
+                item: wait_item(
+                    AppServerCollabAgentToolCallStatus::Completed,
+                    receiver_count,
+                ),
+            }),
+            /*replay_kind*/ None,
+        );
+        assert_eq!(chat.status_state.current_status.header, "Working");
+    }
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    chat.set_status_header(String::from("Thinking"));
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 0,
+            item: wait_item(AppServerCollabAgentToolCallStatus::InProgress, 0),
+        }),
+        Some(ReplayKind::ThreadSnapshot),
+    );
+
+    assert_eq!(chat.status_state.current_status.header, "Thinking");
+    assert!(drain_insert_history(&mut rx).is_empty());
+}
