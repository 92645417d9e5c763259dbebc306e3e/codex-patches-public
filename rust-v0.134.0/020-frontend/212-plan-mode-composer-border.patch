+    #[test]
+    fn plan_mode_composer_draws_magenta_border() {
+        use ratatui::Terminal;
+        use ratatui::backend::TestBackend;
+
+        let (tx, _rx) = unbounded_channel::<AppEvent>();
+        let sender = AppEventSender::new(tx);
+        let mut composer = ChatComposer::new(
+            /*has_input_focus*/ true,
+            sender,
+            /*enhanced_keys_supported*/ true,
+            "Ask Codex to do anything".to_string(),
+            /*disable_paste_burst*/ false,
+        );
+        composer.set_collaboration_mode_indicator(Some(CollaborationModeIndicator::Plan));
+
+        let mut terminal = Terminal::new(TestBackend::new(48, 6)).unwrap();
+        terminal
+            .draw(|f| composer.render(f.area(), f.buffer_mut()))
+            .unwrap();
+
+        let buf = terminal.backend().buffer();
+        assert_eq!(buf[(0, 0)].symbol(), "┌");
+        assert_eq!(buf[(0, 0)].style().fg, Some(Color::Magenta));
+        assert_eq!(buf[(47, 0)].symbol(), "┐");
+        assert_eq!(buf[(47, 0)].style().fg, Some(Color::Magenta));
+        insta::assert_snapshot!("plan_mode_composer_border", terminal.backend());
+    }
