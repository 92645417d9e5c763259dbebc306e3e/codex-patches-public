+fn parse_context_remaining_percent(text: &str) -> Option<i64> {
+    if !text.starts_with(CONTEXT_REMAINING_PREFIX) || !text.ends_with(CONTEXT_REMAINING_SUFFIX) {
+        return None;
+    }
+
+    let percent = text
+        .strip_prefix(CONTEXT_REMAINING_PREFIX)?
+        .strip_suffix(CONTEXT_REMAINING_SUFFIX)?
+        .trim_end_matches('%')
+        .parse::<i64>()
+        .ok()?;
+
+    Some(percent)
+}
+
+pub(crate) fn context_remaining_label_spans(percent: i64, base_style: Style) -> Vec<Span<'static>> {
+    let percent = percent.clamp(0, 100);
+    vec![
+        Span::styled(CONTEXT_REMAINING_PREFIX, base_style),
+        Span::styled(
+            format!("{percent}%"),
+            context_remaining_percent_style(percent),
+        ),
+        Span::styled(CONTEXT_REMAINING_SUFFIX, base_style),
+    ]
+}
+
+pub(crate) fn context_remaining_percent_style(percent: i64) -> Style {
+    Style::default()
+        .fg(context_remaining_color(percent.clamp(0, 100)))
+        .add_modifier(Modifier::BOLD)
+}
+
+fn context_remaining_color(percent: i64) -> Color {
+    match percent {
+        75..=100 => Color::Green,
+        50..=74 => Color::Yellow,
+        25..=49 => CONTEXT_REMAINING_ORANGE,
+        0..=24 => Color::Red,
+        _ => Color::Green,
+    }
+}
