+fn clear_context_description(percent: Option<i64>) -> (String, Option<Line<'static>>) {
+    let Some(percent) = percent else {
+        return ("Fresh thread with this plan.".to_string(), None);
+    };
+
+    let percent = percent.clamp(0, 100);
+    let mut spans = vec!["Fresh thread. ".dim()];
+    spans.extend(context_remaining_label_spans(
+        percent,
+        Style::default().dim(),
+    ));
+    spans.push(".".dim());
+
+    (
+        format!("Fresh thread. Context {percent}% left."),
+        Some(Line::from(spans)),
+    )
+}
