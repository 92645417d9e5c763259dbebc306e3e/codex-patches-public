+#[derive(Debug)]
+struct ContextCompactedHistoryCell {
+    duration_ms: Option<i64>,
+    post_compact_context_percent: Option<i64>,
+}
+
+impl HistoryCell for ContextCompactedHistoryCell {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        let style = deleted_diff_row_style();
+        let detail_style = style.fg(Color::Yellow);
+        let details = self.details_text();
+        let mut spans = vec![Span::styled("• Context compacted", style)];
+        if let Some(details) = &details {
+            spans.push(Span::styled(format!(" {details}"), detail_style));
+        }
+        let line_width = "• Context compacted".width()
+            + details
+                .as_ref()
+                .map(|details| 1 + details.width())
+                .unwrap_or_default();
+        let target_width = usize::from(width);
+        if target_width > line_width {
+            spans.push(Span::styled(" ".repeat(target_width - line_width), style));
+        }
+        vec![Line::from(spans)]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        let mut text = "• Context compacted".to_string();
+        if let Some(details) = self.details_text() {
+            text.push(' ');
+            text.push_str(&details);
+        }
+        vec![text.into()]
+    }
+}
+
+impl ContextCompactedHistoryCell {
+    fn details_text(&self) -> Option<String> {
+        let mut details = Vec::new();
+        if let Some(duration_ms) = self.duration_ms {
+            let elapsed_seconds = u64::try_from(duration_ms.max(0))
+                .unwrap_or_default()
+                .saturating_add(999)
+                / 1_000;
+            let elapsed = crate::status_indicator_widget::fmt_elapsed_compact(elapsed_seconds);
+            details.push(format!("Worked {elapsed}"));
+        }
+        if let Some(percent) = self.post_compact_context_percent {
+            details.push(format!("{}% Used", percent.clamp(0, 100)));
+        }
+        (!details.is_empty()).then(|| format!("· {}", details.join(" · ")))
+    }
+}
+
+pub(crate) fn new_context_compacted_event(
+    duration_ms: Option<i64>,
+    post_compact_context_percent: Option<i64>,
+) -> impl HistoryCell {
+    ContextCompactedHistoryCell {
+        duration_ms,
+        post_compact_context_percent,
+    }
+}
