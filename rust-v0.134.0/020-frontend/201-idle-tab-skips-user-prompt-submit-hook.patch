+#[tokio::test]
+async fn idle_enter_submission_runs_user_prompt_submit_hook() {
+    let (mut chat, _rx, mut op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.thread_id = Some(ThreadId::new());
+
+    chat.bottom_pane
+        .set_composer_text("enter submit".to_string(), Vec::new(), Vec::new());
+    chat.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+
+    match next_submit_op(&mut op_rx) {
+        Op::UserTurn {
+            items,
+            suppress_user_prompt_submit_hook,
+            ..
+        } => {
+            assert!(!suppress_user_prompt_submit_hook);
+            assert_eq!(
+                items,
+                vec![UserInput::Text {
+                    text: "enter submit".to_string(),
+                    text_elements: Vec::new(),
+                }]
+            );
+        }
+        other => panic!("expected Op::UserTurn, got {other:?}"),
+    }
+}
