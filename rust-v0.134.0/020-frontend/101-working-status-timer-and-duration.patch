+#[tokio::test]
+async fn final_worked_for_prefers_local_elapsed_with_runtime_metrics() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+    chat.turn_lifecycle.active_turn_started_at =
+        Some(std::time::Instant::now() - std::time::Duration::from_secs(61));
+
+    let exec = begin_exec_with_source(
+        &mut chat,
+        "call-1",
+        "echo metrics",
+        ExecCommandSource::Agent,
+    );
+    end_exec(&mut chat, exec, "metrics\n", "", /*exit_code*/ 0);
+    chat.apply_runtime_metrics_delta(RuntimeMetricsSummary {
+        responses_api_overhead_ms: 1_200,
+        ..RuntimeMetricsSummary::default()
+    });
+
+    handle_turn_completed(&mut chat, "turn-1", Some(597_000));
+
+    let cells = drain_insert_history(&mut rx);
+    let combined = cells
+        .iter()
+        .map(|lines| lines_to_single_string(lines))
+        .collect::<String>();
+    assert!(
+        combined.contains("Worked for 1m 01s"),
+        "expected final separator to use local active-turn duration, got:\n{combined}"
+    );
+    assert!(
+        combined.contains("Responses API overhead: 1.2s"),
+        "expected final separator to keep runtime metrics, got:\n{combined}"
+    );
+    assert!(
+        !combined.contains("Worked for 9m 57s"),
+        "expected final separator to ignore protocol duration, got:\n{combined}"
+    );
+}
