+#[tokio::test]
+async fn duplicate_turn_started_keeps_active_turn_elapsed() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+    chat.turn_lifecycle.active_turn_started_at =
+        Some(std::time::Instant::now() - std::time::Duration::from_secs(125));
+
+    let now_unix_secs = std::time::SystemTime::now()
+        .duration_since(std::time::UNIX_EPOCH)
+        .expect("system time should be after UNIX epoch")
+        .as_secs() as i64;
+    chat.handle_server_notification(
+        ServerNotification::TurnStarted(TurnStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn: AppServerTurn {
+                id: "turn-1".to_string(),
+                items_view: codex_app_server_protocol::TurnItemsView::Full,
+                items: Vec::new(),
+                status: AppServerTurnStatus::InProgress,
+                error: None,
+                started_at: Some(now_unix_secs),
+                completed_at: None,
+                duration_ms: None,
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+
+    let exec = begin_exec_with_source(
+        &mut chat,
+        "call-1",
+        "echo after compact",
+        ExecCommandSource::Agent,
+    );
+    end_exec(&mut chat, exec, "after compact\n", "", /*exit_code*/ 0);
+
+    complete_assistant_message(
+        &mut chat,
+        "msg-final",
+        "Final response.",
+        Some(MessagePhase::FinalAnswer),
+    );
+    handle_turn_completed(&mut chat, "turn-1", Some(597_000));
+
+    let cells = drain_insert_history(&mut rx);
+    let combined = cells
+        .iter()
+        .map(|lines| lines_to_single_string(lines))
+        .collect::<String>();
+    assert!(
+        combined.contains("Worked for 2m 05s"),
+        "expected duplicate TurnStarted to preserve active-turn duration, got:\n{combined}"
+    );
+    assert!(
+        !combined.contains("Worked for 0s"),
+        "expected duplicate TurnStarted not to reset active-turn duration, got:\n{combined}"
+    );
+}
