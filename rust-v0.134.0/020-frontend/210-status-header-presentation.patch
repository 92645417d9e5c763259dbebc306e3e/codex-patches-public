+
+pub(crate) fn compacting_spans(text: &str) -> Vec<Span<'static>> {
+    animated_color_spans(text, &COMPACTING_TRUECOLOR, &COMPACTING_ANSI)
+}
+
+fn animated_color_spans(
+    text: &str,
+    truecolor_palette: &[(u8, u8, u8)],
+    ansi_palette: &[Color],
+) -> Vec<Span<'static>> {
+    let chars: Vec<char> = text.chars().collect();
+    if chars.is_empty() {
+        return Vec::new();
+    }
+
+    let phase =
+        ((elapsed_since_start().as_millis() / 80) % truecolor_palette.len() as u128) as usize;
+    let color_level = supports_color::on_cached(supports_color::Stream::Stdout);
+    let has_color = color_level.is_some();
+    let has_true_color = color_level.map(|level| level.has_16m).unwrap_or(false);
+
+    chars
+        .into_iter()
+        .enumerate()
+        .map(|(idx, ch)| {
+            let color_idx = (idx + phase) % truecolor_palette.len();
+            let style = if has_true_color {
+                let (r, g, b) = truecolor_palette[color_idx];
+                #[allow(clippy::disallowed_methods)]
+                {
+                    Style::default()
+                        .fg(Color::Rgb(r, g, b))
+                        .add_modifier(Modifier::BOLD)
+                }
+            } else if has_color {
+                Style::default()
+                    .fg(ansi_palette[color_idx])
+                    .add_modifier(Modifier::BOLD)
+            } else {
+                Style::default().add_modifier(Modifier::BOLD)
+            };
+            Span::styled(ch.to_string(), style)
+        })
+        .collect()
+}
