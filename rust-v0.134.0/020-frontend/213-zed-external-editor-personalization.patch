+#[cfg(unix)]
+async fn run_local_zed_external_editor(seed: &str) -> Result<String> {
+    let root = Path::new(LOCAL_ZED_TMP_ROOT);
+    fs::create_dir_all(root)?;
+    let temp_dir = Builder::new().prefix("zed.").tempdir_in(root)?;
+    let work_path = temp_dir.path().join(LOCAL_ZED_FILE_NAME);
+    fs::write(&work_path, seed)?;
+
+    let placer = tokio::task::spawn_blocking(position_local_zed_window);
+    let mut command = Command::new(LOCAL_ZED_BIN);
+    configure_local_zed_command(&mut command);
+    let status = command
+        .arg("--wait")
+        .arg("--new")
+        .arg(&work_path)
+        .stdin(Stdio::inherit())
+        .stdout(Stdio::inherit())
+        .stderr(Stdio::inherit())
+        .status()
+        .await?;
+
+    let _ = placer.await;
+
+    if !status.success() {
+        return Err(Report::msg(format!("editor exited with status {status}")));
+    }
+
+    let contents = fs::read_to_string(&work_path)?;
+    Ok(contents)
+}
+
+#[cfg(unix)]
+fn configure_local_zed_command(command: &mut Command) {
+    command.env("WINIT_UNIX_BACKEND", "x11");
+    command.env_remove("WAYLAND_DISPLAY");
+    for key in LOCAL_ZED_X11_ENV_VARS {
+        if let Some(value) = env::var_os(key) {
+            command.env(key, value);
+        }
+    }
+    for key in LOCAL_ZED_TOOLKIT_IM_ENV_VARS {
+        command.env_remove(key);
+    }
+}
+
+#[cfg(not(unix))]
+async fn run_local_zed_external_editor(_seed: &str) -> Result<String> {
+    Err(Report::msg(
+        "local Zed external editor is only supported on Unix",
+    ))
+}
