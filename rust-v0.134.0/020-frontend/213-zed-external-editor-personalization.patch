+#[cfg(unix)]
+fn local_zed_external_editor_available() -> bool {
+    is_executable(Path::new(LOCAL_ZED_BIN))
+        && command_exists("xrandr")
+        && command_exists("wmctrl")
+        && command_exists("xdotool")
+}
+
+#[cfg(not(unix))]
+fn local_zed_external_editor_available() -> bool {
+    false
+}
+
+#[cfg(unix)]
+fn is_executable(path: &Path) -> bool {
+    use std::os::unix::fs::PermissionsExt;
+
+    path.is_file()
+        && fs::metadata(path)
+            .map(|metadata| metadata.permissions().mode() & 0o111 != 0)
+            .unwrap_or(false)
+}
+
+#[cfg(unix)]
+fn command_exists(command: &str) -> bool {
+    let Some(path) = env::var_os("PATH") else {
+        return false;
+    };
+
+    env::split_paths(&path)
+        .map(|dir| dir.join(command))
+        .any(|path| is_executable(&path))
+}
+
+#[cfg(unix)]
+fn position_local_zed_window() {
+    let Some(window_id) = wait_for_window_by_title(LOCAL_ZED_FILE_NAME) else {
+        return;
+    };
+    let Some(monitor) = primary_monitor_geometry() else {
+        return;
+    };
+    let rect = external_editor_window_rect(monitor);
+
+    let _ = StdCommand::new("xdotool")
+        .args(["windowactivate", "--sync", &window_id])
+        .status();
+    thread::sleep(Duration::from_millis(200));
+    let _ = StdCommand::new("xdotool")
+        .args(["key", "--clearmodifiers", "alt+F7"])
+        .status();
+    thread::sleep(Duration::from_millis(200));
+
+    let _ = StdCommand::new("wmctrl")
+        .args([
+            "-i",
+            "-r",
+            &window_id,
+            "-b",
+            "remove,maximized_vert,maximized_horz",
+        ])
+        .status();
+    let _ = StdCommand::new("wmctrl")
+        .args(["-i", "-r", &window_id, "-b", "add,above"])
+        .status();
+    let geometry = format!("0,{},{},{},{}", rect.x, rect.y, rect.width, rect.height);
+    let _ = StdCommand::new("wmctrl")
+        .args(["-i", "-r", &window_id, "-e", &geometry])
+        .status();
+}
+
+#[cfg(unix)]
+fn wait_for_window_by_title(title_token: &str) -> Option<String> {
+    for _ in 0..100 {
+        let output = StdCommand::new("wmctrl").arg("-lx").output().ok()?;
+        let stdout = String::from_utf8_lossy(&output.stdout);
+        if let Some(window_id) = stdout.lines().find_map(|line| {
+            line.contains(title_token)
+                .then(|| line.split_whitespace().next().map(str::to_string))
+                .flatten()
+        }) {
+            return Some(window_id);
+        }
+        thread::sleep(Duration::from_millis(100));
+    }
+
+    None
+}
+
+#[cfg(unix)]
+fn primary_monitor_geometry() -> Option<MonitorGeometry> {
+    let output = StdCommand::new("xrandr").arg("--query").output().ok()?;
+    let stdout = String::from_utf8_lossy(&output.stdout);
+    parse_primary_monitor_geometry(&stdout)
+}
+
+#[cfg(unix)]
+fn parse_primary_monitor_geometry(xrandr_output: &str) -> Option<MonitorGeometry> {
+    let fallback = xrandr_output
+        .lines()
+        .find(|line| line.contains(" connected "));
+    let line = xrandr_output
+        .lines()
+        .find(|line| line.contains(" connected primary "))
+        .or(fallback)?;
+    let geometry = if let Some((_, after_primary)) = line.split_once(" primary ") {
+        after_primary.split_whitespace().next()?
+    } else {
+        line.split_once(" connected ")?
+            .1
+            .split_whitespace()
+            .next()?
+    };
+    parse_monitor_geometry_token(geometry)
+}
+
+#[cfg(unix)]
+fn parse_monitor_geometry_token(token: &str) -> Option<MonitorGeometry> {
+    let (width, rest) = token.split_once('x')?;
+    let mut parts = rest.split('+');
+    let height = parts.next()?;
+    let x = parts.next()?;
+    let y = parts.next()?;
+    Some(MonitorGeometry {
+        width: width.parse().ok()?,
+        height: height.parse().ok()?,
+        x: x.parse().ok()?,
+        y: y.parse().ok()?,
+    })
+}
+
+#[cfg(unix)]
+fn external_editor_window_rect(monitor: MonitorGeometry) -> WindowRect {
+    WindowRect {
+        width: monitor.width / 2,
+        height: monitor.height / 2,
+        x: monitor.x + (monitor.width / 2) as i32,
+        y: monitor.y,
+    }
+}
