+fn mask_status_email(email: &str) -> String {
+    let Some((local, domain)) = email.split_once('@') else {
+        return email.to_string();
+    };
+
+    let mut local_chars = local.chars().collect::<Vec<_>>();
+    let Some(first) = local_chars.first().copied() else {
+        return email.to_string();
+    };
+
+    let suffix_len = local_chars.len().saturating_sub(1).min(2);
+    let suffix = local_chars.split_off(local_chars.len().saturating_sub(suffix_len));
+    let suffix = suffix.into_iter().collect::<String>();
+
+    format!("{first}***{suffix}@{domain}")
+}
