+        );
+
+        assert_eq!(
+            line.spans
+                .iter()
+                .map(|span| span.content.as_ref())
+                .collect::<String>(),
+            "xhigh"
+        );
+        assert_eq!(line.spans.len(), 5);
+        assert!(
+            line.spans
+                .iter()
+                .all(|span| !span.style.add_modifier.contains(Modifier::DIM))
+        );
+        assert!(
+            line.spans
+                .iter()
+                .all(|span| !span.style.sub_modifier.contains(Modifier::DIM))
+        );
+    }
+
