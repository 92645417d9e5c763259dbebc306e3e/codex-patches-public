+
+    #[allow(clippy::disallowed_methods)]
+    #[test]
+    fn reasoning_effort_status_line_uses_color_without_dim_override() {
+        let cases = [
+            (Some(ReasoningEffortConfig::Minimal), Some(Color::Yellow)),
+            (Some(ReasoningEffortConfig::Low), Some(Color::Yellow)),
+            (
+                Some(ReasoningEffortConfig::Medium),
+                Some(Color::Rgb(255, 128, 0)),
+            ),
+            (Some(ReasoningEffortConfig::High), Some(Color::Red)),
+            (Some(ReasoningEffortConfig::None), None),
+            (None, None),
+        ];
+
+        for (effort, expected_color) in cases {
+            let label = ChatWidget::status_line_reasoning_effort_label(effort);
+            let span = ChatWidget::status_line_reasoning_effort_span(label, effort);
+            assert_eq!(span.style.fg, expected_color, "effort: {effort:?}");
+            assert_eq!(
+                span.style.add_modifier.contains(Modifier::DIM),
+                false,
+                "effort: {effort:?}"
+            );
+            assert_eq!(
+                span.style.sub_modifier.contains(Modifier::DIM),
+                false,
+                "effort: {effort:?}"
+            );
+        }
+    }
+
