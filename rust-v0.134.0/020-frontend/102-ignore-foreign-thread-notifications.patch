+    fn should_accept_thread_notification(
+        &self,
+        thread_id: ThreadId,
+        notification: &ServerNotification,
+    ) -> bool {
+        if self.primary_thread_id == Some(thread_id)
+            || self.thread_event_channels.contains_key(&thread_id)
+            || self.agent_navigation.get(&thread_id).is_some()
+        {
+            return true;
+        }
+
+        let ServerNotification::ThreadStarted(notification) = notification else {
+            return false;
+        };
+
+        self.thread_belongs_to_current_session_tree(&notification.thread)
+    }
+
+    fn thread_belongs_to_current_session_tree(
+        &self,
+        thread: &codex_app_server_protocol::Thread,
+    ) -> bool {
+        let Some(primary_thread_id) = self.primary_thread_id else {
+            return true;
+        };
+
+        if thread.session_id == primary_thread_id.to_string() {
+            return true;
+        }
+
+        if let Some(parent_thread_id) = thread
+            .forked_from_id
+            .as_deref()
+            .and_then(|thread_id| ThreadId::from_string(thread_id).ok())
+            && self.is_current_session_thread(parent_thread_id)
+        {
+            return true;
+        }
+
+        let codex_app_server_protocol::SessionSource::SubAgent(
+            codex_protocol::protocol::SubAgentSource::ThreadSpawn {
+                parent_thread_id, ..
+            },
+        ) = &thread.source
+        else {
+            return false;
+        };
+
+        self.is_current_session_thread(*parent_thread_id)
+    }
+
+    fn is_current_session_thread(&self, thread_id: ThreadId) -> bool {
+        self.primary_thread_id == Some(thread_id)
+            || self.thread_event_channels.contains_key(&thread_id)
+            || self.agent_navigation.get(&thread_id).is_some()
+    }
