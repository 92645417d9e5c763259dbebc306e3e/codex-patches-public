+                ephemeral: false,
+                model_provider: "agent-provider".to_string(),
+                created_at: 1,
+                updated_at: 2,
+                status: codex_app_server_protocol::ThreadStatus::Idle,
+                path: None,
+                cwd: test_path_buf("/tmp/foreign").abs(),
+                cli_version: "0.0.0".to_string(),
+                source: SessionSource::Cli,
+                thread_source: None,
+                agent_nickname: None,
+                agent_role: None,
+                git_info: None,
+                name: Some("foreign main thread".to_string()),
+                turns: Vec::new(),
+            },
+        }),
+    )
+    .await?;
+
+    assert!(!app.thread_event_channels.contains_key(&foreign_thread_id));
