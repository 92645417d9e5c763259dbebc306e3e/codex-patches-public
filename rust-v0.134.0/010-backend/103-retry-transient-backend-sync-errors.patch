+#[test]
+fn transient_limit_errors_use_longer_retry_delay() {
+    let usage_limit = CodexErr::UsageLimitReached(UsageLimitReachedError {
+        plan_type: None,
+        resets_at: None,
+        rate_limits: None,
+        promo_message: None,
+        rate_limit_reached_type: None,
+    });
+
+    assert_eq!(
+        sampling_retry_delay(&usage_limit, /*retries*/ 1),
+        Duration::from_secs(5)
+    );
+    assert_eq!(
+        sampling_retry_delay(&CodexErr::QuotaExceeded, /*retries*/ 1),
+        Duration::from_secs(5)
+    );
+    assert_eq!(
