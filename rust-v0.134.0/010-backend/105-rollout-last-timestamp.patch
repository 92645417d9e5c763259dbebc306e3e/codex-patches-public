+async fn rollout_updated_time(path: &Path) -> io::Result<Option<OffsetDateTime>> {
+    if let Some(updated_at) = rollout_last_timestamp(path).await? {
+        return Ok(Some(updated_at));
+    }
+    file_modified_time(path).await
+}
+
+async fn rollout_last_timestamp(path: &Path) -> io::Result<Option<OffsetDateTime>> {
+    let Some(line) = read_last_non_empty_line(path).await? else {
+        return Ok(None);
+    };
+    let Ok(rollout_line) = serde_json::from_str::<RolloutLine>(line.as_str()) else {
+        return Ok(None);
+    };
+    Ok(
+        OffsetDateTime::parse(rollout_line.timestamp.as_str(), &Rfc3339)
+            .ok()
+            .and_then(truncate_to_millis),
+    )
+}
+
+async fn read_last_non_empty_line(path: &Path) -> io::Result<Option<String>> {
+    use tokio::io::AsyncReadExt;
+    use tokio::io::AsyncSeekExt;
+
+    const CHUNK_SIZE: u64 = 8192;
+
+    let mut file = tokio::fs::File::open(path).await?;
+    let mut position = file.metadata().await?.len();
+    let mut tail = Vec::new();
+    while position > 0 {
+        let read_len = position.min(CHUNK_SIZE) as usize;
+        position = position.saturating_sub(read_len as u64);
+        file.seek(std::io::SeekFrom::Start(position)).await?;
+        let mut chunk = vec![0; read_len];
+        file.read_exact(&mut chunk).await?;
+        chunk.extend_from_slice(tail.as_slice());
+        tail = chunk;
+        if let Some(line) = last_complete_non_empty_line(tail.as_slice(), position == 0) {
+            return Ok(Some(line));
+        }
+    }
+    Ok(None)
+}
+
+fn last_complete_non_empty_line(buffer: &[u8], at_start: bool) -> Option<String> {
+    let mut end = buffer.len();
+    loop {
+        while end > 0 && matches!(buffer[end - 1], b'\n' | b'\r') {
+            end -= 1;
+        }
+        if end == 0 {
+            return None;
+        }
+
+        let start = match buffer[..end].iter().rposition(|byte| *byte == b'\n') {
+            Some(index) => index.saturating_add(1),
+            None if at_start => 0,
+            None => return None,
+        };
+        let line = &buffer[start..end];
+        if !line.iter().all(u8::is_ascii_whitespace) {
+            return Some(String::from_utf8_lossy(line).trim().to_string());
+        }
+        if start == 0 {
+            return None;
+        }
+        end = start.saturating_sub(1);
+    }
+}
+
 fn format_rfc3339(dt: OffsetDateTime) -> Option<String> {
     dt.format(&Rfc3339).ok()
 }
