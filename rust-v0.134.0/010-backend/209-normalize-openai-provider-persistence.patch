+#[test]
+fn test_merge_configured_model_providers_defaults_empty_custom_name_to_openai() {
+    let custom_provider = ModelProviderInfo {
+        base_url: Some("http://127.0.0.1:1080/backend-api/codex".to_string()),
+        requires_openai_auth: true,
+        supports_websockets: true,
+        ..ModelProviderInfo::default()
+    };
+    let configured_model_providers =
+        std::collections::HashMap::from([("codex".to_string(), custom_provider.clone())]);
+
+    let mut expected_provider = custom_provider;
+    expected_provider.name = "OpenAI".to_string();
+    let mut expected = built_in_model_providers(/*openai_base_url*/ None);
+    expected.insert("codex".to_string(), expected_provider);
+
+    assert_eq!(
+        merge_configured_model_providers(
+            built_in_model_providers(/*openai_base_url*/ None),
+            configured_model_providers,
+        ),
+        Ok(expected)
+    );
+}
