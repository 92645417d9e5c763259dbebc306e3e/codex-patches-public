+/// Returns the Codex runtime temp root under the system temp directory.
+///
+/// This uses [`std::env::temp_dir`] so it follows the platform temp directory
+/// conventions and honors environment overrides such as `TMPDIR`.
+pub fn find_codex_tmp_root() -> std::io::Result<AbsolutePathBuf> {
+    let path = std::env::temp_dir().join("codex").join("tmp");
+    AbsolutePathBuf::from_absolute_path(path).map_err(|path| {
+        std::io::Error::new(
+            std::io::ErrorKind::InvalidInput,
+            format!("system temp dir resolved to a non-absolute path: {path:?}"),
+        )
+    })
+}
+
 fn find_codex_home_from_env(codex_home_env: Option<&str>) -> std::io::Result<AbsolutePathBuf> {
