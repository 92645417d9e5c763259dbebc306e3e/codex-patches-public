+    let codex_home = TempDir::new()?;
+    let memories_root = codex_home.path().join("memories");
+    let config = Config::load_from_base_config_with_overrides(
+        ConfigToml {
+            features: Some(FeaturesToml::from(BTreeMap::from([(
+                "memories".to_string(),
+                false,
+            )]))),
+            sandbox_workspace_write: Some(SandboxWorkspaceWrite {
+                writable_roots: vec![codex_home.path().join("workspace").abs()],
+                ..Default::default()
+            }),
+            ..Default::default()
+        },
+        ConfigOverrides {
+            sandbox_mode: Some(SandboxMode::WorkspaceWrite),
+            ..Default::default()
+        },
+        codex_home.abs(),
+    )
+    .await?;
+
+    assert!(
+        !memories_root.exists(),
+        "expected disabled memories feature not to create {}",
+        memories_root.display()
+    );
+    let expected_memories_root = memories_root.abs();
+    if let SandboxPolicy::WorkspaceWrite { writable_roots, .. } = &config.legacy_sandbox_policy() {
+        assert!(
+            !writable_roots.contains(&expected_memories_root),
+            "expected disabled memories root not to be writable"
+        );
+    }
+
+    Ok(())
+}
