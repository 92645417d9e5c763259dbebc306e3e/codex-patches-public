+#[cfg(test)]
+mod tests {
+    use codex_protocol::models::BaseInstructions;
+    use codex_protocol::protocol::SessionSource;
+
+    use super::*;
+    use crate::InMemoryThreadStore;
+    use crate::ThreadEventPersistenceMode;
+
+    #[tokio::test]
+    async fn append_items_after_shutdown_clone_is_noop() {
+        let store = InMemoryThreadStore::for_id("live-thread-shutdown-noop");
+        let live_thread =
+            LiveThread::create(store.clone(), create_thread_params(ThreadId::default()))
+                .await
+                .expect("create live thread");
+        let stale_clone = live_thread.clone();
+
+        live_thread.shutdown().await.expect("shutdown live thread");
+        stale_clone
+            .append_items(&[])
+            .await
+            .expect("append after shutdown");
+
+        assert_eq!(store.calls().await.append_items, 0);
+        InMemoryThreadStore::remove_id("live-thread-shutdown-noop");
+    }
+
+    #[tokio::test]
+    async fn append_items_after_discard_clone_is_noop() {
+        let store = InMemoryThreadStore::for_id("live-thread-discard-noop");
+        let live_thread =
+            LiveThread::create(store.clone(), create_thread_params(ThreadId::default()))
+                .await
+                .expect("create live thread");
+        let stale_clone = live_thread.clone();
+
+        live_thread.discard().await.expect("discard live thread");
+        stale_clone
+            .append_items(&[])
+            .await
+            .expect("append after discard");
+
+        assert_eq!(store.calls().await.append_items, 0);
+        InMemoryThreadStore::remove_id("live-thread-discard-noop");
+    }
+
+    fn create_thread_params(thread_id: ThreadId) -> CreateThreadParams {
+        CreateThreadParams {
+            thread_id,
+            forked_from_id: None,
+            source: SessionSource::Exec,
+            thread_source: None,
+            base_instructions: BaseInstructions::default(),
+            dynamic_tools: Vec::new(),
+            metadata: crate::ThreadPersistenceMetadata {
+                cwd: Some(std::env::current_dir().expect("cwd")),
+                model_provider: "test-provider".to_string(),
+                memory_mode: codex_protocol::protocol::ThreadMemoryMode::Enabled,
+            },
+            event_persistence_mode: ThreadEventPersistenceMode::Limited,
+        }
+    }
+}
