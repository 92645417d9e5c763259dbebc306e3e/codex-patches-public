diff --git a/codex-rs/core/src/ws_stream_retry.rs b/codex-rs/core/src/ws_stream_retry.rs
new file mode 100644
index 0000000000..215f572876
--- /dev/null
+++ b/codex-rs/core/src/ws_stream_retry.rs
@@ -0,0 +1,85 @@
+use std::time::Duration;
+
+use codex_protocol::error::CodexErr;
+
+pub(crate) const WS_STREAM_MAX_RETRIES: u64 = 30;
+pub(crate) const WS_STREAM_RETRY_BUDGET: Duration = Duration::from_secs(30 * 60);
+
+const WS_STREAM_RETRY_DELAY: Duration = Duration::from_secs(60);
+
+pub(crate) fn is_ws_stream_retryable(err: &CodexErr) -> bool {
+    match err {
+        CodexErr::Stream(message, _) => {
+            let message = message.to_ascii_lowercase();
+            message.contains("websocket")
+                || message.contains("connection reset")
+                || message.contains("connection closed")
+                || message.contains("closed connection")
+                || message.contains("connection refused")
+                || message.contains("connection aborted")
+                || message.contains("stream closed")
+                || message.contains("unexpected eof")
+                || message.contains("tls handshake eof")
+                || message.contains("close_notify")
+                || message.contains("failed to write whole buffer")
+                || message.contains("timed out")
+                || message.contains("timeout")
+                || message.contains("network error")
+                || message.contains("dns error")
+                || message.contains("failed to lookup")
+                || message.contains("name resolution")
+                || message.contains("temporary failure in name resolution")
+        }
+        CodexErr::Timeout | CodexErr::RequestTimeout => true,
+        _ => false,
+    }
+}
+
+pub(crate) fn ws_stream_retry_delay(elapsed: Duration) -> Option<Duration> {
+    if elapsed >= WS_STREAM_RETRY_BUDGET {
+        None
+    } else {
+        Some(WS_STREAM_RETRY_DELAY.min(WS_STREAM_RETRY_BUDGET - elapsed))
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn retry_delay_stays_inside_budget() {
+        assert_eq!(
+            ws_stream_retry_delay(Duration::ZERO),
+            Some(WS_STREAM_RETRY_DELAY)
+        );
+        assert_eq!(
+            ws_stream_retry_delay(WS_STREAM_RETRY_BUDGET - Duration::from_secs(1)),
+            Some(Duration::from_secs(1))
+        );
+        assert_eq!(ws_stream_retry_delay(WS_STREAM_RETRY_BUDGET), None);
+    }
+
+    #[test]
+    fn classifies_websocket_stream_errors() {
+        assert!(is_ws_stream_retryable(&CodexErr::Stream(
+            "websocket closed".to_string(),
+            None,
+        )));
+        assert!(is_ws_stream_retryable(&CodexErr::Stream(
+            "tls handshake eof".to_string(),
+            None,
+        )));
+        assert!(is_ws_stream_retryable(&CodexErr::Stream(
+            "IO error: peer closed connection without sending TLS close_notify: https://docs.rs/rustls/latest/rustls/manual/_03_howto/index.html#unexpected-eof".to_string(),
+            None,
+        )));
+        assert!(is_ws_stream_retryable(&CodexErr::Stream(
+            "network error: error sending request for url (https://api.openai.com/v1/responses): error trying to connect: dns error: failed to lookup address information: Temporary failure in name resolution".to_string(),
+            None,
+        )));
+        assert!(is_ws_stream_retryable(&CodexErr::Timeout));
+        assert!(is_ws_stream_retryable(&CodexErr::RequestTimeout));
+        assert!(!is_ws_stream_retryable(&CodexErr::UsageNotIncluded));
+    }
+}
