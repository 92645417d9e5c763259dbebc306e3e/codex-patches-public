+pub fn cli_overrides_with_project_trust(
+    cli_overrides: &[(String, TomlValue)],
+    project_path: &Path,
+    trust_level: TrustLevel,
+) -> Vec<(String, TomlValue)> {
+    let mut overrides = cli_overrides.to_vec();
+    let project_key = project_trust_key(project_path);
+    let trust_level_value = TomlValue::String(trust_level.to_string());
+
+    if let Some((_, projects_value)) = overrides.iter_mut().find(|(path, _)| path == "projects")
+        && let Some(projects) = projects_value.as_table_mut()
+    {
+        match projects.get_mut(&project_key) {
+            Some(existing_project) => {
+                if let Some(existing_project_table) = existing_project.as_table_mut() {
+                    existing_project_table.insert("trust_level".to_string(), trust_level_value);
+                } else {
+                    let mut project = toml::map::Map::new();
+                    project.insert("trust_level".to_string(), trust_level_value);
+                    *existing_project = TomlValue::Table(project);
+                }
+            }
+            None => {
+                let mut project = toml::map::Map::new();
+                project.insert("trust_level".to_string(), trust_level_value);
+                projects.insert(project_key, TomlValue::Table(project));
+            }
+        }
+        return overrides;
+    }
+
+    let mut project = toml::map::Map::new();
+    project.insert("trust_level".to_string(), trust_level_value);
+    let mut projects = toml::map::Map::new();
+    projects.insert(project_key, TomlValue::Table(project));
+    overrides.push(("projects".to_string(), TomlValue::Table(projects)));
+    overrides
+}
