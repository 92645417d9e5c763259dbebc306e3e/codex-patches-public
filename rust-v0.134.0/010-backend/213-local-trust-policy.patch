+fn cli_overrides_with_project_trust_merges_existing_projects_override() {
+    let project_dir = Path::new("/some/path");
+    let mut existing_project = toml::map::Map::new();
+    existing_project.insert("foo".to_string(), TomlValue::String("bar".to_string()));
+    let mut existing_projects = toml::map::Map::new();
+    existing_projects.insert(
+        project_trust_key(project_dir),
+        TomlValue::Table(existing_project),
+    );
+    let cli_overrides = vec![("projects".to_string(), TomlValue::Table(existing_projects))];
+
+    let merged = cli_overrides_with_project_trust(&cli_overrides, project_dir, TrustLevel::Trusted);
+
+    assert_eq!(merged.len(), 1);
+    let projects = merged[0]
+        .1
+        .as_table()
+        .expect("projects override should stay a table");
+    let project = projects[&project_trust_key(project_dir)]
+        .as_table()
+        .expect("project override should stay a table");
+    assert_eq!(
+        project.get("foo"),
+        Some(&TomlValue::String("bar".to_string()))
+    );
+    assert_eq!(
+        project.get("trust_level"),
+        Some(&TomlValue::String("trusted".to_string()))
+    );
+}
