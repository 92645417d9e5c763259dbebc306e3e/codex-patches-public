+fn should_limit_thread_list_for_client(client_name: Option<&str>) -> bool {
+    client_name != Some(TUI_CLIENT_NAME)
+}
+
+fn should_limit_thread_list_params(params: &ThreadListParams) -> bool {
+    !params.source_kinds.as_deref().is_some_and(|source_kinds| {
+        source_kinds.iter().any(|source_kind| {
+            matches!(
+                source_kind,
+                ThreadSourceKind::SubAgent
+                    | ThreadSourceKind::SubAgentReview
+                    | ThreadSourceKind::SubAgentCompact
+                    | ThreadSourceKind::SubAgentThreadSpawn
+                    | ThreadSourceKind::SubAgentOther
+            )
+        })
+    })
+}
+
+fn apply_non_tui_thread_list_limit(params: &mut ThreadListParams) {
+    params.cursor = None;
+    params.limit = Some(NON_TUI_THREAD_LIST_LIMIT);
+    params.sort_key = Some(ThreadSortKey::UpdatedAt);
+    params.sort_direction = Some(SortDirection::Desc);
+}
+
+fn limit_non_tui_response(response: ClientResponsePayload) -> ClientResponsePayload {
+    match response {
+        ClientResponsePayload::ThreadList(mut response) => {
+            response.next_cursor = None;
+            response.backwards_cursor = None;
+            ClientResponsePayload::ThreadList(response)
+        }
+        other => other,
+    }
+}
+
+#[cfg(test)]
+mod non_tui_thread_list_tests {
+    use super::*;
+    use codex_app_server_protocol::ThreadListResponse;
+
+    #[test]
+    fn only_tui_thread_list_requests_are_unlimited() {
+        assert!(!should_limit_thread_list_for_client(Some("codex-tui")));
+        assert!(should_limit_thread_list_for_client(Some("codex-backend")));
+        assert!(should_limit_thread_list_for_client(Some(
+            "codex_app_server_daemon"
+        )));
+        assert!(should_limit_thread_list_for_client(None));
+    }
+
+    #[test]
+    fn non_tui_thread_list_request_is_forced_to_recent_five() {
+        let mut params = ThreadListParams {
+            cursor: Some("client-cursor".to_string()),
+            limit: Some(100),
+            sort_key: Some(ThreadSortKey::CreatedAt),
+            sort_direction: Some(SortDirection::Asc),
+            model_providers: None,
+            source_kinds: None,
+            archived: None,
+            cwd: None,
+            use_state_db_only: false,
+            search_term: None,
+        };
+
+        apply_non_tui_thread_list_limit(&mut params);
+
+        assert_eq!(params.cursor, None);
+        assert_eq!(params.limit, Some(NON_TUI_THREAD_LIST_LIMIT));
+        assert_eq!(params.sort_key, Some(ThreadSortKey::UpdatedAt));
+        assert_eq!(params.sort_direction, Some(SortDirection::Desc));
+    }
+
+    #[test]
+    fn non_tui_subagent_thread_list_request_keeps_client_pagination() {
+        let params = ThreadListParams {
+            cursor: Some("client-cursor".to_string()),
+            limit: Some(100),
+            sort_key: Some(ThreadSortKey::CreatedAt),
+            sort_direction: Some(SortDirection::Asc),
+            model_providers: None,
+            source_kinds: Some(vec![ThreadSourceKind::SubAgentThreadSpawn]),
+            archived: None,
+            cwd: None,
+            use_state_db_only: false,
+            search_term: None,
+        };
+
+        assert!(!should_limit_thread_list_params(&params));
+    }
+
+    #[test]
+    fn non_tui_thread_list_response_hides_pagination() {
+        let response = ClientResponsePayload::ThreadList(ThreadListResponse {
+            data: Vec::new(),
+            next_cursor: Some("next".to_string()),
+            backwards_cursor: Some("back".to_string()),
+        });
+
+        let ClientResponsePayload::ThreadList(response) = limit_non_tui_response(response) else {
+            panic!("expected thread list response");
+        };
+
+        assert_eq!(response.next_cursor, None);
+        assert_eq!(response.backwards_cursor, None);
+    }
+}
