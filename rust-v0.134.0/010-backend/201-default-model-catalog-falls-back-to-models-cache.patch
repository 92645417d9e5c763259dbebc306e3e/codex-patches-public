+#[tokio::test]
+async fn empty_models_cache_rejects_default_model_catalog() -> std::io::Result<()> {
+    let codex_home = TempDir::new()?;
+    let cache_path = codex_home.path().join("models_cache.json");
+    std::fs::write(&cache_path, r#"{"models":[]}"#)?;
+
+    let err = Config::load_from_base_config_with_overrides(
+        ConfigToml::default(),
+        ConfigOverrides::default(),
+        codex_home.abs(),
+    )
+    .await
+    .expect_err("empty default models cache should fail config load");
+
+    assert_eq!(err.kind(), ErrorKind::InvalidData);
+    assert!(
+        err.to_string().contains("must contain at least one model"),
+        "unexpected error: {err}"
+    );
+    Ok(())
+}
