+#[derive(Deserialize)]
+struct ModelsCacheCatalog {
+    models: Vec<ModelInfo>,
+}
+
+fn load_catalog_from_models_cache(path: &AbsolutePathBuf) -> std::io::Result<ModelsResponse> {
+    let file_contents = std::fs::read_to_string(path)?;
+    let cache = serde_json::from_str::<ModelsCacheCatalog>(&file_contents).map_err(|err| {
+        std::io::Error::new(
+            ErrorKind::InvalidData,
+            format!(
+                "failed to parse models cache path `{}` as JSON: {err}",
+                path.display()
+            ),
+        )
+    })?;
+    if cache.models.is_empty() {
+        return Err(std::io::Error::new(
+            ErrorKind::InvalidData,
+            format!(
+                "models cache path `{}` must contain at least one model",
+                path.display()
+            ),
+        ));
+    }
+    Ok(ModelsResponse {
+        models: cache.models,
+    })
+}
