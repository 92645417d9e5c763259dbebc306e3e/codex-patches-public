+fn guarded_tool_path_span(text: String) -> Span<'static> {
+    text.green()
+}
+
+fn unknown_run_command_line(cmd: String) -> (&'static str, Vec<Span<'static>>) {
+    ("Run", styled_unknown_run_command_spans(&cmd))
+}
+
+fn parsed_run_command_line(parsed: &ParsedCommand) -> (&'static str, Vec<Span<'static>>) {
+    match parsed {
+        ParsedCommand::Read { cmd, name, .. } => {
+            ("Run", styled_parsed_run_command_spans(cmd, &[name]))
+        }
+        ParsedCommand::ListFiles {
+            cmd,
+            path: Some(path),
+            ..
+        }
+        | ParsedCommand::Search {
+            cmd,
+            path: Some(path),
+            ..
+        } => ("Run", styled_parsed_run_command_spans(cmd, &[path])),
+        ParsedCommand::ListFiles {
+            cmd, path: None, ..
+        }
+        | ParsedCommand::Search {
+            cmd, path: None, ..
+        } => ("Run", styled_parsed_run_command_spans(cmd, &[])),
+        ParsedCommand::Unknown { cmd } => unknown_run_command_line(cmd.clone()),
+    }
+}
+
+fn styled_unknown_run_command_spans(cmd: &str) -> Vec<Span<'static>> {
+    let Some(tokens) = shlex::split(cmd) else {
+        return vec![cmd.to_string().into()];
+    };
+    if tokens.is_empty() {
+        return vec![cmd.to_string().into()];
+    }
+
+    tokens
+        .iter()
+        .enumerate()
+        .flat_map(|(index, token)| {
+            let mut spans: Vec<Span<'static>> = Vec::new();
+            if index > 0 {
+                spans.push(" ".into());
+            }
+            if index == 0 {
+                spans.push(token.clone().into());
+            } else {
+                spans.push(token.clone().dim());
+            }
+            spans
+        })
+        .collect()
+}
+
+fn styled_parsed_run_command_spans(cmd: &str, parsed_path_names: &[&str]) -> Vec<Span<'static>> {
+    let Some(tokens) = shlex::split(cmd) else {
+        return vec![cmd.to_string().into()];
+    };
+    if tokens.is_empty() {
+        return vec![cmd.to_string().into()];
+    }
+
+    let mut spans = Vec::new();
+    let mut parsed_path_seen = false;
+    for (index, token) in tokens.iter().enumerate() {
+        if parsed_path_seen
+            && !parsed_path_names.is_empty()
+            && run_token_looks_like_path_operand(token)
+        {
+            continue;
+        }
+        if index > 0 {
+            spans.push(" ".into());
+        }
+        let matches_parsed_path = parsed_path_names
+            .iter()
+            .any(|name| run_token_matches_path_name(token, name));
+        let span = if index == 0 {
+            token.clone().into()
+        } else if matches_parsed_path {
+            parsed_path_seen = true;
+            display_run_path_token(token).fg(RUN_PATH_COLOR)
+        } else {
+            token.clone().dim()
+        };
+        spans.push(span);
+    }
+    spans
+}
+
+fn run_token_matches_path_name(token: &str, name: &str) -> bool {
+    let unquoted = token.trim_matches(['"', '\'']);
+    unquoted == name || display_run_path_token(unquoted) == name
+}
+
+fn display_run_path_token(token: &str) -> String {
+    let unquoted = token.trim_matches(['"', '\'']);
+    let Some(name) = unquoted
+        .rsplit(['/', '\\'])
+        .next()
+        .filter(|name| !name.is_empty())
+    else {
+        return token.to_string();
+    };
+    name.to_string()
+}
+
+fn run_token_looks_like_path_operand(token: &str) -> bool {
+    let unquoted = token.trim_matches(['"', '\'']);
+    !unquoted.starts_with('-') && unquoted.contains(['/', '\\'])
+}
