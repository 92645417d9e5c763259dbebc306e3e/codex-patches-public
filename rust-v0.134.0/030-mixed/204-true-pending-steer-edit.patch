+    for image_url in &message.remote_image_urls {
+        items.push(UserInput::Image {
+            detail: None,
+            url: image_url.clone(),
+        });
+    }
+    for image in &message.local_images {
+        items.push(UserInput::LocalImage {
+            detail: None,
+            path: image.path.clone(),
+        });
+    }
+    if !message.text.is_empty() {
+        items.push(UserInput::Text {
+            text: message.text.clone(),
+            text_elements: app_server_text_elements(&message.text_elements),
+        });
+    }
+    items
+}
