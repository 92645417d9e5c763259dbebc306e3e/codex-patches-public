+
+fn limit_pace_style(pace: i64) -> Style {
+    let color = if pace < -15 {
+        Color::Red
+    } else if pace < 0 {
+        CONTEXT_REMAINING_ORANGE
+    } else if pace <= 15 {
+        Color::Green
+    } else {
+        Color::Cyan
+    };
+    Style::default().fg(color).add_modifier(Modifier::BOLD)
+}
