+fn limit_metric_line_spans(line: &Line<'static>, base_style: Style) -> Option<Vec<Span<'static>>> {
+    let mut output = Vec::new();
+    let mut parsed_metric = false;
+
+    for span in &line.spans {
+        if span.style == Style::default()
+            && let Some(mut spans) = limit_metric_label_spans(span.content.as_ref(), base_style)
+        {
+            parsed_metric = true;
+            output.append(&mut spans);
+        } else {
+            output.push(span.clone());
+        }
+    }
+
+    parsed_metric.then_some(output)
+}
+
+fn limit_metric_label_spans(text: &str, base_style: Style) -> Option<Vec<Span<'static>>> {
+    let mut spans = Vec::new();
+    let mut label_parts = Vec::new();
+    let mut saw_metric = false;
+
+    for part in text.split_whitespace() {
+        if let Some(percent) = parse_percent(part) {
+            saw_metric = true;
+            if !spans.is_empty() {
+                spans.push(" ".into());
+            }
+            spans.push(Span::styled(
+                format!("{percent}%"),
+                context_remaining_percent_style(percent),
+            ));
+        } else if let Some(pace) = parse_pace_percent(part) {
+            saw_metric = true;
+            if !spans.is_empty() {
+                spans.push(" ".into());
+            }
+            spans.push(Span::styled(format!("{pace:+}%"), limit_pace_style(pace)));
+        } else if saw_metric {
+            return None;
+        } else {
+            label_parts.push(part);
+        }
+    }
+
+    if !saw_metric || label_parts.is_empty() {
+        return None;
+    }
+
+    let label = label_parts.join(" ");
+    spans.insert(0, Span::styled(format!("{label} "), base_style));
+    Some(spans)
+}
+
+fn parse_percent(text: &str) -> Option<i64> {
+    if matches!(text.as_bytes().first(), Some(b'+' | b'-')) {
+        return None;
+    }
+    let percent = text.strip_suffix('%')?.parse::<i64>().ok()?;
+    Some(percent.clamp(0, 100))
+}
+
+fn parse_pace_percent(text: &str) -> Option<i64> {
+    if !matches!(text.as_bytes().first(), Some(b'+' | b'-')) {
+        return None;
+    }
+    text.strip_suffix('%')?.parse::<i64>().ok()
 }
 
