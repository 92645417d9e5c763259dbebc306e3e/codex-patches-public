diff --git a/codex-rs/tui/src/chatwidget/model_shortcuts.rs b/codex-rs/tui/src/chatwidget/model_shortcuts.rs
new file mode 100644
index 0000000000..3e2ed53b3e
--- /dev/null
+++ b/codex-rs/tui/src/chatwidget/model_shortcuts.rs
@@ -0,0 +1,79 @@
+//! Keyboard shortcuts for stepping through model picker choices.
+
+use codex_protocol::openai_models::ModelPreset;
+use crossterm::event::KeyEvent;
+
+use super::ChatWidget;
+use crate::key_hint::KeyBindingListExt;
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+enum ModelShortcutDirection {
+    Previous,
+    Next,
+}
+
+impl ChatWidget {
+    pub(super) fn handle_model_shortcut(&mut self, key_event: KeyEvent) -> bool {
+        let direction = if self.chat_keymap.previous_model.is_pressed(key_event) {
+            ModelShortcutDirection::Previous
+        } else if self.chat_keymap.next_model.is_pressed(key_event) {
+            ModelShortcutDirection::Next
+        } else {
+            return false;
+        };
+
+        if !self.bottom_pane.no_modal_or_popup_active() {
+            return false;
+        }
+
+        if !self.is_session_configured() {
+            return true;
+        }
+
+        let choices = self.model_shortcut_choices();
+        let Some(next_preset) = next_model_preset(&choices, self.current_model(), direction) else {
+            return true;
+        };
+
+        self.apply_model_and_effort(
+            next_preset.model,
+            Some(next_preset.default_reasoning_effort),
+        );
+
+        true
+    }
+
+    fn model_shortcut_choices(&self) -> Vec<ModelPreset> {
+        let presets = match self.model_catalog.try_list_models() {
+            Ok(presets) => presets,
+            Err(err) => match err {},
+        };
+        let (mut auto_presets, other_presets): (Vec<ModelPreset>, Vec<ModelPreset>) = presets
+            .into_iter()
+            .filter(|preset| preset.show_in_picker)
+            .partition(|preset| Self::is_auto_model(&preset.model));
+        auto_presets.sort_by_key(|preset| Self::auto_model_order(&preset.model));
+        auto_presets.into_iter().chain(other_presets).collect()
+    }
+}
+
+fn next_model_preset(
+    choices: &[ModelPreset],
+    current_model: &str,
+    direction: ModelShortcutDirection,
+) -> Option<ModelPreset> {
+    if choices.is_empty() {
+        return None;
+    }
+
+    let current_idx = choices
+        .iter()
+        .position(|preset| preset.model.as_str() == current_model);
+    let next_idx = match (direction, current_idx) {
+        (ModelShortcutDirection::Previous, Some(0) | None) => choices.len() - 1,
+        (ModelShortcutDirection::Previous, Some(idx)) => idx - 1,
+        (ModelShortcutDirection::Next, Some(idx)) => (idx + 1) % choices.len(),
+        (ModelShortcutDirection::Next, None) => 0,
+    };
+    choices.get(next_idx).cloned()
+}
