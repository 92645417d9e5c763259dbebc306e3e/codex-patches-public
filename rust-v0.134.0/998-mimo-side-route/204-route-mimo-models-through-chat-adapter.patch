+        !value.eq_ignore_ascii_case("none") && value != SERVICE_TIER_DEFAULT_REQUEST_VALUE
+    })
+}
+
+pub(crate) fn deserialize_optional_tool_string<'de, D>(
+    deserializer: D,
+) -> std::result::Result<Option<String>, D::Error>
+where
+    D: serde::Deserializer<'de>,
+{
+    Ok(normalize_optional_tool_string(
+        Option::<String>::deserialize(deserializer)?,
+    ))
+}
+
+pub(crate) fn deserialize_optional_reasoning_effort<'de, D>(
+    deserializer: D,
+) -> std::result::Result<Option<ReasoningEffort>, D::Error>
+where
+    D: serde::Deserializer<'de>,
+{
+    let Some(value) = normalize_optional_tool_string(Option::<String>::deserialize(deserializer)?)
+    else {
+        return Ok(None);
+    };
+    value.parse().map(Some).map_err(serde::de::Error::custom)
+}
