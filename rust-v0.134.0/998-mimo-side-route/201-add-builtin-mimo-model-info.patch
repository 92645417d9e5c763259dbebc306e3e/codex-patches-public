+pub fn with_deepseek_side_route_models(mut models: Vec<ModelInfo>) -> Vec<ModelInfo> {
+    models.retain(|model| !model_info::is_obsolete_side_route_model(&model.slug));
+    for model in model_info::side_route_models() {
+        if let Some(existing_index) = models
+            .iter()
+            .position(|existing| existing.slug == model.slug)
+        {
+            models[existing_index] = model;
+        } else {
+            models.push(model);
+        }
+    }
+    models
+}
