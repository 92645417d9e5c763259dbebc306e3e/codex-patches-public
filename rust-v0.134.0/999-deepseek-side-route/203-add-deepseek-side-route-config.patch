+use std::fs;
+use std::path::Path;
+use std::sync::Arc;
+use std::time::Duration;
+
+use codex_api::AuthProvider;
+use codex_api::Provider;
+use codex_api::RetryConfig;
+use codex_model_provider::BearerAuthProvider;
+use codex_protocol::error::CodexErr;
+use codex_protocol::error::EnvVarError;
+use codex_protocol::error::Result;
+
+pub(crate) const DEEPSEEK_MODEL: &str = "deepseek-v4";
+pub(crate) const DEEPSEEK_PRO_API_MODEL: &str = "deepseek-v4-pro";
+pub(crate) const DEEPSEEK_FLASH_API_MODEL: &str = "deepseek-v4-flash";
+
+const API_KEY_FILE: &str = "deepseek.toml";
+const API_KEY_PLACEHOLDER: &str = "sk-dummy";
+const API_KEY_FIELD: &str = "api_key";
+const BASE_URL_FIELD: &str = "base_url";
+const DEFAULT_BASE_URL: &str = "https://api.deepseek.com/v1";
+const EXAMPLE_API_KEY_FILE: &str = concat!(
+    "# DeepSeek side-route credentials for Codex.\n",
+    "api_key = \"sk-dummy\"\n",
+    "base_url = \"https://api.deepseek.com/v1\"\n",
+);
+
+pub(crate) fn is_deepseek_model(model: &str) -> bool {
+    model == DEEPSEEK_MODEL
+}
+
+pub(crate) fn ensure_api_key_file(codex_home: &Path) {
+    let path = codex_home.join(API_KEY_FILE);
+    if path.exists() {
+        return;
+    }
+    if fs::create_dir_all(codex_home).is_ok() {
+        let _ = fs::write(path, EXAMPLE_API_KEY_FILE);
+    }
+}
+
+pub(crate) fn provider_and_auth(codex_home: &Path) -> Result<(Provider, Arc<dyn AuthProvider>)> {
+    ensure_api_key_file(codex_home);
+    let api_key = read_api_key(codex_home)?;
+    let provider = Provider {
+        name: "DeepSeek".to_string(),
+        base_url: read_base_url(codex_home)?,
+        query_params: None,
+        headers: Default::default(),
+        retry: RetryConfig {
+            max_attempts: 3,
+            base_delay: Duration::from_millis(200),
+            retry_429: true,
+            retry_5xx: true,
+            retry_transport: true,
+        },
+        stream_idle_timeout: Duration::from_millis(300_000),
+    };
+    Ok((provider, Arc::new(BearerAuthProvider::new(api_key))))
+}
+
+fn read_api_key(codex_home: &Path) -> Result<String> {
+    let path = codex_home.join(API_KEY_FILE);
+    let contents = fs::read_to_string(&path)?;
+    let Some(api_key) = parse_field(&contents, API_KEY_FIELD) else {
+        return Err(missing_api_key_error(&path));
+    };
+    if api_key.is_empty() || api_key == API_KEY_PLACEHOLDER {
+        return Err(missing_api_key_error(&path));
+    }
+    Ok(api_key)
+}
+
+fn read_base_url(codex_home: &Path) -> Result<String> {
+    let path = codex_home.join(API_KEY_FILE);
+    let contents = match fs::read_to_string(&path) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => {
+            return Ok(DEFAULT_BASE_URL.to_string());
+        }
+        Err(err) => return Err(err.into()),
+    };
+    Ok(parse_field(&contents, BASE_URL_FIELD)
+        .filter(|base_url| !base_url.is_empty())
+        .unwrap_or_else(|| DEFAULT_BASE_URL.to_string()))
+}
+
+fn parse_field(contents: &str, field: &str) -> Option<String> {
+    contents.lines().find_map(|line| {
+        let line = line.trim();
+        if line.is_empty() || line.starts_with('#') {
+            return None;
+        }
+        let (key, value) = line.split_once('=')?;
+        if key.trim() != field {
+            return None;
+        }
+        Some(
+            value
+                .trim()
+                .trim_matches('"')
+                .trim_matches('\'')
+                .to_string(),
+        )
+    })
+}
+
+fn missing_api_key_error(path: &Path) -> CodexErr {
+    CodexErr::EnvVar(EnvVarError {
+        var: path.display().to_string(),
+        instructions: Some(format!(
+            "Fill `{API_KEY_FIELD}` in this file with a DeepSeek API key before selecting `{DEEPSEEK_MODEL}`."
+        )),
+    })
+}
