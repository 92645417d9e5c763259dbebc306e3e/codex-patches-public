+    pub(super) fn refresh_deepseek_balance(
+        &mut self,
+        origin: RateLimitRefreshOrigin,
+        retry_until_loaded: bool,
+    ) {
+        if retry_until_loaded && self.deepseek_balance_loaded {
+            return;
+        }
+
+        let stale_refresh = matches!(origin, RateLimitRefreshOrigin::StartupPrefetch);
+        if stale_refresh {
+            if self.deepseek_balance_stale_refresh_in_flight {
+                return;
+            }
+            if self
+                .deepseek_balance_last_refresh_at
+                .is_some_and(|refreshed_at| {
+                    refreshed_at.elapsed() < DEEPSEEK_BALANCE_REFRESH_INTERVAL
+                })
+            {
+                return;
+            }
+            self.deepseek_balance_stale_refresh_in_flight = true;
+        }
+        self.deepseek_balance_last_refresh_at = Some(Instant::now());
+        let app_event_tx = self.app_event_tx.clone();
+        let codex_home = self.config.codex_home.clone();
+        tokio::spawn(async move {
+            let result =
+                crate::legacy_core::deepseek_side_route::fetch_balance_display(&codex_home)
+                    .await
+                    .map_err(|err| err.to_string());
+            app_event_tx.send(AppEvent::DeepSeekBalanceLoaded {
+                origin,
+                retry_until_loaded,
+                result,
+            });
+        });
+    }
+
