+async fn status_cache_survives_chat_widget_replacement() {
+    let (mut previous, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    previous.on_deepseek_balance(Some("DeepSeek $7.42".to_string()));
+    previous.on_rate_limit_snapshot(Some(RateLimitSnapshot {
+        limit_id: Some("codex".to_string()),
+        limit_name: Some("codex".to_string()),
+        primary: Some(RateLimitWindow {
+            used_percent: 20,
+            window_duration_mins: Some(300),
+            resets_at: None,
+        }),
+        secondary: None,
+        credits: None,
+        plan_type: Some(PlanType::Pro),
+        rate_limit_reached_type: None,
+    }));
+    previous.on_rate_limit_snapshot(Some(RateLimitSnapshot {
+        limit_id: Some("codex_other".to_string()),
+        limit_name: Some("spark".to_string()),
+        primary: Some(RateLimitWindow {
+            used_percent: 90,
+            window_duration_mins: Some(60),
+            resets_at: None,
+        }),
+        secondary: None,
+        credits: None,
+        plan_type: Some(PlanType::Pro),
+        rate_limit_reached_type: None,
+    }));
+
+    let (mut replacement, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    replacement.inherit_status_cache_from(&previous);
+
+    assert_eq!(
+        replacement.status_line_value_for_item(crate::bottom_pane::StatusLineItem::DeepSeekBalance),
+        Some("DeepSeek $7.42".to_string())
+    );
+    assert_eq!(
+        replacement
+            .rate_limit_snapshots_by_limit_id
+            .get("codex")
+            .and_then(|snapshot| snapshot.primary.as_ref())
+            .map(|window| window.used_percent),
+        Some(20.0)
+    );
+    assert_eq!(
+        replacement
+            .rate_limit_snapshots_by_limit_id
+            .get("codex_other")
+            .and_then(|snapshot| snapshot.primary.as_ref())
+            .map(|window| window.used_percent),
+        Some(90.0)
+    );
+    assert_eq!(replacement.plan_type, Some(PlanType::Pro));
+}
