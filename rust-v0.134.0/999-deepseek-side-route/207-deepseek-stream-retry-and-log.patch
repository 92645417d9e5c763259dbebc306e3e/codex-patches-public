+++ b/codex-rs/core/src/openai_v1_side_route.rs
@@ -0,0 +1,91 @@
+use std::time::Duration;
+
+use codex_protocol::error::CodexErr;
+
+use crate::deepseek_side_route;
+use crate::mimo_side_route;
+
+pub(crate) const STREAM_MAX_RETRIES: u64 = 5;
+pub(crate) const STREAM_RETRY_BUDGET: Duration = Duration::from_secs(5 * 60);
+const STREAM_RETRY_DELAY: Duration = Duration::from_secs(60);
+
+pub(crate) fn is_openai_v1_side_route_model(model: &str) -> bool {
+    deepseek_side_route::is_deepseek_model(model) || mimo_side_route::is_mimo_model(model)
+}
+
+pub(crate) fn retry_delay(elapsed: Duration) -> Option<Duration> {
+    if elapsed >= STREAM_RETRY_BUDGET {
+        None
+    } else {
+        Some(STREAM_RETRY_DELAY.min(STREAM_RETRY_BUDGET - elapsed))
+    }
+}
+
+pub(crate) fn is_retryable_stream_error(err: &CodexErr) -> bool {
+    match err {
+        CodexErr::Stream(message, _) => {
+            let message = message.to_ascii_lowercase();
+            message.contains("chat completions stream error")
+                || message.contains("idle timeout")
+                || message.contains("stream closed")
+                || message.contains("connection reset")
+                || message.contains("connection closed")
+                || message.contains("closed connection")
+                || message.contains("connection refused")
+                || message.contains("connection aborted")
+                || message.contains("unexpected eof")
+                || message.contains("tls handshake eof")
+                || message.contains("close_notify")
+                || message.contains("failed to write whole buffer")
+                || message.contains("timed out")
+                || message.contains("timeout")
+                || message.contains("network error")
+                || message.contains("dns error")
+                || message.contains("failed to lookup")
+                || message.contains("name resolution")
+                || message.contains("temporary failure in name resolution")
+        }
+        CodexErr::Timeout | CodexErr::RequestTimeout | CodexErr::Io(_) => true,
+        _ => false,
+    }
+}
+
+pub(crate) fn log_event_for_model(model: &str, codex_home: &std::path::Path, message: String) {
+    if deepseek_side_route::is_deepseek_model(model) {
+        deepseek_side_route::log_event(codex_home, message);
+    } else if mimo_side_route::is_mimo_model(model) {
+        mimo_side_route::log_event(codex_home, message);
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn retry_delay_stays_inside_budget() {
+        assert_eq!(retry_delay(Duration::ZERO), Some(STREAM_RETRY_DELAY));
+        assert_eq!(
+            retry_delay(STREAM_RETRY_BUDGET - Duration::from_secs(1)),
+            Some(Duration::from_secs(1))
+        );
+        assert_eq!(retry_delay(STREAM_RETRY_BUDGET), None);
+    }
+
+    #[test]
+    fn classifies_openai_v1_stream_errors() {
+        assert!(is_retryable_stream_error(&CodexErr::Stream(
+            "Chat completions stream error code=434 type=server_error: upstream failed".to_string(),
+            None,
+        )));
+        assert!(is_retryable_stream_error(&CodexErr::Stream(
+            "stream disconnected before completion: Transport error: network error: error decoding response body".to_string(),
+            None,
+        )));
+        assert!(is_retryable_stream_error(&CodexErr::RequestTimeout));
+        assert!(!is_retryable_stream_error(&CodexErr::TurnAborted));
+        assert!(!is_retryable_stream_error(&CodexErr::InvalidRequest(
+            "Chat completions stream error type=authentication_error: invalid api key".to_string(),
+        )));
+    }
+}
