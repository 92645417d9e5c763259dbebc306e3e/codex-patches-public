+struct MultiAgentV1PlainFunctionOverride {
+    handler: Arc<dyn CoreToolRuntime>,
+}
+
+#[async_trait::async_trait]
+impl ToolExecutor<ToolInvocation> for MultiAgentV1PlainFunctionOverride {
+    fn tool_name(&self) -> ToolName {
+        ToolName::plain(self.handler.tool_name().name)
+    }
+
+    fn spec(&self) -> ToolSpec {
+        match self.handler.spec() {
+            ToolSpec::Namespace(namespace) => {
+                let tool_name = self.handler.tool_name().name;
+                namespace
+                    .tools
+                    .into_iter()
+                    .find_map(|tool| match tool {
+                        ResponsesApiNamespaceTool::Function(tool) if tool.name == tool_name => {
+                            Some(ToolSpec::Function(tool))
+                        }
+                        ResponsesApiNamespaceTool::Function(_) => None,
+                    })
+                    .unwrap_or_else(|| {
+                        ToolSpec::Namespace(ResponsesApiNamespace {
+                            name: namespace.name,
+                            description: namespace.description,
+                            tools: Vec::new(),
+                        })
+                    })
+            }
+            spec => spec,
+        }
+    }
+
+    fn exposure(&self) -> ToolExposure {
+        self.handler.exposure()
+    }
+
+    fn supports_parallel_tool_calls(&self) -> bool {
+        self.handler.supports_parallel_tool_calls()
+    }
+
+    async fn handle(
+        &self,
+        invocation: ToolInvocation,
+    ) -> Result<Box<dyn ToolOutput>, codex_tools::FunctionCallError> {
+        self.handler.handle(invocation).await
+    }
+}
+
+impl CoreToolRuntime for MultiAgentV1PlainFunctionOverride {
+    fn matches_kind(&self, payload: &crate::tools::context::ToolPayload) -> bool {
+        self.handler.matches_kind(payload)
+    }
+
+    fn search_info(&self) -> Option<crate::tools::tool_search_entry::ToolSearchInfo> {
+        self.handler.search_info()
+    }
+
+    fn create_diff_consumer(
+        &self,
+    ) -> Option<Box<dyn crate::tools::registry::ToolArgumentDiffConsumer>> {
+        self.handler.create_diff_consumer()
+    }
+}
