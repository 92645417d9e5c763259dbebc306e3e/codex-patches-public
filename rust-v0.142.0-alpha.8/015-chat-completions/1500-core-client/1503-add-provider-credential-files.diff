+use std::fs;
+use std::path::Path;
+use std::sync::Arc;
+use std::time::Duration;
+
+use codex_api::AuthProvider;
+use codex_api::Provider;
+use codex_api::RetryConfig;
+use codex_model_provider::BearerAuthProvider;
+use codex_protocol::error::CodexErr;
+use codex_protocol::error::EnvVarError;
+use codex_protocol::error::Result;
+use codex_protocol::openai_models::ModelInfo;
+use codex_protocol::openai_models::ReasoningEffort;
+use serde::Deserialize;
+
+pub(crate) const CHAT_COMPLETIONS_ENDPOINT: &str = "/chat/completions";
+pub(crate) const CONFIG_DIR: &str = "chat-completions";
+const API_KEY_PLACEHOLDER: &str = "sk-dummy";
+const STREAM_MAX_RETRIES: u64 = 5;
+pub(crate) const STREAM_IDLE_TIMEOUT: Duration = Duration::from_secs(60);
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub(crate) enum ProviderId {
+    Mimo,
+    DeepSeek,
+}
+
+impl ProviderId {
+    fn file_name(self) -> &'static str {
+        match self {
+            ProviderId::Mimo => "mimo.toml",
+            ProviderId::DeepSeek => "deepseek.toml",
+        }
+    }
+
+    fn display_name(self) -> &'static str {
+        match self {
+            ProviderId::Mimo => "MiMo",
+            ProviderId::DeepSeek => "DeepSeek",
+        }
+    }
+
+    fn default_base_url(self) -> &'static str {
+        match self {
+            ProviderId::Mimo => "https://api.xiaomimimo.com/v1",
+            ProviderId::DeepSeek => "https://api.deepseek.com/v1",
+        }
+    }
+}
+
+pub(crate) fn provider_for_model(model: &str) -> Option<ProviderId> {
+    match model {
+        "mimo-v2.5" => Some(ProviderId::Mimo),
+        "deepseek-v4" => Some(ProviderId::DeepSeek),
+        _ => None,
+    }
+}
+
+pub(crate) fn is_model(model: &str) -> bool {
+    provider_for_model(model).is_some()
+}
+
+pub(crate) fn api_model_slug(model: &ModelInfo, effort: Option<ReasoningEffort>) -> String {
+    let Some(provider) = provider_for_model(&model.slug) else {
+        return model.slug.clone();
+    };
+    match provider {
+        ProviderId::Mimo => match effort.or_else(|| model.default_reasoning_level.clone()) {
+            Some(ReasoningEffort::Low | ReasoningEffort::Medium) | None => "mimo-v2.5",
+            Some(
+                ReasoningEffort::None
+                | ReasoningEffort::Minimal
+                | ReasoningEffort::High
+                | ReasoningEffort::XHigh
+                | ReasoningEffort::Custom(_),
+            ) => "mimo-v2.5-pro",
+        },
+        ProviderId::DeepSeek => match effort.or_else(|| model.default_reasoning_level.clone()) {
+            Some(ReasoningEffort::Low | ReasoningEffort::Medium) | None => "deepseek-v4-flash",
+            Some(
+                ReasoningEffort::None
+                | ReasoningEffort::Minimal
+                | ReasoningEffort::High
+                | ReasoningEffort::XHigh
+                | ReasoningEffort::Custom(_),
+            ) => "deepseek-v4-pro",
+        },
+    }
+    .to_string()
+}
+
+pub(crate) fn provider_and_auth(
+    codex_home: &Path,
+    provider_id: ProviderId,
+) -> Result<(Provider, Arc<dyn AuthProvider>)> {
+    let config = read_provider_config(codex_home, provider_id)?;
+    let provider = Provider {
+        name: provider_id.display_name().to_string(),
+        base_url: config
+            .base_url
+            .clone()
+            .unwrap_or_else(|| provider_id.default_base_url().to_string()),
+        query_params: None,
+        headers: Default::default(),
+        retry: RetryConfig {
+            max_attempts: STREAM_MAX_RETRIES,
+            base_delay: Duration::from_millis(200),
+            retry_429: true,
+            retry_5xx: true,
+            retry_transport: true,
+        },
+        stream_idle_timeout: STREAM_IDLE_TIMEOUT,
+    };
+    Ok((provider, Arc::new(BearerAuthProvider::new(config.api_key))))
+}
+
+pub(crate) fn compaction_disabled_error(model: &str) -> CodexErr {
+    CodexErr::UnsupportedOperation(format!(
+        "automatic compaction is disabled for OpenAI-compatible Chat Completions model {model}; switch to a non-Chat Completions model, start a new thread, or split the task"
+    ))
+}
+
+#[derive(Clone, Debug)]
+struct ProviderConfig {
+    api_key: String,
+    base_url: Option<String>,
+}
+
+#[derive(Debug, Deserialize)]
+struct RawProviderConfig {
+    api_key: Option<String>,
+    base_url: Option<String>,
+}
+
+pub(crate) fn ensure_config_files(codex_home: &Path) {
+    let dir = codex_home.join(CONFIG_DIR);
+    if fs::create_dir_all(&dir).is_err() {
+        return;
+    }
+    for provider_id in [ProviderId::Mimo, ProviderId::DeepSeek] {
+        let path = provider_config_path(codex_home, provider_id);
+        if !path.exists() {
+            let _ = fs::write(path, default_provider_config(provider_id));
+        }
+    }
+}
+
+fn read_provider_config(codex_home: &Path, provider_id: ProviderId) -> Result<ProviderConfig> {
+    let path = provider_config_path(codex_home, provider_id);
+    let contents = fs::read_to_string(&path)?;
+    let raw = toml::from_str::<RawProviderConfig>(&contents).map_err(|err| {
+        CodexErr::UnsupportedOperation(format!("failed to parse {}: {err}", path.display()))
+    })?;
+    let Some(api_key) = raw
+        .api_key
+        .filter(|value| !value.is_empty() && value != API_KEY_PLACEHOLDER)
+    else {
+        return Err(missing_api_key_error(&path, provider_id));
+    };
+    Ok(ProviderConfig {
+        api_key,
+        base_url: raw.base_url.filter(|value| !value.is_empty()),
+    })
+}
+
+fn provider_config_path(codex_home: &Path, provider_id: ProviderId) -> std::path::PathBuf {
+    codex_home.join(CONFIG_DIR).join(provider_id.file_name())
+}
+
+fn default_provider_config(provider_id: ProviderId) -> String {
+    format!(
+        "api_key = \"{}\"\nbase_url = \"{}\"\n",
+        API_KEY_PLACEHOLDER,
+        provider_id.default_base_url()
+    )
+}
+
+fn missing_api_key_error(path: &Path, provider_id: ProviderId) -> CodexErr {
+    CodexErr::EnvVar(EnvVarError {
+        var: path.display().to_string(),
+        instructions: Some(format!(
+            "Fill `api_key` in {} before selecting a {} model.",
+            path.display(),
+            provider_id.display_name()
+        )),
+    })
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+
+    #[test]
+    fn creates_provider_config_files() {
+        let temp_home = tempfile::TempDir::new().expect("temp home");
+        ensure_config_files(temp_home.path());
+
+        assert_eq!(
+            fs::read_to_string(provider_config_path(temp_home.path(), ProviderId::Mimo))
+                .expect("read mimo config"),
+            "api_key = \"sk-dummy\"\nbase_url = \"https://api.xiaomimimo.com/v1\"\n"
+        );
+        assert_eq!(
+            fs::read_to_string(provider_config_path(temp_home.path(), ProviderId::DeepSeek))
+                .expect("read deepseek config"),
+            "api_key = \"sk-dummy\"\nbase_url = \"https://api.deepseek.com/v1\"\n"
+        );
+    }
+
+    #[test]
+    fn reads_provider_config_from_provider_file() {
+        let temp_home = tempfile::TempDir::new().expect("temp home");
+        fs::create_dir_all(temp_home.path().join(CONFIG_DIR)).expect("create config dir");
+        fs::write(
+            provider_config_path(temp_home.path(), ProviderId::Mimo),
+            r#"api_key = "mimo-key"
+base_url = "https://mimo.example/v1"
+"#,
+        )
+        .expect("write mimo config");
+        fs::write(
+            provider_config_path(temp_home.path(), ProviderId::DeepSeek),
+            r#"api_key = "deepseek-key"
+"#,
+        )
+        .expect("write deepseek config");
+        let mimo = read_provider_config(temp_home.path(), ProviderId::Mimo).expect("mimo config");
+        let deepseek =
+            read_provider_config(temp_home.path(), ProviderId::DeepSeek).expect("deepseek config");
+
+        assert_eq!(mimo.api_key, "mimo-key");
+        assert_eq!(mimo.base_url.as_deref(), Some("https://mimo.example/v1"));
+        assert_eq!(deepseek.api_key, "deepseek-key");
+        assert_eq!(deepseek.base_url, None);
+    }
+}
