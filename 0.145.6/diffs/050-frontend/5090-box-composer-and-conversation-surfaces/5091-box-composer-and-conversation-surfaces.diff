+#[test]
+fn finalized_agent_surfaces_use_channel_colored_rules() {
+    let commentary = AgentMarkdownCell::new_with_channel(
+        "Commentary".to_string(),
+        Path::new("/tmp"),
+        AgentMessageChannel::Commentary,
+    )
+    .display_lines(20);
+    let final_answer = AgentMarkdownCell::new_with_channel(
+        "Final".to_string(),
+        Path::new("/tmp"),
+        AgentMessageChannel::FinalAnswer,
+    )
+    .display_lines(20);
+
+    assert_eq!(commentary.len(), 3);
+    assert_eq!(commentary[0].spans[0].style.fg, Some(Color::Cyan));
+    assert_eq!(commentary[2].spans[0].style.fg, Some(Color::Cyan));
+    assert_eq!(commentary[1].to_string(), " Commentary");
+    assert_eq!(final_answer[0].spans[0].style.fg, Some(Color::Green));
+    assert_eq!(final_answer[2].spans[0].style.fg, Some(Color::Green));
+}
+
+#[test]
+fn streamed_agent_surface_closes_only_in_the_mutable_tail() {
+    let stable = AgentMessageCell::new_hyperlink_lines_with_channel(
+        plain_hyperlink_lines(vec![Line::from("stable")]),
+        /*is_first_line*/ true,
+        AgentMessageChannel::Commentary,
+    )
+    .display_lines(20);
+    let tail = StreamingAgentTailCell::new_with_channel(
+        plain_hyperlink_lines(vec![Line::from("tail")]),
+        /*is_first_line*/ false,
+        AgentMessageChannel::Commentary,
+    )
+    .display_lines(20);
+
+    assert_eq!(stable.len(), 2);
+    assert_eq!(stable[0].spans[0].style.fg, Some(Color::Cyan));
+    assert_eq!(stable[1].to_string(), " stable");
+    assert_eq!(tail.len(), 2);
+    assert_eq!(tail[0].to_string(), " tail");
+    assert_eq!(tail[0].style.bg, None);
+    assert_eq!(tail[1].spans[0].style.fg, Some(Color::Cyan));
+}
+
+#[test]
+fn user_surface_uses_yellow_rules_without_a_prompt_marker() {
+    let cell = UserHistoryCell {
+        message: "question".to_string(),
+        text_elements: Vec::new(),
+        local_image_paths: Vec::new(),
+        remote_image_urls: Vec::new(),
+        persisted_prompt: OnceLock::new(),
+    };
+    let lines = cell.display_lines(20);
