--- /dev/null
+++ b/codex-rs/tui/src/codex_socket.rs
@@ -0,0 +1,485 @@
+//! Transport for optional CXU helper integrations.
+//!
+//! The helper is deliberately optional. Notifications must never delay the TUI, while editor
+//! requests may wait for the helper because the caller can fall back to the configured editor.
+
+use serde::Deserialize;
+use serde::Serialize;
+use std::path::Path;
+use std::path::PathBuf;
+use std::time::Duration;
+use thiserror::Error;
+
+#[cfg(unix)]
+use std::io::Read;
+#[cfg(unix)]
+use std::io::Write;
+#[cfg(unix)]
+use std::os::unix::net::UnixStream;
+
+const SOCKET_IO_TIMEOUT: Duration = Duration::from_millis(500);
+const CXU_RUNTIME_EPHEMERAL_ROOT_ENV: &str = "RUNTIME_EPHEMERAL_ROOT";
+const CXU_RUNTIME_ROOT_NAME: &str = "cxu";
+const CODEX_SOCKET_NAME: &str = "codex.sock";
+const CXU_EDITOR_DISABLED_ERROR: &str = "helper editor disabled";
+
+/// A helper completion event. CXU consumes this exact JSON schema.
+#[derive(Clone, Debug, PartialEq, Eq, Serialize)]
+pub(crate) struct CompletionRequest {
+    #[serde(rename = "Type")]
+    kind: &'static str,
+    #[serde(rename = "Source")]
+    source: &'static str,
+    #[serde(rename = "SessionID")]
+    pub(crate) session_id: String,
+    #[serde(rename = "TurnID")]
+    pub(crate) turn_id: u64,
+    #[serde(rename = "Status")]
+    pub(crate) status: String,
+    #[serde(rename = "DurationMS")]
+    pub(crate) duration_ms: u64,
+    #[serde(rename = "WorkingDir")]
+    pub(crate) working_dir: String,
+    #[serde(rename = "Title")]
+    pub(crate) title: String,
+    #[serde(rename = "Body")]
+    pub(crate) body: String,
+    #[serde(rename = "CreatedAt")]
+    pub(crate) created_at: String,
+}
+
+impl CompletionRequest {
+    #[allow(clippy::too_many_arguments)]
+    pub(crate) fn new(
+        session_id: String,
+        turn_id: u64,
+        status: String,
+        duration_ms: u64,
+        working_dir: String,
+        title: String,
+        body: String,
+        created_at: String,
+    ) -> Self {
+        Self {
+            kind: "Completion",
+            source: "codex",
+            session_id,
+            turn_id,
+            status,
+            duration_ms,
+            working_dir,
+            title,
+            body,
+            created_at,
+        }
+    }
+}
+
+#[derive(Clone, Debug, PartialEq, Eq, Serialize)]
+struct EditorRequest {
+    #[serde(rename = "Type")]
+    kind: &'static str,
+    #[serde(rename = "Source")]
+    source: &'static str,
+    #[serde(rename = "SessionID", skip_serializing_if = "Option::is_none")]
+    session_id: Option<String>,
+    #[serde(rename = "Seed")]
+    seed: String,
+}
+
+impl EditorRequest {
+    fn new(seed: &str, session_id: Option<&str>) -> Self {
+        Self {
+            kind: "Editor",
+            source: "codex",
+            session_id: session_id.map(ToOwned::to_owned),
+            seed: seed.to_string(),
+        }
+    }
+}
+
+/// The result of asking CXU to edit the current composer content.
+///
+/// `Unavailable`, `Disabled`, and `Empty` all permit the caller to use its normal editor
+/// fallback. Only an unexpected transport or protocol failure is returned as an error.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub(crate) enum HelperEditorResult {
+    Edited(String),
+    Unavailable,
+    Disabled,
+    Empty,
+}
+
+#[derive(Debug, Error)]
+pub(crate) enum HelperSocketError {
+    #[error("failed to connect to codex helper socket: {0}")]
+    Connect(#[source] std::io::Error),
+    #[error("failed to configure codex helper socket: {0}")]
+    Configure(#[source] std::io::Error),
+    #[error("failed to serialize codex helper request: {0}")]
+    Serialize(#[source] serde_json::Error),
+    #[error("failed to write codex helper request: {0}")]
+    Write(#[source] std::io::Error),
+    #[error("failed to finish codex helper request: {0}")]
+    Shutdown(#[source] std::io::Error),
+    #[error("failed to read codex helper response: {0}")]
+    Read(#[source] std::io::Error),
+    #[error("invalid codex helper response: {0}")]
+    Deserialize(#[source] serde_json::Error),
+    #[error("codex helper returned an error: {0}")]
+    HelperResponse(String),
+    #[error("codex helper socket is unsupported on this platform")]
+    UnsupportedPlatform,
+    #[error("codex helper blocking task failed: {0}")]
+    Task(#[source] tokio::task::JoinError),
+}
+
+impl HelperSocketError {
+    fn is_unavailable(&self) -> bool {
+        match self {
+            Self::Connect(error) => matches!(
+                error.kind(),
+                std::io::ErrorKind::NotFound
+                    | std::io::ErrorKind::ConnectionRefused
+                    | std::io::ErrorKind::AddrNotAvailable
+            ),
+            Self::UnsupportedPlatform => true,
+            _ => false,
+        }
+    }
+}
+
+/// Notify CXU about a completion without delaying the TUI.
+///
+/// The blocking socket operation has a 500ms write and response-read limit. Failures are only
+/// logged because the helper may legitimately not be installed or running.
+pub(crate) fn notify_completion(request: CompletionRequest) {
+    std::mem::drop(tokio::task::spawn_blocking(move || {
+        if let Err(error) = send_notification_to_path(&request, &codex_socket_path()) {
+            tracing::debug!(%error, "codex helper completion socket notification skipped");
+        }
+    }));
+}
+
+/// Ask CXU to edit text, waiting for its response without the notification read deadline.
+pub(crate) async fn edit_with_helper(
+    seed: &str,
+    session_id: Option<&str>,
+) -> Result<HelperEditorResult, HelperSocketError> {
+    let request = EditorRequest::new(seed, session_id);
+    let response = tokio::task::spawn_blocking(move || {
+        send_payload_to_path_with_read_timeout(&request, &codex_socket_path(), None)
+    })
+    .await
+    .map_err(HelperSocketError::Task)?;
+
+    classify_editor_response(response)
+}
+
+fn classify_editor_response(
+    response: Result<CodexSocketResponse, HelperSocketError>,
+) -> Result<HelperEditorResult, HelperSocketError> {
+    match response {
+        Ok(response)
+            if !response.ok && response.error.as_deref() == Some(CXU_EDITOR_DISABLED_ERROR) =>
+        {
+            Ok(HelperEditorResult::Disabled)
+        }
+        Ok(response) => match response.into_success()?.content {
+            Some(content) if !content.is_empty() => Ok(HelperEditorResult::Edited(content)),
+            _ => Ok(HelperEditorResult::Empty),
+        },
+        Err(error) if error.is_unavailable() => Ok(HelperEditorResult::Unavailable),
+        Err(error) => Err(error),
+    }
+}
+
+fn codex_socket_path() -> PathBuf {
+    let root = std::env::var(CXU_RUNTIME_EPHEMERAL_ROOT_ENV)
+        .ok()
+        .filter(|value| !value.trim().is_empty())
+        .map(PathBuf::from)
+        .unwrap_or_else(|| std::env::temp_dir().join(CXU_RUNTIME_ROOT_NAME));
+    root.join(CODEX_SOCKET_NAME)
+}
+
+fn send_notification_to_path<T: Serialize>(
+    payload: &T,
+    path: &Path,
+) -> Result<(), HelperSocketError> {
+    send_payload_to_path_with_read_timeout(payload, path, Some(SOCKET_IO_TIMEOUT))?
+        .into_success()?;
+    Ok(())
+}
+
+fn send_payload_to_path_with_read_timeout<T: Serialize>(
+    payload: &T,
+    path: &Path,
+    read_timeout: Option<Duration>,
+) -> Result<CodexSocketResponse, HelperSocketError> {
+    send_payload_to_path_impl(payload, path, read_timeout)
+}
+
+#[cfg(unix)]
+fn send_payload_to_path_impl<T: Serialize>(
+    payload: &T,
+    path: &Path,
+    read_timeout: Option<Duration>,
+) -> Result<CodexSocketResponse, HelperSocketError> {
+    let mut stream = UnixStream::connect(path).map_err(HelperSocketError::Connect)?;
+    stream
+        .set_read_timeout(read_timeout)
+        .map_err(HelperSocketError::Configure)?;
+    stream
+        .set_write_timeout(Some(SOCKET_IO_TIMEOUT))
+        .map_err(HelperSocketError::Configure)?;
+
+    let request = serde_json::to_vec(payload).map_err(HelperSocketError::Serialize)?;
+    stream
+        .write_all(&request)
+        .map_err(HelperSocketError::Write)?;
+    stream
+        .shutdown(std::net::Shutdown::Write)
+        .map_err(HelperSocketError::Shutdown)?;
+
+    let mut response = String::new();
+    stream
+        .read_to_string(&mut response)
+        .map_err(HelperSocketError::Read)?;
+    serde_json::from_str(&response).map_err(HelperSocketError::Deserialize)
+}
+
+#[cfg(not(unix))]
+fn send_payload_to_path_impl<T: Serialize>(
+    _payload: &T,
+    _path: &Path,
+    _read_timeout: Option<Duration>,
+) -> Result<CodexSocketResponse, HelperSocketError> {
+    Err(HelperSocketError::UnsupportedPlatform)
+}
+
+#[derive(Debug, Deserialize)]
+struct CodexSocketResponse {
+    #[serde(rename = "OK")]
+    ok: bool,
+    #[serde(rename = "Error")]
+    error: Option<String>,
+    #[serde(rename = "Content")]
+    content: Option<String>,
+}
+
+impl CodexSocketResponse {
+    fn into_success(self) -> Result<Self, HelperSocketError> {
+        if self.ok {
+            return Ok(self);
+        }
+        let error = self
+            .error
+            .unwrap_or_else(|| "codex helper returned OK=false".to_string());
+        Err(HelperSocketError::HelperResponse(error))
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use serial_test::serial;
+
+    #[cfg(unix)]
+    use std::os::unix::net::UnixListener;
+    #[cfg(unix)]
+    use std::thread;
+    #[cfg(unix)]
+    use tempfile::TempDir;
+
+    fn completion_request() -> CompletionRequest {
+        CompletionRequest::new(
+            "123e4567-e89b-12d3-a456-426614174000".to_string(),
+            9,
+            "Completed".to_string(),
+            2_000,
+            "/repo".to_string(),
+            "Codex task finished".to_string(),
+            "Applied the requested patch.".to_string(),
+            "2026-06-12T10:11:12Z".to_string(),
+        )
+    }
+
+    #[test]
+    fn completion_request_serializes_helper_schema() {
+        let json = serde_json::to_value(completion_request()).expect("serialize");
+
+        assert_eq!(json["Type"], "Completion");
+        assert_eq!(json["Source"], "codex");
+        assert_eq!(json["SessionID"], "123e4567-e89b-12d3-a456-426614174000");
+        assert_eq!(json["TurnID"], 9);
+        assert_eq!(json["Status"], "Completed");
+        assert_eq!(json["DurationMS"], 2_000);
+        assert_eq!(json["WorkingDir"], "/repo");
+        assert_eq!(json["Title"], "Codex task finished");
+        assert_eq!(json["Body"], "Applied the requested patch.");
+        assert_eq!(json["CreatedAt"], "2026-06-12T10:11:12Z");
+    }
+
+    #[test]
+    fn editor_request_serializes_helper_schema() {
+        let json =
+            serde_json::to_value(EditorRequest::new("draft", Some("session"))).expect("serialize");
+
+        assert_eq!(json["Type"], "Editor");
+        assert_eq!(json["Source"], "codex");
+        assert_eq!(json["SessionID"], "session");
+        assert_eq!(json["Seed"], "draft");
+        assert!(json.get("Editor").is_none());
+        assert!(json.get("Display").is_none());
+    }
+
+    #[test]
+    #[serial]
+    fn socket_path_uses_system_temp_root_without_runtime_override() {
+        let previous = std::env::var_os(CXU_RUNTIME_EPHEMERAL_ROOT_ENV);
+        unsafe { std::env::remove_var(CXU_RUNTIME_EPHEMERAL_ROOT_ENV) };
+
+        let path = codex_socket_path();
+
+        restore_runtime_root(previous);
+        assert_eq!(
+            path,
+            std::env::temp_dir()
+                .join(CXU_RUNTIME_ROOT_NAME)
+                .join(CODEX_SOCKET_NAME)
+        );
+    }
+
+    #[test]
+    #[serial]
+    fn socket_path_uses_runtime_ephemeral_root_override() {
+        let previous = std::env::var_os(CXU_RUNTIME_EPHEMERAL_ROOT_ENV);
+        unsafe { std::env::set_var(CXU_RUNTIME_EPHEMERAL_ROOT_ENV, "/tmp/runtime-root") };
+
+        let path = codex_socket_path();
+
+        restore_runtime_root(previous);
+        assert_eq!(path, Path::new("/tmp/runtime-root").join(CODEX_SOCKET_NAME));
+    }
+
+    #[cfg(unix)]
+    #[test]
+    fn socket_request_reads_exact_response_envelope() {
+        let temp_dir = TempDir::new().expect("temp dir");
+        let socket_path = temp_dir.path().join(CODEX_SOCKET_NAME);
+        let listener = UnixListener::bind(&socket_path).expect("bind listener");
+        let handle = thread::spawn(move || {
+            let (mut stream, _) = listener.accept().expect("accept");
+            let mut request = String::new();
+            stream.read_to_string(&mut request).expect("read request");
+            assert!(request.contains("\"Type\":\"Completion\""));
+            stream
+                .write_all(br#"{"OK":true,"Content":"ignored"}"#)
+                .expect("write response");
+        });
+
+        send_notification_to_path(&completion_request(), &socket_path).expect("response");
+        handle.join().expect("server thread");
+    }
+
+    #[cfg(unix)]
+    #[test]
+    fn editor_request_waits_beyond_notification_read_timeout() {
+        let temp_dir = TempDir::new().expect("temp dir");
+        let socket_path = temp_dir.path().join(CODEX_SOCKET_NAME);
+        let listener = UnixListener::bind(&socket_path).expect("bind listener");
+        let handle = thread::spawn(move || {
+            let (mut stream, _) = listener.accept().expect("accept");
+            let mut request = String::new();
+            stream.read_to_string(&mut request).expect("read request");
+            assert!(request.contains("\"Type\":\"Editor\""));
+            thread::sleep(SOCKET_IO_TIMEOUT + Duration::from_millis(100));
+            stream
+                .write_all(br#"{"OK":true,"Content":"edited"}"#)
+                .expect("write response");
+        });
+
+        let response = send_payload_to_path_with_read_timeout(
+            &EditorRequest::new("draft", None),
+            &socket_path,
+            None,
+        )
+        .expect("response");
+
+        assert_eq!(
+            classify_editor_response(Ok(response)).expect("editor result"),
+            HelperEditorResult::Edited("edited".to_string())
+        );
+        handle.join().expect("server thread");
+    }
+
+    #[cfg(unix)]
+    #[test]
+    fn notification_response_read_times_out_after_500ms() {
+        let temp_dir = TempDir::new().expect("temp dir");
+        let socket_path = temp_dir.path().join(CODEX_SOCKET_NAME);
+        let listener = UnixListener::bind(&socket_path).expect("bind listener");
+        let handle = thread::spawn(move || {
+            let (mut stream, _) = listener.accept().expect("accept");
+            let mut request = String::new();
+            stream.read_to_string(&mut request).expect("read request");
+            thread::sleep(SOCKET_IO_TIMEOUT + Duration::from_millis(100));
+        });
+
+        let error = send_notification_to_path(&completion_request(), &socket_path)
+            .expect_err("notification should time out");
+        assert!(matches!(
+            &error,
+            HelperSocketError::Read(error)
+                if matches!(error.kind(), std::io::ErrorKind::TimedOut | std::io::ErrorKind::WouldBlock)
+        ));
+        assert!(!error.is_unavailable());
+        handle.join().expect("server thread");
+    }
+
+    #[test]
+    fn unavailable_editor_socket_falls_back() {
+        let error = HelperSocketError::Connect(std::io::Error::from(std::io::ErrorKind::NotFound));
+
+        assert_eq!(
+            classify_editor_response(Err(error)).expect("fallback"),
+            HelperEditorResult::Unavailable
+        );
+    }
+
+    #[test]
+    fn disabled_editor_response_falls_back() {
+        let response = CodexSocketResponse {
+            ok: false,
+            error: Some(CXU_EDITOR_DISABLED_ERROR.to_string()),
+            content: None,
+        };
+
+        assert_eq!(
+            classify_editor_response(Ok(response)).expect("fallback"),
+            HelperEditorResult::Disabled
+        );
+    }
+
+    #[test]
+    fn unexpected_helper_error_is_reported() {
+        let response = CodexSocketResponse {
+            ok: false,
+            error: Some("invalid editor request".to_string()),
+            content: None,
+        };
+
+        let error = classify_editor_response(Ok(response)).expect_err("error");
+        assert!(
+            matches!(error, HelperSocketError::HelperResponse(message) if message == "invalid editor request")
+        );
+    }
+
+    fn restore_runtime_root(previous: Option<std::ffi::OsString>) {
+        match previous {
+            Some(value) => unsafe { std::env::set_var(CXU_RUNTIME_EPHEMERAL_ROOT_ENV, value) },
+            None => unsafe { std::env::remove_var(CXU_RUNTIME_EPHEMERAL_ROOT_ENV) },
+        }
+    }
+}
