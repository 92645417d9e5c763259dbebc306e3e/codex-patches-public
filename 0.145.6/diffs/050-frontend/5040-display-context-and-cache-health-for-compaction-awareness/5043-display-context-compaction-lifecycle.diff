+    pub(crate) fn start_context_compaction_status(&mut self) {
+        self.status_state.terminal_title_status_kind = TerminalTitleStatusKind::Working;
+        self.add_to_history(history_cell::new_context_compaction_triggered_event(
+            self.context_compaction_trigger_usage(),
