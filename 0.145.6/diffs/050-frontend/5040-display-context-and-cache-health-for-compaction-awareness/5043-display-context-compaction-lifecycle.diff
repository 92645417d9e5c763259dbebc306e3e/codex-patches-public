+#[derive(Debug)]
+struct ContextCompactedHistoryCell {
+    duration_ms: Option<i64>,
+}
+
+#[derive(Debug)]
+struct ContextCompactionTriggeredHistoryCell {
+    trigger_context_usage: ContextCompactionTriggerUsage,
+}
+
+#[derive(Clone, Copy, Debug)]
+pub(crate) struct ContextCompactionTriggerUsage {
+    pub(crate) used_tokens: Option<i64>,
+    pub(crate) context_window: Option<i64>,
+}
+
+impl HistoryCell for ContextCompactedHistoryCell {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        vec![context_compaction_separator_line(
+            "Context compacted",
+            self.details_text().as_deref(),
+            width,
+        )]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        let mut text = "Context compacted".to_string();
+        if let Some(details) = self.details_text() {
+            text.push_str(" ▪ ");
+            text.push_str(&details);
+        }
+        vec![text.into()]
+    }
+}
+
+impl HistoryCell for ContextCompactionTriggeredHistoryCell {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        vec![context_compaction_separator_line(
+            "Context compaction triggered",
+            self.trigger_context_usage.label().as_deref(),
+            width,
+        )]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        vec![Line::from(self.label())]
+    }
+}
+
+impl ContextCompactionTriggeredHistoryCell {
+    fn label(&self) -> String {
+        match self.trigger_context_usage.label() {
+            Some(details) => format!("Context compaction triggered ▪ {details}"),
+            None => "Context compaction triggered".to_string(),
+        }
+    }
+}
+
+impl ContextCompactionTriggerUsage {
+    fn label(self) -> Option<String> {
+        match (self.used_tokens, self.context_window) {
+            (Some(used_tokens), Some(context_window)) if context_window > 0 => {
+                let percent =
+                    (used_tokens.saturating_mul(100) + context_window / 2) / context_window;
+                Some(format!("{}% Used", percent.clamp(0, 100)))
+            }
+            _ => None,
+        }
+    }
+}
+
+impl ContextCompactedHistoryCell {
+    fn details_text(&self) -> Option<String> {
+        let duration_ms = self.duration_ms?;
+        let elapsed_seconds = u64::try_from(duration_ms.max(0))
+            .unwrap_or_default()
+            .saturating_add(999)
+            / 1_000;
+        let elapsed = crate::status_indicator_widget::fmt_elapsed_compact(elapsed_seconds);
+        Some(format!("Worked {elapsed}"))
+    }
+}
+
+fn context_compaction_separator_line(
+    label: &str,
+    details: Option<&str>,
+    width: u16,
+) -> Line<'static> {
+    let label_text = match details {
+        Some(details) => format!("{label} ▪ {details}"),
+        None => label.to_string(),
+    };
+    let visible_label = format!("─ {label_text} ─");
+    let label_width = UnicodeWidthStr::width(visible_label.as_str());
+    if label_width > usize::from(width) {
+        let (prefix, _suffix, prefix_width) =
+            take_prefix_by_width(&visible_label, usize::from(width));
+        return Line::from_iter([
+            prefix,
+            "─".repeat(usize::from(width).saturating_sub(prefix_width)),
+        ])
+        .dim();
+    }
+
+    let mut spans = vec![
+        "─ ".dim(),
+        label
+            .to_string()
+            .fg(Color::Yellow)
+            .add_modifier(Modifier::BOLD),
+    ];
+    if let Some(details) = details {
+        spans.push(" ▪ ".dim());
+        spans.push(details.to_string().dim());
+    }
+    spans.push(" ─".dim());
+    spans.push(
+        "─"
+            .repeat(usize::from(width).saturating_sub(label_width))
+            .dim(),
+    );
+    Line::from(spans)
+}
+
+pub(crate) fn new_context_compacted_event(duration_ms: Option<i64>) -> impl HistoryCell {
+    ContextCompactedHistoryCell { duration_ms }
+}
+
+pub(crate) fn new_context_compaction_triggered_event(
+    trigger_context_usage: ContextCompactionTriggerUsage,
+) -> impl HistoryCell {
+    ContextCompactionTriggeredHistoryCell {
+        trigger_context_usage,
+    }
+}
