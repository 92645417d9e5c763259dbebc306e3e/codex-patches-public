+    pub(super) fn handle_context_compaction_item(
+        &mut self,
+        duration_ms: Option<i64>,
+        _render_source: ThreadItemRenderSource,
+    ) {
+        self.add_to_history(history_cell::new_context_compacted_event(duration_ms));
+        self.request_redraw();
+    }
