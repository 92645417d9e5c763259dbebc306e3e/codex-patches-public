+#[tokio::test]
+async fn context_compaction_item_tracks_live_duration_and_replay_omits_it() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 1_000,
+            item: AppServerThreadItem::ContextCompaction {
+                id: "compact-1".to_string(),
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(chat.current_status_header_for_test(), "Working");
+    let cells = drain_insert_history(&mut rx);
+    assert!(
+        lines_to_single_string(&cells[0]).contains("Context compaction triggered"),
+        "expected compaction trigger banner"
+    );
+
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 85_000,
+            item: AppServerThreadItem::ContextCompaction {
+                id: "compact-1".to_string(),
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+
+    let cells = drain_insert_history(&mut rx);
+    assert!(
+        lines_to_single_string(&cells[0]).contains("Context compacted ▪ Worked 1m 24s"),
+        "expected live compaction duration"
+    );
+
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 200_000,
+            item: AppServerThreadItem::ContextCompaction {
+                id: "replay-compact".to_string(),
+            },
+        }),
+        Some(ReplayKind::ResumeInitialMessages),
+    );
+
+    let cells = drain_insert_history(&mut rx);
+    let replay_text = lines_to_single_string(&cells[0]);
+    assert!(replay_text.contains("Context compacted"));
+    assert!(!replay_text.contains("Worked"));
+}
