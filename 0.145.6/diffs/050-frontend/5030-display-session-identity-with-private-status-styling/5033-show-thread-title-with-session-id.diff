+    fn status_line_thread_title_display_line(&self) -> Option<Line<'static>> {
+        let thread_name = self
+            .thread_name
+            .as_deref()
+            .map(str::trim)
+            .filter(|name| !name.is_empty());
+        let session_id = self.thread_id.map(|thread_id| thread_id.to_string());
+        let session_span = session_id.and_then(|session_id| {
+            status_line_from_lines_with_styles(
+                [(StatusLineItem::SessionId, Line::from(session_id))],
+                self.config.tui_status_line_use_colors,
+                |_| None,
+            )
+            .and_then(|line| line.spans.into_iter().next())
+        });
+
+        match (thread_name, session_span) {
+            (Some(thread_name), Some(session_span)) => Some(Line::from(vec![
+                Span::from(thread_name.to_string()),
+                Span::from(" "),
+                session_span,
+            ])),
+            (Some(thread_name), None) => Some(Line::from(thread_name.to_string())),
+            (None, Some(session_span)) => Some(Line::from(session_span)),
+            (None, None) => None,
+        }
+    }
+
+    fn status_line_plain_text(line: &Line<'_>) -> String {
