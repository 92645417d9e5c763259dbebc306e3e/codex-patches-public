+#[tokio::test]
+async fn named_thread_title_includes_thread_id_on_status_and_terminal_surfaces() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let thread_id = ThreadId::new();
+    chat.thread_id = Some(thread_id);
+    chat.thread_name = Some("Roadmap cleanup".to_string());
+    let expected = format!("Roadmap cleanup {thread_id}");
+
+    assert_eq!(
+        status_preview_line(&mut chat, &[StatusLineItem::ThreadTitle]),
+        expected
+    );
+    let terminal_title = title_preview_line(&mut chat, &[TerminalTitleItem::Thread]);
+    assert!(terminal_title.starts_with("Roadmap cleanup "));
+    assert!(terminal_title.ends_with("..."));
+    assert_eq!(terminal_title.chars().count(), 48);
+}
