+#[tokio::test]
+async fn interrupted_turn_stops_commit_animation() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_turn_started(&mut chat, "turn-1");
+    while rx.try_recv().is_ok() {}
+
+    handle_agent_message_delta(&mut chat, "streamed response\n");
+    assert!(
+        std::iter::from_fn(|| rx.try_recv().ok())
+            .any(|event| matches!(event, AppEvent::StartCommitAnimation)),
+        "streaming should arm the commit animation"
+    );
+
+    handle_turn_interrupted(&mut chat, "turn-1");
+    assert!(
+        std::iter::from_fn(|| rx.try_recv().ok())
+            .any(|event| matches!(event, AppEvent::StopCommitAnimation)),
+        "turn finalization should stop the commit animation"
+    );
+}
