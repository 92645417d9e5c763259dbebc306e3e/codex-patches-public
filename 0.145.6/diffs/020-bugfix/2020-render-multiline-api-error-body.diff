index e5cc14db4e..06cd9f8588 100644
--- a/codex-rs/tui/src/history_cell/notices.rs
+++ b/codex-rs/tui/src/history_cell/notices.rs
@@ -211,9 +211,39 @@ pub(crate) fn new_info_event(message: String, hint: Option<String>) -> PlainHist
 }
 
 pub(crate) fn new_error_event(message: String) -> PlainHistoryCell {
-    // Use a hair space (U+200A) to create a subtle, near-invisible separation
-    // before the text. VS16 is intentionally omitted to keep spacing tighter
-    // in terminals like Ghostty.
-    let lines: Vec<Line<'static>> = vec![vec![format!("▪ {message}").red()].into()];
+    let mut message_lines = message.split('\n');
+    let first = message_lines
+        .next()
+        .unwrap_or_default()
+        .trim_end_matches('\r');
+    let mut lines: Vec<Line<'static>> = vec![format!("▪ {first}").red().into()];
+    lines.extend(
+        message_lines.map(|line| format!("  {}", line.trim_end_matches('\r')).red().into()),
+    );
     PlainHistoryCell { lines }
 }
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn error_event_preserves_multiline_body_rows() {
+        let message = "{\n  \"error\": {\n    \"code\": 400\n  }\n}";
+        let cell = new_error_event(message.to_string());
+        let rendered = cell.lines.iter().map(Line::to_string).collect::<Vec<_>>();
+
+        assert_eq!(rendered.len(), 5, "one rendered line per source line");
+        assert!(rendered[0].ends_with('{'));
+        assert_eq!(
+            &rendered[1..],
+            ["    \"error\": {", "      \"code\": 400", "    }", "  }",]
+        );
+        assert!(
+            cell.lines
+                .iter()
+                .flat_map(|line| &line.spans)
+                .all(|span| span.style.fg == Some(Color::Red))
+        );
+    }
+}
