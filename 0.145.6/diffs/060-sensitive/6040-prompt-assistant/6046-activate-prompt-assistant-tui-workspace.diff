+    received_bytes: u64,
+    progress_initialized: bool,
+}
+
+impl ChatWidget {
+    pub(crate) fn prompt_assistant_active(&self) -> bool {
+        self.prompt_assistant.is_some()
+    }
+
+    pub(crate) fn open_prompt_assistant(&mut self) {
+        if self.prompt_assistant.is_some() {
+            return;
+        }
+        if self.bottom_pane.is_task_running() {
+            self.add_error_message(
+                "Prompt Assistant is unavailable while the main thread is working.".to_string(),
+            );
+            return;
+        }
+        let Some(thread_id) = self.thread_id else {
+            self.add_error_message(
+                "Prompt Assistant is unavailable until startup completes.".to_string(),
+            );
+            return;
+        };
+
+        let source_draft = self.bottom_pane.composer_draft_snapshot();
+        if !source_draft.local_images.is_empty() || !source_draft.remote_image_urls.is_empty() {
+            self.add_error_message(
+                "Prompt Assistant cannot open while the composer contains images.".to_string(),
+            );
+            return;
+        }
+        let initial_input = self.bottom_pane.composer_text_with_pending();
+        self.prompt_assistant = Some(PromptAssistantUiState {
+            source_draft,
+            initial_input,
+            revision_draft: String::new(),
+            workspace: None,
+            models: Vec::new(),
+            editing_kind: PromptAssistantEditingKind::Compose,
+            working: false,
+            received_bytes: 0,
+            progress_initialized: false,
+        });
+        self.bottom_pane
+            .set_composer_input_enabled(false, Some("Opening Prompt Assistant…".to_string()));
+        self.app_event_tx
+            .send(AppEvent::PromptAssistantOpen { thread_id });
+        self.request_redraw();
+    }
+
+    pub(crate) fn prompt_assistant_opened(
+        &mut self,
+        result: Result<PromptAssistantOpenResponse, String>,
+    ) {
+        let Ok(response) = result else {
+            let message = result.expect_err("checked above");
+            self.close_prompt_assistant_restoring_source();
+            self.add_error_message(message);
+            return;
+        };
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        state.workspace = Some(response.workspace);
+        state.models = response.models;
+        self.bottom_pane
+            .set_composer_config(ChatComposerConfig::plain_text());
+        self.bottom_pane
+            .set_composer_text(state.initial_input.clone(), Vec::new(), Vec::new());
+        self.bottom_pane.set_remote_image_urls(Vec::new());
+        self.bottom_pane.set_composer_pending_pastes(Vec::new());
+        self.bottom_pane
+            .set_composer_input_enabled(true, Some("Describe the prompt to compose".to_string()));
+        self.update_prompt_assistant_status_line();
+        self.request_redraw();
+    }
+
+    pub(crate) fn handle_prompt_assistant_key_event(&mut self, key_event: KeyEvent) -> bool {
+        if self.prompt_assistant.is_none() {
+            return false;
+        }
+        if self.bottom_pane.has_active_view() {
+            return false;
+        }
+
+        if key_event.kind != KeyEventKind::Press {
+            return true;
+        }
+
+        if matches!(key_event.code, KeyCode::Esc) {
+            let working = self
+                .prompt_assistant
+                .as_ref()
+                .is_some_and(|state| state.working);
+            if working {
+                self.request_prompt_assistant_interrupt();
+            } else if self.prompt_assistant.as_ref().is_some_and(|state| {
+                state.editing_kind == PromptAssistantEditingKind::Revise
+                    && state
+                        .workspace
+                        .as_ref()
+                        .and_then(|workspace| workspace.candidate.as_ref())
+                        .is_some()
+            }) {
+                if let Some(state) = self.prompt_assistant.as_mut() {
+                    state.revision_draft = self.bottom_pane.composer_text_with_pending();
+                }
+                self.show_prompt_assistant_result();
+            } else {
+                self.request_prompt_assistant_cancel();
+            }
+            return true;
+        }
+
+        if matches!(
+            key_event,
+            KeyEvent {
+                code: KeyCode::Char('c'),
+                modifiers,
+                ..
+            } if modifiers.contains(KeyModifiers::ALT)
+        ) {
+            self.copy_prompt_assistant_candidate();
+            return true;
+        }
+
+        if matches!(
+            key_event,
+            KeyEvent {
+                code: KeyCode::Char('g'),
+                modifiers,
+                ..
+            } if modifiers.contains(KeyModifiers::CONTROL)
+        ) {
+            return true;
+        }
+
+        if matches!(
+            key_event,
+            KeyEvent {
+                code: KeyCode::Char('v'),
+                modifiers,
+                ..
+            } if modifiers.intersects(KeyModifiers::CONTROL | KeyModifiers::ALT)
+        ) {
+            self.add_error_message(
+                "Prompt Assistant accepts text paste only; image paste is disabled.".to_string(),
+            );
+            return true;
+        }
+
+        if self.prompt_assistant_step_model(key_event)
+            || self.prompt_assistant_step_reasoning(key_event)
+        {
+            return true;
+        }
+
+        if self.bottom_pane.composer_submit_key_pressed(key_event) {
+            self.submit_prompt_assistant_edit();
+            return true;
+        }
+
+        key_event
+            .modifiers
+            .intersects(KeyModifiers::CONTROL | KeyModifiers::ALT | KeyModifiers::SUPER)
+    }
+
+    fn submit_prompt_assistant_edit(&mut self) {
+        let input = self.bottom_pane.composer_text_with_pending();
+        if input.trim().is_empty() {
+            self.add_warning_message("Prompt Assistant input must not be empty.".to_string());
+            return;
+        }
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        let Some(workspace) = state.workspace.as_ref() else {
+            return;
+        };
+        if state.working {
+            return;
+        }
+
+        let event = match state.editing_kind {
+            PromptAssistantEditingKind::Compose => {
+                AppEvent::PromptAssistantCompose(PromptAssistantComposeParams {
+                    thread_id: workspace.thread_id.clone(),
+                    workspace_id: workspace.workspace_id.clone(),
+                    expected_generation: workspace.generation,
+                    input,
+                    model: workspace.selected_model.clone(),
+                    reasoning_effort: workspace.selected_reasoning_effort.clone(),
+                })
+            }
+            PromptAssistantEditingKind::Revise => {
+                let Some(candidate_hash) = workspace.candidate_hash.clone() else {
+                    self.add_error_message(
+                        "Prompt Assistant cannot revise a candidate without an audit hash."
+                            .to_string(),
+                    );
+                    return;
+                };
+                AppEvent::PromptAssistantRevise(PromptAssistantReviseParams {
+                    thread_id: workspace.thread_id.clone(),
+                    workspace_id: workspace.workspace_id.clone(),
+                    expected_generation: workspace.generation,
+                    expected_candidate_generation: workspace.candidate_generation,
+                    expected_candidate_hash: candidate_hash,
+                    input,
+                    model: workspace.selected_model.clone(),
+                    reasoning_effort: workspace.selected_reasoning_effort.clone(),
+                })
+            }
+        };
+        state.working = true;
+        state.received_bytes = 0;
+        state.progress_initialized = false;
+        self.bottom_pane.clear_response_output_bytes();
+        self.bottom_pane
+            .set_composer_input_enabled(false, Some("Prompt Assistant is working…".to_string()));
+        self.bottom_pane.ensure_status_indicator();
+        self.bottom_pane.set_status_timer_started_at(Instant::now());
+        self.bottom_pane.update_status(
+            match state.editing_kind {
+                PromptAssistantEditingKind::Compose => "Composing prompt".to_string(),
+                PromptAssistantEditingKind::Revise => "Revising prompt".to_string(),
+            },
+            None,
+            StatusDetailsCapitalization::Preserve,
+            1,
+        );
+        self.app_event_tx.send(event);
+    }
+
+    pub(crate) fn prompt_assistant_request_acknowledged(
+        &mut self,
+        result: Result<PromptAssistantWorkspace, String>,
+    ) {
+        match result {
+            Ok(workspace) => {
+                if let Some(state) = self.prompt_assistant.as_mut() {
+                    state.workspace = Some(workspace);
+                }
+            }
+            Err(message) => {
+                if let Some(state) = self.prompt_assistant.as_mut() {
+                    state.working = false;
+                }
+                self.bottom_pane.hide_status_indicator();
+                self.bottom_pane
+                    .set_composer_input_enabled(true, Some("Try again".to_string()));
+                self.add_error_message(message);
+            }
+        }
+    }
+
+    pub(crate) fn on_prompt_assistant_progress(
+        &mut self,
+        notification: PromptAssistantProgressNotification,
+    ) {
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        let Some(workspace) = state.workspace.as_ref() else {
+            return;
+        };
+        if workspace.workspace_id != notification.workspace_id
+            || notification.generation < workspace.generation
+        {
+            return;
+        }
+        if notification.received_bytes < state.received_bytes {
+            return;
+        }
+        let delta = notification.received_bytes - state.received_bytes;
+        if !state.progress_initialized {
+            self.bottom_pane
+                .update_response_output_bytes(&notification.workspace_id, 0, true);
+            state.progress_initialized = true;
+        }
+        state.received_bytes = notification.received_bytes;
+        self.bottom_pane
+            .update_response_output_bytes(&notification.workspace_id, delta, false);
+    }
+
+    pub(crate) fn on_prompt_assistant_workspace_updated(
+        &mut self,
+        workspace: PromptAssistantWorkspace,
+    ) {
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if state
+            .workspace
+            .as_ref()
+            .is_some_and(|current| current.workspace_id != workspace.workspace_id)
+        {
+            return;
+        }
+        state.workspace = Some(workspace.clone());
+        state.working = matches!(
+            workspace.phase,
+            PromptAssistantPhase::Preparing | PromptAssistantPhase::Revising
+        );
+        if workspace.outcome == Some(PromptAssistantOutcome::Ready) {
+            state.revision_draft.clear();
+        }
+        if state.working {
+            return;
+        }
+
+        self.update_prompt_assistant_status_line();
+        self.bottom_pane.clear_response_output_bytes();
+        self.bottom_pane.hide_status_indicator();
+        match workspace.outcome {
+            Some(PromptAssistantOutcome::Ready) => self.show_prompt_assistant_result(),
+            Some(outcome @ (PromptAssistantOutcome::Blocked | PromptAssistantOutcome::Failed)) => {
+                let message = workspace.message.unwrap_or_else(|| {
+                    "Prompt Assistant could not produce a candidate.".to_string()
+                });
+                self.bottom_pane
+                    .set_composer_input_enabled(true, Some("Revise the request".to_string()));
+                match outcome {
+                    PromptAssistantOutcome::Blocked => self.add_warning_message(message),
+                    PromptAssistantOutcome::Failed => self.add_error_message(message),
+                    _ => unreachable!("matched blocked or failed"),
+                }
+            }
+            Some(PromptAssistantOutcome::Interrupted) => {
+                self.bottom_pane
+                    .set_composer_input_enabled(true, Some("Continue editing".to_string()));
+            }
+            Some(PromptAssistantOutcome::Cancelled) => {
+                self.close_prompt_assistant_restoring_source();
+            }
+            None => {}
+        }
+    }
+
+    fn show_prompt_assistant_result(&mut self) {
+        let Some(workspace) = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.clone())
+        else {
+            return;
+        };
+        let Some(candidate) = workspace.candidate.clone() else {
+            return;
+        };
+        let tx = self.app_event_tx.clone();
+        self.bottom_pane
+            .set_composer_input_enabled(false, Some("Review the candidate".to_string()));
+        self.bottom_pane
+            .show_view(Box::new(PromptAssistantResultView::new(
+                candidate,
+                workspace.selected_model,
+                workspace.selected_reasoning_effort,
+                move |action| tx.send(AppEvent::PromptAssistantResultAction(action)),
+            )));
+    }
+
+    pub(crate) fn handle_prompt_assistant_result_action(
+        &mut self,
+        action: PromptAssistantResultAction,
+    ) {
+        match action {
+            PromptAssistantResultAction::Apply => self.request_prompt_assistant_apply(),
+            PromptAssistantResultAction::Revise => {
+                let revision_draft = self
+                    .prompt_assistant
+                    .as_ref()
+                    .map(|state| state.revision_draft.clone())
+                    .unwrap_or_default();
+                if let Some(state) = self.prompt_assistant.as_mut() {
+                    state.editing_kind = PromptAssistantEditingKind::Revise;
+                }
+                self.bottom_pane
+                    .set_composer_text(revision_draft, Vec::new(), Vec::new());
+                self.bottom_pane.set_composer_input_enabled(
+                    true,
+                    Some("Describe how to revise the candidate".to_string()),
+                );
+                self.update_prompt_assistant_status_line();
+            }
+            PromptAssistantResultAction::Copy => self.copy_prompt_assistant_candidate(),
+            PromptAssistantResultAction::Discard => self.request_prompt_assistant_cancel(),
+        }
+    }
+
+    fn request_prompt_assistant_apply(&mut self) {
+        let Some(workspace) = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.as_ref())
+        else {
+            return;
+        };
+        let Some(candidate_hash) = workspace.candidate_hash.clone() else {
+            return;
+        };
+        self.app_event_tx
+            .send(AppEvent::PromptAssistantApply(PromptAssistantApplyParams {
+                thread_id: workspace.thread_id.clone(),
+                workspace_id: workspace.workspace_id.clone(),
+                expected_generation: workspace.generation,
+                expected_candidate_generation: workspace.candidate_generation,
+                expected_candidate_hash: candidate_hash,
+            }));
+    }
+
+    pub(crate) fn prompt_assistant_applied(
+        &mut self,
+        result: Result<PromptAssistantApplyResponse, String>,
+    ) {
+        match result {
+            Ok(response) => {
+                self.prompt_assistant = None;
+                self.bottom_pane
+                    .dismiss_active_view_if_id(PROMPT_ASSISTANT_RESULT_VIEW_ID);
+                self.bottom_pane
+                    .set_composer_config(ChatComposerConfig::default());
+                self.bottom_pane
+                    .set_composer_text(response.candidate, Vec::new(), Vec::new());
+                self.bottom_pane.set_composer_input_enabled(true, None);
+                self.refresh_status_line();
+            }
+            Err(message) => self.add_error_message(message),
+        }
+    }
+
+    fn request_prompt_assistant_interrupt(&mut self) {
+        let Some(workspace) = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.as_ref())
+        else {
+            return;
+        };
+        self.app_event_tx.send(AppEvent::PromptAssistantInterrupt(
+            PromptAssistantInterruptParams {
+                thread_id: workspace.thread_id.clone(),
+                workspace_id: workspace.workspace_id.clone(),
+                expected_generation: workspace.generation,
+                active_operation_generation: workspace.generation,
+            },
+        ));
+    }
+
+    fn request_prompt_assistant_cancel(&mut self) {
+        let Some(workspace) = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.as_ref())
+        else {
+            self.close_prompt_assistant_restoring_source();
+            return;
+        };
+        self.app_event_tx.send(AppEvent::PromptAssistantCancel(
+            PromptAssistantCancelParams {
+                thread_id: workspace.thread_id.clone(),
+                workspace_id: workspace.workspace_id.clone(),
+            },
+        ));
+    }
+
+    pub(crate) fn prompt_assistant_cancelled(&mut self, result: Result<(), String>) {
+        self.close_prompt_assistant_restoring_source();
+        if let Err(message) = result {
+            self.add_error_message(message);
+        }
+    }
+
+    fn close_prompt_assistant_restoring_source(&mut self) {
+        let Some(state) = self.prompt_assistant.take() else {
+            return;
+        };
+        self.bottom_pane
+            .dismiss_active_view_if_id(PROMPT_ASSISTANT_RESULT_VIEW_ID);
+        self.bottom_pane.hide_status_indicator();
+        self.bottom_pane.clear_response_output_bytes();
+        self.bottom_pane
+            .set_composer_config(ChatComposerConfig::default());
+        self.bottom_pane.restore_composer_draft(state.source_draft);
+        self.bottom_pane.set_composer_input_enabled(true, None);
+        self.refresh_status_line();
+        self.request_redraw();
+    }
+
+    fn copy_prompt_assistant_candidate(&mut self) {
+        let candidate = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.as_ref())
+            .and_then(|workspace| workspace.candidate.as_deref());
+        let Some(candidate) = candidate else {
+            return;
+        };
+        match crate::clipboard_copy::copy_to_clipboard(candidate) {
+            Ok(lease) => {
+                self.clipboard_lease = lease;
+                self.add_info_message(
+                    "Copied Prompt Assistant candidate to clipboard.".to_string(),
+                    None,
+                );
+            }
+            Err(message) => self.add_error_message(format!("Copy failed: {message}")),
+        }
+    }
+
+    fn prompt_assistant_step_model(&mut self, key_event: KeyEvent) -> bool {
+        let delta = if self.chat_keymap.previous_model.is_pressed(key_event) {
+            -1
+        } else if self.chat_keymap.next_model.is_pressed(key_event) {
+            1
+        } else {
+            return false;
+        };
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return false;
+        };
+        if state.working || state.models.is_empty() {
+            return true;
+        }
+        let Some(workspace) = state.workspace.as_mut() else {
+            return true;
+        };
+        let current = state
+            .models
+            .iter()
+            .position(|model| model.model == workspace.selected_model)
+            .unwrap_or(0);
+        let next = (current as isize + delta).rem_euclid(state.models.len() as isize) as usize;
+        let model = &state.models[next];
+        workspace.selected_model = model.model.clone();
+        workspace.selected_reasoning_effort = model.default_reasoning_effort.clone();
+        self.update_prompt_assistant_status_line();
+        self.request_redraw();
+        true
+    }
+
+    fn prompt_assistant_step_reasoning(&mut self, key_event: KeyEvent) -> bool {
+        let delta = if self
+            .chat_keymap
+            .decrease_reasoning_effort
+            .is_pressed(key_event)
+        {
+            -1
+        } else if self
+            .chat_keymap
+            .increase_reasoning_effort
+            .is_pressed(key_event)
+        {
+            1
+        } else {
+            return false;
+        };
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return false;
+        };
+        if state.working {
+            return true;
+        }
+        let Some(workspace) = state.workspace.as_mut() else {
+            return true;
+        };
+        let Some(model) = state
+            .models
+            .iter()
+            .find(|model| model.model == workspace.selected_model)
+        else {
+            return true;
+        };
+        if model.supported_reasoning_efforts.is_empty() {
+            return true;
+        }
+        let current = model
+            .supported_reasoning_efforts
+            .iter()
+            .position(|effort| effort == &workspace.selected_reasoning_effort)
+            .unwrap_or(0);
+        let next = (current as isize + delta)
+            .clamp(0, model.supported_reasoning_efforts.len() as isize - 1)
+            as usize;
+        workspace.selected_reasoning_effort = model.supported_reasoning_efforts[next].clone();
+        self.update_prompt_assistant_status_line();
+        self.request_redraw();
+        true
+    }
+
+    fn update_prompt_assistant_status_line(&mut self) {
+        let Some(workspace) = self
+            .prompt_assistant
+            .as_ref()
+            .and_then(|state| state.workspace.as_ref())
+        else {
+            return;
+        };
+        self.bottom_pane.set_status_line(Some(Line::from(vec![
+            Span::from("Prompt Assistant").bold(),
+            Span::from(" ▪ ").dim(),
+            Span::styled(
+                workspace.selected_model.clone(),
+                model_style(&workspace.selected_model),
+            ),
+            Span::from(" ▪ ").dim(),
+            Span::styled(
+                workspace.selected_reasoning_effort.to_string(),
+                reasoning_effort_style(&workspace.selected_reasoning_effort),
+            ),
+        ])));
+    }
+}
