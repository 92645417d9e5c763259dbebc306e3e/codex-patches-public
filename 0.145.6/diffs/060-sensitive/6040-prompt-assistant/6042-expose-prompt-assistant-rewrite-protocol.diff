+use super::TokenUsageBreakdown;
+use codex_protocol::openai_models::ReasoningEffort;
+use schemars::JsonSchema;
+use serde::Deserialize;
+use serde::Serialize;
+use ts_rs::TS;
+
+#[derive(Serialize, Deserialize, Debug, Clone, Copy, PartialEq, Eq, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub enum PromptAssistantOutcome {
+    Ready,
+    Blocked,
+    Failed,
+    Interrupted,
+}
+
+#[derive(Serialize, Deserialize, Debug, Clone, PartialEq, Eq, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub struct PromptAssistantRewriteParams {
+    pub thread_id: String,
+    pub input: String,
+    pub model: String,
+    pub reasoning_effort: ReasoningEffort,
+}
+
+#[derive(Serialize, Deserialize, Debug, Clone, PartialEq, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub struct PromptAssistantRewriteResponse {
+    pub outcome: PromptAssistantOutcome,
+    pub candidate: Option<String>,
+    pub reason: Option<String>,
+    pub effective_model: String,
+    pub effective_reasoning_effort: ReasoningEffort,
+    pub fallback_from_model: Option<String>,
+    pub usage: Option<TokenUsageBreakdown>,
+}
+
+#[derive(Serialize, Deserialize, Debug, Clone, PartialEq, Eq, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub struct PromptAssistantInterruptParams {
+    pub thread_id: String,
+}
+
+#[derive(Serialize, Deserialize, Debug, Clone, PartialEq, Eq, Default, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub struct PromptAssistantInterruptResponse {}
+
+#[derive(Serialize, Deserialize, Debug, Clone, PartialEq, Eq, JsonSchema, TS)]
+#[serde(rename_all = "camelCase")]
+#[ts(export_to = "v2/")]
+pub struct PromptAssistantProgressNotification {
+    pub thread_id: String,
+    pub received_bytes: u64,
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn rewrite_response_round_trip_preserves_terminal_metadata_and_usage() {
+        let response = PromptAssistantRewriteResponse {
+            outcome: PromptAssistantOutcome::Ready,
+            candidate: Some("full candidate".to_string()),
+            reason: None,
+            effective_model: "model".to_string(),
+            effective_reasoning_effort: ReasoningEffort::High,
+            fallback_from_model: Some("requested-model".to_string()),
+            usage: Some(TokenUsageBreakdown {
+                total_tokens: 21,
+                input_tokens: 13,
+                cached_input_tokens: 5,
+                cache_write_input_tokens: 2,
+                output_tokens: 8,
+                reasoning_output_tokens: 3,
+            }),
+        };
+
+        let encoded = serde_json::to_value(&response).expect("serialize rewrite response");
+        let decoded: PromptAssistantRewriteResponse =
+            serde_json::from_value(encoded).expect("deserialize rewrite response");
+        assert_eq!(decoded, response);
+    }
+
+    #[test]
+    fn rewrite_contract_has_no_workspace_or_generation_fields() {
+        let params = PromptAssistantRewriteParams {
+            thread_id: "thread".to_string(),
+            input: "rewrite this".to_string(),
+            model: "model".to_string(),
+            reasoning_effort: ReasoningEffort::Medium,
+        };
+        let progress = PromptAssistantProgressNotification {
+            thread_id: "thread".to_string(),
+            received_bytes: 42,
+        };
+
+        assert_eq!(
+            serde_json::to_value(params).expect("serialize rewrite params"),
+            serde_json::json!({
+                "threadId": "thread",
+                "input": "rewrite this",
+                "model": "model",
+                "reasoningEffort": "medium",
+            })
+        );
+        assert_eq!(
+            serde_json::to_value(progress).expect("serialize rewrite progress"),
+            serde_json::json!({
+                "threadId": "thread",
+                "receivedBytes": 42,
+            })
+        );
+    }
+}
