+/// Reject source text that cannot fit beside the trunk's current live context and the maximum
+/// structured response. Callers supply the selected model's effective context window.
+pub fn validate_prompt_assistant_source_context_fit(
+    source: &str,
+    active_context_tokens: i64,
+    model_context_window: Option<i64>,
+) -> Result<()> {
+    let Some(model_context_window) = model_context_window else {
+        return Ok(());
+    };
+    let source_tokens = i64::try_from(approx_token_count(source)).unwrap_or(i64::MAX);
+    let required_tokens = active_context_tokens
+        .max(0)
+        .saturating_add(source_tokens)
+        .saturating_add(STRUCTURED_OUTPUT_RESERVE_TOKENS);
+    ensure!(
+        required_tokens <= model_context_window,
+        "Prompt Assistant source does not fit the selected model context window"
+    );
+    Ok(())
+}
+
+/// Validate the structural subset of repository Markdown style that can be proven from a
+/// generated candidate. Language and non-ASCII literal attribution remain model obligations.
+pub fn validate_prompt_assistant_candidate_markdown(candidate: &str) -> Result<()> {
+    let mut in_front_matter = false;
+    let mut front_matter_closed = false;
+    let mut fence: Option<(char, usize)> = None;
+
+    for (index, line) in candidate.lines().enumerate() {
+        if index == 0 && line == "---" {
+            in_front_matter = true;
+            continue;
+        }
+        if in_front_matter {
+            if line == "---" {
+                in_front_matter = false;
+                front_matter_closed = true;
+            }
+            continue;
+        }
+        if let Some((fence_char, fence_len)) = fence {
+            if is_closing_fence(line, fence_char, fence_len) {
+                fence = None;
+            }
+            continue;
+        }
+        if let Some(opening_fence) = opening_fence(line) {
+            fence = Some(opening_fence);
+            continue;
+        }
+        if line.is_empty() || is_atx_heading(line) || is_flat_item(line) {
+            continue;
+        }
+        anyhow::bail!(
+            "Prompt Assistant candidate line {} must be an ATX heading or flat `- ` item",
+            index + 1
+        );
+    }
+
+    ensure!(
+        !in_front_matter || front_matter_closed,
+        "Prompt Assistant candidate has unclosed front matter"
+    );
+    ensure!(
+        fence.is_none(),
+        "Prompt Assistant candidate has an unclosed fenced code block"
+    );
+    Ok(())
+}
+
+fn is_atx_heading(line: &str) -> bool {
+    let hashes = line.bytes().take_while(|byte| *byte == b'#').count();
+    (1..=6).contains(&hashes)
+        && line.as_bytes().get(hashes) == Some(&b' ')
+        && line[hashes + 1..].trim().len() > 0
+}
+
+fn is_flat_item(line: &str) -> bool {
+    line.strip_prefix("- ")
+        .is_some_and(|content| !content.trim().is_empty())
+}
+
+fn opening_fence(line: &str) -> Option<(char, usize)> {
+    let fence_char = line.chars().next()?;
+    if !matches!(fence_char, '`' | '~') {
+        return None;
+    }
+    let fence_len = line.chars().take_while(|ch| *ch == fence_char).count();
+    (fence_len >= 3).then_some((fence_char, fence_len))
+}
+
+fn is_closing_fence(line: &str, fence_char: char, fence_len: usize) -> bool {
+    let closing_len = line.chars().take_while(|ch| *ch == fence_char).count();
+    closing_len >= fence_len && line[closing_len..].trim().is_empty()
+}
