+pub(crate) fn freeze_parent_context(items: &[ResponseItem]) -> PromptAssistantFrozenContext {
+    let latest_summary_index = items.iter().rposition(|item| {
+        let ResponseItem::Message { role, content, .. } = item else {
+            return false;
+        };
+        role == "user"
+            && content_items_to_text(content)
+                .as_deref()
+                .is_some_and(is_summary_message)
+    });
+
+    let entries = items
+        .iter()
+        .enumerate()
+        .filter(|(index, _)| latest_summary_index.is_none_or(|summary| *index >= summary))
+        .filter_map(|(_, item)| context_entry(item))
+        .collect();
+    PromptAssistantFrozenContext { entries }
+}
+
+/// Compute an append-only projection update, falling back to a complete replacement after a
+/// parent compaction, rollback, or any other history rewrite.
+pub fn prompt_assistant_projection_update(
+    synchronized: &PromptAssistantFrozenContext,
+    current: &PromptAssistantFrozenContext,
+) -> PromptAssistantProjectionUpdate {
+    if current.entries.starts_with(&synchronized.entries) {
+        PromptAssistantProjectionUpdate::Append(
+            current.entries[synchronized.entries.len()..].to_vec(),
+        )
+    } else {
+        PromptAssistantProjectionUpdate::Replace(current.entries.clone())
+    }
+}
+
+/// Convert the parent projection into normal child message history. This deliberately avoids a
+/// JSON envelope so the child sees parent conversation in the same role/channel form as a turn.
+pub fn prompt_assistant_projection_items(
+    entries: &[PromptAssistantContextEntry],
+) -> Vec<ResponseItem> {
+    entries
+        .iter()
+        .map(|entry| {
+            let (role, phase) = match entry.kind {
+                PromptAssistantContextKind::CompactionSummary
+                | PromptAssistantContextKind::User => ("user", None),
+                PromptAssistantContextKind::Commentary => {
+                    ("assistant", Some(MessagePhase::Commentary))
+                }
+                PromptAssistantContextKind::Final => ("assistant", Some(MessagePhase::FinalAnswer)),
+            };
+            let content = match phase {
+                Some(_) => ContentItem::OutputText {
+                    text: entry.text.clone(),
+                },
+                None => ContentItem::InputText {
+                    text: entry.text.clone(),
+                },
+            };
+            ResponseItem::Message {
+                id: None,
+                role: role.to_string(),
+                content: vec![content],
+                phase,
+                internal_chat_message_metadata_passthrough: None,
+            }
+        })
+        .collect()
+}
+
+/// Return the billable usage for one child turn from two cumulative child snapshots.
+pub fn prompt_assistant_usage_delta(start: &TokenUsage, end: &TokenUsage) -> TokenUsage {
+    TokenUsage {
+        input_tokens: (end.input_tokens - start.input_tokens).max(0),
+        cached_input_tokens: (end.cached_input_tokens - start.cached_input_tokens).max(0),
+        cache_write_input_tokens: (end.cache_write_input_tokens - start.cache_write_input_tokens)
+            .max(0),
+        output_tokens: (end.output_tokens - start.output_tokens).max(0),
+        reasoning_output_tokens: (end.reasoning_output_tokens - start.reasoning_output_tokens)
+            .max(0),
+        total_tokens: (end.total_tokens - start.total_tokens).max(0),
+    }
+}
+
+fn context_entry(item: &ResponseItem) -> Option<PromptAssistantContextEntry> {
+    let ResponseItem::Message {
+        role,
+        content,
+        phase,
+        ..
+    } = item
+    else {
+        return None;
+    };
+    let text = content_items_to_text(content)?;
+    if text.trim().is_empty() {
+        return None;
+    }
+    let kind = match role.as_str() {
+        "user" if !is_contextual_user_message_content(content) => {
+            if is_summary_message(&text) {
+                PromptAssistantContextKind::CompactionSummary
+            } else {
+                PromptAssistantContextKind::User
+            }
+        }
+        "assistant" if *phase == Some(MessagePhase::Commentary) => {
+            PromptAssistantContextKind::Commentary
+        }
+        "assistant" if *phase == Some(MessagePhase::FinalAnswer) => {
+            PromptAssistantContextKind::Final
+        }
+        _ => return None,
+    };
+    Some(PromptAssistantContextEntry { kind, text })
+}
