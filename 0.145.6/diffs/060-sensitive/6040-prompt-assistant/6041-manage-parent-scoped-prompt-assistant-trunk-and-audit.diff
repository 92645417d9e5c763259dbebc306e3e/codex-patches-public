+pub fn prompt_assistant_output_schema() -> Value {
+    json!({
+        "type": "object",
+        "additionalProperties": false,
+        "required": ["status", "candidate", "reason"],
+        "properties": {
+            "status": {
+                "type": "string",
+                "enum": ["ready", "blocked"]
+            },
+            "candidate": {
+                "type": ["string", "null"]
+            },
+            "reason": {
+                "type": ["string", "null"]
+            }
+        }
+    })
+}
