+pub fn build_prompt_assistant_child_config(
+    parent: &Config,
+    model: &str,
+    reasoning_effort: Option<ReasoningEffort>,
+    instructions: &str,
+) -> Result<Config> {
+    ensure!(
+        !model.trim().is_empty(),
+        "Prompt Assistant model must not be empty"
+    );
+    ensure!(
+        !instructions.trim().is_empty(),
+        "Prompt Assistant instructions must not be empty"
+    );
+    ensure!(
+        approx_token_count(instructions) <= MAX_FIXED_INSTRUCTION_TOKENS,
+        "Prompt Assistant instructions exceed the {MAX_FIXED_INSTRUCTION_TOKENS}-token limit"
+    );
+
+    let mut config = parent.clone();
+    config.model = Some(model.to_string());
+    config.model_reasoning_effort = reasoning_effort;
+    config.model_reasoning_summary = Some(ReasoningSummary::None);
+    config.model_verbosity = None;
+    config.service_tier = None;
+    config.model_context_window = None;
+    config.model_auto_compact_token_limit = None;
+    config.compact_prompt = None;
+    config.base_instructions = None;
+    config.developer_instructions = Some(instructions.to_string());
+    config.personality = None;
+    config.notify = None;
+    config.ephemeral = false;
+    config.project_doc_max_bytes = 0;
+    config.include_environment_context = false;
+    config.include_permissions_instructions = false;
+    config.include_collaboration_mode_instructions = false;
+    config.include_skill_instructions = false;
+    config.include_apps_instructions = false;
+    config.orchestrator_skills_enabled = false;
+    config.orchestrator_mcp_enabled = false;
+    config
+        .permissions
+        .approval_policy
+        .set(AskForApproval::Never)
+        .context("Prompt Assistant could not disable approval prompts")?;
+    config
+        .permissions
+        .set_permission_profile(PermissionProfile::read_only())
+        .context("Prompt Assistant could not install read-only permissions")?;
+    config
+        .mcp_servers
+        .set(HashMap::new())
+        .context("Prompt Assistant could not clear MCP servers")?;
+    config
+        .web_search_mode
+        .set(WebSearchMode::Disabled)
+        .context("Prompt Assistant could not disable web search")?;
+    config.memories.generate_memories = false;
+    config.memories.use_memories = false;
+    config.memories.dedicated_tools = false;
+    config.token_budget = None;
+    config.rollout_budget = None;
+    config.current_time_reminder = None;
+    config.model_provider.request_max_retries = Some(0);
+    config.model_provider.stream_max_retries = Some(0);
+
+    for feature in [
+        Feature::CodexHooks,
+        Feature::CodeMode,
+        Feature::CodeModeHost,
+        Feature::CodeModeOnly,
+        Feature::WebSearchRequest,
+        Feature::WebSearchCached,
+        Feature::StandaloneWebSearch,
+        Feature::MemoryTool,
+        Feature::Collab,
+        Feature::MultiAgentV2,
+        Feature::Apps,
+        Feature::EnableMcpApps,
+        Feature::Plugins,
+        Feature::ToolSuggest,
+    ] {
+        config
+            .features
+            .disable(feature)
+            .with_context(|| format!("Prompt Assistant could not disable `{}`", feature.key()))?;
+    }
+    Ok(config)
+}
+
+pub async fn load_or_seed_prompt_assistant_instructions(codex_home: &Path) -> Result<String> {
+    let codex_home = codex_home.to_path_buf();
+    tokio::task::spawn_blocking(move || load_or_seed_instructions_sync(&codex_home))
+        .await
+        .context("Prompt Assistant instruction initialization task failed")?
+}
+
+fn load_or_seed_instructions_sync(codex_home: &Path) -> Result<String> {
+    let path = codex_home.join(INSTRUCTIONS_RELATIVE_PATH);
+    if let Ok(existing) = fs::read_to_string(&path)
+        && !existing.trim().is_empty()
+    {
+        if !is_known_bundled_default(&existing) {
+            return Ok(existing);
+        }
+    }
+    let parent = path
+        .parent()
+        .context("Prompt Assistant instruction path has no parent")?;
+    fs::create_dir_all(parent).with_context(|| {
+        format!(
+            "failed to create Prompt Assistant instruction directory {}",
+            parent.display()
+        )
+    })?;
+    let lock_path = path.with_extension("md.seed.lock");
+    let lock = match OpenOptions::new()
+        .write(true)
+        .create_new(true)
+        .open(&lock_path)
+    {
+        Ok(lock) => Some(SeedLock(lock_path.clone(), lock)),
+        Err(err) if err.kind() == ErrorKind::AlreadyExists => None,
+        Err(err) => return Err(err).context("failed to lock Prompt Assistant instruction seed"),
+    };
+    if lock.is_none() {
+        for _ in 0..100 {
+            std::thread::sleep(std::time::Duration::from_millis(10));
+            if let Ok(existing) = fs::read_to_string(&path)
+                && !existing.trim().is_empty()
+            {
+                if !is_known_bundled_default(&existing) {
+                    return Ok(existing);
+                }
+            }
+        }
+        anyhow::bail!("timed out waiting for Prompt Assistant instruction initialization");
+    }
+    if let Ok(existing) = fs::read_to_string(&path)
+        && !existing.trim().is_empty()
+    {
+        if !is_known_bundled_default(&existing) {
+            return Ok(existing);
+        }
+    }
+
+    let sequence = SEED_SEQUENCE.fetch_add(1, Ordering::Relaxed);
+    let temp_path = parent.join(format!(
+        ".prompt-assistant.md.seed.{}.{sequence}",
+        std::process::id()
+    ));
+    let mut temp = OpenOptions::new()
+        .write(true)
+        .create_new(true)
+        .open(&temp_path)
+        .context("failed to stage Prompt Assistant instructions")?;
+    temp.write_all(DEFAULT_INSTRUCTIONS.as_bytes())
+        .context("failed to write Prompt Assistant instructions")?;
+    temp.sync_all()
+        .context("failed to sync Prompt Assistant instructions")?;
+    drop(temp);
+    fs::rename(&temp_path, &path).with_context(|| {
+        format!(
+            "failed to publish Prompt Assistant instructions at {}",
+            path.display()
+        )
+    })?;
+    Ok(DEFAULT_INSTRUCTIONS.to_string())
+}
+
+fn is_known_bundled_default(instructions: &str) -> bool {
+    matches!(
+        instructions,
+        OLD_DEFAULT_INSTRUCTIONS | PREVIOUS_REWRITE_ONLY_DEFAULT_INSTRUCTIONS
+    )
+}
+
+struct SeedLock(PathBuf, fs::File);
+
+impl Drop for SeedLock {
+    fn drop(&mut self) {
+        let _ = self.1.sync_all();
+        let _ = fs::remove_file(&self.0);
+    }
+}
