diff --git a/codex-rs/tui/src/chatwidget/prompt_assistant.rs b/codex-rs/tui/src/chatwidget/prompt_assistant.rs
new file mode 100644
index 0000000000..a4c8a3051d
--- /dev/null
+++ b/codex-rs/tui/src/chatwidget/prompt_assistant.rs
@@ -0,0 +1,399 @@
+use codex_app_server_protocol::PromptAssistantInterruptParams;
+use codex_app_server_protocol::PromptAssistantOutcome;
+use codex_app_server_protocol::PromptAssistantProgressNotification;
+use codex_app_server_protocol::PromptAssistantRewriteParams;
+use codex_app_server_protocol::PromptAssistantRewriteResponse;
+use codex_protocol::openai_models::ReasoningEffort;
+use crossterm::event::KeyCode;
+use crossterm::event::KeyEvent;
+use crossterm::event::KeyEventKind;
+use ratatui::text::Line;
+use std::time::Duration;
+use std::time::Instant;
+
+use super::ChatWidget;
+use crate::app_event::AppEvent;
+
+pub(super) struct PromptAssistantUiState {
+    thread_id: String,
+    selected_model: String,
+    selected_reasoning_effort: ReasoningEffort,
+    working: bool,
+    received_bytes: u64,
+    progress_initialized: bool,
+}
+
+impl ChatWidget {
+    pub(crate) fn set_prompt_assistant_root_thread(&mut self, root_thread: bool) {
+        if self.prompt_assistant_root_thread == root_thread {
+            return;
+        }
+        self.prompt_assistant_root_thread = root_thread;
+        self.refresh_prompt_assistant_footer();
+    }
+
+    pub(crate) fn set_prompt_assistant_binding_label(&mut self, label: String) {
+        self.prompt_assistant_binding_label = label;
+        self.refresh_prompt_assistant_footer();
+    }
+
+    pub(crate) fn prompt_assistant_active(&self) -> bool {
+        self.prompt_assistant
+            .as_ref()
+            .is_some_and(|state| state.working)
+    }
+
+    pub(crate) fn open_prompt_assistant(&mut self) {
+        if !self.prompt_assistant_root_thread
+            || self.prompt_assistant_active()
+            || self.bottom_pane.is_task_running()
+        {
+            return;
+        }
+        let Some(thread_id) = self.thread_id else {
+            return;
+        };
+        let source = self.bottom_pane.composer_draft_snapshot();
+        if source.text.is_empty()
+            || !source.local_images.is_empty()
+            || !source.remote_image_urls.is_empty()
+        {
+            return;
+        }
+        let Some((model, effort)) =
+            self.prompt_assistant_selection_for_thread(&thread_id.to_string())
+        else {
+            return;
+        };
+        self.bottom_pane
+            .record_current_composer_draft_local_history();
+        if let Some(state) = self.prompt_assistant.as_mut() {
+            state.working = true;
+            state.received_bytes = 0;
+            state.progress_initialized = false;
+        } else {
+            self.prompt_assistant = Some(PromptAssistantUiState {
+                thread_id: thread_id.to_string(),
+                selected_model: model.clone(),
+                selected_reasoning_effort: effort.clone(),
+                working: true,
+                received_bytes: 0,
+                progress_initialized: false,
+            });
+        }
+        self.bottom_pane.clear_response_output_bytes();
+        self.bottom_pane.set_composer_input_enabled(false, None);
+        self.bottom_pane.ensure_status_indicator();
+        self.bottom_pane.set_status_timer_started_at(Instant::now());
+        self.bottom_pane.update_status(
+            "Rewriting prompt".to_string(),
+            None,
+            crate::status_indicator_widget::StatusDetailsCapitalization::Preserve,
+            1,
+        );
+        self.refresh_prompt_assistant_footer();
+        self.app_event_tx.send(AppEvent::PromptAssistantRewrite(
+            PromptAssistantRewriteParams {
+                thread_id: thread_id.to_string(),
+                input: self.bottom_pane.composer_text_with_pending(),
+                model,
+                reasoning_effort: effort,
+            },
+        ));
+        self.request_redraw();
+    }
+
+    pub(crate) fn handle_prompt_assistant_key_event(&mut self, key_event: KeyEvent) -> bool {
+        if !self.prompt_assistant_active() || key_event.kind != KeyEventKind::Press {
+            return false;
+        }
+        if matches!(key_event.code, KeyCode::Esc) {
+            self.request_prompt_assistant_interrupt();
+        }
+        true
+    }
+
+    pub(crate) fn prompt_assistant_rewrite_finished(
+        &mut self,
+        thread_id: String,
+        result: Result<PromptAssistantRewriteResponse, String>,
+    ) {
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if state.thread_id != thread_id {
+            return;
+        }
+        state.working = false;
+        if self
+            .thread_id
+            .is_none_or(|current| current.to_string() != thread_id)
+        {
+            return;
+        }
+        self.bottom_pane.clear_response_output_bytes();
+        self.bottom_pane.hide_status_indicator();
+        self.bottom_pane.set_composer_input_enabled(true, None);
+        match result {
+            Ok(response) => {
+                if response.outcome == PromptAssistantOutcome::Ready {
+                    if let Some(candidate) = response
+                        .candidate
+                        .as_ref()
+                        .filter(|candidate| !candidate.is_empty())
+                    {
+                        self.bottom_pane.set_composer_text(
+                            candidate.clone(),
+                            Vec::new(),
+                            Vec::new(),
+                        );
+                    }
+                }
+                self.show_prompt_assistant_terminal_flash(&response);
+            }
+            Err(reason) => self.add_error_message(format!("Prompt Assistant failed: {reason}")),
+        }
+        self.refresh_prompt_assistant_footer();
+        self.request_redraw();
+    }
+
+    pub(crate) fn on_prompt_assistant_progress(
+        &mut self,
+        notification: PromptAssistantProgressNotification,
+    ) {
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if state.thread_id != notification.thread_id
+            || self
+                .thread_id
+                .is_none_or(|current| current.to_string() != notification.thread_id)
+            || notification.received_bytes < state.received_bytes
+        {
+            return;
+        }
+        let delta = notification.received_bytes - state.received_bytes;
+        if !state.progress_initialized {
+            self.bottom_pane
+                .update_response_output_bytes(&notification.thread_id, 0, true);
+            state.progress_initialized = true;
+        }
+        state.received_bytes = notification.received_bytes;
+        self.bottom_pane
+            .update_response_output_bytes(&notification.thread_id, delta, false);
+    }
+
+    fn request_prompt_assistant_interrupt(&mut self) {
+        let Some(state) = self.prompt_assistant.as_ref() else {
+            return;
+        };
+        self.app_event_tx.send(AppEvent::PromptAssistantInterrupt(
+            PromptAssistantInterruptParams {
+                thread_id: state.thread_id.clone(),
+            },
+        ));
+    }
+
+    pub(crate) fn show_prompt_assistant_interrupt_error(&mut self, error: String) {
+        self.add_error_message(format!("Prompt Assistant interrupt failed: {error}"));
+    }
+
+    fn prompt_assistant_selection(&self) -> Option<(String, ReasoningEffort)> {
+        let models = self.model_catalog.try_list_models().ok()?;
+        let selected = models
+            .iter()
+            .find(|preset| !preset.show_in_picker)
+            .or_else(|| {
+                models
+                    .iter()
+                    .find(|preset| preset.model == self.current_model())
+            })
+            .or_else(|| models.iter().find(|preset| preset.show_in_picker))?;
+        Some((
+            selected.model.clone(),
+            selected.default_reasoning_effort.clone(),
+        ))
+    }
+
+    fn prompt_assistant_selection_for_thread(
+        &mut self,
+        thread_id: &str,
+    ) -> Option<(String, ReasoningEffort)> {
+        if let Some(state) = self.prompt_assistant.as_ref()
+            && state.thread_id == thread_id
+        {
+            return Some((
+                state.selected_model.clone(),
+                state.selected_reasoning_effort.clone(),
+            ));
+        }
+        let (model, effort) = self.prompt_assistant_selection()?;
+        self.prompt_assistant = Some(PromptAssistantUiState {
+            thread_id: thread_id.to_string(),
+            selected_model: model.clone(),
+            selected_reasoning_effort: effort.clone(),
+            working: false,
+            received_bytes: 0,
+            progress_initialized: false,
+        });
+        Some((model, effort))
+    }
+
+    pub(super) fn handle_prompt_assistant_model_shortcut(&mut self, next: bool) -> bool {
+        if !self.prompt_assistant_root_thread
+            || self.bottom_pane.composer_is_empty()
+            || self.bottom_pane.is_task_running()
+        {
+            return false;
+        }
+        let Some(thread_id) = self.thread_id else {
+            return true;
+        };
+        let Some((current, _)) = self.prompt_assistant_selection_for_thread(&thread_id.to_string())
+        else {
+            return true;
+        };
+        let choices = self.prompt_assistant_models();
+        let Some(current_index) = choices.iter().position(|preset| preset.model == current) else {
+            return true;
+        };
+        let index = if next {
+            (current_index + 1) % choices.len()
+        } else {
+            (current_index + choices.len() - 1) % choices.len()
+        };
+        if let Some(state) = self.prompt_assistant.as_mut()
+            && let Some(model) = choices.get(index)
+        {
+            state.selected_model = model.model.clone();
+            state.selected_reasoning_effort = model.default_reasoning_effort.clone();
+        }
+        self.refresh_prompt_assistant_footer();
+        self.request_redraw();
+        true
+    }
+
+    pub(super) fn handle_prompt_assistant_reasoning_shortcut(&mut self, raise: bool) -> bool {
+        if !self.prompt_assistant_root_thread
+            || self.bottom_pane.composer_is_empty()
+            || self.bottom_pane.is_task_running()
+        {
+            return false;
+        }
+        let Some(thread_id) = self.thread_id else {
+            return true;
+        };
+        let Some((model, current)) =
+            self.prompt_assistant_selection_for_thread(&thread_id.to_string())
+        else {
+            return true;
+        };
+        let Some(preset) = self
+            .prompt_assistant_models()
+            .into_iter()
+            .find(|preset| preset.model == model)
+        else {
+            return true;
+        };
+        let choices = super::reasoning_shortcuts::reasoning_choices(&preset);
+        let Some(index) = choices.iter().position(|effort| effort == &current) else {
+            return true;
+        };
+        let next_index = if raise {
+            index + 1
+        } else {
+            index.saturating_sub(1)
+        };
+        if let Some(next_effort) = choices.get(next_index).cloned()
+            && let Some(state) = self.prompt_assistant.as_mut()
+        {
+            state.selected_reasoning_effort = next_effort;
+            self.refresh_prompt_assistant_footer();
+            self.request_redraw();
+        }
+        true
+    }
+
+    fn prompt_assistant_models(&self) -> Vec<codex_protocol::openai_models::ModelPreset> {
+        let models = match self.model_catalog.try_list_models() {
+            Ok(models) => models,
+            Err(err) => match err {},
+        };
+        let (hidden, listed): (Vec<_>, Vec<_>) = models
+            .into_iter()
+            .partition(|preset| !preset.show_in_picker);
+        hidden.into_iter().chain(listed).collect()
+    }
+
+    pub(super) fn refresh_prompt_assistant_footer(&mut self) {
+        let hint = if !self.bottom_pane.is_task_running()
+            && !self.prompt_assistant_active()
+            && self.prompt_assistant_root_thread
+            && self.bottom_pane.no_modal_or_popup_active()
+        {
+            let source = self.bottom_pane.composer_draft_snapshot();
+            if !source.text.is_empty()
+                && source.local_images.is_empty()
+                && source.remote_image_urls.is_empty()
+            {
+                self.thread_id
+                    .and_then(|thread_id| {
+                        self.prompt_assistant_selection_for_thread(&thread_id.to_string())
+                    })
+                    .map(|(model, effort)| {
+                        vec![(
+                            self.prompt_assistant_binding_label.clone(),
+                            format!(
+                                "Prompt Assistant request: {model} {effort} - translate and organize"
+                            ),
+                        )]
+                    })
+            } else {
+                None
+            }
+        } else {
+            None
+        };
+        self.bottom_pane.set_footer_hint_override(hint);
+    }
+
+    fn show_prompt_assistant_terminal_flash(&mut self, response: &PromptAssistantRewriteResponse) {
+        let outcome = match response.outcome {
+            PromptAssistantOutcome::Ready => "Prompt Assistant complete",
+            PromptAssistantOutcome::Blocked => "Prompt Assistant blocked",
+            PromptAssistantOutcome::Interrupted => "Prompt Assistant cancelled",
+            PromptAssistantOutcome::Failed => "Prompt Assistant failed",
+        };
+        let detail = response.reason.as_deref().unwrap_or("");
+        let fallback = response
+            .fallback_from_model
+            .as_deref()
+            .map(|model| format!(" (fallback from {model})"))
+            .unwrap_or_default();
+        let usage = response
+            .usage
+            .as_ref()
+            .map(|usage| {
+                format!(
+                    " total {} in {} cached {} cache-write {} out {} reasoning {}",
+                    crate::status::format_tokens_compact(usage.total_tokens as i64),
+                    crate::status::format_tokens_compact(usage.input_tokens as i64),
+                    crate::status::format_tokens_compact(usage.cached_input_tokens as i64),
+                    crate::status::format_tokens_compact(usage.cache_write_input_tokens as i64),
+                    crate::status::format_tokens_compact(usage.output_tokens as i64),
+                    crate::status::format_tokens_compact(usage.reasoning_output_tokens as i64),
+                )
+            })
+            .unwrap_or_default();
+        let message = format!(
+            "{outcome}: {} {}{fallback} {detail}{usage}",
+            response.effective_model, response.effective_reasoning_effort,
+        );
+        if response.outcome == PromptAssistantOutcome::Failed {
+            self.add_error_message(message);
+        } else {
+            self.bottom_pane
+                .show_footer_flash(Line::from(message), Duration::from_secs(5));
+        }
+    }
+}
