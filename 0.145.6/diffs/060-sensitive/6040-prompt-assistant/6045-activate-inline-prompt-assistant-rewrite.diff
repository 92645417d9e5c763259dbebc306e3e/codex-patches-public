+#[tokio::test]
+async fn prompt_assistant_failure_preserves_source() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let thread_id = ThreadId::new();
+    chat.thread_id = Some(thread_id);
+    let source = "保留 Tab 按键的行为。\n保留 hook 的说明。".to_string();
+    chat.bottom_pane
+        .set_composer_text(source.clone(), Vec::new(), Vec::new());
+
+    chat.open_prompt_assistant();
+    let params = match rx.try_recv().expect("rewrite request") {
+        AppEvent::PromptAssistantRewrite(params) => params,
+        other => panic!("unexpected event: {other:?}"),
+    };
+    assert_eq!(params.input, source.as_str());
+    chat.prompt_assistant_rewrite_finished(
+        thread_id.to_string(),
+        Err(
+            "promptAssistant/rewrite failed: Prompt Assistant cannot run while the parent turn is active (code -32602)"
+                .to_string(),
+        ),
+    );
+
+    assert_eq!(chat.bottom_pane.composer_text(), source);
+    assert!(chat.bottom_pane.composer_input_enabled());
+    let rendered = drain_insert_history(&mut rx)
+        .into_iter()
+        .flatten()
+        .map(|line| line.to_string())
+        .collect::<Vec<_>>()
+        .join("\n");
+    assert!(rendered.contains("Prompt Assistant failed: promptAssistant/rewrite failed:"));
+    assert!(rendered.contains("cannot run while the parent turn is active"));
+}
