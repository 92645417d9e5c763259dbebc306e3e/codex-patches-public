+        let texts = history
+            .iter()
+            .map(|item| match item {
+                ResponseItem::Message { content, .. } => match &content[0] {
+                    ContentItem::InputText { text } => text.as_str(),
+                    _ => unreachable!(),
+                },
+                _ => unreachable!(),
+            })
+            .collect::<Vec<_>>();
+        assert_eq!(texts, ["parent", "source", "output"]);
+    }
