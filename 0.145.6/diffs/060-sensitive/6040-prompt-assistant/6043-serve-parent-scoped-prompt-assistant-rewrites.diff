--- /dev/null
+++ b/codex-rs/app-server/src/request_processors/prompt_assistant_processor.rs
@@ -0,0 +1,860 @@
+use std::collections::HashMap;
+use std::sync::Arc;
+use std::time::Duration;
+
+use codex_app_server_protocol::JSONRPCErrorError;
+use codex_app_server_protocol::PromptAssistantInterruptParams;
+use codex_app_server_protocol::PromptAssistantInterruptResponse;
+use codex_app_server_protocol::PromptAssistantOutcome;
+use codex_app_server_protocol::PromptAssistantProgressNotification;
+use codex_app_server_protocol::PromptAssistantRewriteParams;
+use codex_app_server_protocol::PromptAssistantRewriteResponse;
+use codex_app_server_protocol::ServerNotification;
+use codex_app_server_protocol::TokenUsageBreakdown;
+use codex_core::CodexThread;
+use codex_core::PromptAssistantFrozenContext;
+use codex_core::PromptAssistantOutputStatus;
+use codex_core::ThreadManager;
+use codex_core::load_or_seed_prompt_assistant_instructions;
+use codex_core::parse_prompt_assistant_output;
+use codex_core::prompt_assistant_output_schema;
+use codex_core::prompt_assistant_projection_items;
+use codex_core::prompt_assistant_projection_update;
+use codex_core::prompt_assistant_usage_delta;
+use codex_core::validate_prompt_assistant_source_context_fit;
+use codex_protocol::ThreadId;
+use codex_protocol::models::ContentItem;
+use codex_protocol::models::MessagePhase;
+use codex_protocol::models::ResponseItem;
+use codex_protocol::openai_models::ModelInfo;
+use codex_protocol::openai_models::ModelVisibility;
+use codex_protocol::openai_models::ReasoningEffort;
+use codex_protocol::protocol::AgentStatus;
+use codex_protocol::protocol::EventMsg;
+use codex_protocol::protocol::Op;
+use codex_protocol::protocol::ThreadSettingsOverrides;
+use codex_protocol::protocol::TokenUsage;
+use codex_protocol::user_input::UserInput;
+use tokio::sync::Mutex;
+use tokio::sync::Semaphore;
+use tokio::time::timeout;
+use tokio_util::sync::CancellationToken;
+
+use crate::error_code::invalid_params;
+use crate::outgoing_message::ConnectionId;
+use crate::outgoing_message::OutgoingMessageSender;
+
+const OPERATION_TIMEOUT: Duration = Duration::from_secs(5 * 60);
+const INTERRUPT_DRAIN_TIMEOUT: Duration = Duration::from_secs(10);
+
+#[derive(Clone)]
+pub(crate) struct PromptAssistantRequestProcessor {
+    inner: Arc<Inner>,
+}
+
+struct Inner {
+    thread_manager: Arc<ThreadManager>,
+    outgoing: Arc<OutgoingMessageSender>,
+    trunks: Mutex<HashMap<ThreadId, Arc<Trunk>>>,
+}
+
+struct Trunk {
+    child: Mutex<Option<Arc<CodexThread>>>,
+    synchronized_projection: Mutex<PromptAssistantFrozenContext>,
+    committed_turns: Mutex<Vec<ResponseItem>>,
+    active: Mutex<Option<ActiveRewrite>>,
+    rewrite_lock: Arc<Semaphore>,
+}
+
+struct ActiveRewrite {
+    connection_id: ConnectionId,
+    cancellation: CancellationToken,
+    completion: CancellationToken,
+}
+
+enum RewriteResult {
+    Ready(String, String),
+    Blocked(String, String),
+    Interrupted,
+    Failed(String),
+}
+
+impl PromptAssistantRequestProcessor {
+    pub(crate) fn new(
+        thread_manager: Arc<ThreadManager>,
+        outgoing: Arc<OutgoingMessageSender>,
+    ) -> Self {
+        Self {
+            inner: Arc::new(Inner {
+                thread_manager,
+                outgoing,
+                trunks: Mutex::new(HashMap::new()),
+            }),
+        }
+    }
+
+    pub(crate) async fn rewrite(
+        &self,
+        connection_id: ConnectionId,
+        params: PromptAssistantRewriteParams,
+    ) -> Result<PromptAssistantRewriteResponse, JSONRPCErrorError> {
+        if params.input.trim().is_empty() {
+            return Err(invalid_params("Prompt Assistant input must not be empty"));
+        }
+        let thread_id = parse_thread_id(&params.thread_id)?;
+        let parent = self
+            .inner
+            .thread_manager
+            .get_thread(thread_id)
+            .await
+            .map_err(|err| invalid_params(err.to_string()))?;
+        let config_snapshot = parent.config_snapshot().await;
+        if config_snapshot.session_source.is_non_root_agent() {
+            return Err(invalid_params(
+                "Prompt Assistant is available only from the root session",
+            ));
+        }
+        if matches!(
+            parent.agent_status().await,
+            AgentStatus::PendingInit | AgentStatus::Running
+        ) {
+            return Err(invalid_params(
+                "Prompt Assistant cannot run while the parent turn is active",
+            ));
+        }
+
+        let guardian_model = parent.guardian_review_model_id().await;
+        let models = eligible_models(
+            self.inner
+                .thread_manager
+                .get_models_manager()
+                .get_remote_models()
+                .await,
+            &guardian_model,
+        );
+        let (effective_model, effective_effort, fallback_from_model) = effective_selection(
+            &models,
+            &params.model,
+            &params.reasoning_effort,
+            &config_snapshot.model,
+            config_snapshot.reasoning_effort.as_ref(),
+        )?;
+        let model_context_limit = models
+            .iter()
+            .find(|model| model.slug == effective_model)
+            .and_then(ModelInfo::auto_compact_token_limit);
+        let trunk = self.trunk_for(thread_id).await;
+        let permit = Arc::clone(&trunk.rewrite_lock)
+            .try_acquire_owned()
+            .map_err(|_| invalid_params("Prompt Assistant rewrite is already active"))?;
+        let cancellation = CancellationToken::new();
+        let completion = CancellationToken::new();
+        {
+            let mut active = trunk.active.lock().await;
+            if active.is_some() {
+                return Err(invalid_params("Prompt Assistant rewrite is already active"));
+            }
+            *active = Some(ActiveRewrite {
+                connection_id,
+                cancellation: cancellation.clone(),
+                completion: completion.clone(),
+            });
+        }
+
+        let result = self
+            .run_rewrite(
+                thread_id,
+                connection_id,
+                &parent,
+                &trunk,
+                cancellation,
+                &params.input,
+                &effective_model,
+                effective_effort.clone(),
+                model_context_limit,
+            )
+            .await;
+        *trunk.active.lock().await = None;
+        completion.cancel();
+        drop(permit);
+
+        let (outcome, candidate, reason, usage) = result;
+        Ok(PromptAssistantRewriteResponse {
+            outcome,
+            candidate,
+            reason,
+            effective_model,
+            effective_reasoning_effort: effective_effort,
+            fallback_from_model,
+            usage,
+        })
+    }
+
+    pub(crate) async fn interrupt(
+        &self,
+        _connection_id: ConnectionId,
+        params: PromptAssistantInterruptParams,
+    ) -> Result<PromptAssistantInterruptResponse, JSONRPCErrorError> {
+        let thread_id = parse_thread_id(&params.thread_id)?;
+        let trunk = self
+            .inner
+            .trunks
+            .lock()
+            .await
+            .get(&thread_id)
+            .cloned()
+            .ok_or_else(|| invalid_params("Prompt Assistant has no active rewrite"))?;
+        if !cancel_active_rewrite(&trunk, |_| true).await {
+            return Err(invalid_params("Prompt Assistant has no active rewrite"));
+        }
+        Ok(PromptAssistantInterruptResponse::default())
+    }
+
+    pub(crate) async fn connection_closed(&self, connection_id: ConnectionId) {
+        let trunks = self
+            .inner
+            .trunks
+            .lock()
+            .await
+            .values()
+            .cloned()
+            .collect::<Vec<_>>();
+        for trunk in trunks {
+            cancel_active_rewrite(&trunk, |active| active.connection_id == connection_id).await;
+        }
+    }
+
+    pub(crate) async fn parent_turn_started(&self, thread_id: ThreadId) {
+        if let Some(trunk) = self.inner.trunks.lock().await.get(&thread_id).cloned() {
+            cancel_active_rewrite(&trunk, |_| true).await;
+        }
+    }
+
+    pub(crate) async fn parent_removed(&self, thread_id: ThreadId) {
+        let trunk = self.inner.trunks.lock().await.remove(&thread_id);
+        if let Some(trunk) = trunk {
+            cancel_active_rewrite(&trunk, |_| true).await;
+            if let Some(child) = trunk.child.lock().await.take() {
+                let _ = child.shutdown_and_wait().await;
+            }
+        }
+    }
+
+    pub(crate) async fn shutdown(&self) {
+        let trunks = {
+            let mut trunks = self.inner.trunks.lock().await;
+            std::mem::take(&mut *trunks)
+        };
+        for (_, trunk) in trunks {
+            cancel_active_rewrite(&trunk, |_| true).await;
+            if let Some(child) = trunk.child.lock().await.take() {
+                let _ = child.shutdown_and_wait().await;
+            }
+        }
+    }
+
+    async fn trunk_for(&self, thread_id: ThreadId) -> Arc<Trunk> {
+        let mut trunks = self.inner.trunks.lock().await;
+        Arc::clone(trunks.entry(thread_id).or_insert_with(|| {
+            Arc::new(Trunk {
+                child: Mutex::new(None),
+                synchronized_projection: Mutex::new(PromptAssistantFrozenContext::default()),
+                committed_turns: Mutex::new(Vec::new()),
+                active: Mutex::new(None),
+                rewrite_lock: Arc::new(Semaphore::new(1)),
+            })
+        }))
+    }
+
+    async fn run_rewrite(
+        &self,
+        thread_id: ThreadId,
+        connection_id: ConnectionId,
+        parent: &Arc<CodexThread>,
+        trunk: &Arc<Trunk>,
+        cancellation: CancellationToken,
+        input: &str,
+        model: &str,
+        effort: ReasoningEffort,
+        model_context_limit: Option<i64>,
+    ) -> (
+        PromptAssistantOutcome,
+        Option<String>,
+        Option<String>,
+        Option<TokenUsageBreakdown>,
+    ) {
+        let child = match self
+            .child_for(thread_id, parent, trunk, model, effort.clone())
+            .await
+        {
+            Ok(child) => child,
+            Err(err) => return (PromptAssistantOutcome::Failed, None, Some(err), None),
+        };
+        if let Err(err) = self.sync_projection(parent, trunk, &child).await {
+            return (PromptAssistantOutcome::Failed, None, Some(err), None);
+        }
+        let active_context_tokens = match child.prompt_assistant_active_context_tokens().await {
+            Ok(tokens) => tokens,
+            Err(err) => {
+                return (
+                    PromptAssistantOutcome::Failed,
+                    None,
+                    Some(err.to_string()),
+                    None,
+                );
+            }
+        };
+        if let Err(err) = validate_prompt_assistant_source_context_fit(
+            input,
+            active_context_tokens,
+            model_context_limit,
+        ) {
+            return (
+                PromptAssistantOutcome::Failed,
+                None,
+                Some(err.to_string()),
+                None,
+            );
+        }
+        let usage_start = child
+            .token_usage_info()
+            .await
+            .map(|usage| usage.total_token_usage);
+        let child_config = child.config_snapshot().await;
+        if (child_config.model != model || child_config.reasoning_effort.as_ref() != Some(&effort))
+            && let Err(err) = child
+                .submit(Op::ThreadSettings {
+                    thread_settings: ThreadSettingsOverrides {
+                        model: Some(model.to_string()),
+                        effort: Some(Some(effort)),
+                        ..Default::default()
+                    },
+                })
+                .await
+        {
+            return (
+                PromptAssistantOutcome::Failed,
+                None,
+                Some(err.to_string()),
+                None,
+            );
+        }
+        let submitted_turn_id = match child
+            .submit(Op::UserInput {
+                items: vec![UserInput::Text {
+                    text: input.to_string(),
+                    text_elements: Vec::new(),
+                }],
+                final_output_json_schema: Some(prompt_assistant_output_schema()),
+                responsesapi_client_metadata: None,
+                additional_context: Default::default(),
+                thread_settings: Default::default(),
+            })
+            .await
+        {
+            Ok(turn_id) => turn_id,
+            Err(err) => {
+                return (
+                    PromptAssistantOutcome::Failed,
+                    None,
+                    Some(err.to_string()),
+                    None,
+                );
+            }
+        };
+        let terminal_cancellation = cancellation.clone();
+        let mut result = match timeout(
+            OPERATION_TIMEOUT,
+            self.consume_events(
+                thread_id,
+                connection_id,
+                &child,
+                cancellation,
+                &submitted_turn_id,
+            ),
+        )
+        .await
+        {
+            Ok(result) => result,
+            Err(_) => {
+                let _ = child.submit(Op::Interrupt).await;
+                let _ = timeout(
+                    INTERRUPT_DRAIN_TIMEOUT,
+                    self.consume_events(
+                        thread_id,
+                        connection_id,
+                        &child,
+                        CancellationToken::new(),
+                        &submitted_turn_id,
+                    ),
+                )
+                .await;
+                RewriteResult::Failed("Prompt Assistant operation timed out".to_string())
+            }
+        };
+        if terminal_cancellation.is_cancelled() {
+            result = RewriteResult::Interrupted;
+        }
+        let usage_end = child
+            .token_usage_info()
+            .await
+            .map(|usage| usage.total_token_usage);
+        let usage = rewrite_usage_delta(usage_start, usage_end);
+        match result {
+            RewriteResult::Ready(candidate, output) => {
+                self.record_committed_turn(trunk, input, &output).await;
+                (PromptAssistantOutcome::Ready, Some(candidate), None, usage)
+            }
+            RewriteResult::Blocked(reason, output) => {
+                self.record_committed_turn(trunk, input, &output).await;
+                (PromptAssistantOutcome::Blocked, None, Some(reason), usage)
+            }
+            RewriteResult::Interrupted => (PromptAssistantOutcome::Interrupted, None, None, usage),
+            RewriteResult::Failed(reason) => {
+                (PromptAssistantOutcome::Failed, None, Some(reason), usage)
+            }
+        }
+    }
+
+    async fn child_for(
+        &self,
+        thread_id: ThreadId,
+        parent: &Arc<CodexThread>,
+        trunk: &Arc<Trunk>,
+        model: &str,
+        effort: ReasoningEffort,
+    ) -> Result<Arc<CodexThread>, String> {
+        if let Some(child) = trunk.child.lock().await.as_ref() {
+            return Ok(Arc::clone(child));
+        }
+        let config = parent.config().await;
+        let instructions = load_or_seed_prompt_assistant_instructions(config.codex_home.as_path())
+            .await
+            .map_err(|err| err.to_string())?;
+        let child = self
+            .inner
+            .thread_manager
+            .start_prompt_assistant_child(thread_id, model, Some(effort), &instructions)
+            .await
+            .map_err(|err| err.to_string())?
+            .thread;
+        *trunk.child.lock().await = Some(Arc::clone(&child));
+        Ok(child)
+    }
+
+    async fn sync_projection(
+        &self,
+        parent: &Arc<CodexThread>,
+        trunk: &Arc<Trunk>,
+        child: &Arc<CodexThread>,
+    ) -> Result<(), String> {
+        let current = parent.prompt_assistant_context_snapshot().await;
+        let mut synchronized = trunk.synchronized_projection.lock().await;
+        match prompt_assistant_projection_update(&synchronized, &current) {
+            codex_core::PromptAssistantProjectionUpdate::Append(entries) if !entries.is_empty() => {
+                child
+                    .inject_response_items(prompt_assistant_projection_items(&entries))
+                    .await
+                    .map_err(|err| err.to_string())?;
+            }
+            codex_core::PromptAssistantProjectionUpdate::Replace(entries) => {
+                let history = replacement_history(
+                    prompt_assistant_projection_items(&entries),
+                    trunk.committed_turns.lock().await.clone(),
+                );
+                child
+                    .replace_prompt_assistant_history(history)
+                    .await
+                    .map_err(|err| err.to_string())?;
+            }
+            _ => {}
+        }
+        *synchronized = current;
+        Ok(())
+    }
+
+    async fn record_committed_turn(&self, trunk: &Arc<Trunk>, input: &str, output: &str) {
+        trunk.committed_turns.lock().await.extend([
+            ResponseItem::Message {
+                id: None,
+                role: "user".to_string(),
+                content: vec![ContentItem::InputText {
+                    text: input.to_string(),
+                }],
+                phase: None,
+                internal_chat_message_metadata_passthrough: None,
+            },
+            ResponseItem::Message {
+                id: None,
+                role: "assistant".to_string(),
+                content: vec![ContentItem::OutputText {
+                    text: output.to_string(),
+                }],
+                phase: Some(MessagePhase::FinalAnswer),
+                internal_chat_message_metadata_passthrough: None,
+            },
+        ]);
+    }
+
+    async fn consume_events(
+        &self,
+        thread_id: ThreadId,
+        connection_id: ConnectionId,
+        child: &Arc<CodexThread>,
+        cancellation: CancellationToken,
+        submitted_turn_id: &str,
+    ) -> RewriteResult {
+        let mut received_bytes: u64 = 0;
+        let mut interrupt_sent = false;
+        loop {
+            tokio::select! {
+                () = cancellation.cancelled(), if !interrupt_sent => {
+                    interrupt_sent = true;
+                    let _ = child.submit(Op::Interrupt).await;
+                }
+                event = child.next_event() => {
+                    let event = match event { Ok(event) => event, Err(err) => return RewriteResult::Failed(err.to_string()) };
+                    match event.msg {
+                        EventMsg::ResponseOutputBytesDelta(delta) if delta.byte_count > 0 => {
+                            received_bytes = received_bytes.saturating_add(delta.byte_count);
+                            self.inner.outgoing.send_server_notification_to_connections(&[connection_id], ServerNotification::PromptAssistantProgress(PromptAssistantProgressNotification { thread_id: thread_id.to_string(), received_bytes })).await;
+                        }
+                        EventMsg::TurnComplete(complete) if complete.turn_id == submitted_turn_id => {
+                            if let Some(error) = complete.error { return RewriteResult::Failed(error.message); }
+                            let Some(output) = complete.last_agent_message else { return RewriteResult::Failed("Prompt Assistant completed without output".to_string()); };
+                            let raw_output = output.clone();
+                            return match parse_prompt_assistant_output(&output) {
+                                Ok(output) if output.status == PromptAssistantOutputStatus::Ready => RewriteResult::Ready(output.candidate.expect("validated ready candidate"), raw_output),
+                                Ok(output) => RewriteResult::Blocked(output.reason.expect("validated blocked reason"), raw_output),
+                                Err(err) => RewriteResult::Failed(err.to_string()),
+                            };
+                        }
+                        EventMsg::TurnAborted(aborted) if aborted.turn_id.as_deref() == Some(submitted_turn_id) => return RewriteResult::Interrupted,
+                        EventMsg::ExecApprovalRequest(_) | EventMsg::ApplyPatchApprovalRequest(_) | EventMsg::McpToolCallBegin(_) | EventMsg::McpToolCallEnd(_) => {
+                            let _ = child.submit(Op::Interrupt).await;
+                            return RewriteResult::Failed("Prompt Assistant isolation violation".to_string());
+                        }
+                        _ => {}
+                    }
+                }
+            }
+        }
+    }
+}
+
+fn replacement_history(
+    projected_parent: Vec<ResponseItem>,
+    committed_turns: Vec<ResponseItem>,
+) -> Vec<ResponseItem> {
+    projected_parent
+        .into_iter()
+        .chain(committed_turns)
+        .collect()
+}
+
+fn rewrite_usage_delta(
+    start: Option<TokenUsage>,
+    end: Option<TokenUsage>,
+) -> Option<TokenUsageBreakdown> {
+    start
+        .zip(end)
+        .map(|(start, end)| prompt_assistant_usage_delta(&start, &end).into())
+}
+
+async fn cancel_active_rewrite(
+    trunk: &Trunk,
+    predicate: impl FnOnce(&ActiveRewrite) -> bool,
+) -> bool {
+    let cancellation = {
+        let active = trunk.active.lock().await;
+        active
+            .as_ref()
+            .filter(|active| predicate(active))
+            .map(|active| (active.cancellation.clone(), active.completion.clone()))
+    };
+    let Some((cancellation, completion)) = cancellation else {
+        return false;
+    };
+    cancellation.cancel();
+    let _ = timeout(INTERRUPT_DRAIN_TIMEOUT, completion.cancelled()).await;
+    true
+}
+
+fn parse_thread_id(value: &str) -> Result<ThreadId, JSONRPCErrorError> {
+    ThreadId::from_string(value).map_err(|err| invalid_params(err.to_string()))
+}
+
+fn eligible_models(mut models: Vec<ModelInfo>, guardian_model: &str) -> Vec<ModelInfo> {
+    models
+        .retain(|model| model.visibility != ModelVisibility::None && model.slug != guardian_model);
+    models.sort_by_key(|model| {
+        (
+            matches!(model.visibility, ModelVisibility::List),
+            model.priority,
+        )
+    });
+    models
+}
+
+fn supports_effort(model: &ModelInfo, effort: &ReasoningEffort) -> bool {
+    model.default_reasoning_level.as_ref() == Some(effort)
+        || model
+            .supported_reasoning_levels
+            .iter()
+            .any(|preset| &preset.effort == effort)
+}
+
+fn effective_selection(
+    models: &[ModelInfo],
+    requested_model: &str,
+    requested_effort: &ReasoningEffort,
+    current_model: &str,
+    current_effort: Option<&ReasoningEffort>,
+) -> Result<(String, ReasoningEffort, Option<String>), JSONRPCErrorError> {
+    if let Some(model) = models
+        .iter()
+        .find(|model| model.slug == requested_model)
+        .filter(|model| supports_effort(model, requested_effort))
+    {
+        return Ok((model.slug.clone(), requested_effort.clone(), None));
+    }
+    let model = models
+        .iter()
+        .find(|model| model.slug == current_model)
+        .or_else(|| models.first())
+        .ok_or_else(|| {
+            invalid_params("Prompt Assistant has no eligible model after Guardian exclusion")
+        })?;
+    let effort = current_effort
+        .filter(|effort| supports_effort(model, effort))
+        .cloned()
+        .or_else(|| model.default_reasoning_level.clone())
+        .or_else(|| {
+            model
+                .supported_reasoning_levels
+                .first()
+                .map(|preset| preset.effort.clone())
+        })
+        .unwrap_or(ReasoningEffort::Medium);
+    Ok((
+        model.slug.clone(),
+        effort,
+        Some(requested_model.to_string()),
+    ))
+}
