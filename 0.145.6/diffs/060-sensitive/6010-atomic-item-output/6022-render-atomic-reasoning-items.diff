+#[test]
+fn atomic_reasoning_response_groups_parts_under_three_item_identities() {
+    let cells = new_atomic_reasoning_response_blocks(
+        vec![
+            (
+                "rs_first".to_string(),
+                vec![
+                    "**Distinguishing source changes from installed binary**".to_string(),
+                    "**Reviewing current improvements before committing**".to_string(),
+                    "**Preparing concise commentary for observation**".to_string(),
+                ],
+            ),
+            (
+                "rs_second".to_string(),
+                vec![
+                    "**Planning chain grouping implementation**".to_string(),
+                    "**Designing buffering and flushing logic**".to_string(),
+                    "**Defining PendingAtomicReasoningItem structure**".to_string(),
+                ],
+            ),
+            (
+                "rs_third".to_string(),
+                vec![
+                    "**Designing atomic reasoning response builder**".to_string(),
+                    "**Assessing replay preorganization scope**".to_string(),
+                    "**Outlining replay grouping plan**".to_string(),
+                ],
+            ),
+        ],
+        &test_cwd(),
+        Some(1_402),
+    );
+
+    let rendered = cells
+        .iter()
+        .flat_map(|cell| render_transcript(cell.as_ref()))
+        .collect::<Vec<_>>();
+    assert_eq!(
+        rendered,
+        vec![
+            "▪ Distinguishing source changes from installed binary ▪ first ▪ 1,402 tokens",
+            "  Reviewing current improvements before committing",
+            "  Preparing concise commentary for observation",
+            "▪ Planning chain grouping implementation ▪ second",
+            "  Designing buffering and flushing logic",
+            "  Defining PendingAtomicReasoningItem structure",
+            "▪ Designing atomic reasoning response builder ▪ third",
+            "  Assessing replay preorganization scope",
+            "  Outlining replay grouping plan",
+        ]
+    );
+    assert_eq!(
+        rendered.iter().filter(|line| line.starts_with('▪')).count(),
+        3
+    );
+}
