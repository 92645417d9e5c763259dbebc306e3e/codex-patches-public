+fn append_atomic_reasoning_response(
+    cells: &mut TranscriptCells,
+    pending_reasoning_items: &mut Vec<(String, Vec<String>)>,
+    cwd: &std::path::Path,
+    reasoning_output_tokens: Option<i64>,
+) {
+    if pending_reasoning_items.is_empty() {
+        return;
+    }
+    cells.extend(
+        crate::history_cell::new_atomic_reasoning_response_blocks(
+            std::mem::take(pending_reasoning_items),
+            cwd,
+            reasoning_output_tokens,
+        )
