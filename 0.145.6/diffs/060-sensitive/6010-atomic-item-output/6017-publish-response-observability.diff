+fn response_performance_durations(
+    timing: &ResponsePerformanceTiming,
+    completed_at: Instant,
+) -> (Option<Duration>, Option<Duration>) {
+    response_performance_durations_from_instants(
+        timing.request_started_at(),
+        timing.first_response_byte_at(),
+        completed_at,
+    )
+}
+
+fn response_performance_durations_from_instants(
+    request_started_at: Option<Instant>,
+    first_response_byte_at: Option<Instant>,
+    completed_at: Instant,
+) -> (Option<Duration>, Option<Duration>) {
+    let ttfb = request_started_at.zip(first_response_byte_at).map(
+        |(request_started_at, first_response_byte_at)| {
+            first_response_byte_at.saturating_duration_since(request_started_at)
+        },
+    );
+    let generation_duration = first_response_byte_at.map(|first_response_byte_at| {
+        completed_at.saturating_duration_since(first_response_byte_at)
+    });
+    (ttfb, generation_duration)
+}
+
+fn record_completed_model_request_performance(
+    session_telemetry: &SessionTelemetry,
+    timing: &ResponsePerformanceTiming,
+    transport: &str,
+    usage: Option<&codex_protocol::protocol::TokenUsage>,
+) {
+    let (ttfb, generation_duration) = response_performance_durations(timing, Instant::now());
+    let output_token_count = usage.map(|usage| usage.output_tokens);
+    let tps = output_token_count.and_then(|output_token_count| {
+        billed_output_tokens_per_second(output_token_count, generation_duration?)
+    });
+    let outcome = if usage.is_some() {
+        "completed"
+    } else {
+        "missing_usage"
+    };
+    session_telemetry.model_request_performance(
+        transport,
+        outcome,
+        ttfb,
+        generation_duration,
+        output_token_count,
+        tps,
+    );
+}
+
+fn billed_output_tokens_per_second(
+    output_token_count: i64,
+    generation_duration: Duration,
+) -> Option<f64> {
+    let seconds = generation_duration.as_secs_f64();
+    (output_token_count > 0 && seconds > 0.0).then_some(output_token_count as f64 / seconds)
+}
+
+fn record_incomplete_model_request_performance(
+    session_telemetry: &SessionTelemetry,
+    timing: &ResponsePerformanceTiming,
+    transport: &str,
+    outcome: &str,
+) {
+    let ttfb = timing
+        .request_started_at()
+        .zip(timing.first_response_byte_at())
+        .map(|(request_started_at, first_response_byte_at)| {
+            first_response_byte_at.saturating_duration_since(request_started_at)
+        });
+    session_telemetry.model_request_performance(transport, outcome, ttfb, None, None, None);
+}
