+pub(crate) fn sampling_error_is_retryable(
+    err: &CodexErr,
+    responses_websocket_enabled: bool,
+) -> bool {
+    match err {
+        CodexErr::UnexpectedStatus(response) if response.status.is_client_error() => {
+            responses_websocket_enabled
+        }
+        _ => err.is_retryable(),
+    }
+}
