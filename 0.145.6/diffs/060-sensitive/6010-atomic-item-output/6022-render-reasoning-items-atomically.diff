+#[test]
+fn atomic_reasoning_item_renders_id_and_exact_usage_without_summary() {
+    let cell = new_atomic_reasoning_summary_block(
+        Vec::new(),
+        &test_cwd(),
+        "rs_abc123".to_string(),
+        Some(516),
+    );
+
+    let lines = cell.transcript_lines(/*width*/ 80);
+    assert_eq!(render_lines(&lines), vec!["▪ rs_abc123  516 tokens"]);
+    assert_eq!(lines[0].spans[1].style.fg, Some(Color::DarkGray));
+    assert_eq!(lines[0].spans[2].style.fg, Some(Color::Yellow));
+}
+
+#[test]
+fn atomic_reasoning_item_without_item_owned_usage_renders_id_only() {
+    let cell = new_atomic_reasoning_summary_block(
+        vec!["**First item**\n\nPartial summary.".to_string()],
+        &test_cwd(),
+        "rs_first".to_string(),
+        None,
+    );
+
+    let lines = cell.transcript_lines(/*width*/ 80);
+    assert_eq!(
+        render_lines(&lines),
+        vec!["▪ First item  rs_first", "  Partial summary."]
+    );
+    assert_eq!(
+        lines[0].spans.last().and_then(|span| span.style.fg),
+        Some(Color::DarkGray)
+    );
+}
+
+#[test]
+fn atomic_reasoning_item_appends_metadata_to_visible_summary() {
+    let cell = new_atomic_reasoning_summary_block(
+        vec!["**Planning**\n\nInspect the response.".to_string()],
+        &test_cwd(),
+        "rs_abc123".to_string(),
+        Some(1_024),
+    );
+
+    let lines = cell.transcript_lines(/*width*/ 120);
+    assert_eq!(
+        render_lines(&lines),
+        vec![
+            "▪ Planning  rs_abc123  1,024 tokens",
+            "  Inspect the response."
+        ]
+    );
+    let span_count = lines[0].spans.len();
+    assert_eq!(
+        lines[0].spans[span_count - 2].style.fg,
+        Some(Color::DarkGray)
+    );
+    assert_eq!(lines[0].spans[span_count - 1].style.fg, Some(Color::Yellow));
+}
