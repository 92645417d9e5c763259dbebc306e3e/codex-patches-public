+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn responses_lite_carries_code_mode_nested_batching_guidance() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = responses::start_mock_server().await;
+    let response_mock = responses::mount_sse_once(
+        &server,
+        responses::sse(vec![
+            responses::ev_response_created("resp-1"),
+            responses::ev_completed("resp-1"),
+        ]),
+    )
+    .await;
+    let mut builder = test_codex()
+        .with_model_info_override("gpt-5.4", |model_info| {
+            model_info.use_responses_lite = true;
+            model_info.supports_parallel_tool_calls = true;
+            model_info.tool_mode = Some(ToolMode::CodeModeOnly);
+        })
+        .with_config(|config| {
+            assert!(config.features.enable(Feature::CodeMode).is_ok());
+            assert!(config.features.enable(Feature::CodeModeOnly).is_ok());
+        });
+    let test = builder.build(&server).await?;
+
+    test.submit_turn("inspect independent inputs").await?;
+
+    let body = response_mock.single_request().body_json();
+    assert_eq!(body.get("parallel_tool_calls"), Some(&Value::Bool(false)));
+    let exec_description = additional_tools(&body)?
+        .iter()
+        .find(|tool| tool.get("name").and_then(Value::as_str) == Some("exec"))
+        .and_then(|tool| tool.get("description"))
+        .and_then(Value::as_str)
+        .context("Responses Lite additional_tools should include the exec description")?;
+    assert!(exec_description.contains("Promise.allSettled"));
+    assert!(exec_description.contains("inspect every settled result"));
+    assert!(exec_description.contains("Promise.all"));
+
+    Ok(())
+}
