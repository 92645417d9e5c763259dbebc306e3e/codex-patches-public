+#[tokio::test]
+async fn list_current_thread_name_entries_returns_newest_current_names() -> std::io::Result<()> {
+    let temp = TempDir::new()?;
+    let path = session_index_path(temp.path());
+    let renamed = ThreadId::new();
+    let other = ThreadId::new();
+    let cleared = ThreadId::new();
+    let encode =
+        |entry: &SessionIndexEntry| serde_json::to_string(entry).map_err(std::io::Error::other);
+    let lines = [
+        encode(&SessionIndexEntry {
+            id: cleared,
+            thread_name: "cleared old name".to_string(),
+            updated_at: "2099-01-01T00:00:00Z".to_string(),
+        })?,
+        encode(&SessionIndexEntry {
+            id: renamed,
+            thread_name: "old name".to_string(),
+            updated_at: "2099-01-01T00:00:00Z".to_string(),
+        })?,
+        encode(&SessionIndexEntry {
+            id: other,
+            thread_name: "other".to_string(),
+            updated_at: "2024-01-02T00:00:00Z".to_string(),
+        })?,
+        "not-json".to_string(),
+        encode(&SessionIndexEntry {
+            id: cleared,
+            thread_name: String::new(),
+            updated_at: "2024-01-03T00:00:00Z".to_string(),
+        })?,
+        encode(&SessionIndexEntry {
+            id: renamed,
+            thread_name: "new name".to_string(),
+            updated_at: "1900-01-01T00:00:00Z".to_string(),
+        })?,
+    ];
+    std::fs::write(&path, lines.join("\n"))?;
+
+    let entries = list_current_thread_name_entries(temp.path(), 2).await?;
+    assert_eq!(
+        entries,
+        vec![
+            SessionIndexEntry {
+                id: renamed,
+                thread_name: "new name".to_string(),
+                updated_at: "1900-01-01T00:00:00Z".to_string(),
+            },
+            SessionIndexEntry {
+                id: other,
+                thread_name: "other".to_string(),
+                updated_at: "2024-01-02T00:00:00Z".to_string(),
+            },
+        ]
+    );
+    Ok(())
+}
+
+#[tokio::test]
+async fn list_current_thread_name_entries_missing_index_is_empty() -> std::io::Result<()> {
+    let temp = TempDir::new()?;
+    assert!(
+        list_current_thread_name_entries(temp.path(), 25)
+            .await?
+            .is_empty()
+    );
+    assert!(
+        list_current_thread_name_entries(temp.path(), 0)
+            .await?
+            .is_empty()
+    );
+    Ok(())
+}
