+/// List the newest current non-empty thread-name entries in append order.
+///
+/// The session index remains an append-only compatibility log. This view treats the newest row
+/// for each thread as authoritative, including an empty name that hides older non-empty names.
+pub async fn list_current_thread_name_entries(
+    codex_home: &Path,
+    limit: usize,
+) -> std::io::Result<Vec<SessionIndexEntry>> {
+    if limit == 0 {
+        return Ok(Vec::new());
+    }
+    let path = session_index_path(codex_home);
+    let entries = tokio::task::spawn_blocking(move || {
+        match list_current_thread_name_entries_from_path(&path, limit) {
+            Err(err) if err.kind() == ErrorKind::NotFound => Ok(Vec::new()),
+            result => result,
+        }
+    })
+    .await
+    .map_err(std::io::Error::other)??;
+    Ok(entries)
+}
