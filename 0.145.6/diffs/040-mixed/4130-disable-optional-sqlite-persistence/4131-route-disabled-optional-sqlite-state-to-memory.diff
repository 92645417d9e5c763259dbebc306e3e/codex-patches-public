+async fn open_in_memory_sqlite(
+    migrator: &Migrator,
+    kind: DbKind,
+    label: &'static str,
+    open_phase: &'static str,
+    migrate_phase: &'static str,
+    telemetry_override: Option<&dyn DbTelemetry>,
+) -> anyhow::Result<SqlitePool> {
+    let options = SqliteConnectOptions::new()
+        .in_memory(true)
+        .create_if_missing(true)
+        .log_statements(log::LevelFilter::Off);
+    let path = Path::new(":memory:");
+    let started = Instant::now();
+    let pool_result = SqlitePoolOptions::new()
+        .max_connections(1)
+        .connect_with(options)
+        .await
+        .map_err(anyhow::Error::from);
+    crate::telemetry::record_init_result(
+        telemetry_override,
+        kind,
+        open_phase,
+        started.elapsed(),
+        &pool_result,
+    );
+    let pool = pool_result
+        .map_err(|source| recovery::RuntimeDbInitError::new(label, "open", path, source))?;
+    let started = Instant::now();
+    let migrate_result = migrator.run(&pool).await.map_err(anyhow::Error::from);
+    crate::telemetry::record_init_result(
+        telemetry_override,
+        kind,
+        migrate_phase,
+        started.elapsed(),
+        &migrate_result,
+    );
+    if let Err(source) = migrate_result {
+        pool.close().await;
+        return Err(recovery::RuntimeDbInitError::new(label, "migrate", path, source).into());
+    }
+    Ok(pool)
+}
