+    let home = TempDir::new().expect("temp dir");
+    let config = RolloutConfig {
+        use_goals: false,
+        persist_feedback_logs: false,
+        generate_memories: false,
+        ..test_rollout_config(&home)
+    };
+
+    let runtime = try_init(&config).await?;
+    assert_eq!(
+        runtime
+            .thread_goals()
+            .get_thread_goal(ThreadId::new())
+            .await?,
+        None
+    );
+    runtime
+        .insert_log(&codex_state::LogEntry {
+            ts: 1,
+            ts_nanos: 0,
+            level: "INFO".to_string(),
+            target: "test".to_string(),
+            message: None,
+            feedback_log_body: Some("kept in memory".to_string()),
+            thread_id: Some("thread-1".to_string()),
+            process_uuid: Some("process-1".to_string()),
+            module_path: None,
+            file: None,
+            line: None,
+        })
+        .await?;
+    assert_eq!(
+        runtime
+            .query_logs(&codex_state::LogQuery {
+                thread_ids: vec!["thread-1".to_string()],
+                ..Default::default()
+            })
+            .await?
+            .len(),
+        1
+    );
+    runtime.memories().clear_memory_data().await?;
+
+    assert!(codex_state::state_db_path(home.path()).is_file());
+    assert!(!codex_state::logs_db_path(home.path()).exists());
+    assert!(!codex_state::goals_db_path(home.path()).exists());
+    assert!(!codex_state::memories_db_path(home.path()).exists());
+    runtime.close().await;
+
+    Ok(())
