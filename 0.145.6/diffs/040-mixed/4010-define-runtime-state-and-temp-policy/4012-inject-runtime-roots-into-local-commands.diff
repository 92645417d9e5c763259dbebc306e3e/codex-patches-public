+fn inject_runtime_path_env(
+    env: &mut HashMap<String, String>,
+    local_cwd: Option<&Path>,
+    resolved_codex_home: &Path,
+) {
+    for key in runtime_path_env_keys() {
+        remove_env_var(env, key);
+    }
+    env.insert(
+        CODEX_HOME_ENV_VAR.to_string(),
+        resolved_codex_home.to_string_lossy().into_owned(),
+    );
+
+    let Some(cwd) = local_cwd else {
+        return;
+    };
+    let roots = match resolve_runtime_path_roots(cwd) {
+        Ok(roots) => roots,
+        Err(error) => {
+            tracing::warn!(%error, "failed to resolve local runtime path roots");
+            return;
+        }
+    };
+    if let Err(error) = roots.ensure_project_scratch_root() {
+        tracing::warn!(%error, "failed to create project scratch root");
+        return;
+    }
+
+    for (key, value) in [
+        (TMPDIR_ENV_VAR, roots.system_tmp_root.as_path()),
+        (CODEX_TMP_ENV_VAR, roots.codex_tmp_root.as_path()),
+        (
+            PROJECT_SCRATCH_ROOT_ENV_VAR,
+            roots.project_scratch_root.as_path(),
+        ),
+        (
+            PROJECT_WORKING_ROOT_ENV_VAR,
+            roots.project_working_root.as_path(),
+        ),
+        (RUNTIME_TMP_ROOT_ENV_VAR, roots.runtime_tmp_root.as_path()),
+        (
+            RUNTIME_STATE_ROOT_ENV_VAR,
+            roots.runtime_state_root.as_path(),
+        ),
+    ] {
+        env.insert(key.to_string(), value.to_string_lossy().into_owned());
+    }
+    env.insert(PROJECT_NAME_ENV_VAR.to_string(), roots.project_name);
+}
+
+pub(crate) fn runtime_path_env_keys() -> [&'static str; 8] {
+    [
+        TMPDIR_ENV_VAR,
+        CODEX_HOME_ENV_VAR,
+        CODEX_TMP_ENV_VAR,
+        PROJECT_NAME_ENV_VAR,
+        PROJECT_SCRATCH_ROOT_ENV_VAR,
+        PROJECT_WORKING_ROOT_ENV_VAR,
+        RUNTIME_TMP_ROOT_ENV_VAR,
+        RUNTIME_STATE_ROOT_ENV_VAR,
+    ]
+}
+
+fn remove_env_var(env: &mut HashMap<String, String>, key: &str) {
+    if cfg!(windows) {
+        env.retain(|candidate, _| !candidate.eq_ignore_ascii_case(key));
+    } else {
+        env.remove(key);
+    }
+}
