+        (CODEX_TMP_ENV_VAR.to_string(), "/live/codex".to_string()),
+        (PROJECT_NAME_ENV_VAR.to_string(), "live-project".to_string()),
+        (
+            PROJECT_WORKING_ROOT_ENV_VAR.to_string(),
+            "/live/working".to_string(),
+        ),
+        (
+            RUNTIME_TMP_ROOT_ENV_VAR.to_string(),
+            "/live/runtime-tmp".to_string(),
+        ),
+    ]);
+    let rewritten = maybe_wrap_shell_lc_with_snapshot(
+        &command,
+        &session_shell,
+        Some(&shell_snapshot),
+        &HashMap::new(),
+        &env,
+        &RuntimePathPrepends::default(),
+    );
+    let output = Command::new(&rewritten[0])
+        .args(&rewritten[1..])
+        .env(TMPDIR_ENV_VAR, "/live/tmp")
+        .env(CODEX_HOME_ENV_VAR, "/live/home")
+        .env(CODEX_TMP_ENV_VAR, "/live/codex")
+        .env(PROJECT_NAME_ENV_VAR, "live-project")
+        .env_remove(PROJECT_SCRATCH_ROOT_ENV_VAR)
+        .env(PROJECT_WORKING_ROOT_ENV_VAR, "/live/working")
+        .env(RUNTIME_TMP_ROOT_ENV_VAR, "/live/runtime-tmp")
+        .env_remove(RUNTIME_STATE_ROOT_ENV_VAR)
+        .output()
+        .expect("run rewritten command");
+
+    assert!(output.status.success(), "command failed: {output:?}");
+    assert_eq!(
+        String::from_utf8_lossy(&output.stdout),
+        "/live/tmp|/live/home|/live/codex|live-project|unset|/live/working|/live/runtime-tmp|unset"
+    );
+}
