+    let codex_tmp = system_tmp.join("codex");
+    let scratch = codex_tmp.join("scratch");
+    let working = codex_home.path().join("working");
+    let runtime_tmp = system_tmp.join("runtime");
+    let runtime_state = codex_home.path().join("state");
+    std::fs::create_dir_all(&codex_tmp)?;
+    std::fs::create_dir_all(&working)?;
+    create_config_toml(codex_home.path(), &server.uri(), "never")?;
+
+    let runtime_env = [
+        ("TMPDIR", Some(system_tmp.to_str().context("TMPDIR")?)),
+        ("CODEX_TMP", Some(codex_tmp.to_str().context("CODEX_TMP")?)),
+        ("PROJECT_NAME", Some("project-token")),
+        (
+            "PROJECT_SCRATCH_ROOT",
+            Some(scratch.to_str().context("PROJECT_SCRATCH_ROOT")?),
+        ),
+        (
+            "PROJECT_WORKING_ROOT",
+            Some(working.to_str().context("PROJECT_WORKING_ROOT")?),
+        ),
+        (
+            "RUNTIME_TMP_ROOT",
+            Some(runtime_tmp.to_str().context("RUNTIME_TMP_ROOT")?),
+        ),
+        (
+            "RUNTIME_STATE_ROOT",
+            Some(runtime_state.to_str().context("RUNTIME_STATE_ROOT")?),
+        ),
+    ];
+    let mut mcp = TestAppServer::builder()
+        .with_codex_home(codex_home.path())
+        .without_auto_env()
+        .with_env_overrides(&runtime_env)
+        .build()
+        .await?;
+    timeout(DEFAULT_READ_TIMEOUT, mcp.initialize()).await??;
+
+    let command_request_id = mcp
+        .send_command_exec_request(CommandExecParams {
+            command: vec![
+                "/bin/sh".to_string(),
+                "-lc".to_string(),
+                "printf '%s|%s|%s|%s|%s|%s|%s|%s' \"$TMPDIR\" \"$CODEX_HOME\" \"$CODEX_TMP\" \"$PROJECT_NAME\" \"$PROJECT_SCRATCH_ROOT\" \"$PROJECT_WORKING_ROOT\" \"$RUNTIME_TMP_ROOT\" \"$RUNTIME_STATE_ROOT\"".to_string(),
+            ],
+            process_id: None,
+            tty: false,
+            stream_stdin: false,
+            stream_stdout_stderr: false,
+            output_bytes_cap: None,
+            disable_output_cap: false,
+            disable_timeout: false,
+            timeout_ms: None,
+            cwd: None,
+            env: None,
+            size: None,
+            sandbox_policy: None,
+            permission_profile: None,
+        })
+        .await?;
+
+    let response = mcp
+        .read_stream_until_response_message(RequestId::Integer(command_request_id))
+        .await?;
+    let response: CommandExecResponse = to_response(response)?;
+    assert_eq!(
+        response,
+        CommandExecResponse {
+            exit_code: 0,
+            stdout: format!(
+                "{}|{}|{}|project-token|{}|{}|{}|{}",
+                system_tmp.display(),
+                codex_home.path().canonicalize()?.display(),
+                codex_tmp.display(),
+                scratch.display(),
+                working.display(),
+                runtime_tmp.display(),
+                runtime_state.display(),
+            ),
+            stderr: String::new(),
+        }
+    );
+    assert!(scratch.is_dir());
+
+    Ok(())
+}
