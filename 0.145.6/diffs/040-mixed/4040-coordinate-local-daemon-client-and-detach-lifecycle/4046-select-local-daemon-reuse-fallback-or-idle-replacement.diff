diff --git a/codex-rs/app-server/src/message_processor_admission_tests.rs b/codex-rs/app-server/src/message_processor_admission_tests.rs
new file mode 100644
index 0000000000..da3c6c9919
--- /dev/null
+++ b/codex-rs/app-server/src/message_processor_admission_tests.rs
@@ -0,0 +1,64 @@
+use super::message_processor::ClientAdmissionState;
+use super::outgoing_message::ConnectionId;
+
+const DAEMON: &str = "codex_app_server_daemon";
+const BACKEND: &str = "codex-backend";
+const CLIENT: &str = "codex-cli";
+const CLAIM_OWNER: ConnectionId = ConnectionId(7);
+
+#[test]
+fn idle_claim_succeeds_and_fences_later_normal_client() {
+    let mut admission = ClientAdmissionState::default();
+
+    assert!(admission.claim_idle_replacement(CLAIM_OWNER, 0));
+    assert!(!admission.admit(CLIENT));
+    assert_eq!(admission.active_client_count(), 0);
+}
+
+#[test]
+fn active_client_denies_claim_without_mutation() {
+    let mut admission = ClientAdmissionState::default();
+
+    assert!(admission.admit(CLIENT));
+    assert!(!admission.claim_idle_replacement(CLAIM_OWNER, 0));
+    admission.remove_active_client();
+    assert!(admission.admit(CLIENT));
+}
+
+#[test]
+fn running_or_pending_turn_denies_claim_without_mutation() {
+    let mut admission = ClientAdmissionState::default();
+
+    assert!(!admission.claim_idle_replacement(CLAIM_OWNER, 1));
+    assert!(admission.admit(CLIENT));
+}
+
+#[test]
+fn daemon_and_backend_remain_admitted_after_claim() {
+    let mut admission = ClientAdmissionState::default();
+
+    assert!(admission.claim_idle_replacement(CLAIM_OWNER, 0));
+    assert!(admission.admit(DAEMON));
+    assert!(admission.admit(BACKEND));
+    assert_eq!(admission.active_client_count(), 0);
+}
+
+#[test]
+fn closing_active_client_decrements_count() {
+    let mut admission = ClientAdmissionState::default();
+
+    assert!(admission.admit(CLIENT));
+    assert_eq!(admission.active_client_count(), 1);
+    admission.remove_active_client();
+    assert_eq!(admission.active_client_count(), 0);
+}
+
+#[test]
+fn only_claim_owner_disconnect_releases_fence() {
+    let mut admission = ClientAdmissionState::default();
+    assert!(admission.claim_idle_replacement(CLAIM_OWNER, 0));
+    admission.release_idle_replacement_claim(ConnectionId(8));
+    assert!(!admission.admit(CLIENT));
+    admission.release_idle_replacement_claim(CLAIM_OWNER);
+    assert!(admission.admit(CLIENT));
+}
