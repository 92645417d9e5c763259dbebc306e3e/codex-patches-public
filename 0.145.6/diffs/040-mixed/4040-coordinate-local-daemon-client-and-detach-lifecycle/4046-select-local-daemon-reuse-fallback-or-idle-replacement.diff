+    }
+
+    pub(crate) fn claim_idle_replacement(
+        &mut self,
+        owner: ConnectionId,
+        running_assistant_turn_count: usize,
+    ) -> bool {
+        if self.idle_replacement_claim_owner == Some(owner) {
+            return true;
+        }
+        if self.active_client_count != 0
+            || running_assistant_turn_count != 0
+            || self.idle_replacement_claim_owner.is_some()
+        {
+            return false;
+        }
+        self.idle_replacement_claim_owner = Some(owner);
+        true
+    }
+
+    pub(crate) fn release_idle_replacement_claim(&mut self, owner: ConnectionId) {
+        if self.idle_replacement_claim_owner == Some(owner) {
+            self.idle_replacement_claim_owner = None;
+        }
+    }
+}
 
