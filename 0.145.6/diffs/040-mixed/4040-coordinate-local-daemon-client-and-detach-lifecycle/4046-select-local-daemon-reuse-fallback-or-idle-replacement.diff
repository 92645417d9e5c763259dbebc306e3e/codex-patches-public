+async fn claim_idle_replacement_inner(socket_path: &Path) -> Result<Option<IdleReplacementClaim>> {
+    let mut websocket = connect(socket_path).await?;
+    initialize(&mut websocket, /*experimental_api*/ false).await?;
+    send_message(
+        &mut websocket,
+        &JSONRPCMessage::Notification(JSONRPCNotification {
+            method: "initialized".to_string(),
+            params: None,
+        }),
+    )
+    .await?;
+    send_message(
+        &mut websocket,
+        &JSONRPCMessage::Request(JSONRPCRequest {
+            id: CLAIM_IDLE_REQUEST_ID,
+            method: CLAIM_IDLE_METHOD.to_string(),
+            params: None,
+            trace: None,
+        }),
+    )
+    .await?;
+    loop {
+        match read_message(&mut websocket).await? {
+            JSONRPCMessage::Response(response) if response.id == CLAIM_IDLE_REQUEST_ID => {
+                #[derive(serde::Deserialize)]
+                struct ClaimIdleResponse {
+                    claimed: bool,
+                }
+                let response = serde_json::from_value::<ClaimIdleResponse>(response.result)
+                    .context("failed to parse idle replacement claim")?;
+                if response.claimed {
+                    return Ok(Some(IdleReplacementClaim {
+                        _websocket: websocket,
+                    }));
+                }
+                websocket.close(None).await.ok();
+                return Ok(None);
+            }
+            JSONRPCMessage::Error(error) if error.id == CLAIM_IDLE_REQUEST_ID => {
+                let _ = error;
+                websocket.close(None).await.ok();
+                return Ok(None);
+            }
+            _ => {}
+        }
+    }
+}
