+async fn shutdown_when_no_active_clients_exits_with_daemon_connected() -> Result<()> {
+    let server = create_mock_responses_server_sequence_unchecked(Vec::new()).await;
+    let codex_home = TempDir::new()?;
+    create_config_toml(codex_home.path(), &server.uri(), "never")?;
+    let (mut process, bind_addr) = spawn_websocket_server(codex_home.path()).await?;
+
+    let mut daemon = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut daemon, 1, "codex_app_server_daemon").await?;
+    let _: InitializeResponse = to_response(read_response_for_id(&mut daemon, 1).await?)?;
+    let mut client = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut client, 2, "shutdown_client").await?;
+    let _: InitializeResponse = to_response(read_response_for_id(&mut client, 2).await?)?;
+    assert_eq!(read_active_client_count(&mut daemon).await?, 1);
+
+    send_jsonrpc(
+        &mut client,
+        JSONRPCMessage::Notification(JSONRPCNotification {
+            method: "shutdownWhenNoActiveClients".to_string(),
+            params: None,
+        }),
+    )
+    .await?;
+    client.close(None).await?;
+    drop(client);
+    assert_eq!(read_active_client_count(&mut daemon).await?, 0);
+
+    let status = timeout(DEFAULT_READ_TIMEOUT, process.wait())
+        .await
+        .context("app-server did not stop after its active client disconnected")??;
+    assert!(status.success());
+    drop(daemon);
+    Ok(())
+}
