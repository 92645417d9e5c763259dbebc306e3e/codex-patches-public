+#[tokio::test]
+async fn detach_exit_falls_back_to_shutdown_first_for_embedded_app_server() {
+    let (mut app, _app_event_rx, mut op_rx) = Box::pin(make_test_app_with_channels()).await;
+    let thread_id = ThreadId::new();
+    app.active_thread_id = Some(thread_id);
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    let control = Box::pin(app.handle_exit_mode(&mut app_server, ExitMode::Detach)).await;
+
+    assert_eq!(app.pending_shutdown_exit_thread_id, None);
+    assert_matches!(control, AppRunControl::Exit(ExitReason::UserRequested));
+    assert!(
+        op_rx.try_recv().is_err(),
+        "embedded detach fallback should not submit Op::Shutdown"
+    );
+}
+
+#[tokio::test]
+async fn detach_exit_leaves_remote_thread_running() {
+    let (mut app, _app_event_rx, mut op_rx) = Box::pin(make_test_app_with_channels()).await;
+    app.app_server_target = crate::AppServerTarget::Remote {
+        endpoint: crate::RemoteAppServerEndpoint::WebSocket {
+            websocket_url: "ws://127.0.0.1:4500".to_string(),
+            auth_token: None,
+        },
+    };
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    let control = Box::pin(app.handle_exit_mode(&mut app_server, ExitMode::Detach)).await;
+
+    assert_eq!(app.pending_shutdown_exit_thread_id, None);
+    assert_matches!(control, AppRunControl::Exit(ExitReason::Detached));
+    assert!(
+        op_rx.try_recv().is_err(),
+        "detaching from a remote app-server should not submit shutdown"
+    );
+}
