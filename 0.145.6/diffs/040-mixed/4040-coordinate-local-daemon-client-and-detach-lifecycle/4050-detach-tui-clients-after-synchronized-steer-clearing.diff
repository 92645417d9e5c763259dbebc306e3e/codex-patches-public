+    use codex_protocol::ThreadId;
+    use codex_tui::TokenUsage;
+
+    #[test]
+    fn format_exit_messages_reports_detached_session() {
+        let thread_id =
+            ThreadId::from_string("123e4567-e89b-12d3-a456-426614174000").expect("valid thread id");
+        let lines = format_exit_messages(
+            AppExitInfo {
+                token_usage: TokenUsage::default(),
+                thread_id: Some(thread_id),
+                resume_hint: Some(format!("codex resume {thread_id}")),
+                update_action: None,
+                exit_reason: ExitReason::Detached,
+            },
+            /*color_enabled*/ false,
+        );
+
+        assert_eq!(
+            lines,
+            [
+                format!("Detached session: {thread_id}"),
+                format!("Reattach with: codex resume {thread_id}"),
+            ]
+        );
+    }
