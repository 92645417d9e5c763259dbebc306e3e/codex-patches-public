+#[tokio::test]
+async fn local_daemon_detach_requests_idle_shutdown_before_disconnect() -> Result<()> {
+    let mut app = make_test_app().await;
+    app.app_server_target = crate::AppServerTarget::LocalDaemon {
+        endpoint: crate::RemoteAppServerEndpoint::WebSocket {
+            websocket_url: "ws://127.0.0.1:4500".to_string(),
+            auth_token: None,
+        },
+    };
+    let (mut app_server, _requests, notifications, proxy) =
+        start_recording_app_server(&app.config).await?;
+
+    let control = app
+        .handle_exit_mode(&mut app_server, ExitMode::Detach)
+        .await;
+    assert_matches!(control, AppRunControl::Exit(ExitReason::Detached));
+
+    app_server.shutdown().await?;
+    proxy.await??;
+    assert_eq!(
+        notifications
+            .lock()
+            .expect("notification recorder lock")
+            .as_slice(),
+        ["shutdownWhenNoActiveClients"]
+    );
+    Ok(())
+}
