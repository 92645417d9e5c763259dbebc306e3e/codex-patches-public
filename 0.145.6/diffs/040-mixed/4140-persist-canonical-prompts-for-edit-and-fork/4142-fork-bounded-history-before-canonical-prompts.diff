+mod prompt_fork_boundary_tests {
+    use super::super::validate_prompt_fork_boundary;
+    use codex_protocol::ThreadId;
+    use codex_protocol::items::TurnItem;
+    use codex_protocol::items::UserMessageItem;
+    use codex_protocol::protocol::EventMsg;
+    use codex_protocol::protocol::ItemCompletedEvent;
+    use codex_protocol::protocol::RolloutItem;
+    use codex_protocol::protocol::TurnCompleteEvent;
+    use codex_protocol::protocol::TurnStartedEvent;
+
+    fn completed_turn(turn_id: &str, item_ids: &[&str]) -> Vec<RolloutItem> {
+        let thread_id = ThreadId::new();
+        let mut items = vec![RolloutItem::EventMsg(EventMsg::TurnStarted(
+            TurnStartedEvent {
+                turn_id: turn_id.to_string(),
+                trace_id: None,
+                started_at: None,
+                model_context_window: None,
+                collaboration_mode_kind: Default::default(),
+            },
+        ))];
+        items.extend(item_ids.iter().map(|item_id| {
+            RolloutItem::EventMsg(EventMsg::ItemCompleted(ItemCompletedEvent {
+                thread_id,
+                turn_id: turn_id.to_string(),
+                item: TurnItem::UserMessage(UserMessageItem {
+                    id: (*item_id).to_string(),
+                    client_id: None,
+                    content: Vec::new(),
+                }),
+                completed_at_ms: 0,
+            }))
+        }));
+        items.push(RolloutItem::EventMsg(EventMsg::TurnComplete(
+            TurnCompleteEvent {
+                turn_id: turn_id.to_string(),
+                started_at: None,
+                last_agent_message: None,
+                error: None,
+                completed_at: None,
+                duration_ms: None,
+                time_to_first_token_ms: None,
+            },
+        )));
+        items
+    }
+
+    #[test]
+    fn accepts_only_the_initial_canonical_prompt_in_a_completed_turn() {
+        let items = completed_turn("turn-1", &["prompt-1", "steer-1"]);
+
+        assert_eq!(
+            validate_prompt_fork_boundary(
+                &items,
+                &super::super::PromptForkBoundary {
+                    turn_id: "turn-1".to_string(),
+                    item_id: "prompt-1".to_string(),
+                },
+            )
+            .expect("initial prompt should be editable"),
+            "turn-1"
+        );
+        let steer = validate_prompt_fork_boundary(
+            &items,
+            &super::super::PromptForkBoundary {
+                turn_id: "turn-1".to_string(),
+                item_id: "steer-1".to_string(),
+            },
+        )
+        .expect_err("steer should not be editable");
+        assert!(steer.message.contains("selected prompt is a steer"));
+    }
+
+    #[test]
+    fn rejects_a_prompt_identity_outside_the_selected_window() {
+        let items = completed_turn("turn-2", &["prompt-2"]);
+
+        let err = validate_prompt_fork_boundary(
+            &items,
+            &super::super::PromptForkBoundary {
+                turn_id: "turn-1".to_string(),
+                item_id: "prompt-1".to_string(),
+            },
+        )
+        .expect_err("omitted prompt should not be guessed");
+        assert!(err.message.contains("selected history window"));
+    }
+}
