+fn validate_prompt_fork_boundary(
+    items: &[RolloutItem],
+    boundary: &PromptForkBoundary,
+) -> Result<String, JSONRPCErrorError> {
+    let turns = build_legacy_api_turns_from_rollout_items(items);
+    let turn = turns
+        .iter()
+        .find(|turn| turn.id == boundary.turn_id)
+        .ok_or_else(|| {
+            invalid_request(format!(
+                "prompt turn '{}' was not found in the selected history window",
+                boundary.turn_id
+            ))
+        })?;
+    if matches!(turn.status, TurnStatus::InProgress) {
+        return Err(invalid_request(format!(
+            "prompt turn '{}' is still in progress",
+            boundary.turn_id
+        )));
+    }
+
+    let user_message_ids = turn.items.iter().filter_map(|item| match item {
+        ThreadItem::UserMessage { id, .. } => Some(id.as_str()),
+        _ => None,
+    });
+    let mut user_message_ids = user_message_ids.peekable();
+    let Some(first_item_id) = user_message_ids.next() else {
+        return Err(invalid_request(format!(
+            "prompt turn '{}' has no persisted canonical user prompt",
+            boundary.turn_id
+        )));
+    };
+    if first_item_id == boundary.item_id {
+        return Ok(turn.id.clone());
+    }
+    if user_message_ids.any(|item_id| item_id == boundary.item_id) {
+        return Err(invalid_request(
+            "the selected prompt is a steer and cannot be branched independently",
+        ));
+    }
+    Err(invalid_request(format!(
+        "prompt item '{}' was not found as the initial prompt of turn '{}'",
+        boundary.item_id, boundary.turn_id
+    )))
+}
