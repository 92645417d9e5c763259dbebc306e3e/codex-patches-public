+const RESPONSES_PROBE_INSTRUCTIONS: &str =
+    "You are Codex. Respond directly to this health-check prompt.";
+
+pub(super) fn body(model: &str, prompt: &str) -> serde_json::Value {
+    serde_json::json!({
+        "model": model,
+        "instructions": RESPONSES_PROBE_INSTRUCTIONS,
+        "input": [{
+            "type": "message",
+            "role": "user",
+            "content": [{"type": "input_text", "text": prompt}],
+        }],
+        "stream": true,
+        "store": false,
+        "tools": [],
+        "tool_choice": "auto",
+        "parallel_tool_calls": false,
+        "reasoning": null,
+        "include": [],
+    })
+}
+
+#[derive(Default)]
+pub(super) struct Decoder {
+    pending: Vec<u8>,
+    output_deltas: String,
+    completed_output_parts: String,
+}
+
+impl Decoder {
+    pub(super) fn push(&mut self, chunk: &[u8]) -> Option<std::result::Result<String, String>> {
+        self.pending.extend_from_slice(chunk);
+        while let Some((frame_end, delimiter_len)) = next_sse_frame(&self.pending) {
+            let frame = self.pending.drain(..frame_end).collect::<Vec<_>>();
+            self.pending.drain(..delimiter_len);
+            if let Some(result) = self.consume_frame(&frame) {
+                return Some(result);
+            }
+        }
+        None
+    }
+
+    pub(super) fn finish(&mut self) -> Option<std::result::Result<String, String>> {
+        if self.pending.is_empty() {
+            return None;
+        }
+        let frame = std::mem::take(&mut self.pending);
+        self.consume_frame(&frame)
+    }
+
+    fn consume_frame(&mut self, frame: &[u8]) -> Option<std::result::Result<String, String>> {
+        let frame = String::from_utf8_lossy(frame).replace('\r', "");
+        let data = frame
+            .lines()
+            .filter_map(|line| line.strip_prefix("data:").map(str::trim_start))
+            .collect::<Vec<_>>()
+            .join("\n");
+        if data.is_empty() || data == "[DONE]" {
+            return None;
+        }
+        let event = serde_json::from_str::<serde_json::Value>(&data).ok()?;
+        match event.get("type").and_then(serde_json::Value::as_str)? {
+            "response.output_text.delta" => {
+                if let Some(delta) = event.get("delta").and_then(serde_json::Value::as_str) {
+                    self.output_deltas.push_str(delta);
+                }
+                None
+            }
+            "response.output_text.done" => {
+                if let Some(text) = event.get("text").and_then(serde_json::Value::as_str) {
+                    self.completed_output_parts.push_str(text);
+                }
+                None
+            }
+            "response.completed" => Some(Ok(completed_output(&event)
+                .or_else(|| {
+                    (!self.completed_output_parts.is_empty())
+                        .then(|| self.completed_output_parts.clone())
+                })
+                .unwrap_or_else(|| self.output_deltas.clone()))),
+            kind @ ("response.failed" | "response.incomplete") => {
+                Some(Err(failure_reason(&event, kind)))
+            }
+            _ => None,
+        }
+    }
+}
+
+fn next_sse_frame(bytes: &[u8]) -> Option<(usize, usize)> {
+    let line_feed = bytes
+        .windows(2)
+        .position(|window| window == b"\n\n")
+        .map(|index| (index, 2));
+    let carriage_return = bytes
+        .windows(4)
+        .position(|window| window == b"\r\n\r\n")
+        .map(|index| (index, 4));
+    match (line_feed, carriage_return) {
+        (Some(left), Some(right)) => Some(if left.0 <= right.0 { left } else { right }),
+        (Some(frame), None) | (None, Some(frame)) => Some(frame),
+        (None, None) => None,
+    }
+}
+
+fn completed_output(event: &serde_json::Value) -> Option<String> {
+    let output = event
+        .get("response")?
+        .get("output")?
+        .as_array()?
+        .iter()
+        .filter_map(|item| item.get("content").and_then(serde_json::Value::as_array))
+        .flatten()
+        .filter(|part| part.get("type").and_then(serde_json::Value::as_str) == Some("output_text"))
+        .filter_map(|part| part.get("text").and_then(serde_json::Value::as_str))
+        .collect::<String>();
+    (!output.is_empty()).then_some(output)
+}
+
+fn failure_reason(event: &serde_json::Value, kind: &str) -> String {
+    let reason = match kind {
+        "response.failed" => event
+            .pointer("/response/error/message")
+            .or_else(|| event.pointer("/error/message")),
+        "response.incomplete" => event.pointer("/response/incomplete_details/reason"),
+        _ => None,
+    }
+    .and_then(serde_json::Value::as_str);
+    reason.map_or_else(|| kind.to_string(), |reason| format!("{kind}: {reason}"))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+
+    #[test]
+    fn waits_for_completed_across_chunks() {
+        let mut decoder = Decoder::default();
+
+        assert_eq!(
+            decoder.push(b"data: {\"type\":\"response.output_text.delta\",\"delta\":\"O\"}\n\n"),
+            None
+        );
+        assert_eq!(
+            decoder
+                .push(b"data: {\"type\":\"response.output_text.delta\",\"delta\":\"K\"}\r\n\r\n"),
+            None
+        );
+        assert_eq!(decoder.push(b"data: {\"type\":\"response.comp"), None);
+        assert_eq!(
+            decoder.push(b"leted\",\"response\":{}}\n\n"),
+            Some(Ok("OK".to_string()))
+        );
+    }
+
+    #[test]
+    fn reports_terminal_failure_and_rejects_partial_eof() {
+        let mut failed = Decoder::default();
+        assert_eq!(
+            failed.push(
+                b"data: {\"type\":\"response.failed\",\"response\":{\"error\":{\"message\":\"denied\"}}}\n\n"
+            ),
+            Some(Err("response.failed: denied".to_string()))
+        );
+
+        let mut partial = Decoder::default();
+        assert_eq!(
+            partial.push(b"data: {\"type\":\"response.output_text.delta\",\"delta\":\"OK\"}\n\n"),
+            None
+        );
+        assert_eq!(partial.finish(), None);
+    }
+
+    #[test]
+    fn uses_the_earliest_mixed_line_ending() {
+        let mut decoder = Decoder::default();
+        assert_eq!(
+            decoder.push(
+                concat!(
+                    "data: {\"type\":\"response.output_text.delta\",\"delta\":\"OK\"}\r\n\r\n",
+                    "data: {\"type\":\"response.completed\",\"response\":{}}\n\n",
+                )
+                .as_bytes()
+            ),
+            Some(Ok("OK".to_string()))
+        );
+    }
+}
