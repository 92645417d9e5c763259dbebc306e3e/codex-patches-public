+#[derive(Serialize)]
+struct WeeklyResetAuditRecord<'a> {
+    event: &'static str,
+    timestamp: String,
+    changes: &'a [WeeklyResetChange],
+}
+
+#[derive(Serialize)]
+struct ModelProbeAuditRecord<'a> {
+    event: &'static str,
+    model: &'a str,
+    timestamp: String,
+    request: &'static str,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    response: Option<&'a str>,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    error: Option<&'a str>,
+}
+
+async fn probe_and_audit_weekly_reset(inner: &Arc<Inner>, batch: WeeklyResetBatch) {
+    let _guard = inner.probe_lock.lock().await;
+    let reset = WeeklyResetAuditRecord {
+        event: "weekly_rate_limit_reset_changed",
+        timestamp: chrono::DateTime::<chrono::Utc>::from(batch.observed_at).to_rfc3339(),
+        changes: &batch.changes,
+    };
+    if let Err(err) =
+        append_audit_records(&inner.probe_log_path, std::slice::from_ref(&reset)).await
+    {
+        tracing::warn!(error = %err, "failed to write weekly rate-limit reset audit");
+    }
+
+    let outcomes = match inner
+        .processor
+        .probe_enabled_models(
+            &batch.identity,
+            WEEKLY_RESET_PROBE_TIMEOUT,
+            WEEKLY_RESET_PROBE_PROMPT,
+        )
+        .await
+    {
+        Ok(outcomes) => outcomes,
+        Err(err) => {
+            tracing::warn!(error = %err, "failed to prepare weekly rate-limit model probes");
+            return;
+        }
+    };
+    let timestamp = chrono::Utc::now().to_rfc3339();
+    let records = outcomes
+        .iter()
+        .map(|outcome| {
+            let (response, error) = match &outcome.result {
+                Ok(response) => (Some(response.as_str()), None),
+                Err(error) => (None, Some(error.as_str())),
+            };
+            ModelProbeAuditRecord {
+                event: "weekly_rate_limit_model_probe",
+                model: &outcome.model,
+                timestamp: timestamp.clone(),
+                request: WEEKLY_RESET_PROBE_PROMPT,
+                response,
+                error,
+            }
+        })
+        .collect::<Vec<_>>();
+    if let Err(err) = append_audit_records(&inner.probe_log_path, &records).await {
+        tracing::warn!(error = %err, "failed to write weekly rate-limit probe audit");
+    }
+}
+
+async fn append_audit_records<T: Serialize>(path: &Path, records: &[T]) -> std::io::Result<()> {
+    use tokio::io::AsyncWriteExt as _;
+
+    let Some(parent) = path.parent() else {
+        return Err(std::io::Error::new(
+            std::io::ErrorKind::InvalidInput,
+            "rate-limit probe log path has no parent",
+        ));
+    };
+    tokio::fs::create_dir_all(parent).await?;
+    let mut output = Vec::new();
+    for record in records {
+        serde_json::to_writer(&mut output, record)?;
+        output.push(b'\n');
+    }
+    let mut file = tokio::fs::OpenOptions::new()
+        .create(true)
+        .append(true)
+        .open(path)
+        .await?;
+    file.write_all(&output).await?;
+    file.flush().await
+}
