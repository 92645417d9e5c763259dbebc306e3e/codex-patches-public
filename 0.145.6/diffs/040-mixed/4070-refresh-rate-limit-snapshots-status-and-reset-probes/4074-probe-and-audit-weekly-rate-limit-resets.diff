+#[derive(Clone, Debug)]
+struct WeeklyResetBatch {
+    identity: RateLimitIdentity,
+    observed_at: SystemTime,
+    changes: Vec<WeeklyResetChange>,
+}
+
+#[derive(Default)]
+struct WeeklyResetDetector {
+    identity: Option<RateLimitIdentity>,
+    resets_at: HashMap<WeeklyWindowKey, i64>,
+}
+
+impl WeeklyResetDetector {
+    fn clear(&mut self) {
+        self.identity = None;
+        self.resets_at.clear();
+    }
+
+    fn observe(
+        &mut self,
+        identity: &RateLimitIdentity,
+        response: &GetAccountRateLimitsResponse,
+        observed_at: SystemTime,
+    ) -> Option<WeeklyResetBatch> {
+        if self.identity.as_ref() != Some(identity) {
+            self.clear();
+            self.identity = Some(identity.clone());
+        }
+        let mut observations = response
+            .rate_limits_by_limit_id
+            .as_ref()?
+            .iter()
+            .flat_map(|(limit_id, snapshot)| {
+                [
+                    (WeeklyWindowSlot::Primary, snapshot.primary.as_ref()),
+                    (WeeklyWindowSlot::Secondary, snapshot.secondary.as_ref()),
+                ]
+                .into_iter()
+                .filter_map(|(slot, window)| {
+                    weekly_reset_at(window).map(|resets_at| {
+                        (
+                            WeeklyWindowKey {
+                                limit_id: limit_id.clone(),
+                                slot,
+                            },
+                            resets_at,
+                        )
+                    })
+                })
+            })
+            .collect::<Vec<_>>();
+        observations.sort_by(|left, right| left.0.cmp(&right.0));
+
+        let mut changes = Vec::new();
+        for (key, resets_at) in observations {
+            let previous = self.resets_at.insert(key.clone(), resets_at);
+            if let Some(previous_resets_at) = previous
+                && previous_resets_at.abs_diff(resets_at) > WEEKLY_RESET_CHANGE_TOLERANCE_SECS
+            {
+                changes.push(WeeklyResetChange {
+                    limit_id: key.limit_id,
+                    slot: key.slot,
+                    previous_resets_at,
+                    resets_at,
+                });
+            }
+        }
+        (!changes.is_empty()).then(|| WeeklyResetBatch {
+            identity: identity.clone(),
+            observed_at,
+            changes,
+        })
+    }
+}
+
+fn weekly_reset_at(window: Option<&RateLimitWindow>) -> Option<i64> {
+    let window = window?;
+    (window.window_duration_mins == Some(WEEKLY_WINDOW_MINUTES))
+        .then_some(window.resets_at)
+        .flatten()
 }
 
