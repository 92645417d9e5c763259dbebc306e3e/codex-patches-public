+#[tokio::test]
+async fn thread_name_updated_broadcasts_when_name_is_cleared() -> Result<()> {
+    let server = create_mock_responses_server_repeating_assistant("Done").await;
+    let codex_home = TempDir::new()?;
+    create_config_toml(codex_home.path(), &server.uri(), "never")?;
+    let conversation_id = create_rollout(codex_home.path(), "2025-01-05T12-10-00")?;
+    let thread_id = ThreadId::from_string(&conversation_id)?;
+    append_thread_name(codex_home.path(), thread_id, "Old name").await?;
+
+    let (mut process, bind_addr) = spawn_websocket_server(codex_home.path()).await?;
+
+    let result = async {
+        let mut ws1 = connect_websocket(bind_addr).await?;
+        let mut ws2 = connect_websocket(bind_addr).await?;
+        initialize_both_clients(&mut ws1, &mut ws2).await?;
+
+        send_request(
+            &mut ws1,
+            "thread/name/set",
+            /*id*/ 30,
+            Some(serde_json::json!({
+                "threadId": conversation_id,
+                "name": null,
+            })),
+        )
+        .await?;
+        let (rename_resp, ws1_notification) = read_response_and_notification_for_method(
+            &mut ws1,
+            /*id*/ 30,
+            "thread/name/updated",
+        )
+        .await?;
+        let _: ThreadSetNameResponse = to_response::<ThreadSetNameResponse>(rename_resp)?;
+        assert_thread_name_updated_value(ws1_notification, &conversation_id, None)?;
+
+        let ws2_notification =
+            read_notification_for_method(&mut ws2, "thread/name/updated").await?;
+        assert_thread_name_updated_value(ws2_notification, &conversation_id, None)?;
+
+        send_request(
+            &mut ws1,
+            "thread/read",
+            /*id*/ 31,
+            Some(serde_json::to_value(ThreadReadParams {
+                thread_id: conversation_id.clone(),
+                include_turns: false,
+            })?),
+        )
+        .await?;
+        let read_resp: JSONRPCResponse = read_response_for_id(&mut ws1, /*id*/ 31).await?;
+        let read: ThreadReadResponse = to_response::<ThreadReadResponse>(read_resp)?;
+        assert_eq!(read.thread.name, None);
+
+        assert_no_message(&mut ws1, Duration::from_millis(250)).await?;
+        assert_no_message(&mut ws2, Duration::from_millis(250)).await?;
+        Ok(())
+    }
+    .await;
+
+    process
+        .kill()
+        .await
+        .context("failed to stop websocket app-server process")?;
+    result
+}
