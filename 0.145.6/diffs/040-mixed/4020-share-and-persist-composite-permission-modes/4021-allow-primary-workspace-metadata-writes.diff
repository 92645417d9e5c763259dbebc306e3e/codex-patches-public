+    /// Retains workspace-write scope while allowing metadata writes in one root.
+    pub fn with_writable_workspace_metadata(mut self, workspace_root: &AbsolutePathBuf) -> Self {
+        if !matches!(self.kind, FileSystemSandboxKind::Restricted) {
+            return self;
+        }
+        self.entries
+            .extend(
+                PROTECTED_METADATA_PATH_NAMES
+                    .iter()
+                    .map(|name| FileSystemSandboxEntry {
+                        path: FileSystemPath::Path {
+                            path: workspace_root.join(name),
+                        },
+                        access: FileSystemAccessMode::Write,
+                        missing_path_behavior: None,
+                    }),
+            );
+        self
+    }
