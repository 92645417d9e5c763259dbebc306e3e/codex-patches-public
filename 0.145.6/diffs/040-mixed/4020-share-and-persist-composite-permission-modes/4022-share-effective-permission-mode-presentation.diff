diff --git a/codex-rs/tui/src/permission_mode.rs b/codex-rs/tui/src/permission_mode.rs
new file mode 100644
index 0000000000..dc69f1f0c6
--- /dev/null
+++ b/codex-rs/tui/src/permission_mode.rs
@@ -0,0 +1,287 @@
+use crate::legacy_core::config::Config;
+use codex_app_server_protocol::AskForApproval;
+use codex_protocol::config_types::ApprovalsReviewer;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_READ_ONLY;
+use codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_WORKSPACE;
+use codex_protocol::models::PermissionProfile;
+use codex_utils_absolute_path::AbsolutePathBuf;
+
+/// Canonical presentation for the built-in permission combinations exposed by
+/// this TUI. Custom and modified profiles remain on the upstream fallback path.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub(crate) enum PermissionMode {
+    ReadOnly,
+    WorkspaceManualApproval,
+    WorkspaceAutoReview,
+    FullAccessAutoReview,
+    Yolo,
+}
+
+impl PermissionMode {
+    pub(crate) fn from_config(config: &Config) -> Option<Self> {
+        let approval_policy = AskForApproval::from(config.permissions.approval_policy.value());
+        let reviewer = config.approvals_reviewer;
+        let permission_profile = config.permissions.effective_permission_profile();
+        let canonical_permission_profile = config.permissions.permission_profile();
+        let active_profile = config.permissions.active_permission_profile();
+        let active_id = active_profile.as_ref().map(|profile| profile.id.as_str());
+        let has_only_primary_workspace_root = config
+            .effective_workspace_roots()
+            .iter()
+            .all(|root| root == &config.cwd);
+        let canonical_profile = match active_id {
+            Some(BUILT_IN_PERMISSION_PROFILE_READ_ONLY) => {
+                canonical_permission_profile == &PermissionProfile::read_only()
+                    && has_only_primary_workspace_root
+            }
+            Some(BUILT_IN_PERMISSION_PROFILE_WORKSPACE) => {
+                (canonical_permission_profile == &PermissionProfile::workspace_write()
+                    || canonical_permission_profile
+                        == &PermissionProfile::local_workspace_write(&config.cwd))
+                    && has_only_primary_workspace_root
+            }
+            Some(BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS) => {
+                matches!(permission_profile, PermissionProfile::Disabled)
+            }
+            _ => false,
+        };
+
+        Self::from_parts(
+            active_id,
+            &permission_profile,
+            approval_policy,
+            reviewer,
+            canonical_profile,
+        )
+    }
+
+    pub(crate) fn from_session(
+        active_id: Option<&str>,
+        permission_profile: &PermissionProfile,
+        cwd: &AbsolutePathBuf,
+        workspace_roots: &[AbsolutePathBuf],
+        approval_policy: AskForApproval,
+        reviewer: ApprovalsReviewer,
+    ) -> Option<Self> {
+        let has_only_primary_workspace_root = workspace_roots.iter().all(|root| root == cwd);
+        let canonical_profile = match active_id {
+            Some(BUILT_IN_PERMISSION_PROFILE_READ_ONLY) => {
+                permission_profile == &PermissionProfile::read_only()
+                    && has_only_primary_workspace_root
+            }
+            Some(BUILT_IN_PERMISSION_PROFILE_WORKSPACE) => {
+                let upstream = PermissionProfile::workspace_write()
+                    .materialize_project_roots_with_workspace_roots(workspace_roots);
+                let local = PermissionProfile::local_workspace_write(cwd)
+                    .materialize_project_roots_with_workspace_roots(workspace_roots);
+                (permission_profile == &upstream || permission_profile == &local)
+                    && has_only_primary_workspace_root
+            }
+            Some(BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS) => {
+                matches!(permission_profile, PermissionProfile::Disabled)
+            }
+            _ => false,
+        };
+
+        Self::from_parts(
+            active_id,
+            permission_profile,
+            approval_policy,
+            reviewer,
+            canonical_profile,
+        )
+    }
+
+    fn from_parts(
+        active_id: Option<&str>,
+        permission_profile: &PermissionProfile,
+        approval_policy: AskForApproval,
+        reviewer: ApprovalsReviewer,
+        canonical_profile: bool,
+    ) -> Option<Self> {
+        if !canonical_profile {
+            return None;
+        }
+
+        if matches!(permission_profile, PermissionProfile::Disabled) {
+            return match (approval_policy, reviewer) {
+                (AskForApproval::Never, _) => Some(Self::Yolo),
+                (AskForApproval::OnRequest, ApprovalsReviewer::AutoReview) => {
+                    Some(Self::FullAccessAutoReview)
+                }
+                _ => None,
+            };
+        }
+
+        match (active_id, approval_policy, reviewer) {
+            (
+                Some(BUILT_IN_PERMISSION_PROFILE_READ_ONLY),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+            ) => Some(Self::ReadOnly),
+            (
+                Some(BUILT_IN_PERMISSION_PROFILE_WORKSPACE),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+            ) => Some(Self::WorkspaceManualApproval),
+            (
+                Some(BUILT_IN_PERMISSION_PROFILE_WORKSPACE),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::AutoReview,
+            ) => Some(Self::WorkspaceAutoReview),
+            (Some(BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS), _, _) => None,
+            _ => None,
+        }
+    }
+
+    pub(crate) fn label(self) -> &'static str {
+        match self {
+            Self::ReadOnly => "Read Only",
+            Self::WorkspaceManualApproval => "Workspace + Manual Approval",
+            Self::WorkspaceAutoReview => "Workspace + Auto Review",
+            Self::FullAccessAutoReview => "Full Access + Auto Review",
+            Self::Yolo => "YOLO",
+        }
+    }
+
+    pub(crate) fn sandbox_label(self) -> &'static str {
+        match self {
+            Self::ReadOnly => "Read Only",
+            Self::WorkspaceManualApproval | Self::WorkspaceAutoReview => "Workspace",
+            Self::FullAccessAutoReview => "Full Access",
+            Self::Yolo => "YOLO",
+        }
+    }
+
+    pub(crate) fn approval_label(self) -> &'static str {
+        match self {
+            Self::ReadOnly | Self::WorkspaceManualApproval => "Manual Approval",
+            Self::WorkspaceAutoReview | Self::FullAccessAutoReview => "Auto Review",
+            Self::Yolo => "No Approval",
+        }
+    }
+
+    pub(crate) fn is_yolo(self) -> bool {
+        self == Self::Yolo
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn classifies_the_five_builtin_permission_modes() {
+        let cases = [
+            (
+                BUILT_IN_PERMISSION_PROFILE_READ_ONLY,
+                PermissionProfile::read_only(),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+                PermissionMode::ReadOnly,
+                "Read Only",
+                "Read Only",
+                "Manual Approval",
+            ),
+            (
+                BUILT_IN_PERMISSION_PROFILE_WORKSPACE,
+                PermissionProfile::workspace_write(),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+                PermissionMode::WorkspaceManualApproval,
+                "Workspace + Manual Approval",
+                "Workspace",
+                "Manual Approval",
+            ),
+            (
+                BUILT_IN_PERMISSION_PROFILE_WORKSPACE,
+                PermissionProfile::workspace_write(),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::AutoReview,
+                PermissionMode::WorkspaceAutoReview,
+                "Workspace + Auto Review",
+                "Workspace",
+                "Auto Review",
+            ),
+            (
+                BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS,
+                PermissionProfile::Disabled,
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::AutoReview,
+                PermissionMode::FullAccessAutoReview,
+                "Full Access + Auto Review",
+                "Full Access",
+                "Auto Review",
+            ),
+            (
+                BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS,
+                PermissionProfile::Disabled,
+                AskForApproval::Never,
+                ApprovalsReviewer::User,
+                PermissionMode::Yolo,
+                "YOLO",
+                "YOLO",
+                "No Approval",
+            ),
+        ];
+
+        for (
+            active_id,
+            profile,
+            approval_policy,
+            reviewer,
+            expected,
+            label,
+            sandbox_label,
+            approval_label,
+        ) in cases
+        {
+            let actual = PermissionMode::from_parts(
+                Some(active_id),
+                &profile,
+                approval_policy,
+                reviewer,
+                true,
+            );
+            assert_eq!(actual, Some(expected));
+            assert_eq!(expected.label(), label);
+            assert_eq!(expected.sandbox_label(), sandbox_label);
+            assert_eq!(expected.approval_label(), approval_label);
+        }
+    }
+
+    #[test]
+    fn leaves_custom_profiles_on_the_upstream_presentation_path() {
+        assert_eq!(
+            PermissionMode::from_parts(
+                Some("custom"),
+                &PermissionProfile::workspace_write(),
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::User,
+                false,
+            ),
+            None
+        );
+        assert_eq!(
+            PermissionMode::from_parts(
+                Some("custom"),
+                &PermissionProfile::Disabled,
+                AskForApproval::Never,
+                ApprovalsReviewer::User,
+                false,
+            ),
+            None
+        );
+        assert_eq!(
+            PermissionMode::from_parts(
+                Some("custom"),
+                &PermissionProfile::Disabled,
+                AskForApproval::OnRequest,
+                ApprovalsReviewer::AutoReview,
+                false,
+            ),
+            None
+        );
+    }
+}
