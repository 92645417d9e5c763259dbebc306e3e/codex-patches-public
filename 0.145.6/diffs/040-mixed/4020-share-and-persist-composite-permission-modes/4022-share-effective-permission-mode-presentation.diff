+#[tokio::test]
+async fn session_info_uses_shared_builtin_yolo_classification() {
+    let config = test_config().await;
+    let mut session = session_configured_event("gpt-5");
+    session.permission_profile = PermissionProfile::Disabled;
+    session.active_permission_profile = Some(codex_protocol::models::ActivePermissionProfile::new(
+        codex_protocol::models::BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS,
+    ));
+    session.runtime_workspace_roots = vec![session.cwd.clone()];
+
+    let yolo = new_session_info(
+        &config, "gpt-5", &session, /*is_first_event*/ false, /*tooltip_override*/ None,
+        /*auth_plan*/ None, /*show_fast_status*/ false,
+    );
+    assert!(render_transcript(&yolo).join("\n").contains("YOLO mode"));
+
+    session.approval_policy = AskForApproval::OnRequest;
+    session.approvals_reviewer = codex_protocol::config_types::ApprovalsReviewer::AutoReview;
+    let auto_review = new_session_info(
+        &config, "gpt-5", &session, /*is_first_event*/ false, /*tooltip_override*/ None,
+        /*auth_plan*/ None, /*show_fast_status*/ false,
+    );
+    assert!(
+        !render_transcript(&auto_review)
+            .join("\n")
+            .contains("YOLO mode")
+    );
+}
