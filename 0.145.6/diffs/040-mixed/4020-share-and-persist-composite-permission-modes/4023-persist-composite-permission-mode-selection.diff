+#[tokio::test]
+async fn permission_profile_selection_persists_composite_mode_before_runtime_apply() -> Result<()> {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let codex_home = tempdir()?;
+    app.config.codex_home = codex_home.path().to_path_buf().abs();
+    let mut app_server = start_config_write_test_app_server(&app).await?;
+
+    assert!(
+        app.apply_permission_profile_selection(
+            &mut app_server,
+            PermissionProfileSelection::builtin(PermissionMode::FullAccessAutoReview),
+        )
+        .await
+    );
+
+    assert_eq!(
+        app.config.permissions.active_permission_profile(),
+        Some(ActivePermissionProfile::new(
+            BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS,
+        ))
+    );
+    assert_eq!(
+        AskForApproval::from(app.config.permissions.approval_policy.value()),
+        AskForApproval::OnRequest
+    );
+    assert_eq!(app.config.approvals_reviewer, ApprovalsReviewer::AutoReview);
+
+    let config = std::fs::read_to_string(codex_home.path().join("config.toml"))?;
+    assert!(config.contains("default_permissions = \":danger-full-access\""));
+    assert!(config.contains("approval_policy = \"on-request\""));
+    assert!(config.contains("approvals_reviewer = \"auto_review\""));
+
+    assert!(matches!(
+        app_event_rx.try_recv(),
+        Ok(AppEvent::CodexOp(Op::OverrideTurnContext {
+            approval_policy: Some(AskForApproval::OnRequest),
+            approvals_reviewer: Some(ApprovalsReviewer::AutoReview),
+            permission_profile: Some(PermissionProfile::Disabled),
+            ..
+        }))
+    ));
+    let cell = match app_event_rx.try_recv() {
+        Ok(AppEvent::InsertHistoryCell(cell)) => cell,
+        other => panic!("expected InsertHistoryCell event, got {other:?}"),
+    };
+    assert!(
+        cell.display_lines(/*width*/ 120)
+            .iter()
+            .any(|line| line.to_string().contains("Full Access + Auto Review"))
+    );
+
+    app_server.shutdown().await?;
+    Ok(())
+}
