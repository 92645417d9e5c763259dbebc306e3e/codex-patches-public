+#[test]
+fn user_prompt_submit_hook_intent_requires_application_true_and_is_consumed() {
+    let unrelated_key = "caller.context".to_string();
+    let unrelated = AdditionalContextEntry {
+        value: "keep".to_string(),
+        kind: AdditionalContextKind::Application,
+    };
+    for (kind, value, expected) in [
+        (AdditionalContextKind::Application, "true", true),
+        (AdditionalContextKind::Application, "false", false),
+        (AdditionalContextKind::Untrusted, "true", false),
+    ] {
+        let mut additional_context = BTreeMap::from([
+            (
+                USER_PROMPT_SUBMIT_HOOK_CONTEXT_KEY.to_string(),
+                AdditionalContextEntry {
+                    value: value.to_string(),
+                    kind,
+                },
+            ),
+            (unrelated_key.clone(), unrelated.clone()),
+        ]);
+
+        assert_eq!(
+            take_user_prompt_submit_hook_intent(&mut additional_context),
+            expected
+        );
+        assert_eq!(
+            additional_context,
+            BTreeMap::from([(unrelated_key.clone(), unrelated.clone())])
+        );
+    }
+}
