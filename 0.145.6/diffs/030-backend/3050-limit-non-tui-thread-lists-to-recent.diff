+#[tokio::test]
+async fn non_tui_thread_list_is_forced_to_recent_five_without_pagination() -> Result<()> {
+    let codex_home = TempDir::new()?;
+    create_minimal_config(codex_home.path())?;
+
+    let mut ids = Vec::new();
+    for day in 1..=6 {
+        let (timestamp_file, timestamp_rfc3339) = timestamp_at(2025, 1, day, 12, 0, 0);
+        let id = create_fake_rollout(
+            codex_home.path(),
+            &timestamp_file,
+            &timestamp_rfc3339,
+            "Hello",
+            Some("mock_provider"),
+            /*git_info*/ None,
+        )?;
+        set_rollout_mtime(
+            rollout_path(codex_home.path(), &timestamp_file, &id).as_path(),
+            &timestamp_rfc3339,
+        )?;
+        ids.push(id);
+    }
+
+    let mut mcp = init_mcp_with_client_name(codex_home.path(), "codex-vscode").await?;
+    let request_id = mcp
+        .send_thread_list_request(codex_app_server_protocol::ThreadListParams {
+            cursor: Some("ignored-client-cursor".to_string()),
+            limit: Some(100),
+            sort_key: Some(ThreadSortKey::CreatedAt),
+            sort_direction: Some(SortDirection::Asc),
+            model_providers: Some(vec!["mock_provider".to_string()]),
+            source_kinds: None,
+            archived: None,
+            is_pinned: None,
+            cwd: None,
+            use_state_db_only: false,
+            search_term: None,
+            parent_thread_id: None,
+            ancestor_thread_id: None,
+        })
+        .await?;
+    let response = timeout(
+        DEFAULT_READ_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(request_id)),
+    )
+    .await??;
+    let ThreadListResponse {
+        data,
+        next_cursor,
+        backwards_cursor,
+    } = to_response::<ThreadListResponse>(response)?;
+
+    let expected_ids: Vec<_> = ids.iter().rev().take(5).map(String::as_str).collect();
+    let actual_ids: Vec<_> = data.iter().map(|thread| thread.id.as_str()).collect();
+    assert_eq!(actual_ids, expected_ids);
+    assert_eq!(next_cursor, None);
+    assert_eq!(backwards_cursor, None);
+
+    Ok(())
+}
