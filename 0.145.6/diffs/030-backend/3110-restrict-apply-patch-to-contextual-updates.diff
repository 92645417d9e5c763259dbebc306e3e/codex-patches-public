@@ -44,6 +39,29 @@ pub(crate) const EOF_MARKER: &str = "*** End of File";
 pub(crate) const CHANGE_CONTEXT_MARKER: &str = "@@ ";
 pub(crate) const EMPTY_CHANGE_CONTEXT_MARKER: &str = "@@";
 
+pub(crate) fn reject_unsupported_operation(
+    line: &str,
+    line_number: usize,
+) -> Result<(), ParseError> {
+    let trimmed = line.trim();
+    let operation = [
+        (ADD_FILE_MARKER.trim_end(), "Add File"),
+        (DELETE_FILE_MARKER.trim_end(), "Delete File"),
+        (MOVE_TO_MARKER.trim_end(), "Move to"),
+    ]
+    .into_iter()
+    .find_map(|(marker, operation)| trimmed.starts_with(marker).then_some(operation));
+    if let Some(operation) = operation {
+        return Err(InvalidHunkError {
+            message: format!(
+                "{operation} is unsupported; apply_patch accepts only contextual Update File hunks"
+            ),
+            line_number,
+        });
+    }
+    Ok(())
+}
