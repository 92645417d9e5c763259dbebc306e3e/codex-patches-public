+    manager.catalog.write().await.models.clear();
+    let fallback_slug = "gpt-5.2-codex";
+    write_instructions_overlay(
+        codex_home.path(),
+        fallback_slug,
+        "raw request overlay must not apply",
+    );
+    let fallback_with_messages = manager.get_model_info(fallback_slug, &config).await;
+    assert!(fallback_with_messages.used_fallback_model_metadata);
+    assert_eq!(
+        fallback_with_messages.model_messages,
+        model_info::model_info_from_slug(fallback_slug).model_messages
+    );
+
+    let missing = remote_model_with_prompt("overlay-missing", "missing catalog instructions");
+    manager.catalog.write().await.models = vec![missing];
+    let missing_overlay = manager.get_model_info("overlay-missing", &config).await;
+    assert_eq!(
+        missing_overlay
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("missing catalog instructions")
+    );
+
+    manager.catalog.write().await.models.clear();
+    write_instructions_overlay(
+        codex_home.path(),
+        "plain-unknown",
+        "must not create messages",
+    );
+    let without_messages = manager.get_model_info("plain-unknown", &config).await;
+    assert!(without_messages.used_fallback_model_metadata);
+    assert_eq!(without_messages.model_messages, None);
+
+    let empty = remote_model_with_prompt("overlay-empty", "catalog instructions");
+    manager.catalog.write().await.models = vec![empty];
+    write_instructions_overlay(codex_home.path(), "overlay-empty", "  \n");
+    let empty_overlay = manager.get_model_info("overlay-empty", &config).await;
+    assert_eq!(
+        empty_overlay
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("catalog instructions")
+    );
+
+    let unreadable = remote_model_with_prompt("overlay-unreadable", "unreadable catalog prompt");
+    manager.catalog.write().await.models = vec![unreadable];
+    std::fs::create_dir_all(instructions_overlay_path(
+        codex_home.path(),
+        "overlay-unreadable",
+    ))
+    .expect("create unreadable overlay path");
+    let unreadable_overlay = manager.get_model_info("overlay-unreadable", &config).await;
+    assert_eq!(
+        unreadable_overlay
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("unreadable catalog prompt")
+    );
+
+    let unsafe_model = remote_model_with_prompt("../unsafe", "unsafe catalog instructions");
+    manager.catalog.write().await.models = vec![unsafe_model];
+    std::fs::write(codex_home.path().join("unsafe.md"), "escaped overlay")
+        .expect("write traversal sentinel");
+    let unsafe_model = manager.get_model_info("../unsafe", &config).await;
+    assert_eq!(
+        unsafe_model
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("unsafe catalog instructions")
+    );
+    logs_assert(|lines: &[&str]| {
+        for message in [
+            "instructions overlay file must not be empty",
+            "failed to load instructions overlay file",
+            "instructions overlay catalog slug is unsafe",
+        ] {
+            if !lines
+                .iter()
+                .any(|line| line.contains("WARN") && line.contains(message))
+            {
+                return Err(format!("missing overlay warning: {message}"));
+            }
+        }
+        if lines
+            .iter()
+            .any(|line| line.contains("overlay-missing") && line.contains("instructions overlay"))
+        {
+            return Err("missing overlay emitted a warning".to_string());
+        }
+        Ok(())
+    });
+}
