+use codex_protocol::openai_models::ModelInfo;
+use std::collections::BTreeMap;
+use std::fs as std_fs;
+use std::fs::File;
+use std::fs::OpenOptions;
+use std::io;
+use std::io::ErrorKind;
+use std::io::Write;
+use std::path::Path;
+use std::path::PathBuf;
+use std::sync::atomic::AtomicU64;
+use std::sync::atomic::Ordering;
+use tokio::fs;
+use tracing::warn;
+
+pub(crate) const INSTRUCTIONS_OVERLAY_DIR: &str = "instructions";
+static SEED_TEMP_SEQUENCE: AtomicU64 = AtomicU64::new(0);
+
+pub(crate) fn dir_path(codex_home: &Path) -> PathBuf {
+    codex_home.join(INSTRUCTIONS_OVERLAY_DIR)
+}
+
+pub(crate) async fn apply(dir: &Path, catalog_slug: &str, model_info: &mut ModelInfo) {
+    if !is_safe_catalog_slug(catalog_slug) {
+        warn!(
+            model = %model_info.slug,
+            catalog_slug,
+            "instructions overlay catalog slug is unsafe"
+        );
+        return;
+    }
+    let Some(path) = matching_overlay_path(dir, catalog_slug).await else {
+        return;
+    };
+    let template = match fs::read_to_string(&path).await {
+        Ok(template) => template,
+        Err(err) if err.kind() == ErrorKind::NotFound => return,
+        Err(err) => {
+            warn!(
+                model = %model_info.slug,
+                path = %path.display(),
+                "failed to load instructions overlay file: {err}"
+            );
+            return;
+        }
+    };
+    if template.trim().is_empty() {
+        warn!(
+            model = %model_info.slug,
+            path = %path.display(),
+            "instructions overlay file must not be empty"
+        );
+        return;
+    }
+    let Some(model_messages) = model_info.model_messages.as_mut() else {
+        return;
+    };
+    model_messages.instructions_template = Some(template);
+}
+
+pub(crate) async fn seed(dir: &Path, models: &[ModelInfo]) {
+    if let Err(err) = fs::create_dir_all(dir).await {
+        warn!(
+            path = %dir.display(),
+            "failed to create instructions overlay directory: {err}"
+        );
+        return;
+    }
+
+    let startup_snapshot = InstructionFileSnapshot::capture(dir).await;
+    for model in models {
+        let Some(template) = model
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref())
+        else {
+            continue;
+        };
+        let Some(path) = model_path(dir, &model.slug) else {
+            warn!(
+                model = %model.slug,
+                "instructions overlay catalog slug is unsafe"
+            );
+            continue;
+        };
+        if startup_snapshot
+            .matching_overlay_path(&model.slug)
+            .is_some()
+        {
+            continue;
+        }
+        if template.trim().is_empty() {
+            warn!(
+                model = %model.slug,
+                path = %path.display(),
+                "instructions overlay seed must not be empty"
+            );
+            continue;
+        }
+        if let Err(err) = create_new(&path, template).await
+            && err.kind() != ErrorKind::AlreadyExists
+        {
+            warn!(
+                model = %model.slug,
+                path = %path.display(),
+                "failed to seed instructions overlay file: {err}"
+            );
+        }
+    }
+}
+
+#[derive(Default)]
+struct InstructionFileSnapshot {
+    paths_by_stem: BTreeMap<String, PathBuf>,
+}
+
+impl InstructionFileSnapshot {
+    async fn capture(dir: &Path) -> Self {
+        let mut entries = match fs::read_dir(dir).await {
+            Ok(entries) => entries,
+            Err(err) if err.kind() == ErrorKind::NotFound => return Self::default(),
+            Err(err) => {
+                warn!(
+                    path = %dir.display(),
+                    "failed to scan instructions overlay directory: {err}"
+                );
+                return Self::default();
+            }
+        };
+        let mut snapshot = Self::default();
+        loop {
+            let entry = match entries.next_entry().await {
+                Ok(Some(entry)) => entry,
+                Ok(None) => break,
+                Err(err) => {
+                    warn!(
+                        path = %dir.display(),
+                        "failed to scan instructions overlay directory entry: {err}"
+                    );
+                    break;
+                }
+            };
+            let path = entry.path();
+            let Some(stem) = path
+                .extension()
+                .filter(|extension| *extension == "md")
+                .and_then(|_| path.file_stem())
+                .and_then(|stem| stem.to_str())
+                .filter(|stem| is_safe_catalog_slug(stem))
+            else {
+                continue;
+            };
+            snapshot.paths_by_stem.insert(stem.to_string(), path);
+        }
+        snapshot
+    }
+
+    fn matching_overlay_path(&self, catalog_slug: &str) -> Option<&Path> {
+        if !is_safe_catalog_slug(catalog_slug) {
+            return None;
+        }
+        if let Some(exact) = self.paths_by_stem.get(catalog_slug) {
+            return Some(exact.as_path());
+        }
+        self.paths_by_stem
+            .iter()
+            .filter(|(stem, _)| catalog_slug.starts_with(stem.as_str()))
+            .max_by_key(|(stem, _)| stem.len())
+            .map(|(_, path)| path.as_path())
+    }
+}
+
+fn model_path(dir: &Path, catalog_slug: &str) -> Option<PathBuf> {
+    is_safe_catalog_slug(catalog_slug).then(|| dir.join(format!("{catalog_slug}.md")))
+}
+
+async fn matching_overlay_path(dir: &Path, catalog_slug: &str) -> Option<PathBuf> {
+    let exact = model_path(dir, catalog_slug)?;
+    match fs::symlink_metadata(&exact).await {
+        Ok(_) => return Some(exact),
+        Err(err) if err.kind() == ErrorKind::NotFound => {}
+        Err(_) => return Some(exact),
+    }
+
+    InstructionFileSnapshot::capture(dir)
+        .await
+        .matching_overlay_path(catalog_slug)
+        .map(Path::to_path_buf)
+}
+
+fn is_safe_catalog_slug(catalog_slug: &str) -> bool {
+    let bytes = catalog_slug.as_bytes();
+    bytes
+        .first()
+        .copied()
+        .is_some_and(is_ascii_lowercase_alphanumeric)
+        && bytes
+            .last()
+            .copied()
+            .is_some_and(is_ascii_lowercase_alphanumeric)
+        && catalog_slug
+            .bytes()
+            .all(|byte| is_ascii_lowercase_alphanumeric(byte) || matches!(byte, b'-' | b'_' | b'.'))
+        && !catalog_slug.contains("..")
+        && !is_windows_reserved_name(catalog_slug)
+}
+
+fn is_ascii_lowercase_alphanumeric(byte: u8) -> bool {
+    byte.is_ascii_lowercase() || byte.is_ascii_digit()
+}
+
+fn is_windows_reserved_name(catalog_slug: &str) -> bool {
+    let stem = catalog_slug.split('.').next().unwrap_or(catalog_slug);
+    matches!(stem, "con" | "prn" | "aux" | "nul")
+        || stem
+            .strip_prefix("com")
+            .or_else(|| stem.strip_prefix("lpt"))
+            .is_some_and(|number| {
+                matches!(number, "1" | "2" | "3" | "4" | "5" | "6" | "7" | "8" | "9")
+            })
+}
+
+async fn create_new(path: &Path, contents: &str) -> io::Result<()> {
+    let path = path.to_path_buf();
+    let contents = contents.as_bytes().to_vec();
+    tokio::task::spawn_blocking(move || {
+        StagedSeed::create(&path, &contents)?.install_no_clobber(&path)
+    })
+    .await
+    .map_err(io::Error::other)?
+}
+
+struct StagedSeed {
+    path: PathBuf,
+    file: Option<File>,
+}
+
+impl StagedSeed {
+    fn create(target: &Path, contents: &[u8]) -> io::Result<Self> {
+        Self::create_with(target, |file| file.write_all(contents))
+    }
+
+    fn create_with(
+        target: &Path,
+        write_contents: impl FnOnce(&mut File) -> io::Result<()>,
+    ) -> io::Result<Self> {
+        let parent = target
+            .parent()
+            .ok_or_else(|| io::Error::other("instructions overlay target has no parent"))?;
+        let file_name = target
+            .file_name()
+            .ok_or_else(|| io::Error::other("instructions overlay target has no file name"))?
+            .to_string_lossy();
+        let (file, temp_path) = (0..128)
+            .find_map(|_| {
+                let sequence = SEED_TEMP_SEQUENCE.fetch_add(1, Ordering::Relaxed);
+                let temp_path = parent.join(format!(
+                    ".{file_name}.seed.{}.{sequence}",
+                    std::process::id()
+                ));
+                match OpenOptions::new()
+                    .write(true)
+                    .create_new(true)
+                    .open(&temp_path)
+                {
+                    Ok(file) => Some(Ok((file, temp_path))),
+                    Err(err) if err.kind() == ErrorKind::AlreadyExists => None,
+                    Err(err) => Some(Err(err)),
+                }
+            })
+            .transpose()?
+            .ok_or_else(|| io::Error::new(ErrorKind::AlreadyExists, "seed temp names exhausted"))?;
+        let mut staged = Self {
+            path: temp_path,
+            file: Some(file),
+        };
+        let Some(file) = staged.file.as_mut() else {
+            return Err(io::Error::other("newly staged seed lost its file"));
+        };
+        write_contents(file).and_then(|()| file.sync_all())?;
+        drop(staged.file.take());
+        Ok(staged)
+    }
+
+    fn install_no_clobber(self, target: &Path) -> io::Result<()> {
+        std_fs::hard_link(&self.path, target)
+    }
+}
+
+impl Drop for StagedSeed {
+    fn drop(&mut self) {
+        drop(self.file.take());
+        let _ = std_fs::remove_file(&self.path);
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn model_with_prompt(slug: &str, prompt: &str) -> ModelInfo {
+        let mut model = crate::bundled_models_response()
+            .expect("bundled models should parse")
+            .models
+            .into_iter()
+            .find(|model| model.model_messages.is_some())
+            .expect("bundled catalog should include instruction messages");
+        model.slug = slug.to_string();
+        model
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some(prompt.to_string());
+        model
+    }
+
+    #[test]
+    fn catalog_slug_paths_use_a_positive_ascii_filename_policy() {
+        let dir = Path::new("instructions");
+        assert_eq!(
+            model_path(dir, "gpt-5.2_codex"),
+            Some(dir.join("gpt-5.2_codex.md"))
+        );
+
+        for slug in [
+            "",
+            ".",
+            "..",
+            ".hidden",
+            "gpt.",
+            "gpt..5",
+            "../gpt-5",
+            "provider/gpt-5",
+            "provider\\gpt-5",
+            "gpt 5",
+            "GPT-5",
+            "con",
+            "nul.model",
+            "com1",
+            "lpt9.extra",
+            "模型",
+        ] {
+            assert_eq!(model_path(dir, slug), None, "accepted unsafe slug {slug:?}");
+        }
+    }
+
+    #[tokio::test]
+    async fn empty_snapshot_seeds_family_members_in_any_order_and_restart_is_idempotent() {
+        for reverse in [false, true] {
+            let temp = tempfile::tempdir().expect("create temp dir");
+            let dir = dir_path(temp.path());
+            let base = model_with_prompt("gpt-5.4", "base prompt");
+            let mini = model_with_prompt("gpt-5.4-mini", "mini prompt");
+            let mut models = vec![base, mini];
+            if reverse {
+                models.reverse();
+            }
+
+            seed(&dir, &models).await;
+
+            assert_eq!(
+                std_fs::read_to_string(dir.join("gpt-5.4.md")).expect("read base seed"),
+                "base prompt"
+            );
+            assert_eq!(
+                std_fs::read_to_string(dir.join("gpt-5.4-mini.md")).expect("read mini seed"),
+                "mini prompt"
+            );
+
+            let mut restarted = vec![
+                model_with_prompt("gpt-5.4", "replacement base"),
+                model_with_prompt("gpt-5.4-mini", "replacement mini"),
+            ];
+            restarted.reverse();
+            seed(&dir, &restarted).await;
+
+            assert_eq!(
+                std_fs::read_to_string(dir.join("gpt-5.4.md")).expect("read base after restart"),
+                "base prompt"
+            );
+            assert_eq!(
+                std_fs::read_to_string(dir.join("gpt-5.4-mini.md"))
+                    .expect("read mini after restart"),
+                "mini prompt"
+            );
+        }
+    }
+
+    #[tokio::test]
+    async fn mixed_startup_snapshot_covers_only_matching_models() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let dir = dir_path(temp.path());
+        fs::create_dir_all(&dir).await.expect("create overlay dir");
+        fs::write(dir.join("gpt-5.4.md"), "existing family")
+            .await
+            .expect("write family overlay");
+        fs::write(dir.join("o4-mini.md"), "existing exact")
+            .await
+            .expect("write exact overlay");
+        let mut family_member = model_with_prompt("gpt-5.4-mini", "cached family member");
+        let mut exact = model_with_prompt("o4-mini", "cached exact");
+        let new_model = model_with_prompt("gpt-6", "new exact");
+
+        seed(&dir, &[family_member.clone(), exact.clone(), new_model]).await;
+
+        assert!(!dir.join("gpt-5.4-mini.md").exists());
+        assert_eq!(
+            std_fs::read_to_string(dir.join("gpt-5.4.md")).expect("read family overlay"),
+            "existing family"
+        );
+        assert_eq!(
+            std_fs::read_to_string(dir.join("o4-mini.md")).expect("read exact overlay"),
+            "existing exact"
+        );
+        assert_eq!(
+            std_fs::read_to_string(dir.join("gpt-6.md")).expect("read new exact seed"),
+            "new exact"
+        );
+
+        apply(&dir, "gpt-5.4-mini", &mut family_member).await;
+        apply(&dir, "o4-mini", &mut exact).await;
+        assert_eq!(
+            family_member
+                .model_messages
+                .as_ref()
+                .and_then(|messages| messages.instructions_template.as_deref()),
+            Some("existing family")
+        );
+        assert_eq!(
+            exact
+                .model_messages
+                .as_ref()
+                .and_then(|messages| messages.instructions_template.as_deref()),
+            Some("existing exact")
+        );
+    }
+
+    #[tokio::test]
+    async fn concurrent_seed_is_atomic_and_never_clobbers_the_winner() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let dir = dir_path(temp.path());
+        let mut first = crate::bundled_models_response()
+            .expect("bundled models should parse")
+            .models
+            .into_iter()
+            .find(|model| model.model_messages.is_some())
+            .expect("bundled catalog should include instruction messages");
+        first.slug = "seed-race".to_string();
+        first
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("first".to_string());
+        let mut second = first.clone();
+        second
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("second".to_string());
+        let first_catalog = vec![first];
+        let second_catalog = vec![second];
+
+        tokio::join!(seed(&dir, &first_catalog), seed(&dir, &second_catalog));
+
+        let path = model_path(&dir, "seed-race").expect("safe test slug");
+        let winner = fs::read_to_string(&path)
+            .await
+            .expect("one concurrent seed should win");
+        assert!(winner == "first" || winner == "second");
+
+        let mut later = first_catalog[0].clone();
+        later
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("later".to_string());
+        seed(&dir, &[later]).await;
+        assert_eq!(
+            fs::read_to_string(path)
+                .await
+                .expect("winning seed should remain readable"),
+            winner
+        );
+    }
+
+    #[tokio::test]
+    async fn family_overlay_prevents_exact_seed_and_exact_overlay_wins() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let dir = dir_path(temp.path());
+        fs::create_dir_all(&dir).await.expect("create overlay dir");
+        fs::write(dir.join("gpt-5.md"), "broad family")
+            .await
+            .expect("write broad family overlay");
+        fs::write(dir.join("gpt-5.6.md"), "specific family")
+            .await
+            .expect("write specific family overlay");
+
+        let mut model = crate::bundled_models_response()
+            .expect("bundled models should parse")
+            .models
+            .into_iter()
+            .find(|model| model.model_messages.is_some())
+            .expect("bundled catalog should include instruction messages");
+        model.slug = "gpt-5.6-terra".to_string();
+        model
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("cached exact template".to_string());
+        let model_slug = model.slug.clone();
+
+        seed(&dir, std::slice::from_ref(&model)).await;
+        assert!(
+            !model_path(&dir, &model.slug)
+                .expect("safe exact path")
+                .exists(),
+            "family selection must not materialize a cached exact file"
+        );
+
+        apply(&dir, &model_slug, &mut model).await;
+        assert_eq!(
+            model
+                .model_messages
+                .as_ref()
+                .and_then(|messages| messages.instructions_template.as_deref()),
+            Some("specific family")
+        );
+
+        fs::write(dir.join("gpt-5.6-terra.md"), "exact model")
+            .await
+            .expect("write exact model overlay");
+        apply(&dir, &model_slug, &mut model).await;
+        assert_eq!(
+            model
+                .model_messages
+                .as_ref()
+                .and_then(|messages| messages.instructions_template.as_deref()),
+            Some("exact model")
+        );
+    }
+
+    #[test]
+    fn staged_seed_is_invisible_until_atomic_no_clobber_install() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let target = temp.path().join("model.md");
+        let staged = StagedSeed::create(&target, b"complete prompt").expect("stage prompt");
+        let staged_path = staged.path.clone();
+        assert!(!target.exists());
+        assert_eq!(
+            std_fs::read(&staged_path).expect("read staged prompt"),
+            b"complete prompt"
+        );
+
+        std_fs::write(&target, "user prompt").expect("write winning user prompt");
+        assert_eq!(
+            staged
+                .install_no_clobber(&target)
+                .expect_err("existing target must win")
+                .kind(),
+            ErrorKind::AlreadyExists
+        );
+        assert_eq!(
+            std_fs::read_to_string(&target).expect("read winning user prompt"),
+            "user prompt"
+        );
+        assert!(!staged_path.exists());
+
+        std_fs::remove_file(&target).expect("remove winning user prompt");
+        let staged = StagedSeed::create(&target, b"published prompt").expect("restage prompt");
+        let staged_path = staged.path.clone();
+        staged
+            .install_no_clobber(&target)
+            .expect("publish staged prompt");
+        assert_eq!(
+            std_fs::read_to_string(&target).expect("read published prompt"),
+            "published prompt"
+        );
+        assert!(!staged_path.exists());
+    }
+
+    #[test]
+    fn failed_staging_removes_partial_file_and_allows_retry() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let target = temp.path().join("model.md");
+        let err = StagedSeed::create_with(&target, |file| {
+            file.write_all(b"partial prompt")?;
+            Err(io::Error::other("injected write failure"))
+        })
+        .err()
+        .expect("staging should fail");
+        assert_eq!(err.to_string(), "injected write failure");
+        assert!(!target.exists());
+        assert_eq!(
+            std_fs::read_dir(temp.path())
+                .expect("read temp directory")
+                .count(),
+            0
+        );
+
+        StagedSeed::create(&target, b"retry prompt")
+            .expect("retry staging")
+            .install_no_clobber(&target)
+            .expect("retry publication");
+        assert_eq!(
+            std_fs::read_to_string(target).expect("read retry prompt"),
+            "retry prompt"
+        );
+    }
+}
