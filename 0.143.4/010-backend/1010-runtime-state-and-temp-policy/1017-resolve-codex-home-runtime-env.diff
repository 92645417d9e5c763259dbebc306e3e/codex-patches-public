+#[test]
+#[serial]
+fn create_runtime_env_prefers_explicit_codex_home_over_process_env() {
+    let temp = TempDir::new().expect("temp dir");
+    let explicit_codex_home = temp.path().join("explicit-codex-home");
+    let process_codex_home = temp.path().join("process-codex-home");
+    let cwd = temp.path().join("workspace");
+    std::fs::create_dir_all(&explicit_codex_home).expect("create explicit codex home");
+    std::fs::create_dir_all(&process_codex_home).expect("create process codex home");
+    std::fs::create_dir_all(&cwd).expect("create cwd");
+    let _codex_home = EnvVarGuard::set("CODEX_HOME", &process_codex_home);
+
+    let env = create_runtime_env(
+        &ShellEnvironmentPolicy {
+            inherit: ShellEnvironmentPolicyInherit::None,
+            ignore_default_excludes: true,
+            ..Default::default()
+        },
+        /*thread_id*/ None,
+        Some(cwd.as_path()),
+        Some(explicit_codex_home.as_path()),
+    );
+
+    assert_eq!(
+        env.get(CODEX_HOME_ENV_VAR),
+        Some(&explicit_codex_home.to_string_lossy().into_owned())
+    );
+}
