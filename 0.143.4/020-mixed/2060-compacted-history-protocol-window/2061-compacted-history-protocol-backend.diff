+pub(super) struct DisplayHistoryWindow {
+    pub(super) items: Vec<RolloutItem>,
+    pub(super) metadata: codex_app_server_protocol::ThreadResumeHistoryWindowMetadata,
+}
+
+pub(super) fn display_history_items(
+    items: &[RolloutItem],
+    history_window: ThreadHistoryWindow,
+) -> Vec<RolloutItem> {
+    display_history_window(items, history_window).items
+}
+
+pub(super) fn display_history_window(
+    items: &[RolloutItem],
+    history_window: ThreadHistoryWindow,
+) -> DisplayHistoryWindow {
+    let replacement_count = replacement_compaction_indices(items).count() as u32;
+    match history_window {
+        ThreadHistoryWindow::Full => DisplayHistoryWindow {
+            items: items.to_vec(),
+            metadata: codex_app_server_protocol::ThreadResumeHistoryWindowMetadata {
+                loaded_context_windows: replacement_count.saturating_add(1),
+                omitted_context_windows: 0,
+                baseline_compaction: false,
+                baseline_compaction_rendered: false,
+            },
+        },
+        ThreadHistoryWindow::SinceLatestCompaction => {
+            let Some(index) = latest_effective_replacement_compaction_index(items) else {
+                return DisplayHistoryWindow {
+                    items: items.to_vec(),
+                    metadata: codex_app_server_protocol::ThreadResumeHistoryWindowMetadata {
+                        loaded_context_windows: 1,
+                        omitted_context_windows: 0,
+                        baseline_compaction: false,
+                        baseline_compaction_rendered: false,
+                    },
+                };
+            };
+            let turn_start = items[..=index]
+                .iter()
+                .rposition(|item| matches!(item, RolloutItem::EventMsg(EventMsg::TurnStarted(_))))
+                .unwrap_or(index);
+            let mut window = items[turn_start..].to_vec();
+            let baseline_offset = index.saturating_sub(turn_start);
+            let baseline_compaction_rendered =
+                remove_baseline_context_compaction(&mut window, baseline_offset).is_none();
+            DisplayHistoryWindow {
+                items: window,
+                metadata: codex_app_server_protocol::ThreadResumeHistoryWindowMetadata {
+                    loaded_context_windows: 1,
+                    omitted_context_windows: replacement_compaction_indices(&items[..index]).count()
+                        as u32,
+                    baseline_compaction: true,
+                    baseline_compaction_rendered,
+                },
+            }
+        }
+    }
+}
+
+fn replacement_compaction_indices(items: &[RolloutItem]) -> impl Iterator<Item = usize> + '_ {
+    items.iter().enumerate().filter_map(|(index, item)| {
+        matches!(
+            item,
+            RolloutItem::Compacted(compacted) if compacted.replacement_history.is_some()
+        )
+        .then_some(index)
+    })
+}
+
+fn latest_effective_replacement_compaction_index(items: &[RolloutItem]) -> Option<usize> {
+    let effective_turn_ids: Vec<String> = build_legacy_api_turns_from_rollout_items(items)
+        .into_iter()
+        .map(|turn| turn.id)
+        .collect();
+    let replacement_indices = replacement_compaction_indices(items).collect::<Vec<_>>();
+    replacement_indices
+        .into_iter()
+        .rev()
+        .find(|index| match turn_id_at_or_before(items, *index) {
+            Some(turn_id) => effective_turn_ids.iter().any(|id| id == &turn_id),
+            None => true,
+        })
+}
+
+fn turn_id_at_or_before(items: &[RolloutItem], index: usize) -> Option<String> {
+    items[..=index].iter().rev().find_map(|item| match item {
+        RolloutItem::EventMsg(EventMsg::TurnStarted(started)) => Some(started.turn_id.clone()),
+        _ => None,
+    })
+}
+
+fn remove_baseline_context_compaction(
+    items: &mut Vec<RolloutItem>,
+    baseline_offset: usize,
+) -> Option<RolloutItem> {
+    let remove_offset = items
+        .iter()
+        .enumerate()
+        .skip(baseline_offset.saturating_add(1))
+        .take_while(|(_, item)| !matches!(item, RolloutItem::EventMsg(EventMsg::TurnStarted(_))))
+        .find_map(|(offset, item)| {
+            matches!(item, RolloutItem::EventMsg(EventMsg::ContextCompacted(_))).then_some(offset)
+        })?;
+    Some(items.remove(remove_offset))
+}
