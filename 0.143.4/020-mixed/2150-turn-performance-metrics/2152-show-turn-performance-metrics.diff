+            codex_protocol::protocol::EventMsg::AgentReasoning(
+                codex_protocol::protocol::AgentReasoningEvent {
+                    text: "Summary only".into(),
+                    continued: true,
+                },
+            ),
+        ),
+        codex_protocol::protocol::RolloutItem::EventMsg(
+            codex_protocol::protocol::EventMsg::ItemCompleted(
+                codex_protocol::protocol::ItemCompletedEvent {
+                    thread_id: ThreadId::new(),
+                    turn_id: "turn-1".into(),
+                    item: codex_protocol::items::TurnItem::Reasoning(
+                        codex_protocol::items::ReasoningItem {
+                            id: "reasoning-1".into(),
