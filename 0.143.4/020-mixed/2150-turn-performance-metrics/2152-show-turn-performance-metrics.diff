+#[tokio::test]
+async fn live_reasoning_block_commits_before_deferred_command_history() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_agent_reasoning_delta(
+        &mut chat,
+        "**Inspecting patches and directories**\n\nNeed to inspect patch artifacts first.",
+    );
+
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 0,
+            item: AppServerThreadItem::CommandExecution {
+                id: "cmd-queue-1".to_string(),
+                command: "echo hi".to_string(),
+                cwd: test_path_buf("/tmp").abs().into(),
+                process_id: None,
+                source: AppServerCommandExecutionSource::UserShell,
+                status: AppServerCommandExecutionStatus::InProgress,
+                command_actions: vec![AppServerCommandAction::Unknown {
+                    command: "echo hi".to_string(),
+                }],
+                aggregated_output: None,
+                exit_code: None,
+                duration_ms: None,
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 0,
+            item: AppServerThreadItem::CommandExecution {
+                id: "cmd-queue-1".to_string(),
+                command: "echo hi".to_string(),
+                cwd: test_path_buf("/tmp").abs().into(),
+                process_id: None,
+                source: AppServerCommandExecutionSource::UserShell,
+                status: AppServerCommandExecutionStatus::Completed,
+                command_actions: vec![AppServerCommandAction::Unknown {
+                    command: "echo hi".to_string(),
+                }],
+                aggregated_output: Some("hi\n".to_string()),
+                exit_code: Some(0),
+                duration_ms: Some(5),
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+
+    assert!(
+        drain_insert_history(&mut rx).is_empty(),
+        "tool history should stay deferred until the reasoning block commits"
+    );
+
+    handle_agent_reasoning_final(&mut chat);
+
+    let rendered = drain_insert_history(&mut rx)
+        .into_iter()
+        .map(|lines| lines_to_single_string(&lines))
+        .collect::<Vec<_>>();
+    assert!(
+        rendered
+            .first()
+            .is_some_and(|cell| cell.contains("Inspecting patches and directories")),
+        "expected reasoning cell to commit before deferred command history, got {rendered:?}"
+    );
+    assert!(
+        rendered.iter().skip(1).any(|cell| cell.contains("echo hi")),
+        "expected deferred command history after reasoning cell, got {rendered:?}"
+    );
+}
