diff --git a/codex-rs/core/src/plaintext_reasoning.rs b/codex-rs/core/src/plaintext_reasoning.rs
new file mode 100644
index 0000000000..648c712a74
--- /dev/null
+++ b/codex-rs/core/src/plaintext_reasoning.rs
@@ -0,0 +1,57 @@
+use codex_protocol::models::ReasoningItemContent;
+use codex_protocol::models::ReasoningItemReasoningSummary;
+use codex_protocol::models::ResponseItem;
+
+pub(crate) fn normalize_plaintext_reasoning_item(item: &mut ResponseItem) {
+    let ResponseItem::Reasoning {
+        summary, content, ..
+    } = item
+    else {
+        return;
+    };
+    let Some(raw_content) = content.take() else {
+        return;
+    };
+    summary.extend(raw_content.into_iter().filter_map(|entry| {
+        let text = match entry {
+            ReasoningItemContent::ReasoningText { text } | ReasoningItemContent::Text { text } => {
+                text
+            }
+        };
+        (!text.trim().is_empty()).then_some(ReasoningItemReasoningSummary::SummaryText { text })
+    }));
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn plaintext_reasoning_is_projected_as_reasoning_summary() {
+        let mut item = ResponseItem::Reasoning {
+            id: Some("rs_test".to_string()),
+            summary: Vec::new(),
+            content: Some(vec![ReasoningItemContent::ReasoningText {
+                text: "visible chain".to_string(),
+            }]),
+            encrypted_content: None,
+            internal_chat_message_metadata_passthrough: None,
+        };
+
+        normalize_plaintext_reasoning_item(&mut item);
+
+        let ResponseItem::Reasoning {
+            summary, content, ..
+        } = item
+        else {
+            panic!("expected reasoning item");
+        };
+        assert_eq!(content, None);
+        assert_eq!(
+            summary,
+            vec![ReasoningItemReasoningSummary::SummaryText {
+                text: "visible chain".to_string()
+            }]
+        );
+    }
+}
