+    notices: Vec<PendingContinuationNotice>,
+}
+
+impl PendingContinuationReasoning {
+    fn push_notice(&mut self, kind: codex_protocol::items::ContinuationNoticeKind) {
+        if let Some(last) = self.notices.last_mut()
+            && last.kind == kind
+        {
+            last.count = last.count.saturating_add(1);
+            return;
+        }
+        self.notices
+            .push(PendingContinuationNotice { kind, count: 1 });
+    }
+}
