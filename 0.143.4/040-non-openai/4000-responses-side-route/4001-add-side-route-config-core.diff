+fn instruction_template_for_model(codex_home: &Path, model_id: &str) -> String {
+    let path = codex_home
+        .join(INSTRUCTIONS_DIR)
+        .join(format!("{model_id}.md"));
+    match fs::read_to_string(path) {
+        Ok(contents) if !contents.trim().is_empty() => contents,
+        _ => BASE_INSTRUCTIONS.to_string(),
+    }
+}
+
+fn load_config_file(path: &Path) -> io::Result<BTreeMap<String, ProviderConfig>> {
+    let contents = match fs::read_to_string(path) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == ErrorKind::NotFound => return Ok(default_config()),
+        Err(err) => return Err(err),
+    };
+    if contents.trim().is_empty() {
+        return Ok(default_config());
+    }
+    let value = serde_json::from_str::<Value>(&contents)
+        .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+    let Some(mut providers_value) = value.as_object().cloned() else {
+        return Ok(default_config());
+    };
+    let defaults_value = serde_json::to_value(default_config())
+        .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+    if let Some(defaults) = defaults_value.as_object() {
+        for (provider_id, default_provider) in defaults {
+            match providers_value.get_mut(provider_id) {
+                Some(provider) if provider.is_object() => {
+                    merge_missing_value(provider, default_provider);
+                }
+                Some(provider) => {
+                    *provider = default_provider.clone();
+                }
+                None => {
+                    providers_value.insert(provider_id.clone(), default_provider.clone());
+                }
+            }
+        }
+    }
+    let mut providers = BTreeMap::new();
+    for (provider_id, provider_value) in providers_value {
+        match serde_json::from_value::<ProviderConfig>(provider_value) {
+            Ok(provider) => {
+                providers.insert(provider_id, provider);
+            }
+            Err(err) => {
+                warn!(provider = %provider_id, "ignoring malformed non-openai provider config: {err}");
+            }
+        }
+    }
+    Ok(providers)
+}
+
+fn merge_missing_value(value: &mut Value, default_value: &Value) {
+    let (Some(value), Some(default_value)) = (value.as_object_mut(), default_value.as_object())
+    else {
+        return;
+    };
+    for (key, default_child) in default_value {
+        match value.get_mut(key) {
+            Some(child) if child.is_object() && default_child.is_object() => {
+                merge_missing_value(child, default_child);
+            }
+            Some(_) => {}
+            None => {
+                value.insert(key.clone(), default_child.clone());
+            }
+        }
+    }
+}
+
+fn write_if_changed(path: &Path, config: &BTreeMap<String, ProviderConfig>) -> io::Result<()> {
+    let next = serde_json::to_string_pretty(config)
+        .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+    if fs::read_to_string(path).ok().as_deref() == Some(next.as_str()) {
+        return Ok(());
+    }
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent)?;
+    }
+    let tmp = path.with_extension("json.tmp");
+    fs::write(&tmp, next)?;
+    fs::rename(tmp, path)?;
+    Ok(())
+}
+
+fn seed_instruction_overlays(codex_home: &Path, config: &BTreeMap<String, ProviderConfig>) {
+    let dir = codex_home.join(INSTRUCTIONS_DIR);
+    if let Err(err) = fs::create_dir_all(&dir) {
+        warn!(path = %dir.display(), "failed to create instructions overlay directory: {err}");
+        return;
+    }
+    for provider in config.values() {
+        for model_id in provider.models.keys() {
+            let path = dir.join(format!("{model_id}.md"));
+            if path.exists() {
+                continue;
+            }
+            if let Err(err) = fs::write(&path, BASE_INSTRUCTIONS) {
+                warn!(model = %model_id, path = %path.display(), "failed to seed instructions overlay file: {err}");
+            }
+        }
+    }
+}
