+fn provider_from_config(provider_id: &str, config: &ProviderConfig) -> NonOpenAiProvider {
+    let info = ModelProviderInfo {
+        name: if config.display_name.trim().is_empty() {
+            provider_id.to_string()
+        } else {
+            config.display_name.clone()
+        },
+        base_url: Some(config.base_url.clone()),
+        env_key: None,
+        env_key_instructions: None,
+        experimental_bearer_token: None,
+        auth: None,
+        aws: None,
+        wire_api: WireApi::Responses,
+        query_params: None,
+        http_headers: None,
+        env_http_headers: None,
+        request_max_retries: None,
+        stream_max_retries: None,
+        stream_idle_timeout_ms: None,
+        websocket_connect_timeout_ms: None,
+        requires_openai_auth: false,
+        supports_websockets: config.transport.websocket,
+    };
+    NonOpenAiProvider {
+        id: provider_id.to_string(),
+        info,
+        capabilities: ProviderCapabilities {
+            supports_json_schema_output: config.capabilities.json_schema_output,
+            supports_plaintext_reasoning: config.capabilities.plaintext_reasoning,
+            supports_previous_response_id: config.capabilities.previous_response_id,
+        },
+    }
+}
