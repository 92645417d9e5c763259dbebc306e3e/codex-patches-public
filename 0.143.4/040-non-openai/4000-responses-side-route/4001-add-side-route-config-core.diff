+fn model_info_from_config(
+    model_id: &str,
+    config: &ModelConfig,
+    plaintext_reasoning: bool,
+    codex_home: &Path,
+) -> ModelInfo {
+    let supported_reasoning_levels = supported_reasoning_levels(&config.reasoning);
+    let default_reasoning_level = supported_reasoning_levels
+        .iter()
+        .find(|preset| preset.effort == ReasoningEffort::High)
+        .or_else(|| supported_reasoning_levels.first())
+        .map(|preset| preset.effort.clone());
+    let input_modalities = if config.image {
+        vec![InputModality::Text, InputModality::Image]
+    } else {
+        vec![InputModality::Text]
+    };
+    let instruction_template = instruction_template_for_model(codex_home, model_id);
+    ModelInfo {
+        slug: model_id.to_string(),
+        display_name: if config.display_name.trim().is_empty() {
+            model_id.to_string()
+        } else {
+            config.display_name.clone()
+        },
+        description: config.description.clone(),
+        default_reasoning_level,
+        supported_reasoning_levels,
+        shell_type: ConfigShellToolType::Default,
+        visibility: ModelVisibility::List,
+        supported_in_api: true,
+        priority: 80,
+        additional_speed_tiers: Vec::new(),
+        service_tiers: Vec::new(),
+        default_service_tier: None,
+        availability_nux: None,
+        upgrade: None,
+        base_instructions: BASE_INSTRUCTIONS.to_string(),
+        model_messages: Some(ModelMessages {
+            instructions_template: Some(instruction_template),
+            instructions_variables: None,
+            approvals: None,
+        }),
+        include_skills_usage_instructions: false,
+        supports_reasoning_summaries: plaintext_reasoning || !config.reasoning.is_empty(),
+        supports_plaintext_reasoning: plaintext_reasoning,
+        default_reasoning_summary: codex_protocol::config_types::ReasoningSummary::None,
+        support_verbosity: false,
+        default_verbosity: None,
+        apply_patch_tool_type: None,
+        web_search_tool_type: if config.image {
+            WebSearchToolType::TextAndImage
+        } else {
+            WebSearchToolType::Text
+        },
+        truncation_policy: TruncationPolicyConfig::bytes(/*limit*/ 10_000),
+        supports_parallel_tool_calls: true,
+        supports_image_detail_original: config.image,
+        context_window: Some(config.context_window),
+        max_context_window: Some(config.context_window),
+        auto_compact_token_limit: None,
+        comp_hash: Some(format!("non-openai:{model_id}")),
+        effective_context_window_percent: config.effective_context_window_percent,
+        experimental_supported_tools: Vec::new(),
+        input_modalities,
+        used_fallback_model_metadata: false,
+        supports_search_tool: config.web_search,
+        use_responses_lite: false,
+        auto_review_model_override: None,
+        tool_mode: None,
+        multi_agent_version: None,
+    }
+}
+
+fn supported_reasoning_levels(
+    reasoning: &BTreeMap<String, ReasoningRouteConfig>,
+) -> Vec<ReasoningEffortPreset> {
+    let mut levels = reasoning
+        .keys()
+        .filter_map(|effort| effort.parse::<ReasoningEffort>().ok())
+        .map(|effort| ReasoningEffortPreset {
+            description: format!("{effort} reasoning"),
+            effort,
+        })
+        .collect::<Vec<_>>();
+    levels.sort_by_key(|preset| reasoning_effort_rank(&preset.effort));
+    levels
+}
+
+fn select_reasoning_route<'a>(
+    model: &'a NonOpenAiModel,
+    effort: Option<&ReasoningEffort>,
+) -> Option<&'a ReasoningRouteConfig> {
+    let effort_key = effort.map(ReasoningEffort::as_str);
+    effort_key
+        .and_then(|effort| model.reasoning.get(effort))
+        .or_else(|| model.reasoning.get("high"))
+        .or_else(|| model.reasoning.values().next())
+}
+
+fn reasoning_effort_rank(effort: &ReasoningEffort) -> usize {
+    match effort {
+        ReasoningEffort::None => 0,
+        ReasoningEffort::Minimal => 1,
+        ReasoningEffort::Low => 2,
+        ReasoningEffort::Medium => 3,
+        ReasoningEffort::High => 4,
+        ReasoningEffort::XHigh => 5,
+        ReasoningEffort::Max => 6,
+        ReasoningEffort::Ultra => 7,
+        ReasoningEffort::Custom(_) => 8,
+    }
+}
