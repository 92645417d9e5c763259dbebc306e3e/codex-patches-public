+impl NonOpenAiConfig {
+    pub(crate) fn load_and_heal(codex_home: &Path) -> io::Result<Self> {
+        let path = codex_home.join(CONFIG_FILE);
+        let normalized = load_config_file(&path)?;
+        write_if_changed(&path, &normalized)?;
+        seed_instruction_overlays(codex_home, &normalized);
+        Ok(Self::from_file(path, normalized, codex_home))
+    }
+
+    pub(crate) fn models(&self) -> Vec<ModelInfo> {
+        self.models
+            .values()
+            .map(|model| model.info.clone())
+            .collect()
+    }
+
+    pub(crate) fn wrap_models_manager(&self, inner: SharedModelsManager) -> SharedModelsManager {
+        if self.models.is_empty() {
+            return inner;
+        }
+        Arc::new(NonOpenAiModelsManager {
+            inner,
+            non_openai: self.clone(),
+        })
+    }
+
+    pub(crate) fn route_for_model(
+        &self,
+        model: &str,
+        effort: Option<&ReasoningEffort>,
+    ) -> Option<NonOpenAiRequestRoute> {
+        let model = self.models.get(model)?;
+        let provider = self.providers.get(&model.provider_id)?;
+        let reasoning = select_reasoning_route(model, effort);
+        let upstream_model = reasoning
+            .as_ref()
+            .and_then(|route| (!route.upstream_model.trim().is_empty()).then_some(route))
+            .map(|route| route.upstream_model.clone())
+            .unwrap_or_else(|| model.info.slug.clone());
+        Some(NonOpenAiRequestRoute {
+            provider_id: provider.id.clone(),
+            provider: provider.info.clone(),
+            upstream_model,
+            upstream_reasoning_effort: reasoning
+                .and_then(|route| route.upstream_reasoning_effort.clone()),
+            supports_json_schema_output: provider.capabilities.supports_json_schema_output,
+            supports_plaintext_reasoning: provider.capabilities.supports_plaintext_reasoning,
+            supports_previous_response_id: provider.capabilities.supports_previous_response_id,
+        })
+    }
+
+    pub(crate) fn supports_plaintext_reasoning(&self, model: &str) -> bool {
+        let Some(model) = self.models.get(model) else {
+            return false;
+        };
+        self.providers
+            .get(&model.provider_id)
+            .is_some_and(|provider| provider.capabilities.supports_plaintext_reasoning)
+    }
+
+    pub(crate) fn model_family(&self, model: &str) -> String {
+        self.models
+            .get(model)
+            .map(|model| format!("non-openai:{}", model.provider_id))
+            .unwrap_or_else(|| "openai".to_string())
+    }
+
+    pub(crate) fn family_takeover_message(
+        &self,
+        previous_model: &str,
+        current_model: &str,
+    ) -> Option<String> {
+        let previous_family = self.model_family(previous_model);
+        let current_family = self.model_family(current_model);
+        (previous_family != current_family).then(|| {
+            format!(
+                "Cannot continue this conversation with `{current_model}` because the previous turn used `{previous_model}`. Start a new conversation to switch model families."
+            )
+        })
+    }
+
+    pub(crate) async fn read_api_key(&self, provider_id: &str) -> CodexResult<String> {
+        read_api_key_from_path(&self.path, provider_id).await
+    }
+
+    fn from_file(path: PathBuf, file: BTreeMap<String, ProviderConfig>, codex_home: &Path) -> Self {
+        let mut providers = BTreeMap::new();
+        let mut models = BTreeMap::new();
+        for (provider_id, provider_config) in file {
+            if !provider_config.enabled {
+                continue;
+            }
+            if provider_config.base_url.trim().is_empty() {
+                warn!(provider = %provider_id, "ignoring non-openai provider without base_url");
+                continue;
+            }
+            let provider = provider_from_config(&provider_id, &provider_config);
+            for (model_id, model_config) in &provider_config.models {
+                if !model_config.text {
+                    warn!(provider = %provider_id, model = %model_id, "ignoring non-openai model without text support");
+                    continue;
+                }
+                let model_info = model_info_from_config(
+                    model_id,
+                    model_config,
+                    provider.capabilities.supports_plaintext_reasoning,
+                    codex_home,
+                );
+                models.insert(
+                    model_id.clone(),
+                    NonOpenAiModel {
+                        provider_id: provider_id.clone(),
+                        info: model_info,
+                        reasoning: model_config.reasoning.clone(),
+                    },
+                );
+            }
+            providers.insert(provider_id, provider);
+        }
+        Self {
+            path,
+            providers,
+            models,
+        }
+    }
+}
