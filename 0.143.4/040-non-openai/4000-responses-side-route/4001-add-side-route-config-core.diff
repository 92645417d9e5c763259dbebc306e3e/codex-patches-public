+async fn read_api_key_from_path(path: &Path, provider_id: &str) -> CodexResult<String> {
+    let contents = tokio::fs::read_to_string(path)
+        .await
+        .map_err(|err| CodexErr::Fatal(format!("failed to read non-openai config: {err}")))?;
+    let value = serde_json::from_str::<Value>(&contents)
+        .map_err(|err| CodexErr::Fatal(format!("failed to parse non-openai config: {err}")))?;
+    let api_key = value
+        .get(provider_id)
+        .and_then(|provider| provider.get("api_key"))
+        .and_then(Value::as_str)
+        .map(str::trim)
+        .filter(|api_key| !api_key.is_empty())
+        .filter(|api_key| *api_key != DEFAULT_API_KEY)
+        .ok_or_else(|| {
+            CodexErr::InvalidRequest(format!(
+                "non-openai provider `{provider_id}` needs a real api_key in {CONFIG_FILE}"
+            ))
+        })?;
+    Ok(api_key.to_string())
+}
+
+pub(crate) fn api_auth_for_key(api_key: String) -> SharedAuthProvider {
+    Arc::new(BearerAuthProvider::new(api_key))
+}
+
+pub(crate) fn api_provider_for_route(route: &NonOpenAiRequestRoute) -> CodexResult<ApiProvider> {
+    route.provider.to_api_provider(None)
+}
+
+fn default_config() -> BTreeMap<String, ProviderConfig> {
+    BTreeMap::new()
+}
