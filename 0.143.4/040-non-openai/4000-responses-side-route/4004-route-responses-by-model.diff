+#[tokio::test]
+async fn non_openai_previous_response_id_capability_stores_and_sends_incremental_http_requests() {
+    let server = MockServer::start().await;
+    let response_count = Arc::new(AtomicUsize::new(0));
+    let response_count_for_mock = Arc::clone(&response_count);
+    Mock::given(method("POST"))
+        .and(path("/v1/responses"))
+        .respond_with(move |_request: &wiremock::Request| {
+            let index = response_count_for_mock.fetch_add(1, Ordering::SeqCst) + 1;
+            let response_id = format!("resp-{index}");
+            ResponseTemplate::new(200)
+                .insert_header("content-type", "text/event-stream")
+                .set_body_raw(
+                    format!(
+                        "data: {{\"type\":\"response.created\",\"response\":{{\"id\":\"{response_id}\"}}}}\n\n\
+                         data: {{\"type\":\"response.completed\",\"response\":{{\"id\":\"{response_id}\"}}}}\n\n",
+                    ),
+                    "text/event-stream",
+                )
+        })
+        .expect(2)
+        .mount(&server)
+        .await;
+    let (_codex_home, non_openai) = test_non_openai_config_with_previous_response_id(
+        &format!("{}/v1", server.uri()),
+        "sk-test",
+        /*previous_response_id*/ true,
+    );
+    let client = ModelClient::new_with_non_openai(
+        /*auth_manager*/ None,
+        AgentIdentityAuthPolicy::JwtOnly,
+        ThreadId::new(),
+        create_oss_provider_with_base_url(
+            "https://openai-compatible.example/v1",
+            WireApi::Responses,
+        ),
+        SessionSource::Exec,
+        "test_originator".to_string(),
+        /*model_verbosity*/ None,
+        /*enable_request_compression*/ false,
+        /*include_timing_metrics*/ false,
+        /*beta_features_header*/ None,
+        /*item_ids_enabled*/ false,
+        /*concurrent_reasoning_summaries_enabled*/ false,
+        non_openai,
+        /*attestation_provider*/ None,
+        /*tx_event*/ None,
+        HttpClientFactory::new(OutboundProxyPolicy::ReqwestDefault),
+    );
+    let model_info = test_model_info_with_slug("mimo-v2.5");
+    let responses_metadata = test_responses_metadata_for_client(
+        &client,
+        /*turn_id*/ None,
+        format!("{}:0", client.state.thread_id),
+        /*parent_thread_id*/ None,
+        TestCodexResponsesRequestKind::Turn,
+    );
+    let session_telemetry = test_session_telemetry();
+    let inference_trace = InferenceTraceContext::disabled();
+    let mut client_session = client.new_session();
+    let prompt_one = prompt_with_text("hello");
+    let prompt_two = Prompt {
+        input: vec![prompt_message("hello"), prompt_message("second")],
+        ..Prompt::default()
+    };
+
+    stream_until_completed(
+        client_session
+            .stream(
+                &prompt_one,
+                &model_info,
+                &session_telemetry,
+                /*effort*/ None,
+                codex_protocol::config_types::ReasoningSummary::None,
+                /*service_tier*/ None,
+                &responses_metadata,
+                &inference_trace,
+            )
+            .await
+            .expect("first non-openai stream"),
+    )
+    .await;
+    stream_until_completed(
+        client_session
+            .stream(
+                &prompt_two,
+                &model_info,
+                &session_telemetry,
+                /*effort*/ None,
+                codex_protocol::config_types::ReasoningSummary::None,
+                /*service_tier*/ None,
+                &responses_metadata,
+                &inference_trace,
+            )
+            .await
+            .expect("second non-openai stream"),
+    )
+    .await;
+
+    let requests = server
+        .received_requests()
+        .await
+        .expect("server should record requests");
+    let response_requests: Vec<_> = requests
+        .iter()
+        .filter(|request| request.url.path() == "/v1/responses")
+        .collect();
+    assert_eq!(response_requests.len(), 2);
+    assert_eq!(response_count.load(Ordering::SeqCst), 2);
+    let first: serde_json::Value = serde_json::from_slice(&response_requests[0].body)
+        .expect("first request body should be json");
+    let second: serde_json::Value = serde_json::from_slice(&response_requests[1].body)
+        .expect("second request body should be json");
+
+    assert_eq!(first["store"], true);
+    assert!(first.get("previous_response_id").is_none());
+    assert_eq!(second["store"], true);
+    assert_eq!(second["previous_response_id"].as_str(), Some("resp-1"));
+    assert_eq!(
+        second["input"],
+        serde_json::to_value([prompt_message("second")]).expect("serialize expected delta")
+    );
+}
