+#[test]
+fn serializes_previous_response_id_only_when_set() {
+    let mut req = ResponsesApiRequest {
+        model: "gpt-5.4".to_string(),
+        instructions: "i".to_string(),
+        previous_response_id: None,
+        input: vec![],
+        tools: Some(vec![]),
+        tool_choice: "auto".to_string(),
+        parallel_tool_calls: true,
+        reasoning: None,
+        store: false,
+        stream: true,
+        stream_options: None,
+        include: vec![],
+        prompt_cache_key: None,
+        service_tier: None,
+        text: None,
+        client_metadata: None,
+    };
+
+    let v = serde_json::to_value(&req).expect("json");
+    assert!(v.get("previous_response_id").is_none());
+
+    req.previous_response_id = Some("resp_123".to_string());
+    let v = serde_json::to_value(&req).expect("json");
+    assert_eq!(
+        v.get("previous_response_id").and_then(|id| id.as_str()),
+        Some("resp_123")
+    );
+}
