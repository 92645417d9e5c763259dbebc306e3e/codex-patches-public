+#[tokio::test]
+async fn session_model_update_rebinds_provider_to_selected_model_family() {
+    let mut session_configuration = make_session_configuration_for_tests().await;
+    std::fs::create_dir_all(session_configuration.codex_home.as_path())
+        .expect("create codex home");
+    let config_path = session_configuration.codex_home.join("non-openai.json");
+    std::fs::write(
+        config_path,
+        serde_json::json!({
+            "mimo": {
+                "enabled": true,
+                "api_key": "sk-test",
+                "base_url": "https://api.xiaomimimo.com/v1",
+                "models": {
+                    "mimo-v2.5": {
+                        "display_name": "mimo-v2.5",
+                        "reasoning": {}
+                    }
+                }
+            }
+        })
+        .to_string(),
+    )
+    .expect("write non-openai config");
+    let mut config = (*session_configuration.original_config_do_not_use).clone();
+    config.non_openai = crate::non_openai::NonOpenAiConfig::load_and_heal(
+        session_configuration.codex_home.as_path(),
+    )
+    .expect("load non-openai config");
+    session_configuration.original_config_do_not_use = Arc::new(config);
+
+    let non_openai = session_configuration
+        .apply(&SessionSettingsUpdate {
+            collaboration_mode: Some(CollaborationMode {
+                mode: ModeKind::Default,
+                settings: Settings {
+                    model: "mimo-v2.5".to_string(),
+                    reasoning_effort: None,
+                    developer_instructions: None,
+                },
+            }),
+            ..Default::default()
+        })
+        .expect("apply non-openai model");
+    assert_eq!(non_openai.thread_config_snapshot().model_provider_id, "mimo");
+    assert_eq!(
+        non_openai.provider.base_url.as_deref(),
+        Some("https://api.xiaomimimo.com/v1")
+    );
+
+    let openai = non_openai
+        .apply(&SessionSettingsUpdate {
+            collaboration_mode: Some(CollaborationMode {
+                mode: ModeKind::Default,
+                settings: Settings {
+                    model: "gpt-5.4".to_string(),
+                    reasoning_effort: None,
+                    developer_instructions: None,
+                },
+            }),
+            ..Default::default()
+        })
+        .expect("apply openai model");
+    assert_eq!(openai.thread_config_snapshot().model_provider_id, "openai");
+    assert!(openai.provider.requires_openai_auth);
+}
