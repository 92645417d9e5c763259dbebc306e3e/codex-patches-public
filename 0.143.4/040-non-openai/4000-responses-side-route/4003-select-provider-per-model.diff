+#[test]
+fn unsupported_service_tier_warning_skips_non_openai_side_route_models() {
+    let mut model_info = model_with_default_service_tier(/*default_service_tier*/ None);
+    model_info.slug = "mimo-v2.5".to_string();
+    model_info.comp_hash = Some("non-openai:mimo-v2.5".to_string());
+    model_info.service_tiers.clear();
+
+    assert_eq!(
+        unsupported_service_tier_warning(
+            Some(ServiceTier::Fast.request_value()),
+            /*fast_mode_enabled*/ true,
+            &model_info,
+        ),
+        None
+    );
+    assert_eq!(
+        get_service_tier(
+            Some(ServiceTier::Fast.request_value().to_string()),
+            /*fast_mode_enabled*/ true,
+            &model_info,
+        ),
+        None
+    );
+}
