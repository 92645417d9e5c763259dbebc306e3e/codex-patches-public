+    },
+    "models": {
+      "step-3.7-flash": {}
+    }
+  }
+}"#,
+    )
+    .unwrap();
+    let non_openai = NonOpenAiConfig::load_and_heal(codex_home.path()).unwrap();
+    let model_info = non_openai
+        .models()
+        .into_iter()
+        .find(|model| model.slug == "step-3.7-flash")
+        .unwrap();
+
+    let plan = probe_with(
+        |turn| {
+            turn.model_info = model_info;
+            update_config(turn, |config| {
+                config.non_openai = non_openai;
+            });
+        },
+        ToolPlanInputs {
+            extension_tool_executors: vec![Arc::new(TestNamespaceExtensionTool {
+                namespace: "blocked",
+                tool_name: "lookup",
+            })],
+            ..ToolPlanInputs::default()
+        },
+    )
+    .await;
+
+    plan.assert_visible_lacks(&["blocked"]);
+}
