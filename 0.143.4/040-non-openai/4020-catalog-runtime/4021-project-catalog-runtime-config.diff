+fn heal_catalog_config(mut config: CatalogConfig, defaults: &CatalogConfig) -> CatalogConfig {
+    for (provider_id, default_provider) in &defaults.non_openai.providers {
+        match config.non_openai.providers.get_mut(provider_id) {
+            Some(provider) => heal_provider_config(provider, default_provider),
+            None => {
+                config
+                    .non_openai
+                    .providers
+                    .insert(provider_id.clone(), default_provider.clone());
+            }
+        }
+    }
+
+    let mut seen_models = config
+        .models
+        .iter()
+        .map(|model| model.info.slug.clone())
+        .collect::<std::collections::BTreeSet<_>>();
+    for default_model in &defaults.models {
+        if seen_models.insert(default_model.info.slug.clone()) {
+            config.models.push(default_model.clone());
+        }
+    }
+    for model in &mut config.models {
+        normalize_catalog_only_model_fields(&mut model.info);
+        if let Some(default_model) = defaults
+            .models
+            .iter()
+            .find(|default_model| default_model.info.slug == model.info.slug)
+        {
+            heal_model_route_config(&mut model.non_openai, &default_model.non_openai);
+        }
+    }
+    config
+}
