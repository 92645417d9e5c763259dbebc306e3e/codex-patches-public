+        provider.display_name = display_name;
+    }
+    if let Some(http_sse) = patch.transport.http_sse {
+        provider.transport.http_sse = http_sse;
+    }
+    if let Some(websocket) = patch.transport.websocket {
+        provider.transport.websocket = websocket;
+    }
+    if let Some(json_schema_output) = patch.capabilities.json_schema_output {
+        provider.capabilities.json_schema_output = json_schema_output;
+    }
+    if let Some(plaintext_reasoning) = patch.capabilities.plaintext_reasoning {
+        provider.capabilities.plaintext_reasoning = plaintext_reasoning;
+    }
+    if let Some(previous_response_id) = patch.capabilities.previous_response_id {
+        provider.capabilities.previous_response_id = previous_response_id;
