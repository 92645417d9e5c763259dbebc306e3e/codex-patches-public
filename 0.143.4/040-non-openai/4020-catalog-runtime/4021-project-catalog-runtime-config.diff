+fn heal_provider_config(provider: &mut ProviderConfig, default_provider: &ProviderConfig) {
+    if provider.api_key.trim().is_empty() {
+        provider.api_key = default_provider.api_key.clone();
+    }
+    if provider.base_url.trim().is_empty() {
+        provider.base_url = default_provider.base_url.clone();
+    }
+    if provider.display_name.trim().is_empty() {
+        provider.display_name = default_provider.display_name.clone();
+    }
+}
+
+fn heal_model_route_config(route: &mut ModelRouteConfig, default_route: &ModelRouteConfig) {
+    if route.provider.trim().is_empty() {
+        route.provider = default_route.provider.clone();
+    }
+    for (effort, default_reasoning) in &default_route.reasoning {
+        route
+            .reasoning
+            .entry(effort.clone())
+            .or_insert_with(|| default_reasoning.clone());
+    }
+    route.reasoning.retain(|effort, reasoning| {
+        effort.parse::<ReasoningEffort>().is_ok()
+            && reasoning
+                .upstream_reasoning_effort
+                .as_ref()
+                .is_none_or(|effort| effort.as_str().parse::<ReasoningEffort>().is_ok())
+    });
+}
