+/// UI state carried when replacing a `ChatWidget` for the same session.
+#[derive(Clone, Debug, Default)]
+pub(crate) struct ChatWidgetReplacementState {
+    pub(crate) status_account_display: Option<StatusAccountDisplay>,
+    pub(crate) rate_limit_snapshots_by_limit_id: BTreeMap<String, RateLimitSnapshotDisplay>,
+    pub(crate) runtime_model_provider_base_url: Option<String>,
+    pub(crate) initial_plan_type: Option<PlanType>,
+}
+
+impl ChatWidgetReplacementState {
+    pub(crate) fn from_widget(widget: &ChatWidget) -> Self {
+        Self {
+            status_account_display: widget.status_account_display().cloned(),
+            rate_limit_snapshots_by_limit_id: widget.rate_limit_snapshots_by_limit_id(),
+            runtime_model_provider_base_url: widget
+                .runtime_model_provider_base_url()
+                .map(str::to_string),
+            initial_plan_type: widget.current_plan_type(),
+        }
+    }
+}
