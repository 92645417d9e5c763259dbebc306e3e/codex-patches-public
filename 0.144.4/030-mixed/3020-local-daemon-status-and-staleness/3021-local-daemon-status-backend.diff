+pub(crate) fn codex_bin_from_path(codex_home: &Path) -> PathBuf {
+    if let Ok(path) = std::env::current_exe()
+        && executable_file(&path)
+    {
+        return path;
+    }
+
+    if let Some(path) = std::env::var_os("PATH")
+        .and_then(|path| find_executable_in_path(managed_codex_file_name(), path))
+    {
+        return path;
+    }
+
+    managed_codex_bin(codex_home)
+}
+
+fn find_executable_in_path(file_name: &str, path: impl AsRef<std::ffi::OsStr>) -> Option<PathBuf> {
+    std::env::split_paths(path.as_ref())
+        .map(|dir| dir.join(file_name))
+        .find(|path| executable_file(path))
+}
+
+fn executable_file(path: &Path) -> bool {
+    path.is_file()
+}
