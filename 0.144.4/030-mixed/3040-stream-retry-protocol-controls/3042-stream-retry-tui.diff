+        !inserted.iter().flatten().any(|line| {
+            let text = line.to_string();
+            !text.is_empty() && text.chars().all(|ch| ch == '─')
+        }),
+        "retry should not insert an empty final message separator"
+    );
+    let mut rendered = inserted
+        .iter()
+        .map(|cell| lines_to_single_string(cell))
+        .collect::<String>();
+    if let Some(active) = chat.transcript.active_cell.as_ref() {
+        rendered.push_str(&lines_to_single_string(&active.display_lines(/*width*/ 80)));
+    }
+    assert!(rendered.contains("retry answer"));
+    assert!(!rendered.contains("partial answer"));
+}
