+    #[test]
+    fn token_usage_info_fill_to_context_window_preserves_cumulative_usage() {
+        let total = TokenUsage {
+            input_tokens: 1_000,
+            cached_input_tokens: 900,
+            output_tokens: 50,
+            reasoning_output_tokens: 25,
+            total_tokens: 2_314_304_474,
+        };
+        let last = TokenUsage {
+            input_tokens: 10,
+            cached_input_tokens: 9,
+            output_tokens: 1,
+            reasoning_output_tokens: 0,
+            total_tokens: 11,
+        };
+        let mut info = TokenUsageInfo {
+            total_token_usage: total.clone(),
+            last_token_usage: last.clone(),
+            model_context_window: None,
+        };
+
+        info.fill_to_context_window(258_400);
+
+        assert_eq!(info.total_token_usage, total);
+        assert_eq!(info.last_token_usage, last);
+        assert_eq!(info.model_context_window, Some(258_400));
+    }
