+
+fn framed_user_message_lines(
+    lines: Vec<Line<'static>>,
+    width: u16,
+    style: Style,
+) -> Vec<Line<'static>> {
+    let box_width = width.max(1);
+    let mut out = vec![separator_line(box_width)];
+
+    for mut line in lines {
+        line.style = style;
+        let mut spans = vec![Span::styled(" ", style)];
+        spans.extend(line.spans);
+        spans.push(Span::styled(" ", style));
+        out.push(Line::from(spans).style(style));
+    }
+
+    out.push(separator_line(box_width));
+    out
+}
