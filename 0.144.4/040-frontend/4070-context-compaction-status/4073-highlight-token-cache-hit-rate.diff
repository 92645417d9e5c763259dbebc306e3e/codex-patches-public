+#[tokio::test]
+async fn session_summary_highlights_cached_input_hit_rate() {
+    let usage = TokenUsage {
+        input_tokens: 1_030_732,
+        cached_input_tokens: 987_264,
+        output_tokens: 18_345,
+        reasoning_output_tokens: 5_262,
+        total_tokens: 1_049_077,
+    };
+    let temp_dir = tempdir().expect("temp dir");
+    let rollout_path = temp_dir.path().join("rollout.jsonl");
+    std::fs::write(&rollout_path, "{}\n").expect("write rollout");
+
+    let summary = session_summary(
+        usage,
+        Some(ThreadId::new()),
+        /*thread_name*/ None,
+        Some(&rollout_path),
+    )
+    .expect("summary");
+    let usage_line = summary.usage_line.expect("usage line");
+
+    assert_eq!(
+        usage_line.to_string(),
+        "Token usage: total=61,813 input=43,468 (+ 987,264 cached, 95.8% hit) output=18,345 (reasoning 5,262)"
+    );
+    let hit_rate = usage_line
+        .spans
+        .iter()
+        .find(|span| span.content.as_ref() == "95.8% hit")
+        .expect("hit-rate span");
+    assert_eq!(hit_rate.style.fg, Some(ratatui::style::Color::Yellow));
+}
