 struct SessionSummary {
-    usage_line: Option<String>,
+    usage_line: Option<Line<'static>>,
     resume_hint: Option<String>,
 }
 
+fn token_usage_summary_line(token_usage: &TokenUsage) -> Line<'static> {
+    let Some(cache_hit_rate) = token_usage.cache_hit_rate_percent() else {
+        return token_usage.to_string().into();
+    };
+
+    let text = token_usage.to_string();
+    let marker = format!("{cache_hit_rate:.1}% hit");
+    let Some(start) = text.find(&marker) else {
+        return text.into();
+    };
+    let end = start + marker.len();
+    Line::from(vec![
+        Span::from(text[..start].to_string()),
+        Span::from(marker).yellow(),
+        Span::from(text[end..].to_string()),
+    ])
+}
