+fn parse_unsigned_percent(text: &str) -> Option<i64> {
+    if matches!(text.as_bytes().first(), Some(b'+' | b'-')) {
+        return None;
+    }
+    let percent = text.strip_suffix('%')?.parse::<i64>().ok()?;
+    Some(percent.clamp(0, 100))
+}
+
+fn context_remaining_line_spans(
+    line: &Line<'static>,
+    base_style: Style,
+) -> Option<Vec<Span<'static>>> {
+    let mut output = Vec::new();
+    let mut parsed_percent = false;
+
+    for span in &line.spans {
+        if span.style == Style::default()
+            && let Some(mut spans) = context_remaining_text_spans(span.content.as_ref(), base_style)
+        {
+            parsed_percent = true;
+            output.append(&mut spans);
+        } else {
+            output.push(span.clone());
+        }
+    }
+
+    parsed_percent.then_some(output)
+}
+
+fn context_remaining_text_spans(text: &str, base_style: Style) -> Option<Vec<Span<'static>>> {
+    let mut spans = Vec::new();
+    let mut saw_percent = false;
+
+    for part in text.split_whitespace() {
+        if !spans.is_empty() {
+            spans.push(" ".into());
+        }
+        if let Some(percent) = parse_unsigned_percent(part) {
+            saw_percent = true;
+            spans.push(Span::styled(
+                format!("{percent}%"),
+                context_remaining_percent_style(percent),
+            ));
+        } else {
+            spans.push(Span::styled(part.to_string(), base_style));
+        }
+    }
+
+    saw_percent.then_some(spans)
+}
+
+fn context_remaining_percent_style(percent: i64) -> Style {
+    let color = match percent {
+        75..=100 => Color::Green,
+        50..=74 => Color::Yellow,
+        25..=49 => Color::Rgb(255, 128, 0),
+        _ => Color::Red,
+    };
+    Style::default().fg(color).add_modifier(Modifier::BOLD)
+}
