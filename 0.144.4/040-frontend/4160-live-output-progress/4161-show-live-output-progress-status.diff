 use super::*;
 
 impl ChatWidget {
+    pub(super) fn clear_live_stream_progress(&mut self) {
+        self.live_output_chars = 0;
+    }
+
+    fn estimated_tokens_for_chars(chars: usize) -> usize {
+        chars.saturating_add(3) / 4
+    }
+
+    fn set_working_output_progress(&mut self) {
+        let tokens = Self::estimated_tokens_for_chars(self.live_output_chars);
+        self.status_state.terminal_title_status_kind = TerminalTitleStatusKind::Working;
+        self.set_status_header(format!("Working · output ~{tokens} tokens"));
+    }
+
+    pub(super) fn set_working_without_stream_count(&mut self) {
+        self.clear_live_stream_progress();
+        self.status_state.terminal_title_status_kind = TerminalTitleStatusKind::Working;
+        self.set_status_header(String::from("Working"));
+    }
+
     pub(super) fn retry_countdown_header(base_header: &str, retry_at: Option<Instant>) -> String {
         let Some(retry_at) = retry_at else {
             return base_header.to_string();
@@ -144,6 +164,12 @@ impl ChatWidget {
