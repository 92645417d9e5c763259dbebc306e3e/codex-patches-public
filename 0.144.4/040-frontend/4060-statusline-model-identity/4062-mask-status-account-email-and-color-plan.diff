+#[tokio::test]
+async fn status_account_line_masks_email_and_colors_plan() {
+    let temp_home = TempDir::new().expect("temp home");
+    let mut config = test_config(&temp_home).await;
+    config.cwd = test_path_buf("/workspace/tests").abs();
+    let account_display = StatusAccountDisplay::ChatGpt {
+        email: Some("sydney@gmail.com".to_string()),
+        plan: Some("Pro Lite".to_string()),
+    };
+    let usage = TokenUsage::default();
+    let model_slug = get_model_offline_for_tests(config.model.as_deref());
+    let composite = new_status_output(
+        &config,
+        Some(&account_display),
+        /*token_info*/ None,
+        &usage,
+        &None,
+        /*thread_name*/ None,
+        /*forked_from*/ None,
+        /*rate_display*/ None,
+        None,
+        chrono::Local
+            .with_ymd_and_hms(2024, 1, 2, 3, 4, 5)
+            .single()
+            .expect("timestamp"),
+        &model_slug,
+        /*collaboration_mode*/ None,
+        /*reasoning_effort_override*/ None,
+    );
+    let lines = composite.display_lines(/*width*/ 80);
+    let rendered_lines = render_lines(&lines);
+    assert!(
+        rendered_lines
+            .iter()
+            .any(|line| line.contains("Account:") && line.contains("s***y@g***l.com Pro Lite")),
+        "missing formatted account line: {rendered_lines:?}"
+    );
+
+    let account_line = lines
+        .iter()
+        .find(|line| {
+            line.spans
+                .iter()
+                .any(|span| span.content.as_ref() == "Pro Lite")
+        })
+        .expect("account line");
+    let plan_span = account_line
+        .spans
+        .iter()
+        .find(|span| span.content.as_ref() == "Pro Lite")
+        .expect("plan span");
+    assert_eq!(plan_span.style.fg, Some(Color::Yellow));
+}
