+fn account_display_spans(account: &StatusAccountDisplay) -> Vec<Span<'static>> {
+    match account {
+        StatusAccountDisplay::ChatGpt { email, plan } => match (email, plan) {
+            (Some(email), Some(plan)) => vec![
+                Span::from(mask_email(email)),
+                Span::from(" "),
+                Span::styled(plan.clone(), account_plan_style(plan)),
+            ],
+            (Some(email), None) => vec![Span::from(mask_email(email))],
+            (None, Some(plan)) => vec![Span::styled(plan.clone(), account_plan_style(plan))],
+            (None, None) => vec![Span::from("ChatGPT")],
+        },
+        StatusAccountDisplay::ApiKey => {
+            vec![Span::from(
+                "API key configured (run codex login to use ChatGPT)",
+            )]
+        }
+    }
+}
+
+fn mask_email(email: &str) -> String {
+    let Some((local, domain)) = email.split_once('@') else {
+        return email.to_string();
+    };
+    let Some((domain_name, suffix)) = domain.rsplit_once('.') else {
+        return email.to_string();
+    };
+    format!(
+        "{}@{}.{}",
+        mask_email_part(local),
+        mask_email_part(domain_name),
+        suffix
+    )
+}
+
+fn mask_email_part(part: &str) -> String {
+    let mut chars = part.chars();
+    let Some(first) = chars.next() else {
+        return String::new();
+    };
+    let last = chars.next_back();
+    match last {
+        Some(last) => format!("{first}***{last}"),
+        None => format!("{first}***"),
+    }
+}
