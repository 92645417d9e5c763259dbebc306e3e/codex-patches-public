+fn limit_metric_line_spans(line: &Line<'static>, base_style: Style) -> Option<Vec<Span<'static>>> {
+    let mut output = Vec::new();
+    let mut parsed_metric = false;
+
+    for span in &line.spans {
+        if span.style == Style::default()
+            && let Some(mut spans) = limit_metric_text_spans(span.content.as_ref(), base_style)
+        {
+            parsed_metric = true;
+            output.append(&mut spans);
+        } else {
+            output.push(span.clone());
+        }
+    }
+
+    parsed_metric.then_some(output)
+}
+
+fn limit_metric_text_spans(text: &str, base_style: Style) -> Option<Vec<Span<'static>>> {
+    let mut spans = Vec::new();
+    let mut saw_metric = false;
+
+    for part in text.split_whitespace() {
+        if !spans.is_empty() {
+            spans.push(" ".into());
+        }
+        if let Some(percent) = parse_unsigned_percent(part) {
+            saw_metric = true;
+            spans.push(Span::styled(format!("{percent}%"), Style::default()));
+        } else if let Some(pace) = parse_pace_percent(part) {
+            saw_metric = true;
+            spans.push(Span::styled(format!("{pace:+}%"), limit_pace_style(pace)));
+        } else {
+            spans.push(Span::styled(part.to_string(), base_style));
+        }
+    }
+
+    saw_metric.then_some(spans)
+}
+
+fn parse_unsigned_percent(text: &str) -> Option<i64> {
+    if matches!(text.as_bytes().first(), Some(b'+' | b'-')) {
+        return None;
+    }
+    let percent = text.strip_suffix('%')?.parse::<i64>().ok()?;
+    Some(percent.clamp(0, 100))
+}
+
+fn parse_pace_percent(text: &str) -> Option<i64> {
+    if !matches!(text.as_bytes().first(), Some(b'+' | b'-')) {
+        return None;
+    }
+    text.strip_suffix('%')?.parse::<i64>().ok()
+}
+
+fn limit_pace_style(pace: i64) -> Style {
+    let color = match pace {
+        ..=-21 => Color::Red,
+        -20..=-11 => Color::Rgb(255, 128, 0),
+        -10..=-1 => Color::Yellow,
+        _ => Color::Green,
+    };
+    Style::default().fg(color).add_modifier(Modifier::BOLD)
+}
