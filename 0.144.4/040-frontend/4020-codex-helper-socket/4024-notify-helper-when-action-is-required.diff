+pub(crate) fn notify_action_required(
+    session_id: &str,
+    turn_id: Option<&str>,
+    working_dir: &Path,
+    title: &str,
+    body: &str,
+) {
+    let Some(payload) = action_required_payload(
+        session_id,
+        turn_id,
+        working_dir,
+        title,
+        body,
+        chrono::Utc::now(),
+    ) else {
+        return;
+    };
+    tokio::task::spawn_blocking(move || {
+        if let Err(err) = send_payload_to_path(&payload, &codex_socket_path()) {
+            tracing::debug!("codex helper action-required socket notification skipped: {err}");
+        }
+    });
+}
