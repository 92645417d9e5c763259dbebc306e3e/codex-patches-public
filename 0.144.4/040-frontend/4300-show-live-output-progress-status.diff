+#[tokio::test]
+async fn live_status_accumulates_normal_output_progress() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_turn_started(&mut chat, "turn-1");
+    handle_agent_message_delta(&mut chat, "abcd");
+    handle_agent_message_delta(&mut chat, "efgh");
+
+    assert_eq!(
+        chat.status_state.current_status.header,
+        "Working · output ~2 tokens"
+    );
+}
+
+#[tokio::test]
+async fn live_status_ignores_commentary_output_progress() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_turn_started(&mut chat, "turn-1");
+    handle_agent_message_delta(&mut chat, "abcdefgh");
+    let thread_id = chat.thread_id.map(|id| id.to_string()).unwrap_or_default();
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: thread_id.clone(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 0,
+            item: AppServerThreadItem::AgentMessage {
+                id: "commentary-1".to_string(),
+                text: String::new(),
+                phase: Some(MessagePhase::Commentary),
+                memory_citation: None,
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+    chat.handle_server_notification(
+        ServerNotification::AgentMessageDelta(
+            codex_app_server_protocol::AgentMessageDeltaNotification {
+                thread_id,
+                turn_id: "turn-1".to_string(),
+                item_id: "commentary-1".to_string(),
+                delta: "commentary should not count".to_string(),
+            },
+        ),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(
+        chat.status_state.current_status.header,
+        "Working · output ~2 tokens"
+    );
+}
