+#[tokio::test]
+async fn live_status_resets_at_command_boundary() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_turn_started(&mut chat, "turn-1");
+    handle_agent_message_delta(&mut chat, "abcdefgh");
+    begin_exec_with_source(&mut chat, "call-1", "echo hi", ExecCommandSource::Agent);
+
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    handle_agent_message_delta(&mut chat, "abcd");
+    assert_eq!(
+        chat.status_state.current_status.header,
+        "Working · output ~1 tokens"
+    );
+}
