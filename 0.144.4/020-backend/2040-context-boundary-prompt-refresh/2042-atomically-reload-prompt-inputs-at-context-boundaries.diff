+#[tokio::test]
+async fn context_boundary_without_provider_retains_global_and_refreshes_project() {
+    let tmp = tempfile::tempdir().expect("tempdir");
+    fs::write(tmp.path().join("AGENTS.md"), "old project instructions").unwrap();
+    let config = make_config(
+        &tmp,
+        /*limit*/ 4096,
+        Some("inherited global instructions"),
+    )
+    .await;
+    let environments = resolved_local_environments([("local", config.config.cwd.clone())]);
+    let manager = AgentsMdManager::new(config.user_instructions.clone(), None);
+
+    manager.refresh(&config.config, &environments).await;
+    assert_eq!(
+        manager.get_loaded().expect("initial instructions").text(),
+        format!("inherited global instructions{AGENTS_MD_SEPARATOR}old project instructions")
+    );
+
+    fs::write(tmp.path().join("AGENTS.md"), "new project instructions").unwrap();
+    let pending_refresh = manager
+        .stage_context_boundary_refresh(&config.config, &environments)
+        .await;
+
+    assert_eq!(
+        pending_refresh
+            .loaded()
+            .expect("staged instructions")
+            .text(),
+        format!("inherited global instructions{AGENTS_MD_SEPARATOR}new project instructions")
+    );
+    assert_eq!(
+        manager
+            .get_loaded()
+            .expect("live instructions before commit")
+            .text(),
+        format!("inherited global instructions{AGENTS_MD_SEPARATOR}old project instructions"),
+        "staging must not change the live context snapshot"
+    );
+    let ((), warnings) = manager.commit_context_boundary_refresh(pending_refresh, || ());
+    assert!(warnings.is_empty());
+    assert_eq!(
+        manager
+            .user_instructions()
+            .expect("inherited global instructions")
+            .text,
+        "inherited global instructions"
+    );
+    assert_eq!(
+        manager.get_loaded().expect("refreshed instructions").text(),
+        format!("inherited global instructions{AGENTS_MD_SEPARATOR}new project instructions")
+    );
+}
+
+#[tokio::test]
+async fn context_boundary_provider_refresh_is_staged_until_commit() {
+    let tmp = tempfile::tempdir().expect("tempdir");
+    fs::write(tmp.path().join("AGENTS.md"), "project instructions").unwrap();
+    let config = make_config(&tmp, /*limit*/ 4096, Some("old global instructions")).await;
+    let provider = Arc::new(StaticUserInstructionsProvider {
+        loaded: LoadedUserInstructions {
+            instructions: Some(UserInstructions {
+                text: "new global instructions".to_string(),
+                source: config.config.codex_home.join("new-AGENTS.md"),
+            }),
+            warnings: Vec::new(),
+        },
+    });
+    let environments = resolved_local_environments([("local", config.config.cwd.clone())]);
+    let manager = AgentsMdManager::new(config.user_instructions.clone(), Some(provider));
+
+    manager.refresh(&config.config, &environments).await;
+    let pending_refresh = manager
+        .stage_context_boundary_refresh(&config.config, &environments)
+        .await;
+
+    assert_eq!(
+        pending_refresh
+            .loaded()
+            .expect("staged instructions")
+            .text(),
+        format!("new global instructions{AGENTS_MD_SEPARATOR}project instructions")
+    );
+    assert_eq!(
+        manager
+            .user_instructions()
+            .expect("live global instructions before commit")
+            .text,
+        "old global instructions"
+    );
+    assert_eq!(
+        manager
+            .get_loaded()
+            .expect("live instructions before commit")
+            .text(),
+        format!("old global instructions{AGENTS_MD_SEPARATOR}project instructions")
+    );
+
+    let (committed, warnings) = manager.commit_context_boundary_refresh(pending_refresh, || true);
+    assert!(committed);
+    assert!(warnings.is_empty());
+    assert_eq!(
+        manager
+            .user_instructions()
+            .expect("live global instructions after commit")
+            .text,
+        "new global instructions"
+    );
+    assert_eq!(
+        manager
+            .get_loaded()
+            .expect("live instructions after commit")
+            .text(),
+        format!("new global instructions{AGENTS_MD_SEPARATOR}project instructions")
+    );
+}
