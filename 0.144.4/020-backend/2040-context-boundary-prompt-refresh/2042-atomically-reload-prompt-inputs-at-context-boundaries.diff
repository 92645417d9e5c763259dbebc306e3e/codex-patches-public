+async fn submit_compact_and_wait(
+    codex: &Arc<codex_core::CodexThread>,
+    expect_error: bool,
+) -> Result<Option<String>> {
+    let submission_id = codex.submit(Op::Compact).await?;
+    let turn_id = loop {
+        let event = codex.next_event().await?;
+        if event.id != submission_id {
+            continue;
+        }
+        match event.msg {
+            EventMsg::TurnStarted(event) => break event.turn_id,
+            EventMsg::Error(error) => {
+                return Err(anyhow!("compact failed before TurnStarted: {error:?}"));
+            }
+            _ => {}
+        }
+    };
+    let mut error_message = None;
+    loop {
+        let event = codex.next_event().await?;
+        if event.id != submission_id {
+            continue;
+        }
+        match event.msg {
+            EventMsg::Error(error) => error_message = Some(error.message),
+            EventMsg::TurnComplete(event) if event.turn_id == turn_id => break,
+            EventMsg::TurnAborted(event) => {
+                return Err(anyhow!("compact turn aborted: {event:?}"));
+            }
+            _ => {}
+        }
+    }
+    if error_message.is_some() != expect_error {
+        return Err(anyhow!(
+            "compact error expectation mismatch: expected={expect_error} observed={error_message:?}"
+        ));
+    }
+    Ok(error_message)
+}
