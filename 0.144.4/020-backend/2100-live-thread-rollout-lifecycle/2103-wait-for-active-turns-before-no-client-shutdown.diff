+
+    let thread_start_id = app_server
+        .send_thread_start_request_with_auto_env(ThreadStartParams {
+            model: Some("mock-model".to_string()),
+            ..Default::default()
+        })
+        .await?;
+    let thread_start_response: JSONRPCResponse = timeout(
+        READ_TIMEOUT,
+        app_server.read_stream_until_response_message(RequestId::Integer(thread_start_id)),
+    )
+    .await??;
+    let ThreadStartResponse { thread, .. } = to_response(thread_start_response)?;
+    let rollout_path = thread.path.context("thread path should be present")?;
+
+    let first_turn_start_id = app_server
+        .send_turn_start_request(TurnStartParams {
+            thread_id: thread.id.clone(),
+            input: vec![UserInput::Text {
+                text: "start a gated turn".to_string(),
+                text_elements: Vec::new(),
+            }],
+            ..Default::default()
+        })
+        .await?;
+    let first_turn_start_response: JSONRPCResponse = timeout(
+        READ_TIMEOUT,
+        app_server.read_stream_until_response_message(RequestId::Integer(first_turn_start_id)),
+    )
+    .await??;
+    let _: TurnStartResponse = to_response(first_turn_start_response)?;
+    timeout(READ_TIMEOUT, server.wait_for_request_count(/*count*/ 1)).await?;
+
+    let steer_start_id = app_server
+        .send_turn_start_request(TurnStartParams {
+            thread_id: thread.id,
+            input: vec![UserInput::Text {
+                text: "continue in the active turn".to_string(),
+                text_elements: Vec::new(),
+            }],
+            ..Default::default()
+        })
+        .await?;
+    let steer_start_response: JSONRPCResponse = timeout(
+        READ_TIMEOUT,
+        app_server.read_stream_until_response_message(RequestId::Integer(steer_start_id)),
+    )
+    .await??;
+    let _: TurnStartResponse = to_response(steer_start_response)?;
+    app_server.close_stdin();
+
+    tokio::time::sleep(Duration::from_millis(100)).await;
+    assert!(
+        app_server.try_wait()?.is_none(),
+        "app-server must remain alive while the steered turn is running"
+    );
+    release_tx
+        .send(())
+        .expect("first model response gate should still be waiting");
+    timeout(READ_TIMEOUT, first_response_completed).await??;
+    timeout(READ_TIMEOUT, server.wait_for_request_count(/*count*/ 2)).await?;
+    timeout(READ_TIMEOUT, second_response_completed).await??;
+
+    let status = timeout(READ_TIMEOUT, app_server.wait_for_exit()).await??;
+    assert!(status.success(), "app-server exited with {status}");
+    let rollout = std::fs::read_to_string(rollout_path)?;
+    assert!(rollout.contains("steer-drain-complete"));
+    server.shutdown().await;
+    Ok(())
+}
