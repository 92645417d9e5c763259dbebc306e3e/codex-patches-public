+fn write_multi_agent_v2_model_cache(codex_home: &Path, model_slug: &str) -> Result<()> {
+    write_models_cache(codex_home)?;
+    let cache_path = codex_home.join("models_cache.json");
+    let mut cache: Value = serde_json::from_str(&std::fs::read_to_string(&cache_path)?)?;
+    let models = cache["models"]
+        .as_array_mut()
+        .context("models_cache.json models should be an array")?;
+    let mut model = models
+        .iter()
+        .find(|model| {
+            model["supported_reasoning_levels"]
+                .as_array()
+                .is_some_and(|levels| {
+                    levels
+                        .iter()
+                        .any(|level| level["effort"] == json!(ReasoningEffort::Ultra))
+                })
+        })
+        .cloned()
+        .context("models cache should contain an Ultra-capable model fixture")?;
+    model["slug"] = json!(model_slug);
+    model["display_name"] = json!(model_slug);
+    model["multi_agent_version"] = json!(MultiAgentVersion::V2);
+    models.retain(|model| model["slug"].as_str() != Some(model_slug));
+    models.push(model);
+    std::fs::write(cache_path, serde_json::to_string_pretty(&cache)?)?;
+    Ok(())
+}
