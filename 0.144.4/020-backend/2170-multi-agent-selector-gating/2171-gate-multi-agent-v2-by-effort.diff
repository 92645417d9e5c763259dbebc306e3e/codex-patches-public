+async fn submit_configured_turn(test: &TestCodex, prompt: &str) -> Result<()> {
+    let submission_id = test
+        .codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: prompt.to_string(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+    let turn_id = loop {
+        let event = test.codex.next_event().await?;
+        if event.id != submission_id {
+            continue;
+        }
+        match event.msg {
+            EventMsg::TurnStarted(event) => break event.turn_id,
+            EventMsg::Error(error) => {
+                return Err(anyhow::anyhow!("turn failed before start: {error:?}"));
+            }
+            EventMsg::TurnAborted(event) => {
+                return Err(anyhow::anyhow!("turn aborted before start: {event:?}"));
+            }
+            _ => {}
+        }
+    };
+    loop {
+        let event = test.codex.next_event().await?;
+        if event.id != submission_id {
+            continue;
+        }
+        match event.msg {
+            EventMsg::TurnComplete(event) if event.turn_id == turn_id => break,
+            EventMsg::Error(error) => return Err(anyhow::anyhow!("turn failed: {error:?}")),
+            EventMsg::TurnAborted(event) => {
+                return Err(anyhow::anyhow!("turn aborted: {event:?}"));
+            }
+            _ => {}
+        }
+    }
+    Ok(())
+}
