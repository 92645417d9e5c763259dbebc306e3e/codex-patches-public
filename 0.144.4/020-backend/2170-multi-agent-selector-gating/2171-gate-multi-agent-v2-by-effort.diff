+        Some(MultiAgentVersion::V1) => MultiAgentVersion::V1,
+        Some(MultiAgentVersion::V2)
+            if matches!(
+                configured_reasoning_effort,
+                Some(ReasoningEffortConfig::Ultra)
+            ) =>
+        {
+            MultiAgentVersion::V2
+        }
+        Some(MultiAgentVersion::V2) => MultiAgentVersion::V1,
+        None if config.features.enabled(Feature::Collab) => MultiAgentVersion::V1,
+        None if config.features.enabled(Feature::MultiAgentV2) => MultiAgentVersion::V1,
+        None => MultiAgentVersion::Disabled,
+    }
+}
