+fn resolve_hook_command_path(source: &HookHandlerSource<'_>, command: &str) -> String {
+    if source.is_managed
+        || source.path.file_name() != Some(std::ffi::OsStr::new("hooks.json"))
+        || !is_safe_literal_relative_hook_path(command)
+    {
+        return command.to_string();
+    }
+
+    let Some(parent) = source.path.parent() else {
+        return command.to_string();
+    };
+    let resolved = parent.join(command);
+    let Some(resolved) = resolved.as_path().to_str() else {
+        return command.to_string();
+    };
+    if is_safe_resolved_hook_path(resolved) {
+        resolved.to_string()
+    } else {
+        command.to_string()
+    }
+}
+
+fn is_safe_literal_relative_hook_path(command: &str) -> bool {
+    command == command.trim()
+        && has_target_path_separator(command)
+        && command.bytes().all(is_safe_hook_path_byte)
+        && Path::new(command).components().all(|component| {
+            matches!(
+                component,
+                Component::Normal(_) | Component::CurDir | Component::ParentDir
+            )
+        })
+}
+
+#[cfg(windows)]
+fn has_target_path_separator(command: &str) -> bool {
+    command.bytes().any(|byte| matches!(byte, b'/' | b'\\'))
+}
+
+#[cfg(not(windows))]
+fn has_target_path_separator(command: &str) -> bool {
+    command.contains('/')
+}
+
+fn is_safe_hook_path_byte(byte: u8) -> bool {
+    byte.is_ascii_alphanumeric()
+        || matches!(byte, b'_' | b'-' | b'.' | b'/')
+        || cfg!(windows) && byte == b'\\'
+}
+
+#[cfg(windows)]
+fn is_safe_resolved_hook_path(path: &str) -> bool {
+    let bytes = path.as_bytes();
+    let has_drive_colon =
+        bytes.get(1) == Some(&b':') && bytes.first().is_some_and(|byte| byte.is_ascii_alphabetic());
+    bytes.iter().enumerate().all(|(index, byte)| {
+        has_drive_colon && index == 1 && *byte == b':' || is_safe_hook_path_byte(*byte)
+    })
+}
+
+#[cfg(not(windows))]
+fn is_safe_resolved_hook_path(path: &str) -> bool {
+    path.bytes().all(is_safe_hook_path_byte)
+}
