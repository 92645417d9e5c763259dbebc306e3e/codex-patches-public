+fn should_limit_thread_list_for_client(client_name: Option<&str>) -> bool {
+    client_name != Some(TUI_CLIENT_NAME)
+}
+
+fn apply_non_tui_thread_list_limit(params: &mut ThreadListParams) {
+    params.cursor = None;
+    params.limit = Some(NON_TUI_THREAD_LIST_LIMIT);
+    params.sort_key = Some(ThreadSortKey::UpdatedAt);
+    params.sort_direction = Some(SortDirection::Desc);
+}
+
+fn limit_non_tui_thread_list_response(response: ClientResponsePayload) -> ClientResponsePayload {
+    match response {
+        ClientResponsePayload::ThreadList(mut response) => {
+            response.next_cursor = None;
+            response.backwards_cursor = None;
+            ClientResponsePayload::ThreadList(response)
+        }
+        other => other,
+    }
+}
