+    let cache_path = codex_home.path().join("models_cache.json");
+    let mut cache: Value = serde_json::from_slice(&std::fs::read(&cache_path)?)?;
+    cache["client_version"] = Value::String("older-client-version".to_string());
+    std::fs::write(&cache_path, serde_json::to_vec_pretty(&cache)?)?;
+
+    let server_uri = server.uri();
+    std::fs::write(
