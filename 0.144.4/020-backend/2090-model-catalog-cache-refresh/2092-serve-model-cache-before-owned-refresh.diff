+        "context_window": 272_000,
+        "max_context_window": 272_000,
+        "experimental_supported_tools": [],
+    }))?;
+    let mut remote_model = cached_model.clone();
+    remote_model.slug = "remote-delayed-model".to_string();
+    remote_model.display_name = "Remote Delayed Model".to_string();
+    remote_model.description = Some("Delayed model should not block model/list".to_string());
