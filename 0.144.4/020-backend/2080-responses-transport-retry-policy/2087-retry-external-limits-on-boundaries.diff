+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn usage_limit_error_warns_and_retries_until_interrupted() -> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+    let server = MockServer::start().await;
+    let responses_mock = mount_response_sequence(
+        &server,
+        vec![ResponseTemplate::new(429).set_body_json(json!({
+            "error": {
+                "type": "usage_limit_reached",
+                "message": "limit reached",
+                "resets_at": 1704067242,
+                "plan_type": "pro"
+            }
+        }))],
+    )
+    .await;
+
+    let codex = test_codex()
+        .with_model("gpt-5.4")
+        .with_config(|config| {
+            config.model_provider.stream_max_retries = Some(1);
+        })
+        .build(&server)
+        .await?
+        .codex;
+    codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "hello".into(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let warning = wait_for_event(&codex, |msg| {
+        matches!(
+            msg,
+            EventMsg::Warning(WarningEvent { message })
+                if message.contains("next 30-minute boundary")
+        )
+    })
+    .await;
+    let EventMsg::Warning(WarningEvent { message }) = warning else {
+        unreachable!();
+    };
+    assert!(message.contains("Account quota limit reached"));
+
+    codex.submit(Op::Interrupt).await?;
+    let aborted = wait_for_event(&codex, |msg| matches!(msg, EventMsg::TurnAborted(_))).await;
+    let EventMsg::TurnAborted(aborted) = aborted else {
+        unreachable!();
+    };
+    assert_eq!(aborted.reason, TurnAbortReason::Interrupted);
+    assert_eq!(responses_mock.requests().len(), 1);
+
+    Ok(())
+}
