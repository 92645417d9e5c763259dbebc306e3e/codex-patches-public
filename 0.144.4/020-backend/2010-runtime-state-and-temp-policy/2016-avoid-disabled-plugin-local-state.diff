+#[tokio::test]
+async fn disabled_plugin_list_background_tasks_do_not_materialize_non_curated_cache() {
+    let tmp = tempfile::tempdir().unwrap();
+    let repo_root = tmp.path().join("repo");
+    fs::create_dir_all(repo_root.join(".git")).unwrap();
+    fs::create_dir_all(repo_root.join(".agents/plugins")).unwrap();
+    write_plugin_with_version(&repo_root, "sample-plugin", "sample-plugin", Some("1.2.3"));
+    write_file(
+        &repo_root.join(".agents/plugins/marketplace.json"),
+        r#"{
+  "name": "debug",
+  "plugins": [
+    {
+      "name": "sample-plugin",
+      "source": {
+        "source": "local",
+        "path": "./sample-plugin"
+      }
+    }
+  ]
+}"#,
+    );
+    write_file(
+        &tmp.path().join(CONFIG_TOML_FILE),
+        r#"[features]
+plugins = false
+
+[plugins."sample-plugin@debug"]
+enabled = true
+"#,
+    );
+
+    let config = load_config(tmp.path(), &repo_root).await;
+    let manager = std::sync::Arc::new(PluginsManager::new(tmp.path().to_path_buf()));
+    manager.maybe_start_plugin_list_background_tasks_for_config(
+        &config,
+        /*auth*/ None,
+        &[repo_root.abs()],
+        PluginListBackgroundTaskOptions::default(),
+        /*on_effective_plugins_changed*/ None,
+    );
+    tokio::time::timeout(Duration::from_secs(1), async {
+        loop {
+            let in_flight = manager
+                .non_curated_cache_refresh_state
+                .read()
+                .unwrap_or_else(std::sync::PoisonError::into_inner)
+                .in_flight;
+            if !in_flight {
+                break;
+            }
+            tokio::time::sleep(Duration::from_millis(10)).await;
+        }
+    })
+    .await
+    .expect("non-curated cache refresh should finish");
+
+    assert!(
+        !tmp.path()
+            .join("plugins/cache/debug/sample-plugin/1.2.3")
+            .exists()
+    );
+}
