+#[cfg(test)]
+mod tests {
+    use super::PRIVATE_DIRECTORY_MODE;
+    use super::PRIVATE_DIRECTORY_PERMISSION_BITS;
+    use super::PrivateCodexTmpDir;
+    use codex_utils_absolute_path::AbsolutePathBuf;
+    use std::fs;
+    use std::os::unix::fs::MetadataExt;
+    use std::os::unix::fs::PermissionsExt;
+    use std::os::unix::fs::symlink;
+    use tempfile::TempDir;
+
+    fn absolute(path: impl Into<std::path::PathBuf>) -> AbsolutePathBuf {
+        AbsolutePathBuf::from_absolute_path(path.into()).expect("absolute test path")
+    }
+
+    fn temp_in_working_directory() -> std::io::Result<TempDir> {
+        TempDir::new_in(std::env::current_dir()?)
+    }
+
+    #[test]
+    fn rejects_non_sticky_writable_parent() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let unsafe_parent = root.path().join("unsafe-parent");
+        fs::create_dir(&unsafe_parent)?;
+        fs::set_permissions(&unsafe_parent, fs::Permissions::from_mode(0o777))?;
+        let controlled_root = absolute(unsafe_parent.join("codex"));
+
+        let error = PrivateCodexTmpDir::prepare(controlled_root.clone())
+            .expect_err("non-sticky writable parent should be rejected");
+        assert_eq!(error.kind(), std::io::ErrorKind::PermissionDenied);
+        assert!(!controlled_root.as_path().exists());
+        Ok(())
+    }
+
+    #[test]
+    fn accepts_sticky_writable_parent() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let sticky_parent = root.path().join("sticky-parent");
+        fs::create_dir(&sticky_parent)?;
+        fs::set_permissions(&sticky_parent, fs::Permissions::from_mode(0o1777))?;
+        let controlled_root = absolute(sticky_parent.join("codex"));
+
+        PrivateCodexTmpDir::prepare(controlled_root.clone())?;
+        let metadata = fs::symlink_metadata(controlled_root.as_path())?;
+        assert_eq!(metadata.uid(), unsafe { libc::geteuid() });
+        assert_eq!(
+            metadata.mode() & PRIVATE_DIRECTORY_PERMISSION_BITS,
+            PRIVATE_DIRECTORY_MODE
+        );
+        Ok(())
+    }
+
+    #[test]
+    fn accepts_current_user_symlink_ancestor() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let physical_parent = root.path().join("physical-parent");
+        let linked_parent = root.path().join("linked-parent");
+        fs::create_dir(&physical_parent)?;
+        symlink(&physical_parent, &linked_parent)?;
+
+        PrivateCodexTmpDir::prepare(absolute(linked_parent.join("codex")))?;
+
+        assert!(physical_parent.join("codex").is_dir());
+        Ok(())
+    }
+
+    #[test]
+    fn rejects_unsafe_resolved_symlink_ancestor_without_creating_child() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let unsafe_parent = root.path().join("unsafe-parent");
+        let physical_parent = unsafe_parent.join("physical-parent");
+        let linked_parent = root.path().join("linked-parent");
+        fs::create_dir_all(&physical_parent)?;
+        fs::set_permissions(&unsafe_parent, fs::Permissions::from_mode(0o777))?;
+        fs::set_permissions(&physical_parent, fs::Permissions::from_mode(0o700))?;
+        symlink(&physical_parent, &linked_parent)?;
+
+        let error = PrivateCodexTmpDir::prepare(absolute(linked_parent.join("codex")))
+            .expect_err("unsafe resolved ancestor should be rejected");
+
+        assert_eq!(error.kind(), std::io::ErrorKind::PermissionDenied);
+        assert!(!physical_parent.join("codex").exists());
+        Ok(())
+    }
+
+    #[test]
+    fn rejects_retargeted_symlink_ancestor() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let first_parent = root.path().join("first-parent");
+        let second_parent = root.path().join("second-parent");
+        let linked_parent = root.path().join("linked-parent");
+        fs::create_dir(&first_parent)?;
+        fs::create_dir(&second_parent)?;
+        symlink(&first_parent, &linked_parent)?;
+
+        let private_root = PrivateCodexTmpDir::prepare(absolute(linked_parent.join("codex")))?;
+        fs::create_dir(second_parent.join("codex"))?;
+        fs::set_permissions(
+            second_parent.join("codex"),
+            fs::Permissions::from_mode(PRIVATE_DIRECTORY_MODE),
+        )?;
+        fs::remove_file(&linked_parent)?;
+        symlink(&second_parent, &linked_parent)?;
+
+        let error = private_root
+            .validate()
+            .expect_err("retargeted symlink ancestor should be rejected");
+        assert_eq!(error.kind(), std::io::ErrorKind::PermissionDenied);
+        Ok(())
+    }
+
+    #[test]
+    fn rejects_symlink_root() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let target = root.path().join("target");
+        let controlled_root = root.path().join("codex");
+        fs::create_dir(&target)?;
+        symlink(&target, &controlled_root)?;
+
+        let error = PrivateCodexTmpDir::prepare(absolute(&controlled_root))
+            .expect_err("symlink root should be rejected");
+        assert_eq!(error.kind(), std::io::ErrorKind::PermissionDenied);
+        assert_eq!(fs::read_link(controlled_root)?, target);
+        Ok(())
+    }
+
+    #[test]
+    fn rejects_replacement() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let controlled_root = root.path().join("codex");
+        let replaced_root = root.path().join("codex-replaced");
+        let private_root = PrivateCodexTmpDir::prepare(absolute(&controlled_root))?;
+        fs::rename(&controlled_root, &replaced_root)?;
+        fs::create_dir(&controlled_root)?;
+
+        let error = private_root
+            .validate()
+            .expect_err("replaced root should be rejected");
+        assert_eq!(error.kind(), std::io::ErrorKind::PermissionDenied);
+        Ok(())
+    }
+
+    #[test]
+    fn tightens_current_user_readable_mode() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let controlled_root = root.path().join("codex");
+        fs::create_dir(&controlled_root)?;
+        fs::set_permissions(&controlled_root, fs::Permissions::from_mode(0o755))?;
+
+        PrivateCodexTmpDir::prepare(absolute(&controlled_root))?;
+        let metadata = fs::symlink_metadata(controlled_root)?;
+        assert_eq!(
+            metadata.mode() & PRIVATE_DIRECTORY_PERMISSION_BITS,
+            PRIVATE_DIRECTORY_MODE
+        );
+        Ok(())
+    }
+
+    #[test]
+    fn subdir_must_be_one_component() -> std::io::Result<()> {
+        let root = temp_in_working_directory()?;
+        let private_root = PrivateCodexTmpDir::prepare(absolute(root.path().join("codex")))?;
+
+        let error = private_root
+            .ensure_subdir("nested/child")
+            .expect_err("nested child should be rejected");
+        assert_eq!(error.kind(), std::io::ErrorKind::InvalidInput);
+        Ok(())
+    }
