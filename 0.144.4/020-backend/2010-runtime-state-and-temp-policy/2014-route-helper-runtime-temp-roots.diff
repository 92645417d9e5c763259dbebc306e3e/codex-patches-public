+use super::find_codex_tmp_root;
+use codex_utils_absolute_path::AbsolutePathBuf;
+use std::ffi::OsStr;
+use std::path::Component;
+use std::path::Path;
+use std::path::PathBuf;
+
+const PRIVATE_DIRECTORY_MODE: u32 = 0o700;
+const PRIVATE_DIRECTORY_PERMISSION_BITS: u32 = 0o7777;
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct DirectoryIdentity {
+    device: u64,
+    inode: u64,
+}
+
+#[derive(Debug, Eq, PartialEq)]
+struct SafeAncestorChain {
+    lexical_entries: Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>,
+    resolved_entries: Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>,
+}
+
+impl SafeAncestorChain {
+    fn capture(path: &Path) -> std::io::Result<Self> {
+        let lexical_entries = Self::capture_entries(path)?;
+        let resolved_path = std::fs::canonicalize(path)?;
+        let resolved_entries = Self::capture_entries(&resolved_path)?;
+        Ok(Self {
+            lexical_entries,
+            resolved_entries,
+        })
+    }
+
+    fn capture_entries(
+        path: &Path,
+    ) -> std::io::Result<Vec<(PathBuf, DirectoryIdentity, DirectoryIdentity)>> {
+        use std::os::unix::fs::MetadataExt;
+
+        let effective_uid = unsafe { libc::geteuid() };
+        let mut entries = Vec::new();
+        for ancestor in path.ancestors().collect::<Vec<_>>().into_iter().rev() {
+            let lexical_metadata = std::fs::symlink_metadata(ancestor)?;
+            if lexical_metadata.file_type().is_symlink() {
+                let owner = lexical_metadata.uid();
+                if owner != 0 && owner != effective_uid {
+                    return Err(private_directory_error(format!(
+                        "temporary directory symlink is owned by uid {owner}, not root or the current uid {effective_uid}: {}",
+                        ancestor.display()
+                    )));
+                }
+            }
+
+            let metadata = std::fs::metadata(ancestor)?;
+            if !metadata.is_dir() {
+                return Err(private_directory_error(format!(
+                    "temporary directory ancestor does not resolve to a directory: {}",
+                    ancestor.display()
+                )));
+            }
+            let owner = metadata.uid();
+            if owner != 0 && owner != effective_uid {
+                return Err(private_directory_error(format!(
+                    "temporary directory ancestor is owned by uid {owner}, not root or the current uid {effective_uid}: {}",
+                    ancestor.display()
+                )));
+            }
+
+            let mode = metadata.mode();
+            if mode & 0o022 != 0 && mode & 0o1000 == 0 {
+                return Err(private_directory_error(format!(
+                    "temporary directory ancestor is writable by other users without the sticky bit: {} (mode {:04o})",
+                    ancestor.display(),
+                    mode & PRIVATE_DIRECTORY_PERMISSION_BITS
+                )));
+            }
+
+            entries.push((
+                ancestor.to_path_buf(),
+                directory_identity(&lexical_metadata),
+                directory_identity(&metadata),
+            ));
+        }
+        Ok(entries)
+    }
+
+    fn validate(&self) -> std::io::Result<()> {
+        let current = self
+            .lexical_entries
+            .last()
+            .map(|(path, _, _)| path.as_path())
+            .ok_or_else(|| private_directory_error("temporary directory has no ancestors"))?;
+        let refreshed = Self::capture(current)?;
+        if &refreshed != self {
+            return Err(private_directory_error(format!(
+                "temporary directory ancestor was replaced: {}",
+                current.display()
+            )));
+        }
+        Ok(())
+    }
+}
+
+/// A current-user-private directory under the resolved Codex temp root.
+///
+/// The path is host-local and absolute. Call [`Self::validate`] immediately
+/// before security-sensitive filesystem operations.
+#[derive(Debug)]
+pub struct PrivateCodexTmpDir {
+    path: AbsolutePathBuf,
+    parent_chain: SafeAncestorChain,
+    identity: DirectoryIdentity,
+}
+
+impl PrivateCodexTmpDir {
+    fn prepare(path: AbsolutePathBuf) -> std::io::Result<Self> {
+        use std::os::unix::fs::DirBuilderExt;
+        use std::os::unix::fs::MetadataExt;
+        use std::os::unix::fs::PermissionsExt;
+
+        let parent = path.as_path().parent().ok_or_else(|| {
+            private_directory_error(format!(
+                "private directory has no parent: {}",
+                path.as_path().display()
+            ))
+        })?;
+        let parent_chain = SafeAncestorChain::capture(parent)?;
+
+        let mut builder = std::fs::DirBuilder::new();
+        builder.mode(PRIVATE_DIRECTORY_MODE);
+        match builder.create(path.as_path()) {
+            Ok(()) => {}
+            Err(err) if err.kind() == std::io::ErrorKind::AlreadyExists => {}
+            Err(err) => return Err(err),
+        }
+        parent_chain.validate()?;
+
+        let effective_uid = unsafe { libc::geteuid() };
+        let mut metadata = private_directory_metadata(path.as_path())?;
+        if metadata.uid() != effective_uid {
+            return Err(private_directory_error(format!(
+                "private temp directory is owned by uid {}, not the current uid {effective_uid}: {}",
+                metadata.uid(),
+                path.as_path().display()
+            )));
+        }
+        let mode = metadata.mode();
+        if mode & 0o022 != 0 {
+            return Err(private_directory_error(format!(
+                "private temp directory is writable by other users: {} (mode {:04o})",
+                path.as_path().display(),
+                mode & PRIVATE_DIRECTORY_PERMISSION_BITS
+            )));
+        }
+        if mode & PRIVATE_DIRECTORY_PERMISSION_BITS != PRIVATE_DIRECTORY_MODE {
+            std::fs::set_permissions(
+                path.as_path(),
+                std::fs::Permissions::from_mode(PRIVATE_DIRECTORY_MODE),
+            )?;
+            metadata = private_directory_metadata(path.as_path())?;
+        }
+        if metadata.uid() != effective_uid
+            || metadata.mode() & PRIVATE_DIRECTORY_PERMISSION_BITS != PRIVATE_DIRECTORY_MODE
+        {
+            return Err(private_directory_error(format!(
+                "private temp directory could not be secured for the current user: {}",
+                path.as_path().display()
+            )));
+        }
+        parent_chain.validate()?;
+
+        Ok(Self {
+            path,
+            parent_chain,
+            identity: directory_identity(&metadata),
+        })
+    }
+
+    pub fn as_path(&self) -> &Path {
+        self.path.as_path()
+    }
+
+    /// Creates or validates one direct private child directory.
+    pub fn ensure_subdir(&self, name: impl AsRef<OsStr>) -> std::io::Result<Self> {
+        self.validate()?;
+        let name = name.as_ref();
+        let mut components = Path::new(name).components();
+        if !matches!(components.next(), Some(Component::Normal(_))) || components.next().is_some() {
+            return Err(std::io::Error::new(
+                std::io::ErrorKind::InvalidInput,
+                format!(
+                    "private temp subdirectory must be one path component: {}",
+                    name.to_string_lossy()
+                ),
+            ));
+        }
+        Self::prepare(self.path.join(name))
+    }
+
+    pub fn validate(&self) -> std::io::Result<()> {
+        use std::os::unix::fs::MetadataExt;
+
+        self.parent_chain.validate()?;
+        let metadata = private_directory_metadata(self.path.as_path())?;
+        let effective_uid = unsafe { libc::geteuid() };
+        if directory_identity(&metadata) != self.identity
+            || metadata.uid() != effective_uid
+            || metadata.mode() & PRIVATE_DIRECTORY_PERMISSION_BITS != PRIVATE_DIRECTORY_MODE
+        {
+            return Err(private_directory_error(format!(
+                "private temp directory was replaced or made unsafe: {}",
+                self.path.as_path().display()
+            )));
+        }
+        Ok(())
+    }
+}
+
+/// Creates or validates the fixed `$CODEX_TMP` root for the current Unix user.
+pub fn prepare_private_codex_tmp_root() -> std::io::Result<PrivateCodexTmpDir> {
+    PrivateCodexTmpDir::prepare(find_codex_tmp_root()?)
+}
+
+fn private_directory_metadata(path: &Path) -> std::io::Result<std::fs::Metadata> {
+    let metadata = std::fs::symlink_metadata(path)?;
+    if !metadata.file_type().is_dir() {
+        return Err(private_directory_error(format!(
+            "private temp path is not a non-symlink directory: {}",
+            path.display()
+        )));
+    }
+    Ok(metadata)
+}
+
+fn directory_identity(metadata: &std::fs::Metadata) -> DirectoryIdentity {
+    use std::os::unix::fs::MetadataExt;
+
+    DirectoryIdentity {
+        device: metadata.dev(),
+        inode: metadata.ino(),
+    }
+}
+
+fn private_directory_error(message: impl Into<String>) -> std::io::Error {
+    std::io::Error::new(std::io::ErrorKind::PermissionDenied, message.into())
+}
