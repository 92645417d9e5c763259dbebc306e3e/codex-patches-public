+#[tokio::test]
+async fn apply_advanced_reasoning_success_uses_footer_flash_without_history() -> Result<()> {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    while app_event_rx.try_recv().is_ok() {}
+    app.chat_widget
+        .set_footer_hint_override(Some(vec![("K".to_string(), "label".to_string())]));
+    let mut tui = crate::tui::test_support::make_test_tui()?;
+    let mut app_server = crate::start_embedded_app_server_for_picker(&app.config).await?;
+
+    let control = Box::pin(app.handle_event(
+        &mut tui,
+        &mut app_server,
+        AppEvent::ApplyAdvancedReasoning {
+            model: "gpt-5.4".to_string(),
+            effort: ReasoningEffortConfig::Ultra,
+        },
+    ))
+    .await?;
+
+    assert!(matches!(control, AppRunControl::Continue));
+    assert_eq!(app.chat_widget.current_model(), "gpt-5.4");
+    assert_eq!(
+        app.chat_widget.current_reasoning_effort(),
+        Some(ReasoningEffortConfig::Ultra)
+    );
+    let rendered = render_bottom_popup(&app.chat_widget, /*width*/ 80);
+    assert!(
+        rendered.contains("gpt-5.4 ultra"),
+        "expected model footer flash, got: {rendered:?}"
+    );
+    assert!(
+        !rendered.contains("K label"),
+        "expected model footer flash to override footer hint, got: {rendered:?}"
+    );
+    while let Ok(event) = app_event_rx.try_recv() {
+        assert!(
+            !matches!(event, AppEvent::InsertHistoryCell(_)),
+            "advanced reasoning success should not add history"
+        );
+    }
+
+    app_server.shutdown().await?;
+    Ok(())
+}
