+#[test]
+fn create_runtime_env_omits_runtime_temp_paths_without_local_cwd() {
+    let mut policy = ShellEnvironmentPolicy {
+        inherit: ShellEnvironmentPolicyInherit::None,
+        ignore_default_excludes: true,
+        ..Default::default()
+    };
+    for (key, value) in [
+        ("TMPDIR", "/stale/tmpdir"),
+        (CODEX_HOME_ENV_VAR, "/stale/codex-home"),
+        (CODEX_TMP_ENV_VAR, "/stale/codex"),
+        (PROJECT_SCRATCH_ROOT_ENV_VAR, "/stale/scratch"),
+        (PROJECT_WORKING_ROOT_ENV_VAR, "/stale/working"),
+        (PROJECT_NAME_ENV_VAR, "stale-project"),
+        (RUNTIME_TMP_ROOT_ENV_VAR, "/stale/runtime-tmp"),
+        (RUNTIME_STATE_ROOT_ENV_VAR, "/stale/runtime-state"),
+    ] {
+        policy.r#set.insert(key.to_string(), value.to_string());
+    }
+
+    let env = create_runtime_env(
+        &policy,
+        /*thread_id*/ None,
+        /*local_cwd*/ None,
+        Path::new("/resolved/codex-home"),
+    );
+
+    assert_eq!(env.get("TMPDIR"), None);
+    assert_eq!(
+        env.get(CODEX_HOME_ENV_VAR),
+        Some(&"/resolved/codex-home".to_string())
+    );
+    assert_eq!(env.get(CODEX_TMP_ENV_VAR), None);
+    assert_eq!(env.get(PROJECT_SCRATCH_ROOT_ENV_VAR), None);
+    assert_eq!(env.get(PROJECT_WORKING_ROOT_ENV_VAR), None);
+    assert_eq!(env.get(PROJECT_NAME_ENV_VAR), None);
+    assert_eq!(env.get(RUNTIME_TMP_ROOT_ENV_VAR), None);
+    assert_eq!(env.get(RUNTIME_STATE_ROOT_ENV_VAR), None);
+}
