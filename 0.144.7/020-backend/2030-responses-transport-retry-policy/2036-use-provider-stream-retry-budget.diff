+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn stream_retry_backoff_is_bounded_and_preserves_requested_delay() {
+        let automatic = CodexErr::Stream("disconnected".to_string(), None);
+        let delays: Vec<Duration> = (1..=30)
+            .map(|retry_count| stream_retry_delay(&automatic, retry_count))
+            .collect();
+
+        assert!(
+            delays
+                .iter()
+                .all(|delay| *delay <= STREAM_RETRY_MAX_BACKOFF_DELAY)
+        );
+        assert_eq!(delays.last(), Some(&STREAM_RETRY_MAX_BACKOFF_DELAY));
+        let total: Duration = delays.into_iter().sum();
+        assert!(total <= Duration::from_secs(30 * 60));
+
+        let requested = CodexErr::Stream("retry later".to_string(), Some(Duration::from_secs(45)));
+        assert_eq!(stream_retry_delay(&requested, 30), Duration::from_secs(45));
+    }
+}
