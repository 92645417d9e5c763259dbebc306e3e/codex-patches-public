+#[test]
+fn openai_default_base_url_supports_websockets() {
+    let provider = ModelProviderInfo::create_openai_provider(/*base_url*/ None);
+    let api_provider = provider
+        .to_api_provider(/*auth_mode*/ None)
+        .expect("OpenAI provider should build API provider");
+
+    assert!(provider.supports_websockets);
+    assert_eq!(api_provider.base_url, OPENAI_DEFAULT_BASE_URL);
+}
+
+#[test]
+fn custom_openai_base_url_requires_explicit_websocket_opt_in() {
+    let canonical =
+        ModelProviderInfo::create_openai_provider(Some(OPENAI_DEFAULT_BASE_URL.to_string()));
+    let custom =
+        ModelProviderInfo::create_openai_provider(Some("http://127.0.0.1:12345/v1".to_string()));
+
+    assert!(canonical.supports_websockets);
+    assert!(!custom.supports_websockets);
+}
