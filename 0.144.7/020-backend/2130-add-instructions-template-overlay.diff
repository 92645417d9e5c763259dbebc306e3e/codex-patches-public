diff --git a/codex-rs/models-manager/src/instructions_overlay.rs b/codex-rs/models-manager/src/instructions_overlay.rs
new file mode 100644
index 0000000000..4ef0ac0670
--- /dev/null
+++ b/codex-rs/models-manager/src/instructions_overlay.rs
@@ -0,0 +1,360 @@
+use codex_protocol::openai_models::ModelInfo;
+use std::fs as std_fs;
+use std::fs::File;
+use std::fs::OpenOptions;
+use std::io;
+use std::io::ErrorKind;
+use std::io::Write;
+use std::path::Path;
+use std::path::PathBuf;
+use std::sync::atomic::AtomicU64;
+use std::sync::atomic::Ordering;
+use tokio::fs;
+use tracing::warn;
+
+pub(crate) const INSTRUCTIONS_OVERLAY_DIR: &str = "instructions";
+static SEED_TEMP_SEQUENCE: AtomicU64 = AtomicU64::new(0);
+
+pub(crate) fn dir_path(codex_home: &Path) -> PathBuf {
+    codex_home.join(INSTRUCTIONS_OVERLAY_DIR)
+}
+
+pub(crate) async fn apply(dir: &Path, catalog_slug: &str, model_info: &mut ModelInfo) {
+    let Some(path) = model_path(dir, catalog_slug) else {
+        warn!(
+            model = %model_info.slug,
+            catalog_slug,
+            "instructions overlay catalog slug is unsafe"
+        );
+        return;
+    };
+    let template = match fs::read_to_string(&path).await {
+        Ok(template) => template,
+        Err(err) if err.kind() == ErrorKind::NotFound => return,
+        Err(err) => {
+            warn!(
+                model = %model_info.slug,
+                path = %path.display(),
+                "failed to load instructions overlay file: {err}"
+            );
+            return;
+        }
+    };
+    if template.trim().is_empty() {
+        warn!(
+            model = %model_info.slug,
+            path = %path.display(),
+            "instructions overlay file must not be empty"
+        );
+        return;
+    }
+    let Some(model_messages) = model_info.model_messages.as_mut() else {
+        return;
+    };
+    model_messages.instructions_template = Some(template);
+}
+
+pub(crate) async fn seed(dir: &Path, models: &[ModelInfo]) {
+    if let Err(err) = fs::create_dir_all(dir).await {
+        warn!(
+            path = %dir.display(),
+            "failed to create instructions overlay directory: {err}"
+        );
+        return;
+    }
+
+    for model in models {
+        let Some(template) = model
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref())
+        else {
+            continue;
+        };
+        let Some(path) = model_path(dir, &model.slug) else {
+            warn!(
+                model = %model.slug,
+                "instructions overlay catalog slug is unsafe"
+            );
+            continue;
+        };
+        if template.trim().is_empty() {
+            warn!(
+                model = %model.slug,
+                path = %path.display(),
+                "instructions overlay seed must not be empty"
+            );
+            continue;
+        }
+        if let Err(err) = create_new(&path, template).await
+            && err.kind() != ErrorKind::AlreadyExists
+        {
+            warn!(
+                model = %model.slug,
+                path = %path.display(),
+                "failed to seed instructions overlay file: {err}"
+            );
+        }
+    }
+}
+
+fn model_path(dir: &Path, catalog_slug: &str) -> Option<PathBuf> {
+    is_safe_catalog_slug(catalog_slug).then(|| dir.join(format!("{catalog_slug}.md")))
+}
+
+fn is_safe_catalog_slug(catalog_slug: &str) -> bool {
+    let bytes = catalog_slug.as_bytes();
+    bytes
+        .first()
+        .copied()
+        .is_some_and(is_ascii_lowercase_alphanumeric)
+        && bytes
+            .last()
+            .copied()
+            .is_some_and(is_ascii_lowercase_alphanumeric)
+        && catalog_slug
+            .bytes()
+            .all(|byte| is_ascii_lowercase_alphanumeric(byte) || matches!(byte, b'-' | b'_' | b'.'))
+        && !catalog_slug.contains("..")
+        && !is_windows_reserved_name(catalog_slug)
+}
+
+fn is_ascii_lowercase_alphanumeric(byte: u8) -> bool {
+    byte.is_ascii_lowercase() || byte.is_ascii_digit()
+}
+
+fn is_windows_reserved_name(catalog_slug: &str) -> bool {
+    let stem = catalog_slug.split('.').next().unwrap_or(catalog_slug);
+    matches!(stem, "con" | "prn" | "aux" | "nul")
+        || stem
+            .strip_prefix("com")
+            .or_else(|| stem.strip_prefix("lpt"))
+            .is_some_and(|number| {
+                matches!(number, "1" | "2" | "3" | "4" | "5" | "6" | "7" | "8" | "9")
+            })
+}
+
+async fn create_new(path: &Path, contents: &str) -> io::Result<()> {
+    let path = path.to_path_buf();
+    let contents = contents.as_bytes().to_vec();
+    tokio::task::spawn_blocking(move || {
+        StagedSeed::create(&path, &contents)?.install_no_clobber(&path)
+    })
+    .await
+    .map_err(io::Error::other)?
+}
+
+struct StagedSeed {
+    path: PathBuf,
+    file: Option<File>,
+}
+
+impl StagedSeed {
+    fn create(target: &Path, contents: &[u8]) -> io::Result<Self> {
+        Self::create_with(target, |file| file.write_all(contents))
+    }
+
+    fn create_with(
+        target: &Path,
+        write_contents: impl FnOnce(&mut File) -> io::Result<()>,
+    ) -> io::Result<Self> {
+        let parent = target
+            .parent()
+            .ok_or_else(|| io::Error::other("instructions overlay target has no parent"))?;
+        let file_name = target
+            .file_name()
+            .ok_or_else(|| io::Error::other("instructions overlay target has no file name"))?
+            .to_string_lossy();
+        let (file, temp_path) = (0..128)
+            .find_map(|_| {
+                let sequence = SEED_TEMP_SEQUENCE.fetch_add(1, Ordering::Relaxed);
+                let temp_path = parent.join(format!(
+                    ".{file_name}.seed.{}.{sequence}",
+                    std::process::id()
+                ));
+                match OpenOptions::new()
+                    .write(true)
+                    .create_new(true)
+                    .open(&temp_path)
+                {
+                    Ok(file) => Some(Ok((file, temp_path))),
+                    Err(err) if err.kind() == ErrorKind::AlreadyExists => None,
+                    Err(err) => Some(Err(err)),
+                }
+            })
+            .transpose()?
+            .ok_or_else(|| io::Error::new(ErrorKind::AlreadyExists, "seed temp names exhausted"))?;
+        let mut staged = Self {
+            path: temp_path,
+            file: Some(file),
+        };
+        let Some(file) = staged.file.as_mut() else {
+            return Err(io::Error::other("newly staged seed lost its file"));
+        };
+        write_contents(file).and_then(|()| file.sync_all())?;
+        drop(staged.file.take());
+        Ok(staged)
+    }
+
+    fn install_no_clobber(self, target: &Path) -> io::Result<()> {
+        std_fs::hard_link(&self.path, target)
+    }
+}
+
+impl Drop for StagedSeed {
+    fn drop(&mut self) {
+        drop(self.file.take());
+        let _ = std_fs::remove_file(&self.path);
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn catalog_slug_paths_use_a_positive_ascii_filename_policy() {
+        let dir = Path::new("instructions");
+        assert_eq!(
+            model_path(dir, "gpt-5.2_codex"),
+            Some(dir.join("gpt-5.2_codex.md"))
+        );
+
+        for slug in [
+            "",
+            ".",
+            "..",
+            ".hidden",
+            "gpt.",
+            "gpt..5",
+            "../gpt-5",
+            "provider/gpt-5",
+            "provider\\gpt-5",
+            "gpt 5",
+            "GPT-5",
+            "con",
+            "nul.model",
+            "com1",
+            "lpt9.extra",
+            "模型",
+        ] {
+            assert_eq!(model_path(dir, slug), None, "accepted unsafe slug {slug:?}");
+        }
+    }
+
+    #[tokio::test]
+    async fn concurrent_seed_is_atomic_and_never_clobbers_the_winner() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let dir = dir_path(temp.path());
+        let mut first = crate::bundled_models_response()
+            .expect("bundled models should parse")
+            .models
+            .into_iter()
+            .find(|model| model.model_messages.is_some())
+            .expect("bundled catalog should include instruction messages");
+        first.slug = "seed-race".to_string();
+        first
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("first".to_string());
+        let mut second = first.clone();
+        second
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("second".to_string());
+        let first_catalog = vec![first];
+        let second_catalog = vec![second];
+
+        tokio::join!(seed(&dir, &first_catalog), seed(&dir, &second_catalog));
+
+        let path = model_path(&dir, "seed-race").expect("safe test slug");
+        let winner = fs::read_to_string(&path)
+            .await
+            .expect("one concurrent seed should win");
+        assert!(winner == "first" || winner == "second");
+
+        let mut later = first_catalog[0].clone();
+        later
+            .model_messages
+            .as_mut()
+            .expect("test model should have messages")
+            .instructions_template = Some("later".to_string());
+        seed(&dir, &[later]).await;
+        assert_eq!(
+            fs::read_to_string(path)
+                .await
+                .expect("winning seed should remain readable"),
+            winner
+        );
+    }
+
+    #[test]
+    fn staged_seed_is_invisible_until_atomic_no_clobber_install() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let target = temp.path().join("model.md");
+        let staged = StagedSeed::create(&target, b"complete prompt").expect("stage prompt");
+        let staged_path = staged.path.clone();
+        assert!(!target.exists());
+        assert_eq!(
+            std_fs::read(&staged_path).expect("read staged prompt"),
+            b"complete prompt"
+        );
+
+        std_fs::write(&target, "user prompt").expect("write winning user prompt");
+        assert_eq!(
+            staged
+                .install_no_clobber(&target)
+                .expect_err("existing target must win")
+                .kind(),
+            ErrorKind::AlreadyExists
+        );
+        assert_eq!(
+            std_fs::read_to_string(&target).expect("read winning user prompt"),
+            "user prompt"
+        );
+        assert!(!staged_path.exists());
+
+        std_fs::remove_file(&target).expect("remove winning user prompt");
+        let staged = StagedSeed::create(&target, b"published prompt").expect("restage prompt");
+        let staged_path = staged.path.clone();
+        staged
+            .install_no_clobber(&target)
+            .expect("publish staged prompt");
+        assert_eq!(
+            std_fs::read_to_string(&target).expect("read published prompt"),
+            "published prompt"
+        );
+        assert!(!staged_path.exists());
+    }
+
+    #[test]
+    fn failed_staging_removes_partial_file_and_allows_retry() {
+        let temp = tempfile::tempdir().expect("create temp dir");
+        let target = temp.path().join("model.md");
+        let err = StagedSeed::create_with(&target, |file| {
+            file.write_all(b"partial prompt")?;
+            Err(io::Error::other("injected write failure"))
+        })
+        .err()
+        .expect("staging should fail");
+        assert_eq!(err.to_string(), "injected write failure");
+        assert!(!target.exists());
+        assert_eq!(
+            std_fs::read_dir(temp.path())
+                .expect("read temp directory")
+                .count(),
+            0
+        );
+
+        StagedSeed::create(&target, b"retry prompt")
+            .expect("retry staging")
+            .install_no_clobber(&target)
+            .expect("retry publication");
+        assert_eq!(
+            std_fs::read_to_string(target).expect("read retry prompt"),
+            "retry prompt"
+        );
+    }
+}
