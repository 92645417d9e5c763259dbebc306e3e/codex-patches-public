+#[tokio::test]
+async fn catalog_publication_seeds_no_clobber_and_losing_cache_does_not_seed() {
+    let existing = remote_model_with_prompt("seed-existing", "existing catalog prompt");
+    let missing = remote_model_with_prompt("seed-missing", "missing catalog prompt");
+    let background = remote_model_with_prompt("seed-existing", "background catalog prompt");
+    let codex_home = tempdir().expect("temp dir");
+    write_instructions_overlay(codex_home.path(), "seed-existing", "local prompt");
+    let endpoint = TestModelsEndpoint::new(vec![
+        vec![existing.clone(), missing.clone()],
+        vec![background.clone()],
+    ]);
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint.clone());
+
+    manager
+        .refresh_available_models(RefreshStrategy::Online, &DEFAULT_HTTP_CLIENT_FACTORY)
+        .await
+        .expect("network catalog publication succeeds");
+
+    assert_eq!(
+        std::fs::read_to_string(instructions_overlay_path(
+            codex_home.path(),
+            "seed-existing"
+        ))
+        .expect("read existing overlay"),
+        "local prompt"
+    );
+    assert_eq!(
+        std::fs::read_to_string(instructions_overlay_path(codex_home.path(), "seed-missing"))
+            .expect("read seeded overlay"),
+        "missing catalog prompt"
+    );
+    let cached = manager
+        .cache_manager
+        .load_any(&crate::client_version_to_whole())
+        .await
+        .expect("published network catalog should be cached");
+    assert_eq!(cached.cache.models, vec![existing, missing]);
+
+    manager
+        .refresh_available_models(
+            RefreshStrategy::OnlineIfUncached,
+            &DEFAULT_HTTP_CLIENT_FACTORY,
+        )
+        .await
+        .expect("cache publication succeeds");
+    let background_task = manager
+        .take_background_refresh_task_for_test()
+        .expect("cache publication should start a background refresh");
+    tokio::time::timeout(ASYNC_TEST_TIMEOUT, background_task)
+        .await
+        .expect("background refresh should finish")
+        .expect("background refresh task should succeed");
+    assert_eq!(endpoint.fetch_count(), 2);
+    assert_eq!(manager.get_remote_models().await, vec![background]);
+    assert_eq!(
+        std::fs::read_to_string(instructions_overlay_path(
+            codex_home.path(),
+            "seed-existing"
+        ))
+        .expect("read overlay after cache and background publications"),
+        "local prompt"
+    );
+    assert_eq!(
+        std::fs::read_to_string(instructions_overlay_path(codex_home.path(), "seed-missing"))
+            .expect("read seeded overlay after background publication"),
+        "missing catalog prompt"
+    );
+
+    let losing = remote_model_with_prompt("seed-loser", "losing cache prompt");
+    let losing_cache = ModelsCache {
+        fetched_at: Utc::now(),
+        etag: None,
+        client_version: Some(crate::client_version_to_whole()),
+        models: vec![losing],
+    };
+    assert!(
+        !manager
+            .apply_cached_models_if_revision_matches(/*observed_revision*/ 0, losing_cache)
+            .await
+    );
+    assert!(!instructions_overlay_path(codex_home.path(), "seed-loser").exists());
+}
