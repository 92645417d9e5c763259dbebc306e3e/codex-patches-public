+        TestModelsEndpoint::without_refresh(Vec::new()),
+    );
+    manager.catalog.write().await.models = vec![remote_model_with_prompt(
+        "overlay-reload",
+        "catalog instructions",
+    )];
+    write_instructions_overlay(
+        codex_home.path(),
+        "overlay-reload",
+        "overlay one\n{{ personality }}",
+    );
+    let config = ModelsManagerConfig {
+        personality_enabled: true,
+        ..Default::default()
+    };
+
+    let first = manager.get_model_info("overlay-reload", &config).await;
+    assert_eq!(
+        first
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("overlay one\n{{ personality }}")
+    );
+
+    write_instructions_overlay(
+        codex_home.path(),
+        "overlay-reload",
+        "overlay two\n{{ personality }}",
+    );
+    let reloaded = manager.get_model_info("overlay-reload", &config).await;
+    assert_eq!(
+        reloaded
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("overlay two\n{{ personality }}")
+    );
+    let personality_none = reloaded.get_model_instructions(Some(Personality::None));
+    assert!(personality_none.contains("overlay two"));
+    assert!(!personality_none.contains("{{ personality }}"));
+
+    let personality_disabled = manager
+        .get_model_info("overlay-reload", &ModelsManagerConfig::default())
+        .await;
+    assert_eq!(personality_disabled.model_messages, None);
+
+    let config_override = ModelsManagerConfig {
+        base_instructions: Some("configured instructions".to_string()),
+        personality_enabled: true,
+        ..Default::default()
+    };
+    let overridden = manager
+        .get_model_info("overlay-reload", &config_override)
+        .await;
+    assert_eq!(overridden.base_instructions, "configured instructions");
+    assert_eq!(overridden.model_messages, None);
+}
