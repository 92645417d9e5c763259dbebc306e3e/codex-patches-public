+#[derive(Debug, Clone, Deserialize, Serialize, PartialEq, JsonSchema, TS)]
+pub struct ResponsePerformance {
+    pub latency_ms: Option<i64>,
+    pub ttft_ms: Option<i64>,
+    pub generation_ms: Option<i64>,
+    pub output_tokens: i64,
+    pub reasoning_output_tokens: i64,
+    pub visible_output_tokens: i64,
+    pub output_tokens_per_second: Option<f64>,
+    pub reasoning_tokens_per_second: Option<f64>,
+    pub visible_output_tokens_per_second: Option<f64>,
+}
+
+impl ResponsePerformance {
+    pub fn from_usage_and_timings(
+        usage: &TokenUsage,
+        ttft_ms: Option<i64>,
+        latency_ms: i64,
+        include_token_rates: bool,
+    ) -> Self {
+        let output_tokens = usage.output_tokens.max(0);
+        let reasoning_output_tokens = usage.reasoning_output_tokens.max(0);
+        let visible_output_tokens = output_tokens.saturating_sub(reasoning_output_tokens);
+        let latency_ms = latency_ms.max(0);
+        let ttft_ms = ttft_ms.filter(|ttft_ms| *ttft_ms > 0);
+        let generation_ms = ttft_ms
+            .map(|ttft_ms| latency_ms.saturating_sub(ttft_ms))
+            .filter(|generation_ms| *generation_ms > 0);
+        let token_rate_generation_ms = include_token_rates.then_some(generation_ms).flatten();
+        Self {
+            latency_ms: Some(latency_ms),
+            ttft_ms,
+            generation_ms,
+            output_tokens,
+            reasoning_output_tokens,
+            visible_output_tokens,
+            output_tokens_per_second: tokens_per_second(output_tokens, token_rate_generation_ms),
+            reasoning_tokens_per_second: tokens_per_second(
+                reasoning_output_tokens,
+                token_rate_generation_ms,
+            ),
+            visible_output_tokens_per_second: tokens_per_second(
+                visible_output_tokens,
+                token_rate_generation_ms,
+            ),
+        }
+    }
+
+    pub fn from_ttft(ttft_ms: i64) -> Self {
+        Self {
+            latency_ms: None,
+            ttft_ms: (ttft_ms > 0).then_some(ttft_ms),
+            generation_ms: None,
+            output_tokens: 0,
+            reasoning_output_tokens: 0,
+            visible_output_tokens: 0,
+            output_tokens_per_second: None,
+            reasoning_tokens_per_second: None,
+            visible_output_tokens_per_second: None,
+        }
+    }
+}
+
+fn tokens_per_second(tokens: i64, generation_ms: Option<i64>) -> Option<f64> {
+    let generation_ms = generation_ms?;
+    if tokens <= 0 || generation_ms <= 0 {
+        return None;
+    }
+    Some(tokens as f64 / (generation_ms as f64 / 1_000.0))
+}
+
+#[derive(Debug, Clone, Deserialize, Serialize, PartialEq, JsonSchema, TS)]
+pub struct ResponsePerformanceEvent {
+    pub thread_id: ThreadId,
+    pub turn_id: String,
+    pub performance: ResponsePerformance,
+}
