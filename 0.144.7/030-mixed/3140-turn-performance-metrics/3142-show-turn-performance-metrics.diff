+async fn response_stream_emits_ttft_and_completed_performance_samples() {
+    let item = output_message("msg-1", "done");
+    let api_stream = futures::stream::iter([
+        Ok(ResponseEvent::OutputItemAdded(item.clone())),
+        Ok(ResponseEvent::OutputItemDone(item)),
+        Ok(ResponseEvent::Completed {
+            response_id: "resp-123".to_string(),
+            token_usage: Some(response_performance_usage()),
+            end_turn: Some(true),
+        }),
+    ]);
+    let (mut stream, _last_response) = super::map_response_events(
+        /*upstream_request_id*/ None,
+        api_stream,
+        test_session_telemetry(),
+        InferenceTraceAttempt::disabled(),
+        test_model_provider(),
+    );
+
+    let early = stream
+        .next()
+        .await
+        .expect("stream should emit early performance")
+        .expect("early performance should be valid");
+    let ResponseEvent::ResponsePerformance(early) = early else {
+        panic!("expected early response performance");
+    };
+    assert_eq!(early.latency_ms, None);
+    assert_eq!(early.output_tokens, 0);
+
+    assert!(matches!(
+        stream.next().await,
+        Some(Ok(ResponseEvent::OutputItemAdded(_)))
+    ));
+    assert!(matches!(
+        stream.next().await,
+        Some(Ok(ResponseEvent::OutputItemDone(_)))
+    ));
+
+    let completed = stream
+        .next()
+        .await
+        .expect("stream should emit completed performance")
+        .expect("completed performance should be valid");
+    let ResponseEvent::ResponsePerformance(completed) = completed else {
+        panic!("expected completed response performance");
+    };
+    assert_eq!(completed.output_tokens, 150);
+    assert_eq!(completed.reasoning_output_tokens, 100);
