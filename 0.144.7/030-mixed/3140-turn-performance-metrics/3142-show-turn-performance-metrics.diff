+#[test]
+fn response_performance_rates_reject_tool_other_and_agent_message_items() {
+    let assistant = output_message("msg-1", "done");
+    for completed_items in [
+        vec![assistant.clone(), function_call_item("call-1")],
+        vec![function_call_item("call-2"), assistant.clone()],
+        vec![assistant.clone(), ResponseItem::Other],
+        vec![assistant.clone(), agent_message_item("agent-msg-1")],
+        Vec::new(),
+    ] {
+        let performance = super::response_performance_for_completed_items(
+            &response_performance_usage(),
+            Some(500),
+            2_000,
+            &completed_items,
+        );
+
+        assert_no_token_rates(&performance);
+    }
+}
+
+#[test]
+fn response_performance_rates_recover_for_a_later_independent_response() {
+    let contaminated = super::response_performance_for_completed_items(
+        &response_performance_usage(),
+        Some(500),
+        2_000,
+        &[
+            output_message("msg-1", "working"),
+            function_call_item("call-1"),
+        ],
+    );
+    assert_no_token_rates(&contaminated);
+
+    let independent = super::response_performance_for_completed_items(
+        &response_performance_usage(),
+        Some(500),
+        2_000,
+        &[
+            reasoning_item("reasoning-2"),
+            output_message("msg-2", "done"),
+        ],
+    );
+    assert_eq!(independent.output_tokens_per_second, Some(100.0));
+    assert!(independent.reasoning_tokens_per_second.is_some());
+    assert!(independent.visible_output_tokens_per_second.is_some());
+}
