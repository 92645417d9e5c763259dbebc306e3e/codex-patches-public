+fn response_performance(
+    ttft_ms: Option<i64>,
+    output_tokens_per_second: Option<f64>,
+) -> codex_app_server_protocol::ResponsePerformance {
+    codex_app_server_protocol::ResponsePerformance {
+        latency_ms: None,
+        ttft_ms,
+        generation_ms: None,
+        output_tokens: 0,
+        reasoning_output_tokens: 0,
+        visible_output_tokens: 0,
+        output_tokens_per_second,
+        reasoning_tokens_per_second: None,
+        visible_output_tokens_per_second: None,
+    }
+}
+
+fn handle_response_performance(
+    chat: &mut ChatWidget,
+    performance: codex_app_server_protocol::ResponsePerformance,
+) {
+    chat.handle_server_notification(
+        ServerNotification::ResponsePerformance(
+            codex_app_server_protocol::ResponsePerformanceNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                performance,
+            },
+        ),
+        /*replay_kind*/ None,
+    );
+}
+
+#[tokio::test]
+async fn status_line_response_performance_notification_renders_latest_values() {
+    let (mut chat, _rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    handle_response_performance(&mut chat, response_performance(Some(500), Some(100.04)));
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::TokensPerSecond),
+        Some("100.0 TPS".to_string())
+    );
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::TimeToFirstToken),
+        Some("500ms TTFT".to_string())
+    );
+
+    handle_response_performance(&mut chat, response_performance(Some(1_250), None));
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::TokensPerSecond),
+        None
+    );
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::TimeToFirstToken),
+        Some("1.25s TTFT".to_string())
