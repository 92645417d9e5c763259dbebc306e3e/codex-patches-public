+#[test]
+fn response_performance_rates_allow_reasoning_and_assistant_output() {
+    let completed_items = vec![
+        reasoning_item("reasoning-1"),
+        output_message("msg-1", "done"),
+    ];
+
+    let performance = super::response_performance_for_completed_items(
+        &response_performance_usage(),
+        Some(500),
+        2_000,
+        &completed_items,
+    );
+
+    assert_eq!(performance.output_tokens_per_second, Some(100.0));
+    assert_eq!(performance.reasoning_tokens_per_second, Some(100.0 / 1.5));
+    assert_eq!(
+        performance.visible_output_tokens_per_second,
+        Some(50.0 / 1.5)
+    );
+}
