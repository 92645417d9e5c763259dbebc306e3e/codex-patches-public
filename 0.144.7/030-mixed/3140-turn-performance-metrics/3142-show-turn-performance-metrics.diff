+            ResponseItem::Reasoning { .. } => true,
+            ResponseItem::Message { role, .. } => role == "assistant",
+            _ => false,
+        });
+    ResponsePerformance::from_usage_and_timings(usage, ttft_ms, latency_ms, include_token_rates)
+}
