+    fn post_compact_context_usage(&self) -> history_cell::PostCompactContextUsage {
+        let used_tokens = self
+            .token_info
+            .as_ref()
+            .map(|info| info.last_token_usage.tokens_in_context_window().max(0));
+        let Some(context_window) = self
+            .status_line_context_window_size()
+            .filter(|window| *window > 0)
+        else {
+            return history_cell::PostCompactContextUsage::UnknownContextWindow { used_tokens };
+        };
+        let Some(used_tokens) = used_tokens else {
+            return history_cell::PostCompactContextUsage::UnknownContextWindow { used_tokens };
+        };
+        if used_tokens > 0 && used_tokens < context_window / 100 {
+            return history_cell::PostCompactContextUsage::LessThanOnePercent { used_tokens };
+        }
+        let percent = (used_tokens.saturating_mul(100) + context_window / 2) / context_window;
+        history_cell::PostCompactContextUsage::Percent {
+            percent,
+            used_tokens,
+        }
+    }
