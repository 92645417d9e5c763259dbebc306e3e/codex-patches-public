+#[derive(Debug)]
+pub struct ResumeHistoryLoadedSeparator {
+    messages: u64,
+    turns: u64,
+    app_server_turns: u64,
+    context_windows: u64,
+}
+
+impl ResumeHistoryLoadedSeparator {
+    pub(crate) fn new(
+        messages: u64,
+        turns: u64,
+        app_server_turns: u64,
+        context_windows: u64,
+    ) -> Self {
+        Self {
+            messages,
+            turns,
+            app_server_turns,
+            context_windows,
+        }
+    }
+
+    fn label(&self) -> String {
+        let messages = pluralize(self.messages, "message", "messages");
+        let turns = pluralize(self.turns, "turn", "turns");
+        let app_server_turns =
+            pluralize(self.app_server_turns, "app-server turn", "app-server turns");
+        let context_windows = pluralize(self.context_windows, "context", "contexts");
+        format!(
+            "Loaded {} {messages}, {} {turns}, {} {app_server_turns}, {} {context_windows}",
+            self.messages, self.turns, self.app_server_turns, self.context_windows
+        )
+    }
+}
+
+impl HistoryCell for ResumeHistoryLoadedSeparator {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        let label_text = self.label();
+        let label = format!("─ {label_text} ─");
+        let label_width = UnicodeWidthStr::width(label.as_str());
+        if label_width > width as usize {
+            let (label, _suffix, label_width) = take_prefix_by_width(&label, width as usize);
+            return vec![
+                Line::from_iter([
+                    label,
+                    "─".repeat((width as usize).saturating_sub(label_width)),
+                ])
+                .dim(),
+            ];
+        }
+
+        let mut spans = Vec::new();
+        spans.push("─ ".dim());
+        spans.push(label_text.fg(Color::Cyan).add_modifier(Modifier::BOLD));
+        spans.push(" ─".dim());
+        spans.push(
+            "─"
+                .repeat((width as usize).saturating_sub(label_width))
+                .dim(),
+        );
+        vec![Line::from(spans)]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        vec![Line::from(self.label())]
+    }
+}
