+#[derive(Debug)]
+struct ContextCompactedHistoryCell {
+    duration_ms: Option<i64>,
+    post_compact_context_usage: Option<PostCompactContextUsage>,
+}
+
+#[derive(Clone, Copy, Debug)]
+pub(crate) enum PostCompactContextUsage {
+    UnknownContextWindow { used_tokens: Option<i64> },
+    LessThanOnePercent { used_tokens: i64 },
+    Percent { percent: i64, used_tokens: i64 },
+}
+
+impl HistoryCell for ContextCompactedHistoryCell {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        let style = Self::banner_style();
+        let details = self.details_text();
+        let mut spans = vec![Span::styled("■ Context compacted", style)];
+        if let Some(details) = &details {
+            spans.push(Span::styled(format!(" {details}"), style));
+        }
+        let line_width = "■ Context compacted".width()
+            + details
+                .as_ref()
+                .map(|details| 1 + details.width())
+                .unwrap_or_default();
+        let target_width = usize::from(width);
+        if target_width > line_width {
+            spans.push(Span::styled(" ".repeat(target_width - line_width), style));
+        }
+        vec![Line::from(spans).style(style)]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        let mut text = "■ Context compacted".to_string();
+        if let Some(details) = self.details_text() {
+            text.push(' ');
+            text.push_str(&details);
+        }
+        vec![text.into()]
+    }
+}
+
+impl ContextCompactedHistoryCell {
+    fn banner_style() -> Style {
+        Style::default()
+            .fg(Color::Red)
+            .bg(Color::Yellow)
+            .add_modifier(Modifier::BOLD)
+    }
+
+    fn details_text(&self) -> Option<String> {
+        let mut details = Vec::new();
+        if let Some(duration_ms) = self.duration_ms {
+            let elapsed_seconds = u64::try_from(duration_ms.max(0))
+                .unwrap_or_default()
+                .saturating_add(999)
+                / 1_000;
+            let elapsed = crate::status_indicator_widget::fmt_elapsed_compact(elapsed_seconds);
+            details.push(format!("Worked {elapsed}"));
+        }
+        if let Some(usage) = self.post_compact_context_usage {
+            details.push(usage.label());
+        }
+        (!details.is_empty()).then(|| format!("· {}", details.join(" · ")))
+    }
+}
+
+impl PostCompactContextUsage {
+    fn label(self) -> String {
+        match self {
+            PostCompactContextUsage::UnknownContextWindow { used_tokens } => {
+                if let Some(used_tokens) = used_tokens {
+                    format!("{} Used (window unknown)", compact_token_count(used_tokens))
+                } else {
+                    "Context window unknown".to_string()
+                }
+            }
+            PostCompactContextUsage::LessThanOnePercent { used_tokens } => {
+                format!("<1% Used ({})", compact_token_count(used_tokens))
+            }
+            PostCompactContextUsage::Percent {
+                percent,
+                used_tokens,
+            } => {
+                format!(
+                    "{}% Used ({})",
+                    percent.clamp(0, 100),
+                    compact_token_count(used_tokens)
+                )
+            }
+        }
+    }
+}
+
+fn compact_token_count(tokens: i64) -> String {
+    let token_label = if tokens == 1 { "token" } else { "tokens" };
+    format!("{} {token_label}", format_tokens_compact(tokens))
+}
+
+pub(crate) fn new_context_compacted_event(
+    duration_ms: Option<i64>,
+    post_compact_context_usage: Option<PostCompactContextUsage>,
+) -> impl HistoryCell {
+    ContextCompactedHistoryCell {
+        duration_ms,
+        post_compact_context_usage,
+    }
+}
