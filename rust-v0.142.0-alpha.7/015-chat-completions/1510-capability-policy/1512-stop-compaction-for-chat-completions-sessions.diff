+pub(crate) async fn ensure_chat_completions_compaction_allowed(
+    sess: &Session,
+    turn_context: &TurnContext,
+) -> CodexResult<()> {
+    if crate::chat_completions_config::is_model(&turn_context.model_info.slug) {
+        return Err(crate::chat_completions_config::compaction_disabled_error(
+            &turn_context.model_info.slug,
+        ));
+    }
+    if sess.has_chat_completions_model_participation().await {
+        return Err(CodexErr::UnsupportedOperation(
+            "compaction is disabled because this session includes OpenAI-compatible Chat Completions model participation; start a new thread or split the task"
+                .to_string(),
+        ));
+    }
+    Ok(())
+}
+
+pub(crate) async fn emit_compaction_error(
+    sess: &Session,
+    turn_context: &TurnContext,
+    err: &CodexErr,
+) {
+    sess.track_turn_codex_error(turn_context, err);
+    sess.send_event(
+        turn_context,
+        EventMsg::Error(err.to_error_event(/*message_prefix*/ None)),
+    )
+    .await;
+}
