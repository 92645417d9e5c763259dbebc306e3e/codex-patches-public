+/// Returns the Codex runtime temp root under the system temp parent.
+pub fn find_codex_tmp_root() -> std::io::Result<AbsolutePathBuf> {
+    let parent = codex_tmp_parent_from_env(
+        std::env::var_os("TMPDIR"),
+        std::env::var_os("TMP"),
+        std::env::var_os("TEMP"),
+    )
+    .unwrap_or_else(std::env::temp_dir);
+    AbsolutePathBuf::from_absolute_path(parent.join("codex"))
+}
+
+fn codex_tmp_parent_from_env(
+    tmpdir: Option<OsString>,
+    tmp: Option<OsString>,
+    temp: Option<OsString>,
+) -> Option<PathBuf> {
+    [tmpdir, tmp, temp]
+        .into_iter()
+        .flatten()
+        .find(|value| !value.is_empty())
+        .map(PathBuf::from)
+}
+
 fn find_codex_home_from_env(codex_home_env: Option<&str>) -> std::io::Result<AbsolutePathBuf> {
     // Honor the `CODEX_HOME` environment variable when it is set to allow users
     // (and tests) to override the default location.
