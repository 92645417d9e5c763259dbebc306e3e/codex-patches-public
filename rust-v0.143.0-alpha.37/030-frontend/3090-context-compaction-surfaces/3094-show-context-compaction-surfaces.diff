+impl ContextCompactionTriggerUsage {
+    fn label(self) -> Option<String> {
+        let mut details = Vec::new();
+        match (self.used_tokens, self.context_window) {
+            (Some(used_tokens), Some(context_window)) if context_window > 0 => {
+                let percent =
+                    (used_tokens.saturating_mul(100) + context_window / 2) / context_window;
+                details.push(format!(
+                    "{}% Used ({} / {})",
+                    percent.clamp(0, 100),
+                    compact_token_count(used_tokens),
+                    compact_token_count(context_window)
+                ));
+            }
+            (Some(used_tokens), _) => {
+                details.push(format!(
+                    "{} Used (window unknown)",
+                    compact_token_count(used_tokens)
+                ));
+            }
+            (None, Some(context_window)) => {
+                details.push(format!("Window {}", compact_token_count(context_window)));
+            }
+            (None, None) => {}
+        }
+        if let Some(limit) = self.auto_compact_limit.filter(|limit| *limit > 0) {
+            details.push(format!("Auto limit {}", compact_token_count(limit)));
+        }
+        (!details.is_empty()).then(|| details.join(" ■ "))
     }
