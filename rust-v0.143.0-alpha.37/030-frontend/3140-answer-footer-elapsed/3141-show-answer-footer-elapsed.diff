+    let rendered = render_lines(&cell.display_lines(/*width*/ 200));
+
+    assert_eq!(rendered.len(), 1);
+    assert!(rendered[0].contains("Answered in 1m 01s"));
+    assert_eq!(render_lines(&cell.raw_lines()), vec!["Answered in 1m 01s"]);
