+#[tokio::test]
+async fn final_answer_without_work_shows_answered_elapsed() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+    chat.turn_lifecycle.active_turn_started_at =
+        Some(std::time::Instant::now() - std::time::Duration::from_secs(125));
+
+    complete_assistant_message(
+        &mut chat,
+        "msg-final",
+        "Final response.",
+        Some(MessagePhase::FinalAnswer),
+    );
+    handle_turn_completed(&mut chat, "turn-1", Some(597_000));
+
+    let cells = drain_insert_history(&mut rx);
+    let combined = cells
+        .iter()
+        .map(|lines| lines_to_single_string(lines))
+        .collect::<String>();
+    assert!(
+        combined.contains("Answered in 2m 05s"),
+        "expected final answer without work to show answer elapsed time, got:\n{combined}"
+    );
+    assert!(
+        !combined.contains("Worked for"),
+        "expected final answer without work not to use work wording, got:\n{combined}"
+    );
+    assert!(
+        !combined.contains("Answered in 9m 57s"),
+        "expected final answer to prefer local active-turn duration, got:\n{combined}"
+    );
+}
