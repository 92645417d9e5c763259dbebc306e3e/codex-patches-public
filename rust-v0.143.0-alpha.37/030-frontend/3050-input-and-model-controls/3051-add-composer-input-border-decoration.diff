+    }
+
+    #[test]
+    fn composer_draws_normal_mode_border() {
+        use ratatui::Terminal;
+        use ratatui::backend::TestBackend;
+
+        let (tx, _rx) = unbounded_channel::<AppEvent>();
+        let sender = AppEventSender::new(tx);
+        let composer = ChatComposer::new(
+            /*has_input_focus*/ true,
+            sender,
+            /*enhanced_keys_supported*/ true,
+            "Ask Codex to do anything".to_string(),
+            /*disable_paste_burst*/ false,
+        );
+
+        let mut terminal = Terminal::new(TestBackend::new(48, 6)).unwrap();
+        terminal
+            .draw(|f| composer.render(f.area(), f.buffer_mut()))
+            .unwrap();
+
+        let buf = terminal.backend().buffer();
+        assert_eq!(buf[(0, 0)].symbol(), "─");
+        assert_eq!(buf[(0, 0)].style().fg, Some(Color::Reset));
+        assert_eq!(buf[(47, 0)].symbol(), "─");
+        assert_eq!(buf[(47, 0)].style().fg, Some(Color::Reset));
+        insta::assert_snapshot!("composer_normal_mode_input_border", terminal.backend());
+    }
+
+    #[test]
+    fn composer_keeps_trailing_text_visible_without_side_border() {
+        use ratatui::Terminal;
+        use ratatui::backend::TestBackend;
+
+        for mode in [None, Some(CollaborationModeIndicator::Plan)] {
+            let (tx, _rx) = unbounded_channel::<AppEvent>();
+            let sender = AppEventSender::new(tx);
+            let mut composer = ChatComposer::new(
+                /*has_input_focus*/ true,
+                sender,
+                /*enhanced_keys_supported*/ true,
+                "Ask Codex to do anything".to_string(),
+                /*disable_paste_burst*/ false,
+            );
+            composer.set_collaboration_mode_indicator(mode);
+            composer.set_text_content("abcdefg|".to_string(), Vec::new(), Vec::new());
+            composer
+                .draft
+                .textarea
+                .set_cursor(composer.draft.textarea.text().len());
+
+            let mut terminal = Terminal::new(TestBackend::new(12, 5)).unwrap();
+            terminal
+                .draw(|f| composer.render(f.area(), f.buffer_mut()))
+                .unwrap();
+
+            let buf = terminal.backend().buffer();
+            let row = (0..12)
+                .map(|x| buf[(x, 1)].symbol().chars().next().unwrap_or(' '))
+                .collect::<String>();
+            assert!(
+                row.contains("abcdefg|"),
+                "expected trailing text to stay visible, saw row {row:?}",
+            );
+            assert!(composer.cursor_pos(Rect::new(0, 0, 12, 5)).is_some());
+            assert_eq!(buf[(11, 2)].symbol(), " ");
+            assert_eq!(buf[(11, 3)].symbol(), "─");
+        }
+    }
