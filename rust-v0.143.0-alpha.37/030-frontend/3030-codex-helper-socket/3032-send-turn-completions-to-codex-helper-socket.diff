+fn completion_payload(
+    notification: &TurnCompletedNotification,
+    working_dir: &Path,
+    created_at: chrono::DateTime<chrono::Utc>,
+) -> Option<CompletionPayload> {
+    if notification.turn.status != TurnStatus::Completed {
+        return None;
+    }
+    let session_id = Uuid::parse_str(&notification.thread_id).ok()?.to_string();
+    let turn_id = positive_turn_id(&notification.turn.id);
+    let duration_ms = notification
+        .turn
+        .duration_ms
+        .and_then(|duration_ms| u64::try_from(duration_ms).ok())
+        .unwrap_or_default();
+
+    Some(CompletionPayload {
+        kind: "Completion",
+        source: "codex",
+        session_id: session_id.clone(),
+        turn_id,
+        status: "Completed",
+        duration_ms,
+        working_dir: working_dir.display().to_string(),
+        title: "Codex task finished".to_string(),
+        body: format!(
+            "Thread {session_id} turn {} completed.",
+            notification.turn.id
+        ),
+        created_at: created_at.to_rfc3339_opts(chrono::SecondsFormat::Secs, true),
+    })
+}
+
+fn positive_turn_id(turn_id: &str) -> u64 {
+    if let Ok(parsed) = turn_id.parse::<u64>()
+        && parsed > 0
+    {
+        return parsed;
+    }
+    if let Some(parsed) = trailing_positive_number(turn_id) {
+        return parsed;
+    }
+    let mut hasher = DefaultHasher::new();
+    turn_id.hash(&mut hasher);
+    (hasher.finish() % (i64::MAX as u64)).max(1)
+}
+
+fn trailing_positive_number(value: &str) -> Option<u64> {
+    let digits = value
+        .chars()
+        .rev()
+        .take_while(|ch| ch.is_ascii_digit())
+        .collect::<Vec<_>>();
+    if digits.is_empty() {
+        return None;
+    }
+    let number = digits.into_iter().rev().collect::<String>();
+    number.parse::<u64>().ok().filter(|number| *number > 0)
+}
