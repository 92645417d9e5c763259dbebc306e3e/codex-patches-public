+//! Local model-name colors for TUI personalization.
+
+#![allow(clippy::disallowed_methods)]
+
+use ratatui::style::Color;
+use ratatui::style::Style;
+
+const MODEL_COLORS: [Color; 5] = [
+    Color::Rgb(89, 169, 255),
+    Color::Rgb(45, 212, 191),
+    Color::Rgb(74, 222, 128),
+    Color::Rgb(167, 139, 250),
+    Color::Rgb(148, 163, 184),
+];
+
+pub(crate) fn model_style(model: &str) -> Style {
+    Style::default().fg(model_color(model))
+}
+
+fn model_color(model: &str) -> Color {
+    let idx = model
+        .bytes()
+        .enumerate()
+        .fold(0_u64, |acc, (idx, byte)| {
+            acc.wrapping_mul(131)
+                .wrapping_add(u64::from(byte))
+                .wrapping_add((idx as u64 + 1) * 17)
+        }) as usize
+        % MODEL_COLORS.len();
+    MODEL_COLORS[idx]
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+
+    #[test]
+    fn model_color_is_stable_for_common_names() {
+        for model in ["gpt-5", "gpt-5-mini", "gpt-5-codex", "o3", "o4-mini"] {
+            assert_eq!(model_style(model), model_style(model));
+        }
+    }
+
+    #[test]
+    fn common_model_names_spread_across_palette() {
+        let colors: std::collections::HashSet<_> = [
+            "gpt-5.4",
+            "gpt-5.5",
+            "gpt-5.4-mini",
+            "gpt-5.3-codex",
+            "gpt-5.2",
+        ]
+            .iter()
+            .map(|model| model_style(model).fg)
+            .collect();
+
+        assert!(
+            colors.len() >= 4,
+            "common model names should spread across most of the palette"
+        );
+    }
+
+    #[test]
+    fn unknown_model_color_is_deterministic() {
+        assert_eq!(model_style("future-model"), model_style("future-model"));
+    }
+}
