+                if ws_stream.send(Message::Pong(payload)).await.is_err() {
+                    return None;
+                }
+            }
+            Message::Pong(_) => {}
+            Message::Close(_) => return None,
+            message => {
+                if let Some(body) = parse_ws_request_body(message) {
+                    return Some(body);
+                }
+            }
+        }
+    }
