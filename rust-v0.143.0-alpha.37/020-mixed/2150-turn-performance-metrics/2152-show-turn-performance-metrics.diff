+                if previous.info.is_none()
+                    && previous.rate_limits.is_none()
+                    && previous.response_metrics.is_some()
+                    && next.response_metrics.is_none()
+                    && (next.info.is_some() || next.rate_limits.is_some()) =>
+            {
+                let mut merged = next.clone();
+                merged.response_metrics = previous.response_metrics.clone();
+                *previous = merged;
+            }
+            _ => events.push(event.clone()),
+        }
+    }
+    events
