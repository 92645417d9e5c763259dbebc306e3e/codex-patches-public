+    fn reconcile_reasoning_item_in_turn_id(
+        &mut self,
+        turn_id: &str,
+        reasoning: &codex_protocol::items::ReasoningItem,
+    ) {
+        let reconcile = |items: &mut Vec<ThreadItem>| -> Option<ThreadItem> {
+            if let Some(ThreadItem::Reasoning {
+                id,
+                summary,
+                content,
+                continued,
+                reasoning_output_tokens,
+            }) = items.last_mut()
+                && *summary == reasoning.summary_text
+                && *content == reasoning.raw_content
+            {
+                *id = reasoning.id.clone();
+                *continued = reasoning.continued;
+                *reasoning_output_tokens = reasoning.reasoning_output_tokens;
+                return items.last().cloned();
+            }
+            None
+        };
+
+        let tracking_changes = self.is_tracking_changes();
+        if let Some(turn) = self.current_turn.as_mut()
+            && turn.id == turn_id
+        {
+            let changed_item = reconcile(&mut turn.items)
+                .and_then(|item| tracking_changes.then_some((turn.id.clone(), item)));
+            if let Some((turn_id, item)) = changed_item {
+                self.record_changed_item(turn_id, item);
+            }
+            return;
+        }
+
+        if let Some(turn) = self.turns.iter_mut().find(|turn| turn.id == turn_id) {
+            let changed_item = reconcile(&mut turn.items)
+                .and_then(|item| tracking_changes.then_some((turn.id.clone(), item)));
+            if let Some((turn_id, item)) = changed_item {
+                self.record_changed_item(turn_id, item);
+            }
+        }
+    }
