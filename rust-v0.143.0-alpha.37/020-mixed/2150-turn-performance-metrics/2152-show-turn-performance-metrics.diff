+        model: "test-model".to_string(),
+        model_provider_id: "test-provider".to_string(),
+        service_tier: None,
+        approval_policy: AskForApproval::Never,
+        approvals_reviewer: ApprovalsReviewer::User,
+        permission_profile: PermissionProfile::read_only(),
+        active_permission_profile: None,
+        cwd: test_project_path().abs(),
+        runtime_workspace_roots: Vec::new(),
+        instruction_source_paths: Vec::new(),
+        reasoning_effort: None,
+        collaboration_mode: None,
+        personality: None,
+        message_history: None,
+        network_proxy: None,
+        rollout_path: None,
+    });
+    let _ = drain_insert_history(&mut rx);
+
+    let turns = codex_app_server_protocol::build_turns_from_rollout_items(&[
+        codex_protocol::protocol::RolloutItem::EventMsg(
+            codex_protocol::protocol::EventMsg::TurnStarted(
+                codex_protocol::protocol::TurnStartedEvent {
+                    turn_id: "turn-1".into(),
+                    trace_id: None,
+                    started_at: None,
+                    model_context_window: None,
+                    collaboration_mode_kind: Default::default(),
+                },
+            ),
+        ),
+        codex_protocol::protocol::RolloutItem::EventMsg(
+            codex_protocol::protocol::EventMsg::AgentReasoning(
+                codex_protocol::protocol::AgentReasoningEvent {
+                    text: "Summary only".into(),
+                    continued: true,
+                },
+            ),
+        ),
+        codex_protocol::protocol::RolloutItem::EventMsg(
+            codex_protocol::protocol::EventMsg::ItemCompleted(
+                codex_protocol::protocol::ItemCompletedEvent {
+                    thread_id: ThreadId::new(),
+                    turn_id: "turn-1".into(),
+                    item: codex_protocol::items::TurnItem::Reasoning(
+                        codex_protocol::items::ReasoningItem {
+                            id: "reasoning-1".into(),
+                            summary_text: vec!["Summary only".into()],
+                            raw_content: Vec::new(),
+                            continued: true,
+                            reasoning_output_tokens: Some(516),
+                        },
+                    ),
+                    completed_at_ms: 0,
+                },
+            ),
