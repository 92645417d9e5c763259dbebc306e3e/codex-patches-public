+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn truncated_encrypted_reasoning_continues_at_most_five_rounds() -> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = MockServer::start().await;
+    let mut responses = Vec::new();
+    for index in 1..=6 {
+        let response_id = format!("resp-{index}");
+        let reasoning_id = format!("rs-{index}");
+        let mut events = vec![
+            ev_response_created(&response_id),
+            ev_reasoning_item(&reasoning_id, &["thinking"], &["raw"]),
+        ];
+        if index == 6 {
+            events.push(ev_assistant_message("msg-6", "done"));
+        }
+        events.push(json!({
+            "type": "response.completed",
+            "response": {
+                "id": response_id,
+                "usage": {
+                    "input_tokens": 10,
+                    "input_tokens_details": null,
+                    "output_tokens": 520,
+                    "output_tokens_details": { "reasoning_tokens": 516 },
+                    "total_tokens": 530
+                }
+            }
+        }));
+        responses.push(sse(events));
+    }
+    let response_mock = mount_sse_sequence(&server, responses).await;
+    let test = test_codex().build(&server).await?;
+
+    test.submit_turn("hello").await?;
+
+    assert_eq!(
+        response_mock.requests().len(),
+        6,
+        "five hidden continuation rounds plus one accepted cap-hit round"
+    );
+
+    test.codex.ensure_rollout_materialized().await;
+    test.codex.flush_rollout().await?;
+    let rollout_path = test.codex.rollout_path().expect("rollout path");
+    let rollout_text = std::fs::read_to_string(&rollout_path)?;
+    assert!(
+        rollout_text.lines().any(|line| {
+            serde_json::from_str::<RolloutLine>(line)
+                .ok()
+                .and_then(|line| match line.item {
+                    RolloutItem::EventMsg(EventMsg::AgentReasoning(event)) => {
+                        Some(event.continuation_limit_hit)
+                    }
+                    _ => None,
+                })
+                .unwrap_or(false)
+        }),
+        "accepted cap-hit reasoning item should be marked for distinct rendering"
+    );
+
+    Ok(())
+}
