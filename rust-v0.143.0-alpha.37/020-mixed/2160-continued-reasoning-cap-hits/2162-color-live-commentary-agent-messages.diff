+#[derive(Clone, Copy, Debug, Default, Eq, PartialEq)]
+pub(crate) enum AgentMessageStyle {
+    #[default]
+    Normal,
+    Commentary,
+}
+
+impl AgentMessageStyle {
+    fn apply_to_hyperlink_lines(
+        lines: Vec<HyperlinkLine>,
+        message_style: Self,
+    ) -> Vec<HyperlinkLine> {
+        match message_style {
+            Self::Normal => lines,
+            Self::Commentary => lines
+                .into_iter()
+                .map(|mut line| {
+                    line.line = Self::apply_to_line(line.line);
+                    line
+                })
+                .collect(),
+        }
+    }
+
+    fn apply_to_line(mut line: Line<'static>) -> Line<'static> {
+        let style = Self::commentary_style();
+        line.style = line.style.patch(style);
+        line.spans = line
+            .spans
+            .into_iter()
+            .map(|span| Span::styled(span.content, span.style.patch(style)))
+            .collect();
+        line
+    }
+
+    fn commentary_style() -> Style {
+        Style::default().fg(Color::Rgb(192, 160, 0))
+    }
+}
