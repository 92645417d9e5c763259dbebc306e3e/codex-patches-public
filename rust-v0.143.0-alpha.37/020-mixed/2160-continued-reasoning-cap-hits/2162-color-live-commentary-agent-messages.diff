+fn live_agent_lines(
+    chat: &mut ChatWidget,
+    rx: &mut tokio::sync::mpsc::UnboundedReceiver<AppEvent>,
+) -> Vec<ratatui::text::Line<'static>> {
+    let mut lines = drain_insert_history(rx)
+        .into_iter()
+        .flatten()
+        .collect::<Vec<_>>();
+    if lines.is_empty() {
+        chat.run_commit_tick();
+        lines.extend(drain_insert_history(rx).into_iter().flatten());
+    }
+    if lines.is_empty()
+        && let Some(cell) = chat.transcript.active_cell.as_ref()
+    {
+        lines.extend(cell.display_lines(/*width*/ 80));
+    }
+    lines
+}
