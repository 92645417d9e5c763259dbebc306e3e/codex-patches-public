+                ev_completed("resp-2"),
+            ]),
+        ],
+    )
+    .await;
+    let test = test_codex().build(&server).await.unwrap();
+
+    test.submit_turn("hello").await.unwrap();
+
+    let requests = response_mock.requests();
+    assert_eq!(requests.len(), 2);
+    let second = requests[1].body_json();
+    assert!(
+        !json_contains_truthy_continuation_hidden(&second),
+        "outbound OpenAI continuation request must strip local-only continuation_hidden metadata: {second}"
+    );
+
+    test.codex.ensure_rollout_materialized().await;
+    test.codex.flush_rollout().await.unwrap();
+    let rollout_path = test.codex.rollout_path().expect("rollout path");
+    let rollout_text = std::fs::read_to_string(&rollout_path).unwrap();
+    let mut hidden_raw_ids = Vec::new();
+    let mut model_history_ids = Vec::new();
+    for line in rollout_text.lines() {
+        let Ok(line) = serde_json::from_str::<RolloutLine>(line) else {
+            continue;
+        };
+        match line.item {
+            RolloutItem::EventMsg(EventMsg::RawResponseItem(raw)) if raw.continuation_hidden => {
+                if let Some(id) = raw.item.id() {
+                    hidden_raw_ids.push(id.to_string());
+                }
+            }
+            RolloutItem::ResponseItem(item) => {
+                if let Some(id) = item.id() {
+                    model_history_ids.push(id.to_string());
+                }
+            }
+            _ => {}
+        }
+    }
+    assert!(
+        hidden_raw_ids.iter().any(|id| id == "rs-1")
+            && hidden_raw_ids.iter().any(|id| id == "msg-1"),
+        "hidden-round artifacts should be recorded once as local raw events: {hidden_raw_ids:?}"
+    );
+    assert!(
+        !model_history_ids
+            .iter()
+            .any(|id| id == "rs-1" || id == "msg-1"),
+        "hidden-round artifacts must not be prompt-history response_items: {model_history_ids:?}"
+    );
+}
+
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn truncated_encrypted_reasoning_round_does_not_execute_tool_after_reasoning_starts()
+-> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = MockServer::start().await;
+    let response_mock = mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-1"),
+                ev_reasoning_item_added("rs-1", &[]),
+                core_test_support::responses::ev_reasoning_summary_text_delta(
+                    "**Planning next step**\n\nStill thinking",
+                ),
+                ev_function_call(
+                    "call-update-plan",
+                    "update_plan",
+                    r#"{"plan":[{"step":"keep thinking","status":"in_progress"}]}"#,
+                ),
+                ev_reasoning_item("rs-1", &["**Planning next step**\n\nStill thinking"], &[]),
+                json!({
+                    "type": "response.completed",
+                    "response": {
+                        "id": "resp-1",
+                        "usage": {
+                            "input_tokens": 10,
+                            "input_tokens_details": null,
+                            "output_tokens": 520,
+                            "output_tokens_details": { "reasoning_tokens": 516 },
+                            "total_tokens": 530
+                        }
+                    }
+                }),
+            ]),
+            sse(vec![
+                ev_response_created("resp-2"),
+                ev_assistant_message("msg-2", "done"),
+                ev_completed("resp-2"),
+            ]),
+        ],
+    )
+    .await;
+    let test = test_codex().build(&server).await.unwrap();
+
+    test.submit_turn("hello").await?;
+
+    let requests = response_mock.requests();
+    assert_eq!(requests.len(), 2);
+    let second = requests[1].body_json();
+    let second_input = second["input"]
+        .as_array()
+        .expect("second request should include continuation input");
+    assert!(second_input.iter().all(|item| {
+        item.get("type").and_then(serde_json::Value::as_str) != Some("function_call")
+    }));
+
+    test.codex.ensure_rollout_materialized().await;
+    test.codex.flush_rollout().await?;
+    let rollout_path = test.codex.rollout_path().expect("rollout path");
+    let rollout_text = std::fs::read_to_string(&rollout_path)?;
+    let hidden_tool_recorded = rollout_text.lines().any(|line| {
+        serde_json::from_str::<RolloutLine>(line)
+            .ok()
+            .and_then(|line| match line.item {
+                RolloutItem::EventMsg(EventMsg::RawResponseItem(raw))
+                    if raw.continuation_hidden =>
+                {
+                    match raw.item {
+                        ResponseItem::FunctionCall { name, .. } => Some(name == "update_plan"),
+                        _ => Some(false),
+                    }
+                }
+                _ => None,
+            })
+            .unwrap_or(false)
+    });
+    assert!(
+        hidden_tool_recorded,
+        "hidden-round tool proposal should still be recorded in rollout"
+    );
+    assert!(
+        !rollout_text.contains("\"type\":\"plan_update\""),
+        "hidden-round update_plan tool call must not execute"
     );
+    assert!(
+        !rollout_text.contains("\"type\":\"function_call_output\""),
+        "hidden-round tool call must not emit tool output"
+    );
+    assert!(
+        !rollout_text.lines().any(|line| {
+            serde_json::from_str::<RolloutLine>(line)
+                .ok()
+                .and_then(|line| match line.item {
+                    RolloutItem::ResponseItem(ResponseItem::FunctionCall { name, .. }) => {
+                        Some(name == "update_plan")
+                    }
+                    _ => None,
+                })
+                .unwrap_or(false)
+        }),
+        "hidden-round tool proposal must not be prompt-history response_item"
+    );
+
+    Ok(())
 }
 
