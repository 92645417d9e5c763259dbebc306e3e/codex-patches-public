+#[tokio::test]
+async fn context_boundary_refresh_uses_latest_instruction_overlay() {
+    let (session, turn_context) = make_session_and_context().await;
+    let overlay_dir = turn_context.config.codex_home.join("instructions");
+    std::fs::create_dir_all(&overlay_dir).expect("create instructions overlay dir");
+    std::fs::write(
+        overlay_dir.join(format!("{}.md", turn_context.collaboration_mode.model())),
+        "fresh model instructions",
+    )
+    .expect("write instructions overlay file");
+
+    session
+        .refresh_base_instructions_for_context_boundary(&turn_context)
+        .await;
+
+    assert_eq!(
+        session.get_base_instructions().await.text,
+        "fresh model instructions"
+    );
+}
+
+#[tokio::test]
+async fn context_boundary_refresh_uses_latest_global_agents_md() {
+    let (session, turn_context) = make_session_and_context().await;
+    let session = Arc::new(session);
+    let turn_context = Arc::new(turn_context);
+    let global_agents = turn_context.config.codex_home.join("AGENTS.md");
+    std::fs::create_dir_all(turn_context.config.codex_home.as_path()).expect("create codex home");
+    std::fs::write(&global_agents, "first global instructions")
+        .expect("write first global AGENTS.md");
+    let first_world_state = session
+        .refresh_context_boundary_inputs(Arc::clone(&turn_context))
+        .await;
+    let first_items = session
+        .build_initial_context_with_world_state(turn_context.as_ref(), first_world_state.as_ref())
+        .await;
+    let first_text = user_input_texts(&first_items).join("\n");
+    assert!(first_text.contains("first global instructions"));
+
+    std::fs::write(&global_agents, "second global instructions")
+        .expect("write second global AGENTS.md");
+    let second_world_state = session
+        .refresh_context_boundary_inputs(Arc::clone(&turn_context))
+        .await;
+    let second_items = session
+        .build_initial_context_with_world_state(turn_context.as_ref(), second_world_state.as_ref())
+        .await;
+    let second_text = user_input_texts(&second_items).join("\n");
+    assert!(second_text.contains("second global instructions"));
+    assert!(!second_text.contains("first global instructions"));
+}
