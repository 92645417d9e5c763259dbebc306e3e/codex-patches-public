+#[tokio::test]
+async fn plugin_list_background_tasks_do_not_create_tmp_when_feature_disabled() {
+    let tmp = tempfile::tempdir().unwrap();
+    write_file(
+        &tmp.path().join(CONFIG_TOML_FILE),
+        r#"[features]
+plugins = false
+"#,
+    );
+
+    let config = load_config(tmp.path(), tmp.path()).await;
+    let manager = std::sync::Arc::new(PluginsManager::new(tmp.path().to_path_buf()));
+    manager.maybe_start_plugin_list_background_tasks_for_config(
+        &config,
+        /*auth*/ None,
+        &[tmp.path().abs()],
+        PluginListBackgroundTaskOptions::default(),
+        /*on_effective_plugins_changed*/ None,
+    );
+    tokio::time::sleep(Duration::from_millis(50)).await;
+
+    assert!(!tmp.path().join(".tmp").exists());
+}
