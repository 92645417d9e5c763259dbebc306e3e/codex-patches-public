+#[tokio::test]
+async fn disabled_memories_state_db_does_not_create_placeholder_file() -> anyhow::Result<()> {
+    let home = TempDir::new().expect("temp dir");
+    let config = RolloutConfig {
+        codex_home: home.path().to_path_buf(),
+        sqlite_home: home.path().to_path_buf(),
+        cwd: home.path().to_path_buf(),
+        model_provider_id: "test-provider".to_string(),
+        generate_memories: false,
+    };
+
+    let _runtime = try_init(&config).await?;
+
+    assert!(codex_state::state_db_path(home.path()).is_file());
+    assert!(codex_state::logs_db_path(home.path()).is_file());
+    assert!(codex_state::goals_db_path(home.path()).is_file());
+    assert!(!codex_state::memories_db_path(home.path()).exists());
+
+    Ok(())
+}
