+async fn open_optional_sqlite(
+    path: &Path,
+    migrator: &Migrator,
+    spec: RuntimeDbSpec,
+    create_if_missing: bool,
+    telemetry_override: Option<&dyn DbTelemetry>,
+) -> anyhow::Result<SqlitePool> {
+    if create_if_missing || tokio::fs::try_exists(path).await? {
+        return open_sqlite(path, migrator, spec, telemetry_override).await;
+    }
+
+    let options = SqliteConnectOptions::new()
+        .in_memory(true)
+        .create_if_missing(true)
+        .log_statements(LevelFilter::Off);
+    open_sqlite_with_options(
+        options,
+        /*max_connections*/ 1,
+        migrator,
+        spec,
+        telemetry_override,
+    )
+    .await
+}
