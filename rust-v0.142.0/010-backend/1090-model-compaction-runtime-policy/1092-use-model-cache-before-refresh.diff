+async fn fetch_and_update_models_inner(
+    endpoint_client: SharedModelsEndpointClient,
+    cache_manager: ModelsCacheManager,
+    remote_models: Arc<RwLock<Vec<ModelInfo>>>,
+    etag_store: Arc<RwLock<Option<String>>>,
+    auth_manager: Option<Arc<AuthManager>>,
+) -> CoreResult<()> {
+    let client_version = crate::client_version_to_whole();
+    let (models, etag) = endpoint_client.list_models(&client_version).await?;
+    apply_remote_models_to(&remote_models, auth_manager.as_ref(), models.clone()).await;
+    *etag_store.write().await = etag.clone();
+    cache_manager
+        .persist_cache(&models, etag, client_version)
+        .await;
+    Ok(())
+}
+
+async fn apply_remote_models_to(
+    remote_models: &RwLock<Vec<ModelInfo>>,
+    auth_manager: Option<&Arc<AuthManager>>,
+    models: Vec<ModelInfo>,
+) {
+    // Use the remote models list as the source of truth if it contains at least one
+    // non-hidden model and the user is using ChatGPT auth.
+    let should_use_remote_models_only = !models.is_empty()
+        && models
+            .iter()
+            .any(|model| model.visibility == ModelVisibility::List)
+        && auth_manager.is_some_and(|auth_manager| {
+            auth_manager
+                .auth_mode()
+                .is_some_and(AuthMode::has_chatgpt_account)
+        });
+    if should_use_remote_models_only {
+        *remote_models.write().await = models;
+        return;
+    }
+
+    let mut existing_models = load_remote_models_from_file().unwrap_or_default();
+    for model in models {
+        if let Some(existing_index) = existing_models
+            .iter()
+            .position(|existing| existing.slug == model.slug)
+        {
+            existing_models[existing_index] = model;
+        } else {
+            existing_models.push(model);
+        }
+    }
+    *remote_models.write().await = existing_models;
 }
 
