+pub fn with_chat_completions_models(mut models: Vec<ModelInfo>) -> Vec<ModelInfo> {
+    models.retain(|model| !is_obsolete_chat_completions_model(&model.slug));
+    for model in chat_completions_models() {
+        if let Some(index) = models
+            .iter()
+            .position(|existing| existing.slug == model.slug)
+        {
+            models[index] = model;
+        } else {
+            models.push(model);
+        }
+    }
+    models
+}
+
+pub fn chat_completions_model_info(slug: &str) -> Option<ModelInfo> {
+    chat_completions_models()
+        .into_iter()
+        .find(|model| model.slug == slug)
+}
