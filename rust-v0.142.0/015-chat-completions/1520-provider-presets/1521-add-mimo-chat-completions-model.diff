+#[test]
+fn chat_completions_models_use_shared_backend_limits() {
+    let model =
+        chat_completions_model_info("mimo-v2.5").expect("Chat Completions model should exist");
+
+    assert_eq!(model.context_window, Some(384_000));
+    assert_eq!(model.max_context_window, Some(384_000));
+    assert_eq!(
+        model.auto_review_model_override.as_deref(),
+        Some("mimo-v2.5")
+    );
+    assert_eq!(model.input_modalities, vec![InputModality::Text]);
+    assert!(!model.supports_search_tool);
+    assert!(!model.supports_image_detail_original);
+    assert!(!model.supports_parallel_tool_calls);
+}
+
+#[test]
+fn chat_completions_models_replace_obsolete_api_model_entries() {
+    let mut obsolete = model_info_from_slug("mimo-v2.5-pro");
+    obsolete.slug = "mimo-v2.5-pro".to_string();
+    let models = with_chat_completions_models(vec![obsolete]);
+
+    assert!(models.iter().any(|model| model.slug == "mimo-v2.5"));
+    assert!(!models.iter().any(|model| model.slug == "mimo-v2.5-pro"));
+}
