+#[cfg(not(target_os = "android"))]
+fn clipboard_temp_dir() -> PathBuf {
+    std::env::temp_dir()
+        .join(CLIPBOARD_TEMP_ROOT)
+        .join(CLIPBOARD_TEMP_DIR)
+}
+
+#[cfg(not(target_os = "android"))]
+fn write_clipboard_png_to_temp(png: &[u8]) -> Result<PathBuf, PasteImageError> {
+    let temp_dir = clipboard_temp_dir();
+    std::fs::create_dir_all(&temp_dir).map_err(|e| PasteImageError::IoError(e.to_string()))?;
+    let tmp = Builder::new()
+        .prefix("codex-clipboard-")
+        .suffix(".png")
+        .tempfile_in(&temp_dir)
+        .map_err(|e| PasteImageError::IoError(e.to_string()))?;
+    std::fs::write(tmp.path(), png).map_err(|e| PasteImageError::IoError(e.to_string()))?;
+    let (_file, path) = tmp
+        .keep()
+        .map_err(|e| PasteImageError::IoError(e.error.to_string()))?;
+    Ok(path)
+}
+
+#[cfg(all(test, not(target_os = "android")))]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn clipboard_png_temp_file_uses_codex_clipboard_dir() {
+        let path = write_clipboard_png_to_temp(b"png").expect("write clipboard png");
+
+        assert_eq!(path.parent(), Some(clipboard_temp_dir().as_path()));
+        assert!(
+            path.file_name()
+                .and_then(|name| name.to_str())
+                .is_some_and(|name| name.starts_with("codex-clipboard-") && name.ends_with(".png"))
+        );
+        assert_eq!(std::fs::read(&path).expect("read clipboard png"), b"png");
+
+        std::fs::remove_file(&path).expect("remove clipboard png");
+    }
+}
