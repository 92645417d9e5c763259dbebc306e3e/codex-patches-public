+fn visual_row_idx(rows: &[Row], row_idx: usize) -> usize {
+    row_idx + pinned_group_boundaries_before(rows, row_idx)
+}
+
+fn pinned_group_boundaries_before(rows: &[Row], row_idx: usize) -> usize {
+    if row_idx == 0 {
+        return 0;
+    }
+    (1..=row_idx)
+        .filter(|&idx| is_pinned_group_boundary(rows, idx))
+        .count()
+}
+
+fn pinned_group_boundaries_between(rows: &[Row], start: usize, end_inclusive: usize) -> usize {
+    if start >= end_inclusive {
+        return 0;
+    }
+    (start.saturating_add(1)..=end_inclusive)
+        .filter(|&idx| is_pinned_group_boundary(rows, idx))
+        .count()
+}
+
+fn is_pinned_group_boundary(rows: &[Row], row_idx: usize) -> bool {
+    row_idx > 0
+        && rows
+            .get(row_idx - 1)
+            .zip(rows.get(row_idx))
+            .is_some_and(|(previous, current)| previous.pinned && !current.pinned)
+}
