+#[derive(Deserialize)]
+struct PinnedRenamedSessionEntry {
+    id: ThreadId,
+    thread_name: String,
+    updated_at: String,
+}
+
+async fn load_pinned_renamed_rows(
+    app_server: &mut AppServerSession,
+    codex_home: &Path,
+    provider_filter: &ProviderFilter,
+    include_non_interactive: bool,
+) -> Vec<Row> {
+    let entries = load_pinned_renamed_entries(codex_home).await;
+    let mut rows = Vec::with_capacity(entries.len());
+    for (thread_id, _) in entries {
+        let Ok(thread) = app_server
+            .thread_read(thread_id, /*include_turns*/ false)
+            .await
+        else {
+            continue;
+        };
+        if !thread_matches_provider_filter(&thread, provider_filter)
+            || !thread_matches_resume_source_filter(&thread, include_non_interactive)
+        {
+            continue;
+        }
+        if let Some(row) = row_from_app_server_thread(thread) {
+            rows.push(row);
+        }
+    }
+    rows
+}
+
+async fn load_pinned_renamed_entries(codex_home: &Path) -> Vec<(ThreadId, DateTime<Utc>)> {
+    let path = codex_home.join(SESSION_INDEX_FILE);
+    let Ok(contents) = tokio::fs::read_to_string(path).await else {
+        return Vec::new();
+    };
+    let mut latest_by_id: HashMap<ThreadId, DateTime<Utc>> = HashMap::new();
+    for line in contents.lines() {
+        let trimmed = line.trim();
+        if trimmed.is_empty() {
+            continue;
+        }
+        let Ok(entry) = serde_json::from_str::<PinnedRenamedSessionEntry>(trimmed) else {
+            continue;
+        };
+        if entry.thread_name.trim().is_empty() {
+            continue;
+        }
+        let Ok(updated_at) = chrono::DateTime::parse_from_rfc3339(&entry.updated_at) else {
+            continue;
+        };
+        let updated_at = updated_at.with_timezone(&Utc);
+        latest_by_id
+            .entry(entry.id)
+            .and_modify(|current| {
+                if updated_at > *current {
+                    *current = updated_at;
+                }
+            })
+            .or_insert(updated_at);
+    }
+
+    let mut entries = latest_by_id.into_iter().collect::<Vec<_>>();
+    entries.sort_by(|(_, left), (_, right)| right.cmp(left));
+    entries.truncate(PINNED_RENAMED_SESSION_LIMIT);
+    entries
+}
+
+fn thread_matches_provider_filter(thread: &Thread, provider_filter: &ProviderFilter) -> bool {
+    match provider_filter {
+        ProviderFilter::Any => true,
+        ProviderFilter::MatchDefault(default_provider) => {
+            thread.model_provider == *default_provider
+        }
+    }
+}
+
+fn thread_matches_resume_source_filter(thread: &Thread, include_non_interactive: bool) -> bool {
+    crate::resume_source_kinds(include_non_interactive)
+        .iter()
+        .any(|kind| thread_source_matches_kind(&thread.source, *kind))
+}
+
+fn thread_source_matches_kind(source: &SessionSource, kind: ThreadSourceKind) -> bool {
+    match kind {
+        ThreadSourceKind::Cli => matches!(source, SessionSource::Cli),
+        ThreadSourceKind::VsCode => matches!(source, SessionSource::VsCode),
+        ThreadSourceKind::Exec => matches!(source, SessionSource::Exec),
+        ThreadSourceKind::AppServer => matches!(source, SessionSource::AppServer),
+        ThreadSourceKind::SubAgent => matches!(source, SessionSource::SubAgent(_)),
+        ThreadSourceKind::SubAgentReview
+        | ThreadSourceKind::SubAgentCompact
+        | ThreadSourceKind::SubAgentThreadSpawn
+        | ThreadSourceKind::SubAgentOther => false,
+        ThreadSourceKind::Unknown => matches!(source, SessionSource::Unknown),
+    }
+}
