+        for mode in [None, Some(CollaborationModeIndicator::Plan)] {
+            let (tx, _rx) = unbounded_channel::<AppEvent>();
+            let sender = AppEventSender::new(tx);
+            let mut composer = ChatComposer::new(
+                /*has_input_focus*/ true,
+                sender,
+                /*enhanced_keys_supported*/ true,
+                "Ask Codex to do anything".to_string(),
+                /*disable_paste_burst*/ false,
+            );
+            composer.set_collaboration_mode_indicator(mode);
+            composer.set_text_content("abcdefg|".to_string(), Vec::new(), Vec::new());
+            composer
+                .draft
+                .textarea
+                .set_cursor(composer.draft.textarea.text().len());
+
+            let mut terminal = Terminal::new(TestBackend::new(12, 5)).unwrap();
+            terminal
+                .draw(|f| composer.render(f.area(), f.buffer_mut()))
+                .unwrap();
+
+            let buf = terminal.backend().buffer();
+            assert_eq!(buf[(9, 1)].symbol(), "|");
+            assert_eq!(composer.cursor_pos(Rect::new(0, 0, 12, 5)), Some((10, 1)));
+            assert_eq!(buf[(10, 1)].symbol(), " ");
+            assert_eq!(buf[(11, 1)].symbol(), "│");
+            assert_eq!(buf[(11, 2)].symbol(), "│");
+            assert_eq!(buf[(11, 3)].symbol(), "┘");
+        }
+    }
