+
+        let mut terminal = Terminal::new(TestBackend::new(48, 6)).unwrap();
+        terminal
+            .draw(|f| composer.render(f.area(), f.buffer_mut()))
+            .unwrap();
+
+        let buf = terminal.backend().buffer();
+        assert_eq!(buf[(0, 0)].symbol(), "┌");
+        assert_eq!(buf[(0, 0)].style().fg, Some(Color::Reset));
+        assert_eq!(buf[(47, 0)].symbol(), "┐");
+        assert_eq!(buf[(47, 0)].style().fg, Some(Color::Reset));
+        insta::assert_snapshot!("composer_normal_mode_input_border", terminal.backend());
+    }
