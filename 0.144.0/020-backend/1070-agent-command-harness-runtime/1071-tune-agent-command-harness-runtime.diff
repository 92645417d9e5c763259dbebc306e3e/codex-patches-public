+async fn wait_for_received_requests(
+    server: &MockServer,
+    expected_len: usize,
+    predicate: impl Fn(&wiremock::Request) -> bool,
+) -> Result<Vec<wiremock::Request>> {
+    let deadline = Instant::now() + Duration::from_secs(10);
+    loop {
+        let all_requests = server.received_requests().await.unwrap_or_default();
+        let requests = all_requests
+            .iter()
+            .filter(|request| predicate(request))
+            .cloned()
+            .collect::<Vec<_>>();
+        if requests.len() >= expected_len {
+            return Ok(requests);
+        }
+        if Instant::now() >= deadline {
+            anyhow::bail!(
+                "expected at least {expected_len} matching requests, got {}; total captured {}",
+                requests.len(),
+                all_requests.len()
+            );
+        }
+        sleep(Duration::from_millis(10)).await;
+    }
+}
