+#[tokio::test]
+async fn disabled_feedback_logs_state_db_uses_in_memory_logs() -> anyhow::Result<()> {
+    let home = TempDir::new().expect("temp dir");
+    let config = DisabledFeedbackLogsConfig {
+        inner: RolloutConfig {
+            codex_home: home.path().to_path_buf(),
+            sqlite_home: home.path().to_path_buf(),
+            cwd: home.path().to_path_buf(),
+            model_provider_id: "test-provider".to_string(),
+            use_goals: true,
+            generate_memories: true,
+        },
+    };
+
+    let runtime = try_init(&config).await?;
+    runtime
+        .insert_log(&codex_state::LogEntry {
+            ts: 1,
+            ts_nanos: 0,
+            level: "INFO".to_string(),
+            target: "test".to_string(),
+            message: None,
+            feedback_log_body: Some("kept in memory".to_string()),
+            thread_id: Some("thread-1".to_string()),
+            process_uuid: Some("process-1".to_string()),
+            module_path: None,
+            file: None,
+            line: None,
+        })
+        .await?;
+
+    assert!(codex_state::state_db_path(home.path()).is_file());
+    assert!(!codex_state::logs_db_path(home.path()).exists());
+    assert!(codex_state::goals_db_path(home.path()).is_file());
+    assert!(codex_state::memories_db_path(home.path()).is_file());
+
+    Ok(())
+}
