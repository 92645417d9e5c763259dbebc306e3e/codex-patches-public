+#[tokio::test]
+async fn thread_settings_updated_syncs_model_provider_metadata() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(Some("gpt-5.3-codex")).await;
+    let thread_id = ThreadId::new();
+    chat.handle_thread_session(configured_thread_session(thread_id));
+
+    let mut side_route_provider = chat.config.model_provider.clone();
+    side_route_provider.requires_openai_auth = false;
+    chat.config
+        .model_providers
+        .insert("side-route".to_string(), side_route_provider);
+
+    chat.handle_server_notification(
+        ServerNotification::ThreadSettingsUpdated(thread_settings_for_test_with_provider(
+            "gpt-5",
+            thread_id,
+            "side-route",
+        )),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(chat.config_ref().model_provider_id, "side-route");
+    assert!(!chat.config_ref().model_provider.requires_openai_auth);
+}
