+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn continued_round_hides_visible_output_and_aggregates_reasoning_metrics()
+-> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+    let server = MockServer::start().await;
+
+    mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-1"),
+                ev_reasoning_item("rs-1", &["thinking"], &[]),
+                ev_assistant_message("msg-1", "wrong"),
+                json!({
+                    "type": "response.completed",
+                    "response": {
+                        "id": "resp-1",
+                        "usage": {
+                            "input_tokens": 10,
+                            "input_tokens_details": null,
+                            "output_tokens": 520,
+                            "output_tokens_details": { "reasoning_tokens": 516 },
+                            "total_tokens": 530
+                        }
+                    }
+                }),
+            ]),
+            sse(vec![
+                ev_response_created("resp-2"),
+                ev_assistant_message("msg-2", "done"),
+                json!({
+                    "type": "response.completed",
+                    "response": {
+                        "id": "resp-2",
+                        "usage": {
+                            "input_tokens": 12,
+                            "input_tokens_details": null,
+                            "output_tokens": 40,
+                            "output_tokens_details": { "reasoning_tokens": 10 },
+                            "total_tokens": 52
+                        }
+                    }
+                }),
+            ]),
+        ],
+    )
+    .await;
+
+    let TestCodex { codex, .. } = test_codex().build(&server).await?;
+
+    codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "hello".into(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let mut agent_messages = Vec::new();
+    let mut response_metrics = None;
+    loop {
+        let event = wait_for_event(&codex, |_| true).await;
+        match event {
+            EventMsg::AgentMessage(message) => agent_messages.push(message.message),
+            EventMsg::TokenCount(payload) => {
+                if payload.response_metrics.is_some() {
+                    response_metrics = payload.response_metrics;
+                }
+            }
+            EventMsg::TurnComplete(_) => break,
+            _ => {}
+        }
+    }
+
+    assert_eq!(agent_messages, vec!["done".to_string()]);
+    let metrics = response_metrics.expect("final round should publish response metrics");
+    let usage = metrics
+        .token_usage
+        .expect("final round metrics should include token usage");
+    assert_eq!(usage.reasoning_output_tokens, 526);
+    assert_eq!(usage.output_tokens, 556);
+    assert_eq!(usage.total_tokens, 568);
+    assert!(
+        metrics.time_to_first_token_ms.is_some(),
+        "accepted final round should keep visible TTFT"
+    );
+    Ok(())
+}
