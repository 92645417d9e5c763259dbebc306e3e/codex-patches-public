+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn response_metrics_ttft_starts_at_first_visible_assistant_output() -> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+    let server = MockServer::start().await;
+
+    mount_sse_once(
+        &server,
+        sse(vec![
+            ev_response_created("resp1"),
+            ev_reasoning_item_added("reasoning-1", &[]),
+            ev_assistant_message("msg-1", "done"),
+            ev_completed("resp1"),
+        ]),
+    )
+    .await;
+
+    let TestCodex { codex, .. } = test_codex().build(&server).await?;
+
+    codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "hello".into(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let token_event = wait_for_event(
+        &codex,
+        |ev| matches!(ev, EventMsg::TokenCount(payload) if payload.response_metrics.is_some()),
+    )
+    .await;
+    let EventMsg::TokenCount(event) = token_event else {
+        unreachable!("wait_for_event returned unexpected event");
+    };
+    let metrics = event
+        .response_metrics
+        .expect("response metrics should be attached to token count");
+    let ttft_ms = metrics
+        .time_to_first_token_ms
+        .expect("visible assistant output should seed accepted-round TTFT");
+
+    assert!(metrics.duration_ms >= ttft_ms);
+    assert!(metrics.token_usage.is_some());
+    wait_for_event(&codex, |ev| matches!(ev, EventMsg::TurnComplete(_))).await;
+    Ok(())
+}
