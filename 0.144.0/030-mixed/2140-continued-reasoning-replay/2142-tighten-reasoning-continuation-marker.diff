+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn truncated_encrypted_reasoning_round_continues_before_tool_execution() {
+    skip_if_no_network!();
+
+    let server = MockServer::start().await;
+    let response_mock = mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-1"),
+                ev_reasoning_item("rs-1", &["thinking"], &["raw"]),
+                ev_function_call("call-1", "get_context_remaining", "{}"),
+                json!({
+                    "type": "response.completed",
+                    "response": {
+                        "id": "resp-1",
+                        "usage": {
+                            "input_tokens": 10,
+                            "input_tokens_details": null,
+                            "output_tokens": 520,
+                            "output_tokens_details": { "reasoning_tokens": 516 },
+                            "total_tokens": 530
+                        }
+                    }
+                }),
+            ]),
+            sse(vec![
+                ev_response_created("resp-2"),
+                ev_assistant_message("msg-2", "done"),
+                ev_completed("resp-2"),
+            ]),
+        ],
+    )
+    .await;
+    let test = test_codex().build(&server).await.unwrap();
+
+    test.submit_turn("hello").await.unwrap();
+
+    let requests = response_mock.requests();
+    assert_eq!(requests.len(), 2);
+    let second = requests[1].body_json();
+    let second_input = second["input"]
+        .as_array()
+        .expect("second request should include continuation input");
+    assert!(
+        second_input.iter().all(|item| {
+            item.get("type").and_then(serde_json::Value::as_str) != Some("function_call")
+        }),
+        "continuation request should drop truncated-round tool calls"
+    );
+    assert_eq!(
+        second_input
+            .last()
+            .and_then(|item| item.get("content"))
+            .and_then(serde_json::Value::as_array)
+            .and_then(|content| content.first())
+            .and_then(|entry| entry.get("text"))
+            .and_then(serde_json::Value::as_str),
+        Some("Continue the same turn from the preserved reasoning chain. Unaccepted replies and tool calls have not taken effect; request any still-needed tool again.")
+    );
+    assert!(
+        requests[1]
+            .inputs_of_type("function_call_output")
+            .is_empty()
+    );
+}
