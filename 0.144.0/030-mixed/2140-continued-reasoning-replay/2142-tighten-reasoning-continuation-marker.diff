+enum SamplingAttemptResult {
+    Finished(SamplingRequestResult),
+    Continue { next_input: Vec<ResponseItem> },
+}
+
+#[derive(Default)]
+struct ContinuationResponseMetricsState {
+    hidden_reasoning_output_tokens: i64,
+}
+
+impl ContinuationResponseMetricsState {
+    fn record_hidden_round(&mut self, usage: &TokenUsage) {
+        self.hidden_reasoning_output_tokens = self
+            .hidden_reasoning_output_tokens
+            .saturating_add(usage.reasoning_output_tokens.max(0));
+    }
+
+    fn finalize(
+        &self,
+        duration_ms: i64,
+        time_to_first_token_ms: Option<i64>,
+        token_usage: Option<TokenUsage>,
+    ) -> ResponseMetricsEvent {
+        let token_usage = token_usage.map(|mut usage| {
+            let hidden_reasoning = self.hidden_reasoning_output_tokens.max(0);
+            usage.output_tokens = usage.output_tokens.saturating_add(hidden_reasoning);
+            usage.reasoning_output_tokens = usage
+                .reasoning_output_tokens
+                .saturating_add(hidden_reasoning);
+            usage.total_tokens = usage.total_tokens.saturating_add(hidden_reasoning);
+            usage
+        });
+        ResponseMetricsEvent {
+            duration_ms,
+            time_to_first_token_ms,
+            token_usage,
+        }
+    }
+}
+
+struct DeferredNonToolItem {
+    response_item: ResponseItem,
+    previously_streamed_item: Option<TurnItem>,
+}
+
+const REASONING_CONTINUATION_FINGERPRINT_STEP: i64 = 518;
+const REASONING_CONTINUATION_MAX_ROUNDS: usize = 3;
+const REASONING_CONTINUATION_MARKER: &str = "Continue the same turn from the preserved reasoning chain. Unaccepted replies and tool calls have not taken effect; request any still-needed tool again.";
+
+fn matches_reasoning_continuation_fingerprint(reasoning_output_tokens: i64) -> bool {
+    reasoning_output_tokens >= REASONING_CONTINUATION_FINGERPRINT_STEP - 2
+        && (reasoning_output_tokens + 2) % REASONING_CONTINUATION_FINGERPRINT_STEP == 0
+}
+
+fn reasoning_item_has_encrypted_content(item: &ResponseItem) -> bool {
+    matches!(
+        item,
+        ResponseItem::Reasoning {
+            encrypted_content: Some(_),
+            ..
+        }
+    )
+}
+
+fn response_item_is_deferred_tool_call_candidate(item: &ResponseItem) -> bool {
+    match item {
+        ResponseItem::FunctionCall { .. } | ResponseItem::CustomToolCall { .. } => true,
+        ResponseItem::ToolSearchCall {
+            call_id: Some(_),
+            execution,
+            ..
+        } => execution == "client",
+        _ => false,
+    }
+}
+
+fn build_reasoning_continuation_input(
+    prompt: &Prompt,
+    round_response_items: Vec<ResponseItem>,
+) -> Vec<ResponseItem> {
+    let mut next_input = prompt.input.clone();
+    next_input.extend(round_response_items);
+    next_input.push(ResponseItem::Message {
+        id: None,
+        role: "assistant".to_string(),
+        content: vec![ContentItem::OutputText {
+            text: REASONING_CONTINUATION_MARKER.to_string(),
+        }],
+        phase: Some(MessagePhase::Commentary),
+        internal_chat_message_metadata_passthrough: None,
+    });
+    next_input
+}
+
+fn response_item_is_visible_assistant_output(item: &ResponseItem) -> bool {
+    matches!(
+        item,
+        ResponseItem::Message { role, .. } if role == "assistant"
+    )
+}
+
+fn response_item_has_visible_assistant_text(item: &ResponseItem) -> bool {
+    response_item_is_visible_assistant_output(item)
+        && raw_assistant_output_text_from_item(item).is_some_and(|text| !text.is_empty())
+}
+
+async fn flush_deferred_non_tool_items(
+    ctx: &mut HandleOutputCtx,
+    deferred_non_tool_items: Vec<DeferredNonToolItem>,
+    reasoning_only: bool,
+    reasoning_continued: bool,
+) -> CodexResult<Option<String>> {
+    let mut last_agent_message = None;
+    let plan_mode = ctx.turn_context.collaboration_mode.mode == ModeKind::Plan;
+    for deferred in deferred_non_tool_items {
+        if reasoning_only && !matches!(deferred.response_item, ResponseItem::Reasoning { .. }) {
+            continue;
+        }
+        let mut finalized_turn_item = finalize_non_tool_response_item(
+            ctx.sess.as_ref(),
+            ctx.turn_context.as_ref(),
+            TurnItemContributorPolicy::Run(ctx.turn_store.as_ref()),
+            &deferred.response_item,
+            plan_mode,
+        )
+        .await;
+        if reasoning_continued
+            && let Some(finalized) = finalized_turn_item.as_mut()
+            && let TurnItem::Reasoning(reasoning) = &mut finalized.turn_item
+        {
+            reasoning.continued = true;
+        }
+        let finalized_facts = finalized_turn_item
+            .as_ref()
+            .map(|finalized| finalized.facts.clone());
+        if let Some(finalized_turn_item) = finalized_turn_item {
+            if deferred.previously_streamed_item.is_none() {
+                ctx.sess
+                    .emit_turn_item_started(&ctx.turn_context, &finalized_turn_item.turn_item)
+                    .await;
+            }
+            ctx.sess
+                .emit_turn_item_completed(&ctx.turn_context, finalized_turn_item.turn_item)
+                .await;
+        }
+        record_completed_response_item_with_finalized_facts(
+            ctx.sess.as_ref(),
+            ctx.turn_context.as_ref(),
+            &deferred.response_item,
+            finalized_facts.as_ref(),
+        )
+        .await;
+        if let Some(agent_message) = finalized_facts.and_then(|facts| facts.last_agent_message) {
+            last_agent_message = Some(agent_message);
+        }
+    }
+    Ok(last_agent_message)
+}
+
+async fn flush_one_deferred_non_tool_item(
+    ctx: &mut HandleOutputCtx,
+    deferred: DeferredNonToolItem,
+    reasoning_continued: bool,
+) -> CodexResult<Option<String>> {
+    flush_deferred_non_tool_items(
+        ctx,
+        vec![deferred],
+        /*reasoning_only*/ false,
+        reasoning_continued,
+    )
+    .await
+}
