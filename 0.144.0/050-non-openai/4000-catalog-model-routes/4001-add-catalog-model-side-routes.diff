+
+const CATALOG_FILE: &str = "model-catalogs/model-catalogs.json";
+const INSTRUCTIONS_DIR: &str = "instructions";
+const DEFAULT_API_KEY: &str = "sk-dummy";
+
+#[derive(Debug, Clone, PartialEq)]
+pub(crate) struct NonOpenAiConfig {
+    path: PathBuf,
+    models: BTreeMap<String, NonOpenAiModel>,
+}
+
+impl Default for NonOpenAiConfig {
+    fn default() -> Self {
+        Self {
+            path: PathBuf::from(CATALOG_FILE),
+            models: BTreeMap::new(),
+        }
+    }
+}
+
+#[derive(Debug, Clone, PartialEq)]
+pub(crate) struct NonOpenAiRequestRoute {
+    pub(crate) provider_id: String,
+    pub(crate) provider: ModelProviderInfo,
+    pub(crate) upstream_model: String,
+    pub(crate) upstream_reasoning_effort: Option<ReasoningEffort>,
+    pub(crate) supports_json_schema_output: bool,
+    pub(crate) supports_plaintext_reasoning: bool,
+    pub(crate) supports_previous_response_id: bool,
+    pub(crate) cached_tokens_optional: bool,
+}
+
+#[derive(Debug, Clone, PartialEq)]
+struct NonOpenAiModel {
+    info: ModelInfo,
+    route: ModelRouteConfig,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq, Default)]
+#[serde(default)]
+struct CatalogConfig {
+    models: Vec<CatalogModelConfig>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+struct CatalogModelConfig {
+    #[serde(flatten)]
+    info: ModelInfo,
+    #[serde(default, skip_serializing_if = "Option::is_none")]
+    non_openai: Option<ModelRouteConfig>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(default)]
+struct ModelRouteConfig {
+    api_key: String,
+    base_url: String,
+    websocket: bool,
+    supports_json_schema_output: bool,
+    supports_plaintext_reasoning: bool,
+    supports_previous_response_id: bool,
+    supports_namespace_tools: bool,
+    cached_tokens_optional: bool,
+    reasoning: BTreeMap<String, ReasoningRouteConfig>,
+}
+
+impl Default for ModelRouteConfig {
+    fn default() -> Self {
+        Self {
+            api_key: DEFAULT_API_KEY.to_string(),
+            base_url: String::new(),
+            websocket: false,
+            supports_json_schema_output: false,
+            supports_plaintext_reasoning: false,
+            supports_previous_response_id: false,
+            supports_namespace_tools: true,
+            cached_tokens_optional: false,
+            reasoning: BTreeMap::new(),
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(default)]
+struct ReasoningRouteConfig {
+    upstream_model: String,
+    #[serde(
+        default,
+        deserialize_with = "deserialize_optional_reasoning_effort",
+        skip_serializing_if = "Option::is_none"
+    )]
+    upstream_reasoning_effort: Option<ReasoningEffort>,
+}
+
+impl Default for ReasoningRouteConfig {
+    fn default() -> Self {
+        Self {
+            upstream_model: String::new(),
+            upstream_reasoning_effort: None,
+        }
+    }
+}
+
+fn deserialize_optional_reasoning_effort<'de, D>(
+    deserializer: D,
+) -> Result<Option<ReasoningEffort>, D::Error>
+where
+    D: Deserializer<'de>,
+{
+    let Some(value) = Option::<String>::deserialize(deserializer)? else {
+        return Ok(None);
+    };
+    Ok(value.parse::<ReasoningEffort>().ok())
+}
+
+impl NonOpenAiConfig {
+    pub(crate) fn load_and_heal(codex_home: &Path) -> io::Result<Self> {
+        let path = codex_home.join(CATALOG_FILE);
+        let (normalized, should_write) = load_catalog_file(&path)?;
+        if should_write {
+            write_if_changed(&path, &normalized)?;
+        }
+        seed_instruction_overlays(codex_home, &normalized);
+        Ok(Self::from_catalog(path, normalized, codex_home))
+    }
+
+    pub(crate) fn models(&self) -> Vec<ModelInfo> {
+        self.models
+            .values()
+            .map(|model| model.info.clone())
+            .collect()
+    }
+
+    pub(crate) fn wrap_models_manager(&self, inner: SharedModelsManager) -> SharedModelsManager {
+        if self.models.is_empty() {
+            return inner;
+        }
+        Arc::new(NonOpenAiModelsManager {
+            inner,
+            non_openai: self.clone(),
+        })
+    }
+
+    pub(crate) fn route_for_model(
+        &self,
+        model: &str,
+        effort: Option<&ReasoningEffort>,
+    ) -> Option<NonOpenAiRequestRoute> {
+        let model = self.models.get(model)?;
+        let reasoning = select_reasoning_route(model, effort);
+        let upstream_model = reasoning
+            .as_ref()
+            .and_then(|route| (!route.upstream_model.trim().is_empty()).then_some(route))
+            .map(|route| route.upstream_model.clone())
+            .unwrap_or_else(|| model.info.slug.clone());
+        Some(NonOpenAiRequestRoute {
+            provider_id: model.info.slug.clone(),
+            provider: provider_from_model(model),
+            upstream_model,
+            upstream_reasoning_effort: reasoning
+                .and_then(|route| route.upstream_reasoning_effort.clone()),
+            supports_json_schema_output: model.route.supports_json_schema_output,
+            supports_plaintext_reasoning: model.route.supports_plaintext_reasoning,
+            supports_previous_response_id: model.route.supports_previous_response_id,
+            cached_tokens_optional: model.route.cached_tokens_optional,
+        })
+    }
+
+    pub(crate) fn supports_namespace_tools(&self, model: &str) -> Option<bool> {
+        self.models
+            .get(model)
+            .map(|model| model.route.supports_namespace_tools)
+    }
+
+    pub(crate) fn model_family(&self, model: &str) -> String {
+        self.models
+            .get(model)
+            .map(|model| format!("non-openai:{}", model.route.base_url))
+            .unwrap_or_else(|| "openai".to_string())
+    }
+
+    pub(crate) fn family_takeover_message(
+        &self,
+        previous_model: &str,
+        current_model: &str,
+    ) -> Option<String> {
+        let previous_family = self.model_family(previous_model);
+        let current_family = self.model_family(current_model);
+        (previous_family != current_family).then(|| {
+            format!(
+                "Cannot continue this conversation with `{current_model}` because the previous turn used `{previous_model}`. Start a new conversation to switch model families."
+            )
+        })
+    }
+
+    pub(crate) async fn read_api_key(&self, model: &str) -> CodexResult<String> {
+        read_api_key_from_catalog(&self.path, model).await
+    }
+
+    fn from_catalog(path: PathBuf, catalog: CatalogConfig, codex_home: &Path) -> Self {
+        let mut models = BTreeMap::new();
+        for model_config in catalog.models {
+            let Some(route) = model_config.non_openai else {
+                continue;
+            };
+            if route.base_url.trim().is_empty() {
+                warn!(model = %model_config.info.slug, "ignoring non-openai model without base_url");
+                continue;
+            }
+            if !model_config
+                .info
+                .input_modalities
+                .contains(&InputModality::Text)
+            {
+                warn!(model = %model_config.info.slug, "ignoring non-openai model without text support");
+                continue;
+            }
+            let model_id = model_config.info.slug.clone();
+            let mut model_info = model_config.info;
+            normalize_runtime_model_fields(&mut model_info);
+            apply_instruction_overlay(&mut model_info, codex_home);
+            if route.supports_plaintext_reasoning {
+                model_info.supports_plaintext_reasoning = true;
+                model_info.supports_reasoning_summaries = true;
+            }
+            models.insert(
+                model_id,
+                NonOpenAiModel {
+                    info: model_info,
+                    route,
+                },
+            );
+        }
+        Self { path, models }
+    }
+}
+
+struct NonOpenAiModelsManager {
+    inner: SharedModelsManager,
+    non_openai: NonOpenAiConfig,
+}
+
+impl fmt::Debug for NonOpenAiModelsManager {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.debug_struct("NonOpenAiModelsManager")
+            .field("inner", &self.inner)
+            .field(
+                "non_openai_models",
+                &self.non_openai.models.keys().collect::<Vec<_>>(),
+            )
+            .finish()
+    }
+}
+
+impl ModelsManager for NonOpenAiModelsManager {
+    fn raw_model_catalog(
+        &self,
+        refresh_strategy: RefreshStrategy,
+        http_client_factory: HttpClientFactory,
+    ) -> ModelsManagerFuture<'_, codex_protocol::openai_models::ModelsResponse> {
+        Box::pin(async move {
+            let mut catalog = self
+                .inner
+                .raw_model_catalog(refresh_strategy, http_client_factory)
+                .await;
+            merge_non_openai_models(&mut catalog.models, self.non_openai.models());
+            catalog
+        })
+    }
+
+    fn get_remote_models(&self) -> ModelsManagerFuture<'_, Vec<ModelInfo>> {
+        Box::pin(async move {
+            let mut models = self.inner.get_remote_models().await;
+            merge_non_openai_models(&mut models, self.non_openai.models());
+            models
+        })
+    }
+
+    fn try_get_remote_models(&self) -> Result<Vec<ModelInfo>, tokio::sync::TryLockError> {
+        let mut models = self.inner.try_get_remote_models()?;
+        merge_non_openai_models(&mut models, self.non_openai.models());
+        Ok(models)
+    }
+
+    fn auth_manager(&self) -> Option<&codex_login::AuthManager> {
+        self.inner.auth_manager()
+    }
+
+    fn list_collaboration_modes(&self) -> Vec<CollaborationModeMask> {
+        self.inner.list_collaboration_modes()
+    }
+
+    fn refresh_if_new_etag(
+        &self,
+        etag: String,
+        http_client_factory: HttpClientFactory,
+    ) -> ModelsManagerFuture<'_, ()> {
+        Box::pin(async move {
+            self.inner
+                .refresh_if_new_etag(etag, http_client_factory)
+                .await;
+        })
+    }
+}
+
+fn merge_non_openai_models(models: &mut Vec<ModelInfo>, non_openai_models: Vec<ModelInfo>) {
+    for model in non_openai_models {
+        match models
+            .iter()
+            .position(|existing| existing.slug == model.slug)
+        {
+            Some(index) => models[index] = model,
+            None => models.push(model),
+        }
+    }
+}
+
+fn provider_from_model(model: &NonOpenAiModel) -> ModelProviderInfo {
+    ModelProviderInfo {
+        name: model.info.display_name.clone(),
+        base_url: Some(model.route.base_url.clone()),
+        env_key: None,
+        env_key_instructions: None,
+        experimental_bearer_token: None,
+        auth: None,
+        aws: None,
+        wire_api: WireApi::Responses,
+        query_params: None,
+        http_headers: None,
+        env_http_headers: None,
+        request_max_retries: None,
+        stream_max_retries: None,
+        stream_idle_timeout_ms: None,
+        websocket_connect_timeout_ms: None,
+        requires_openai_auth: false,
+        supports_websockets: model.route.websocket,
+    }
+}
+
+fn select_reasoning_route<'a>(
+    model: &'a NonOpenAiModel,
+    effort: Option<&ReasoningEffort>,
+) -> Option<&'a ReasoningRouteConfig> {
+    let effort_key = effort.map(ReasoningEffort::as_str);
+    effort_key
+        .and_then(|effort| model.route.reasoning.get(effort))
+        .or_else(|| model.route.reasoning.get("high"))
+        .or_else(|| model.route.reasoning.values().next())
+}
+
+fn load_catalog_file(path: &Path) -> io::Result<(CatalogConfig, bool)> {
+    let contents = match fs::read_to_string(path) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == ErrorKind::NotFound => {
+            return Ok((CatalogConfig::default(), false));
+        }
+        Err(err) => return Err(err),
+    };
+    if contents.trim().is_empty() {
+        return Ok((CatalogConfig::default(), true));
+    }
+    let mut catalog = serde_json::from_str::<CatalogConfig>(&contents)
+        .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+    heal_catalog_config(&mut catalog);
+    Ok((catalog, true))
+}
+
+fn heal_catalog_config(catalog: &mut CatalogConfig) {
+    for model in &mut catalog.models {
+        if let Some(route) = &mut model.non_openai {
+            heal_model_route_config(route);
+        }
+    }
+}
+
+fn heal_model_route_config(route: &mut ModelRouteConfig) {
+    route.reasoning.retain(|effort, reasoning| {
+        effort.parse::<ReasoningEffort>().is_ok()
+            && reasoning
+                .upstream_reasoning_effort
+                .as_ref()
+                .is_none_or(|effort| effort.as_str().parse::<ReasoningEffort>().is_ok())
+    });
+    if route.api_key.trim().is_empty() {
+        route.api_key = DEFAULT_API_KEY.to_string();
+    }
+}
+
+fn write_if_changed(path: &Path, config: &CatalogConfig) -> io::Result<()> {
+    let next = serde_json::to_string_pretty(config)
+        .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string()))?;
+    if fs::read_to_string(path).ok().as_deref() == Some(next.as_str()) {
+        return Ok(());
+    }
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent)?;
+    }
+    let tmp = path.with_extension("json.tmp");
+    fs::write(&tmp, next)?;
+    fs::rename(tmp, path)?;
+    Ok(())
+}
+
+fn normalize_runtime_model_fields(info: &mut ModelInfo) {
+    info.service_tiers.clear();
+    info.default_service_tier = None;
+    if info.comp_hash.is_none() {
+        info.comp_hash = Some(format!("non-openai:{}", info.slug));
+    }
+}
+
+fn apply_instruction_overlay(model_info: &mut ModelInfo, codex_home: &Path) {
+    let instruction_template = instruction_template_for_model(codex_home, model_info);
+    model_info.model_messages = Some(ModelMessages {
+        instructions_template: Some(instruction_template),
+        instructions_variables: model_info
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_variables.clone()),
+        approvals: model_info
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.approvals.clone()),
+    });
+}
+
+fn instruction_template_for_model(codex_home: &Path, model_info: &ModelInfo) -> String {
+    let path = codex_home
+        .join(INSTRUCTIONS_DIR)
+        .join(format!("{}.md", model_info.slug));
+    match fs::read_to_string(path) {
+        Ok(contents) if !contents.trim().is_empty() => contents,
+        _ => default_instruction_template(model_info).to_string(),
+    }
+}
+
+fn default_instruction_template(model_info: &ModelInfo) -> &str {
+    model_info
+        .model_messages
+        .as_ref()
+        .and_then(|messages| messages.instructions_template.as_deref())
+        .filter(|template| !template.trim().is_empty())
+        .unwrap_or_else(|| {
+            if model_info.base_instructions.trim().is_empty() {
+                BASE_INSTRUCTIONS
+            } else {
+                model_info.base_instructions.as_str()
+            }
+        })
+}
+
+fn seed_instruction_overlays(codex_home: &Path, config: &CatalogConfig) {
+    let dir = codex_home.join(INSTRUCTIONS_DIR);
+    if let Err(err) = fs::create_dir_all(&dir) {
+        warn!(path = %dir.display(), "failed to create instructions overlay directory: {err}");
+        return;
+    }
+    for model in &config.models {
+        if model.non_openai.is_none() {
+            continue;
+        }
+        let path = dir.join(format!("{}.md", model.info.slug));
+        if path.exists() {
+            continue;
+        }
+        if let Err(err) = fs::write(&path, default_instruction_template(&model.info)) {
+            warn!(model = %model.info.slug, path = %path.display(), "failed to seed instructions overlay file: {err}");
+        }
+    }
+}
+
+async fn read_api_key_from_catalog(path: &Path, model: &str) -> CodexResult<String> {
+    let contents = tokio::fs::read_to_string(path)
+        .await
+        .map_err(|err| CodexErr::Fatal(format!("failed to read non-openai catalog: {err}")))?;
+    let catalog = serde_json::from_str::<CatalogConfig>(&contents)
+        .map_err(|err| CodexErr::Fatal(format!("failed to parse non-openai catalog: {err}")))?;
+    let api_key = catalog
+        .models
+        .into_iter()
+        .find(|entry| entry.info.slug == model)
+        .and_then(|entry| entry.non_openai)
+        .map(|route| route.api_key)
+        .map(|api_key| api_key.trim().to_string())
+        .filter(|api_key| !api_key.is_empty())
+        .filter(|api_key| api_key != DEFAULT_API_KEY)
+        .ok_or_else(|| {
+            CodexErr::InvalidRequest(format!(
+                "non-openai model `{model}` needs a real api_key in {CATALOG_FILE}"
+            ))
+        })?;
+    Ok(api_key)
+}
+
+pub(crate) fn api_auth_for_key(api_key: String) -> SharedAuthProvider {
+    Arc::new(BearerAuthProvider::new(api_key))
+}
