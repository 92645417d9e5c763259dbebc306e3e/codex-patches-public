+#[cfg(test)]
+struct ModelInfoParts<'a> {
+    slug: &'a str,
+    display_name: &'a str,
+    description: Option<&'a str>,
+    image: bool,
+    web_search: bool,
+    context_window: i64,
+    effective_context_window_percent: i64,
+    reasoning: &'a BTreeMap<String, ReasoningRouteConfig>,
+    plaintext_reasoning: bool,
+}
+
+#[cfg(test)]
+fn model_info_from_parts(parts: ModelInfoParts<'_>) -> ModelInfo {
+    let supported_reasoning_levels = supported_reasoning_levels(parts.reasoning);
+    let default_reasoning_level = supported_reasoning_levels
+        .iter()
+        .find(|preset| preset.effort == ReasoningEffort::High)
+        .or_else(|| supported_reasoning_levels.first())
+        .map(|preset| preset.effort.clone());
+    let input_modalities = if parts.image {
+        vec![InputModality::Text, InputModality::Image]
+    } else {
+        vec![InputModality::Text]
+    };
+    ModelInfo {
+        slug: parts.slug.to_string(),
+        display_name: parts.display_name.to_string(),
+        description: parts.description.map(str::to_string),
+        default_reasoning_level,
+        supported_reasoning_levels,
+        shell_type: ConfigShellToolType::Default,
+        visibility: ModelVisibility::List,
+        supported_in_api: true,
+        priority: 80,
+        additional_speed_tiers: Vec::new(),
+        service_tiers: Vec::new(),
+        default_service_tier: None,
