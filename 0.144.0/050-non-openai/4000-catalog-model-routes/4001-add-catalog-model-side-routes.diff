+            instructions_variables: None,
+            approvals: None,
+        }),
+        include_skills_usage_instructions: false,
+        supports_reasoning_summaries: parts.plaintext_reasoning || !parts.reasoning.is_empty(),
+        supports_plaintext_reasoning: parts.plaintext_reasoning,
+        default_reasoning_summary: codex_protocol::config_types::ReasoningSummary::None,
+        support_verbosity: false,
+        default_verbosity: None,
+        apply_patch_tool_type: None,
+        web_search_tool_type: if parts.image {
+            WebSearchToolType::TextAndImage
+        } else {
+            WebSearchToolType::Text
+        },
+        truncation_policy: TruncationPolicyConfig::bytes(/*limit*/ 10_000),
+        supports_parallel_tool_calls: true,
+        supports_image_detail_original: parts.image,
+        context_window: Some(parts.context_window),
+        max_context_window: Some(parts.context_window),
+        auto_compact_token_limit: None,
