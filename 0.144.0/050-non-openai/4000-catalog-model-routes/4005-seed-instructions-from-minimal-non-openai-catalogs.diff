+    #[test]
+    fn omitted_model_prompt_fields_seed_default_instruction_overlay() {
+        let codex_home = TempDir::new().unwrap();
+        fs::create_dir_all(codex_home.path().join("model-catalogs")).unwrap();
+        fs::write(
+            codex_home.path().join(CATALOG_FILE),
+            r#"{
+  "models": [
+    {
+      "slug": "minimal-model",
+      "display_name": "Minimal Model",
+      "description": "Prompt defaults come from the built-in instructions.",
+      "supported_reasoning_levels": [],
+      "context_window": 256000,
+      "input_modalities": ["text"],
+      "non_openai": {
+        "api_key": "sk-live",
+        "base_url": "https://minimal.example/v1",
+        "supports_plaintext_reasoning": true
+      }
+    }
+  ]
+}"#,
+        )
+        .unwrap();
+
+        let loaded = NonOpenAiConfig::load_and_heal(codex_home.path()).unwrap();
+        let healed = fs::read_to_string(codex_home.path().join(CATALOG_FILE)).unwrap();
+        let healed: Value = serde_json::from_str(&healed).unwrap();
+        let model = loaded.models().pop().unwrap();
+        let instructions_path = codex_home
+            .path()
+            .join(INSTRUCTIONS_DIR)
+            .join("minimal-model.md");
+
+        assert!(loaded.route_for_model("minimal-model", None).is_some());
+        assert_eq!(
+            fs::read_to_string(instructions_path).unwrap(),
+            BASE_INSTRUCTIONS
+        );
+        assert_eq!(
+            model
+                .model_messages
+                .as_ref()
+                .and_then(|messages| messages.instructions_template.as_deref()),
+            Some(BASE_INSTRUCTIONS)
+        );
+        assert!(healed["models"][0].get("base_instructions").is_none());
+        assert!(healed["models"][0].get("model_messages").is_none());
+        assert!(
+            healed["models"][0]
+                .get("supports_reasoning_summaries")
+                .is_none()
+        );
+        assert!(
+            healed["models"][0]
+                .get("default_reasoning_summary")
+                .is_none()
+        );
+    }
