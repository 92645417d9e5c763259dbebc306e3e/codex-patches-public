+#[test]
+fn resume_history_loaded_separator_renders_pluralized_counts() {
+    let plural =
+        ResumeHistoryLoadedSeparator::new(3, 2, 4, 1, 63, Some(Duration::from_millis(1500)));
+    let singular = ResumeHistoryLoadedSeparator::new(1, 1, 1, 1, 0, None);
+
+    let rendered = render_lines(&plural.display_lines(/*width*/ 200));
+    assert_eq!(rendered.len(), 1);
+    assert!(
+        rendered[0].contains(
+            "Loaded 3 messages, 2 turns, 4 app-server turns, 1 context loaded, 63 omitted"
+        )
+    );
+    assert!(rendered[0].contains("▪ Worked 1.50s"));
+    let narrow = render_lines(&plural.display_lines(/*width*/ 80));
+    assert_eq!(UnicodeWidthStr::width(narrow[0].as_str()), 80);
+    assert!(narrow[0].contains("… ▪ Worked 1.50s ─"));
+    assert_eq!(
+        render_lines(&singular.raw_lines()),
+        vec!["Loaded 1 message, 1 turn, 1 app-server turn, 1 context loaded"]
+    );
+}
