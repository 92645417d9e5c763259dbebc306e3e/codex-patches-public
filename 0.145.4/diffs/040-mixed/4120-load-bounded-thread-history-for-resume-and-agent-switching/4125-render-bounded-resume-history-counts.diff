+#[derive(Debug)]
+pub struct ResumeHistoryLoadedSeparator {
+    messages: u64,
+    turns: u64,
+    app_server_turns: u64,
+    loaded_context_windows: u64,
+    omitted_context_windows: u64,
+    resume_elapsed: Option<Duration>,
+}
+
+impl ResumeHistoryLoadedSeparator {
+    pub(crate) fn new(
+        messages: u64,
+        turns: u64,
+        app_server_turns: u64,
+        loaded_context_windows: u64,
+        omitted_context_windows: u64,
+        resume_elapsed: Option<Duration>,
+    ) -> Self {
+        Self {
+            messages,
+            turns,
+            app_server_turns,
+            loaded_context_windows,
+            omitted_context_windows,
+            resume_elapsed,
+        }
+    }
+
+    fn label(&self) -> String {
+        let messages = pluralize(self.messages, "message", "messages");
+        let turns = pluralize(self.turns, "turn", "turns");
+        let app_server_turns =
+            pluralize(self.app_server_turns, "app-server turn", "app-server turns");
+        let summary = format!(
+            "Loaded {} {messages}, {} {turns}, {} {app_server_turns}",
+            self.messages, self.turns, self.app_server_turns
+        );
+        let summary = if self.loaded_context_windows == 0 {
+            summary
+        } else {
+            let loaded = pluralize(self.loaded_context_windows, "context", "contexts");
+            if self.omitted_context_windows == 0 {
+                format!("{summary}, {} {loaded} loaded", self.loaded_context_windows)
+            } else {
+                format!(
+                    "{summary}, {} {loaded} loaded, {} omitted",
+                    self.loaded_context_windows, self.omitted_context_windows
+                )
+            }
+        };
+        if let Some(elapsed) = self.resume_elapsed {
+            format!(
+                "{summary} ▪ Worked {}",
+                codex_utils_elapsed::format_duration(elapsed)
+            )
+        } else {
+            summary
+        }
+    }
+}
+
+impl HistoryCell for ResumeHistoryLoadedSeparator {
+    fn display_lines(&self, width: u16) -> Vec<Line<'static>> {
+        let label_text = self.label();
+        let label = format!("─ {label_text} ─");
+        let label_width = UnicodeWidthStr::width(label.as_str());
+        if label_width > width as usize {
+            if let Some(elapsed) = self.resume_elapsed {
+                let suffix = format!(
+                    " ▪ Worked {} ─",
+                    codex_utils_elapsed::format_duration(elapsed)
+                );
+                let fixed_width = UnicodeWidthStr::width("─ …")
+                    .saturating_add(UnicodeWidthStr::width(suffix.as_str()));
+                if fixed_width < width as usize {
+                    let (prefix, _, _) =
+                        take_prefix_by_width(&label_text, width as usize - fixed_width);
+                    return vec![Line::from(format!("─ {prefix}…{suffix}")).dim()];
+                }
+            }
+            let (label, _suffix, label_width) = take_prefix_by_width(&label, width as usize);
+            return vec![
+                Line::from_iter([
+                    label,
+                    "─".repeat((width as usize).saturating_sub(label_width)),
+                ])
+                .dim(),
+            ];
+        }
+
+        let mut spans = Vec::new();
+        spans.push("─ ".dim());
+        spans.push(label_text.fg(Color::Cyan).add_modifier(Modifier::BOLD));
+        spans.push(" ─".dim());
+        spans.push(
+            "─"
+                .repeat((width as usize).saturating_sub(label_width))
+                .dim(),
+        );
+        vec![Line::from(spans)]
+    }
+
+    fn raw_lines(&self) -> Vec<Line<'static>> {
+        vec![Line::from(self.label())]
+    }
+}
