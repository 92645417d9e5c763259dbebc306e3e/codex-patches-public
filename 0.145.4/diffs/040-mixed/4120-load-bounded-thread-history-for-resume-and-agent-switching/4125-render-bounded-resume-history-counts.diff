+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct ResumeHistoryLoadSummary {
+    messages: u64,
+    turns: u64,
+    app_server_turns: u64,
+    loaded_context_windows: u64,
+    omitted_context_windows: u64,
+}
+
+fn resume_history_load_summary(
+    turns: &[Turn],
+    history_window_metadata: codex_app_server_protocol::ThreadResumeHistoryWindowMetadata,
+) -> Option<ResumeHistoryLoadSummary> {
+    if turns.is_empty() {
+        return None;
+    }
+
+    let mut messages = 0;
+    let mut visible_turns = 0;
+    for turn in turns {
+        let mut has_message = false;
+        for item in &turn.items {
+            if matches!(
+                item,
+                ThreadItem::UserMessage { .. } | ThreadItem::AgentMessage { .. }
+            ) {
+                messages += 1;
+                has_message = true;
+            }
+        }
+        if has_message {
+            visible_turns += 1;
+        }
+    }
+
+    Some(ResumeHistoryLoadSummary {
+        messages,
+        turns: visible_turns,
+        app_server_turns: turns.len() as u64,
+        loaded_context_windows: history_window_metadata.loaded_context_windows,
+        omitted_context_windows: history_window_metadata.omitted_context_windows,
+    })
+}
