+fn bounded_resume_history_window_metadata(
+    items: &[RolloutItem],
+    bounded: bool,
+) -> ThreadResumeHistoryWindowMetadata {
+    if !bounded {
+        return ThreadResumeHistoryWindowMetadata::default();
+    }
+
+    let window_numbers = items
+        .iter()
+        .filter_map(|item| match item {
+            RolloutItem::Compacted(compacted) if compacted.replacement_history.is_some() => {
+                compacted.window_number
+            }
+            _ => None,
+        })
+        .collect::<Vec<_>>();
+    let Some(first_window_number) = window_numbers.first().copied() else {
+        return ThreadResumeHistoryWindowMetadata {
+            loaded_context_windows: 1,
+            omitted_context_windows: 0,
+        };
+    };
+    let loaded_replacement_windows = window_numbers.len() as u64;
+    if first_window_number <= loaded_replacement_windows {
+        ThreadResumeHistoryWindowMetadata {
+            loaded_context_windows: loaded_replacement_windows.saturating_add(1),
+            omitted_context_windows: 0,
+        }
+    } else {
+        ThreadResumeHistoryWindowMetadata {
+            loaded_context_windows: loaded_replacement_windows,
+            omitted_context_windows: first_window_number,
+        }
+    }
+}
