+#[tokio::test]
+async fn refreshed_snapshot_session_preserves_the_live_working_turn() {
+    let mut app = make_test_app().await;
+    let thread_id = ThreadId::new();
+    let session = test_thread_session(thread_id, test_path_buf("/tmp/project"));
+    let channel =
+        ThreadEventChannel::new_with_session(/*capacity*/ 1, session.clone(), Vec::new());
+    {
+        let mut store = channel.store.lock().await;
+        store.push_notification(turn_started_notification(thread_id, "turn-live"));
+        store.push_notification(token_usage_notification(
+            thread_id,
+            "turn-live",
+            Some(950_000),
+        ));
+    }
+    app.thread_event_channels.insert(thread_id, channel);
+    let (_receiver, mut snapshot, reused) = app
+        .activate_thread_for_replay(thread_id, None)
+        .await
+        .expect("thread should activate");
+
+    assert!(!reused);
+    app.apply_refreshed_snapshot_thread(
+        thread_id,
+        AppServerStartedThread {
+            session,
+            turns: Vec::new(),
+            blocks_direct_input: false,
+            history_window_metadata: Default::default(),
+            resume_elapsed: None,
+        },
+        &mut snapshot,
+    )
+    .await;
+
+    assert!(
+        snapshot.turns.iter().any(|turn| {
+            turn.id == "turn-live" && matches!(turn.status, TurnStatus::InProgress)
+        })
+    );
+    app.replay_thread_snapshot(snapshot, /*resume_restored_queue*/ false);
+    assert!(app.chat_widget.is_task_running_for_test());
+    assert_eq!(app.chat_widget.current_status_header_for_test(), "Working");
+}
