+#[tokio::test]
+async fn enter_hook_intent_survives_queueing_while_tab_remains_plain() {
+    let (mut enter_chat, _enter_rx, mut enter_op_rx) =
+        make_chatwidget_manual(/*model_override*/ Some("gpt-5")).await;
+    enter_chat.thread_id = Some(ThreadId::new());
+    enter_chat.input_queue.suppress_queue_autosend = true;
+    enter_chat.bottom_pane.set_composer_text(
+        "run hook after queue".to_string(),
+        Vec::new(),
+        Vec::new(),
+    );
+    enter_chat.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+    assert_no_submit_op(&mut enter_op_rx);
+    assert!(
+        enter_chat
+            .input_queue
+            .queued_user_messages
+            .front()
+            .is_some_and(|message| message.run_user_prompt_submit_hook)
+    );
+    enter_chat.input_queue.suppress_queue_autosend = false;
+    assert!(enter_chat.maybe_send_next_queued_input());
+    assert!(matches!(
+        next_submit_op(&mut enter_op_rx),
+        Op::UserTurn {
+            run_user_prompt_submit_hook: true,
+            ..
+        }
+    ));
+
+    let (mut tab_chat, _tab_rx, mut tab_op_rx) =
+        make_chatwidget_manual(/*model_override*/ Some("gpt-5")).await;
+    tab_chat.thread_id = Some(ThreadId::new());
+    tab_chat.input_queue.suppress_queue_autosend = true;
+    tab_chat
+        .bottom_pane
+        .set_composer_text("plain after queue".to_string(), Vec::new(), Vec::new());
+    tab_chat.handle_key_event(KeyEvent::new(KeyCode::Tab, KeyModifiers::NONE));
+    assert_no_submit_op(&mut tab_op_rx);
+    assert!(
+        tab_chat
+            .input_queue
+            .queued_user_messages
+            .front()
+            .is_some_and(|message| !message.run_user_prompt_submit_hook)
+    );
+    tab_chat.input_queue.suppress_queue_autosend = false;
+    assert!(tab_chat.maybe_send_next_queued_input());
+    assert!(matches!(
+        next_submit_op(&mut tab_op_rx),
+        Op::UserTurn {
+            run_user_prompt_submit_hook: false,
+            ..
+        }
+    ));
+}
