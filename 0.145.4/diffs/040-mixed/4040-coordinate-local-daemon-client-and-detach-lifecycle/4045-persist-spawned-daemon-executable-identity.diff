+#[cfg(unix)]
+async fn terminate_spawned_child(child: &mut tokio::process::Child) -> Result<()> {
+    if child
+        .try_wait()
+        .context("failed to inspect spawned process")?
+        .is_some()
+    {
+        return Ok(());
+    }
+    match child.kill().await {
+        Ok(()) => Ok(()),
+        Err(err) if child.try_wait()?.is_some() => Ok(()),
+        Err(err) => Err(err).context("failed to kill spawned process"),
+    }
+}
