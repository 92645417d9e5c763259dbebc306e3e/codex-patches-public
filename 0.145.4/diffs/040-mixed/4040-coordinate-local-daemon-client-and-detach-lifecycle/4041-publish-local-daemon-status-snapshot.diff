+async fn daemon_status_reports_only_initialized_active_clients() -> Result<()> {
+    let server = create_mock_responses_server_sequence_unchecked(Vec::new()).await;
+    let codex_home = TempDir::new()?;
+    create_config_toml(codex_home.path(), &server.uri(), "never")?;
+    let (mut process, bind_addr) = spawn_websocket_server(codex_home.path()).await?;
+
+    let mut daemon = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut daemon, /*id*/ 1, "codex_app_server_daemon").await?;
+    let _: InitializeResponse = to_response(read_response_for_id(&mut daemon, 1).await?)?;
+    send_daemon_status_request(&mut daemon, /*id*/ 101).await?;
+    let status = read_daemon_status_response(&mut daemon, /*id*/ 101).await?;
+    assert_eq!(status.active_client_count, 0);
+    assert_eq!(status.running_assistant_turn_count, 0);
+
+    let mut backend_probe = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut backend_probe, /*id*/ 3, "codex-backend").await?;
+    let _: InitializeResponse = to_response(read_response_for_id(&mut backend_probe, 3).await?)?;
+    send_daemon_status_request(&mut daemon, /*id*/ 103).await?;
+    assert_eq!(
+        read_daemon_status_response(&mut daemon, 103)
+            .await?
+            .active_client_count,
+        0
+    );
+
+    let mut client = connect_websocket(bind_addr).await?;
+    send_initialize_request(&mut client, /*id*/ 2, "ws_client").await?;
+    let _: InitializeResponse = to_response(read_response_for_id(&mut client, 2).await?)?;
+    send_daemon_status_request(&mut client, /*id*/ 200).await?;
+    let unauthorized = read_error_for_id(&mut client, /*id*/ 200).await?;
+    assert!(unauthorized.error.message.contains("unknown method"));
+
+    send_daemon_status_request(&mut daemon, /*id*/ 104).await?;
+    let status = read_daemon_status_response(&mut daemon, /*id*/ 104).await?;
+    assert_eq!(status.active_client_count, 1);
+    assert_eq!(status.running_assistant_turn_count, 0);
+
+    client.close(None).await?;
+    let mut observed_zero = false;
+    for id in 105..=115 {
+        send_daemon_status_request(&mut daemon, id).await?;
+        if read_daemon_status_response(&mut daemon, id)
+            .await?
+            .active_client_count
+            == 0
+        {
+            observed_zero = true;
+            break;
+        }
+        sleep(Duration::from_millis(25)).await;
+    }
+    assert!(observed_zero, "active client count returns to zero");
+
+    process
+        .kill()
+        .await
+        .context("failed to stop websocket app-server process")?;
+    Ok(())
+}
