+
+async fn read_status<S>(
+    websocket: &mut WebSocketStream<S>,
+    deadline: Instant,
+) -> Option<DaemonStatus>
+where
+    S: AsyncRead + AsyncWrite + Unpin,
+{
+    let request = JSONRPCMessage::Request(JSONRPCRequest {
+        id: STATUS_REQUEST_ID,
+        method: "internal/daemon/status".to_string(),
+        params: None,
+        trace: None,
+    });
+    send_message(websocket, &request).await.ok()?;
+
+    let deadline = deadline
+        .checked_sub(Duration::from_millis(10))
+        .unwrap_or(deadline);
+    timeout_at(deadline, async {
+        loop {
+            match read_message(websocket).await.ok()? {
+                JSONRPCMessage::Response(response) if response.id == STATUS_REQUEST_ID => {
+                    return serde_json::from_value(response.result).ok();
+                }
+                JSONRPCMessage::Error(error) if error.id == STATUS_REQUEST_ID => return None,
+                _ => {}
+            }
+        }
+    })
+    .await
+    .ok()
+    .flatten()
+}
