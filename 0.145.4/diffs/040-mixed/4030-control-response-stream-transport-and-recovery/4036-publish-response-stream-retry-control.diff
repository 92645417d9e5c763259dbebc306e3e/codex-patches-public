+    let EventMsg::ResponsesStreamConnectionStatus(disconnected) = disconnected.msg else {
+        panic!("expected websocket connection status");
+    };
+    assert_eq!(disconnected.thread_id, thread_id);
+    assert!(!disconnected.connected);
+    assert_eq!(disconnected.rtt_ms, None);
+}
