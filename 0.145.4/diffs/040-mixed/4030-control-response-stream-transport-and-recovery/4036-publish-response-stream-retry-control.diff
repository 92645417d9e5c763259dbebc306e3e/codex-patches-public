+    .with_responses_stream_connection_status(thread_id, Some(tx_event));
+
+    assert!(telemetry.should_measure_ws_rtt());
+    telemetry.on_ws_ping_rtt(Duration::from_millis(42));
+    let connected = rx_event.recv().await.expect("connected event");
+    let EventMsg::ResponsesStreamConnectionStatus(connected) = connected.msg else {
+        panic!("expected websocket connection status");
+    };
+    assert_eq!(connected.thread_id, thread_id);
+    assert!(connected.connected);
