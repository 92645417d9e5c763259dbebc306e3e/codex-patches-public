+fn load_config_rejects_each_unsupported_openai_provider_override() {
+    let unsupported: [(&str, &str); 12] = [
+        ("name", "name = \"\""),
+        ("base_url", "base_url = \"https://api.openai.com/v1\""),
+        ("env_key", "env_key = \"\""),
+        ("env_key_instructions", "env_key_instructions = \"\""),
+        (
+            "experimental_bearer_token",
+            "experimental_bearer_token = \"\"",
+        ),
+        ("auth", "auth = { command = \"print-token\" }"),
+        ("aws", "aws = {}"),
+        ("wire_api", "wire_api = \"responses\""),
+        ("query_params", "query_params = {}"),
+        ("http_headers", "http_headers = {}"),
+        ("env_http_headers", "env_http_headers = {}"),
+        ("requires_openai_auth", "requires_openai_auth = false"),
+    ];
+
+    for (field, value) in unsupported {
+        let input = format!("[model_providers.openai]\n{value}\n");
+        let err =
+            toml::from_str::<ConfigToml>(&input).expect_err("unsupported OpenAI provider override");
+        let message = err.to_string();
+        assert!(
+            message.contains("model_providers.openai only supports changing"),
+            "unexpected error for `{field}`: {message}"
+        );
+        assert!(
+            message.contains(&format!("`{field}`")),
+            "error should name `{field}`: {message}"
+        );
+        if field == "base_url" {
+            assert!(
+                message.contains("use `openai_base_url` for `base_url`"),
+                "base_url error should direct users to openai_base_url: {message}"
+            );
+        }
+    }
