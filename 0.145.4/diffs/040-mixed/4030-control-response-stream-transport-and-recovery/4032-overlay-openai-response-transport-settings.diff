+    let tmp = tempdir().expect("tempdir");
+    let config_path = tmp.path().join(CONFIG_TOML_FILE);
+    std::fs::write(&config_path, "model = \"user\"\n").unwrap();
+
+    let service = ConfigManager::without_managed_config_for_tests(tmp.path().to_path_buf());
+    for (field, value) in [
+        ("request_max_retries", serde_json::json!(3)),
+        ("stream_max_retries", serde_json::json!(30)),
+        ("stream_idle_timeout_ms", serde_json::json!(120_000)),
+        ("websocket_connect_timeout_ms", serde_json::json!(15_000)),
+        ("supports_websockets", serde_json::json!(false)),
+    ] {
+        service
+            .write_value(ConfigValueWriteParams {
+                file_path: Some(config_path.display().to_string()),
+                key_path: format!("model_providers.openai.{field}"),
+                value,
+                merge_strategy: MergeStrategy::Replace,
+                expected_version: None,
+            })
+            .await
+            .unwrap_or_else(|error| {
+                panic!("should allow OpenAI transport override {field}: {error}")
+            });
+    }
+
+    let contents = std::fs::read_to_string(config_path).expect("read config");
+    let config: TomlValue = toml::from_str(&contents).expect("parse config");
+    let openai = config
+        .get("model_providers")
+        .and_then(TomlValue::as_table)
+        .and_then(|providers| providers.get("openai"))
+        .and_then(TomlValue::as_table)
+        .expect("OpenAI provider overrides");
+
+    assert_eq!(openai.len(), 5);
+    assert_eq!(
+        openai
+            .get("supports_websockets")
+            .and_then(TomlValue::as_bool),
+        Some(false)
+    );
+}
