+#[tokio::test]
+async fn load_config_applies_openai_websocket_override_with_custom_base_url() {
+    let cfg = toml::from_str::<ConfigToml>(
+        r#"
+openai_base_url = "http://127.0.0.1:18080/backend-api/codex"
+
+[model_providers.openai]
+supports_websockets = true
+"#,
+    )
+    .expect("OpenAI websocket override should deserialize");
+
+    let config = Config::load_from_base_config_with_overrides(
+        cfg,
+        ConfigOverrides::default(),
+        tempdir().expect("tempdir").abs(),
+    )
+    .await
+    .expect("load config");
+
+    assert_eq!(config.model_provider_id, "openai");
+    assert_eq!(
+        config.model_provider.base_url.as_deref(),
+        Some("http://127.0.0.1:18080/backend-api/codex")
+    );
+    assert!(config.model_provider.supports_websockets);
+}
