+/// Applies presence-sensitive local overrides, then delegates all ordinary
+/// provider merging to the upstream runtime-provider implementation.
+pub fn merge_configured_model_provider_overrides(
+    mut model_providers: HashMap<String, ModelProviderInfo>,
+    configured_model_providers: HashMap<String, ConfiguredModelProvider>,
+) -> Result<HashMap<String, ModelProviderInfo>, String> {
+    let mut ordinary_providers = HashMap::new();
+    for (key, provider) in configured_model_providers {
+        if key == OPENAI_PROVIDER_ID {
+            validate_openai_provider_override(&provider)?;
+            if let Some(openai) = model_providers.get_mut(OPENAI_PROVIDER_ID) {
+                overlay_openai_transport(openai, provider);
+            }
+        } else {
+            ordinary_providers.insert(key, provider.into());
+        }
+    }
+    merge_configured_model_providers(model_providers, ordinary_providers)
+}
+
+pub fn validate_openai_provider_override(provider: &ConfiguredModelProvider) -> Result<(), String> {
+    let mut unsupported = Vec::new();
+    if provider.name.is_some() {
+        unsupported.push("`name`");
+    }
+    if provider.base_url.is_some() {
+        unsupported.push("`base_url`");
+    }
+    if provider.env_key.is_some() {
+        unsupported.push("`env_key`");
+    }
+    if provider.env_key_instructions.is_some() {
+        unsupported.push("`env_key_instructions`");
+    }
+    if provider.experimental_bearer_token.is_some() {
+        unsupported.push("`experimental_bearer_token`");
+    }
+    if provider.auth.is_some() {
+        unsupported.push("`auth`");
+    }
+    if provider.aws.is_some() {
+        unsupported.push("`aws`");
+    }
+    if provider.wire_api.is_some() {
+        unsupported.push("`wire_api`");
+    }
+    if provider.query_params.is_some() {
+        unsupported.push("`query_params`");
+    }
+    if provider.http_headers.is_some() {
+        unsupported.push("`http_headers`");
+    }
+    if provider.env_http_headers.is_some() {
+        unsupported.push("`env_http_headers`");
+    }
+    if provider.requires_openai_auth.is_some() {
+        unsupported.push("`requires_openai_auth`");
+    }
+
+    if unsupported.is_empty() {
+        return Ok(());
+    }
+
+    let mut message = format!(
+        "model_providers.{OPENAI_PROVIDER_ID} only supports changing \
+`request_max_retries`, `stream_max_retries`, `stream_idle_timeout_ms`, \
+`websocket_connect_timeout_ms`, and `supports_websockets`; unsupported fields: {}",
+        unsupported.join(", ")
+    );
+    if provider.base_url.is_some() {
+        message.push_str("; use `openai_base_url` for `base_url`");
+    }
+    Err(message)
+}
+
+fn overlay_openai_transport(base: &mut ModelProviderInfo, provider: ConfiguredModelProvider) {
+    if let Some(value) = provider.request_max_retries {
+        base.request_max_retries = Some(value);
+    }
+    if let Some(value) = provider.stream_max_retries {
+        base.stream_max_retries = Some(value);
+    }
+    if let Some(value) = provider.stream_idle_timeout_ms {
+        base.stream_idle_timeout_ms = Some(value);
+    }
+    if let Some(value) = provider.websocket_connect_timeout_ms {
+        base.websocket_connect_timeout_ms = Some(value);
+    }
+    if let Some(value) = provider.supports_websockets {
+        base.supports_websockets = value;
+    }
+}
