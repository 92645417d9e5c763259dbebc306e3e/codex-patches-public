+#[tokio::test]
+async fn disabled_optional_state_dbs_do_not_touch_existing_invalid_files() -> anyhow::Result<()> {
+    let home = TempDir::new().expect("temp dir");
+    let invalid_contents = b"not a sqlite database";
+    let logs_path = codex_state::logs_db_path(home.path());
+    let goals_path = codex_state::goals_db_path(home.path());
+    let memories_path = codex_state::memories_db_path(home.path());
+    std::fs::write(&logs_path, invalid_contents)?;
+    std::fs::write(&goals_path, invalid_contents)?;
+    std::fs::write(&memories_path, invalid_contents)?;
+    let config = RolloutConfig {
+        use_goals: false,
+        persist_feedback_logs: false,
+        generate_memories: false,
+        ..test_rollout_config(&home)
+    };
+
+    let runtime = try_init(&config).await?;
+    assert!(
+        runtime
+            .query_logs(&codex_state::LogQuery::default())
+            .await?
+            .is_empty()
+    );
+    assert_eq!(
+        runtime
+            .thread_goals()
+            .get_thread_goal(ThreadId::new())
+            .await?,
+        None
+    );
+    runtime.memories().clear_memory_data().await?;
+    assert_eq!(std::fs::read(&logs_path)?, invalid_contents);
+    assert_eq!(std::fs::read(&goals_path)?, invalid_contents);
+    assert_eq!(std::fs::read(&memories_path)?, invalid_contents);
+    runtime.close().await;
+
+    Ok(())
+}
