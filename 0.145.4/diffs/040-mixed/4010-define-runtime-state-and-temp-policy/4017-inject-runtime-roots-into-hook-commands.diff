+#[tokio::test]
+async fn hook_runtime_environment_is_local_and_feature_gated() -> std::io::Result<()> {
+    let temp = tempfile::tempdir()?;
+    let codex_home = temp.path().join("home");
+    let cwd = temp.path().join("workspace");
+    std::fs::create_dir_all(&codex_home)?;
+    std::fs::create_dir_all(&cwd)?;
+    let cwd = AbsolutePathBuf::from_absolute_path(&cwd)?;
+    let mut config = ConfigBuilder::without_managed_config_for_tests()
+        .codex_home(codex_home.clone())
+        .fallback_cwd(Some(cwd.to_path_buf()))
+        .build()
+        .await?;
+    config
+        .features
+        .enable(Feature::CodexHooks)
+        .expect("enable Codex hooks");
+    let environment = TurnEnvironment::new(
+        codex_exec_server::LOCAL_ENVIRONMENT_ID.to_string(),
+        Arc::new(codex_exec_server::Environment::default_for_tests()),
+        PathUri::from_abs_path(&cwd),
+        Vec::new(),
+        /*shell*/ None,
+    );
+
+    let env = super::build_hook_runtime_env_overlay(&config, Some(&environment));
+
+    for key in crate::exec_env::runtime_path_env_keys() {
+        assert!(env.contains_key(key), "missing {key}");
+    }
+    assert_eq!(
+        env.get(crate::exec_env::CODEX_HOME_ENV_VAR),
+        Some(&codex_home.to_string_lossy().into_owned())
+    );
+    assert!(super::build_hook_runtime_env_overlay(&config, None).is_empty());
+    config.features.disable(Feature::CodexHooks);
+    assert!(super::build_hook_runtime_env_overlay(&config, Some(&environment)).is_empty());
+    Ok(())
+}
