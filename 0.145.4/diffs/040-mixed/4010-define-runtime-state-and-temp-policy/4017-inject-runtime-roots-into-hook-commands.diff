+fn merge_runtime_env_overlay(
+    handlers: &mut [ConfiguredHandler],
+    runtime_env_overlay: &HashMap<String, String>,
+) {
+    if runtime_env_overlay.is_empty() {
+        return;
+    }
+
+    for handler in handlers {
+        let source_env = std::mem::take(&mut handler.env);
+        handler.env = runtime_env_overlay.clone();
+        #[cfg(windows)]
+        for key in source_env.keys() {
+            handler
+                .env
+                .retain(|runtime_key, _| !runtime_key.eq_ignore_ascii_case(key));
+        }
+        handler.env.extend(source_env);
+    }
+}
