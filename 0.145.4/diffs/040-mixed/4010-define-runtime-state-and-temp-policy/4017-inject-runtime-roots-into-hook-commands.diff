+fn build_hook_runtime_env_overlay(
+    config: &Config,
+    environment: Option<&TurnEnvironment>,
+) -> HashMap<String, String> {
+    if !config.features.enabled(Feature::CodexHooks) {
+        return HashMap::new();
+    }
+    let Some(cwd) = environment.and_then(|environment| environment.cwd().to_abs_path().ok()) else {
+        return HashMap::new();
+    };
+
+    create_runtime_env(
+        &config.permissions.shell_environment_policy,
+        /*thread_id*/ None,
+        Some(cwd.as_path()),
+        config.codex_home.as_path(),
+    )
+}
