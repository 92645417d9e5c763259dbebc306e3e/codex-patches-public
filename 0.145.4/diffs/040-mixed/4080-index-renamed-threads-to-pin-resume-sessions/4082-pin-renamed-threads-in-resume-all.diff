+async fn load_pinned_renamed_rows(
+    app_server: &mut AppServerSession,
+    codex_home: &Path,
+    provider_filter: &ProviderFilter,
+    include_non_interactive: bool,
+) -> (Vec<Row>, HashSet<ThreadId>) {
+    let entries = match codex_rollout::list_current_thread_name_entries(codex_home, PAGE_SIZE).await
+    {
+        Ok(entries) => entries,
+        Err(err) => {
+            warn!(%err, "failed to read renamed-thread candidates for resume picker");
+            return (Vec::new(), HashSet::new());
+        }
+    };
+    let mut rows = Vec::with_capacity(entries.len());
+    let mut pinned_thread_ids = HashSet::with_capacity(entries.len());
+    for entry in entries {
+        let mut thread = match app_server
+            .thread_read(entry.id, /*include_turns*/ false)
+            .await
+        {
+            Ok(thread) => thread,
+            Err(err) => {
+                warn!(thread_id = %entry.id, %err, "skipping unreadable renamed thread");
+                continue;
+            }
+        };
+        let Some(thread_name) = pinned_thread_name(&thread, &entry.thread_name) else {
+            continue;
+        };
+        if !thread_metadata_is_pinnable(
+            &thread,
+            codex_home,
+            provider_filter,
+            include_non_interactive,
+        ) {
+            continue;
+        }
+        thread.name = Some(thread_name);
+        if let Some(row) = row_from_app_server_thread(thread) {
+            pinned_thread_ids.insert(entry.id);
+            rows.push(row);
+        }
+    }
+    (rows, pinned_thread_ids)
+}
+
+fn pinned_thread_name(thread: &Thread, indexed_name: &str) -> Option<String> {
+    let canonical_name = thread
+        .name
+        .as_deref()
+        .map(str::trim)
+        .filter(|name| !name.is_empty())
+        .map(str::to_string);
+    match thread.history_mode {
+        codex_app_server_protocol::ThreadHistoryMode::Paginated => canonical_name,
+        codex_app_server_protocol::ThreadHistoryMode::Legacy => canonical_name.or_else(|| {
+            let indexed_name = indexed_name.trim();
+            (!indexed_name.is_empty()).then(|| indexed_name.to_string())
+        }),
+    }
+}
+
+fn thread_metadata_is_pinnable(
+    thread: &Thread,
+    codex_home: &Path,
+    provider_filter: &ProviderFilter,
+    include_non_interactive: bool,
+) -> bool {
+    if thread.ephemeral
+        || thread.parent_thread_id.is_some()
+        || thread.path.as_ref().is_some_and(|path| {
+            path.starts_with(codex_home.join(codex_rollout::ARCHIVED_SESSIONS_SUBDIR))
+        })
+    {
+        return false;
+    }
+    let provider_matches = match provider_filter {
+        ProviderFilter::Any => true,
+        ProviderFilter::MatchDefault(provider) => thread.model_provider.as_str() == provider,
+    };
+    provider_matches
+        && match &thread.source {
+            SessionSource::Cli | SessionSource::VsCode => true,
+            SessionSource::Exec | SessionSource::AppServer => include_non_interactive,
+            SessionSource::Custom(_) | SessionSource::SubAgent(_) | SessionSource::Unknown => false,
+        }
+}
