+    #[test]
+    fn pinned_candidate_requires_canonical_resumable_metadata() {
+        let home = Path::new("/tmp/codex-home");
+        let provider = ProviderFilter::MatchDefault(String::from("openai"));
+        let base = make_named_thread(ThreadId::new(), SessionSource::Cli);
+        assert!(thread_metadata_is_pinnable(&base, home, &provider, false));
+        assert_eq!(
+            pinned_thread_name(&base, "stale index name"),
+            Some(String::from("Named session"))
+        );
+
+        let mut wrong_provider = base.clone();
+        wrong_provider.model_provider = String::from("other");
+        assert!(!thread_metadata_is_pinnable(
+            &wrong_provider,
+            home,
+            &provider,
+            false
+        ));
+
+        let mut child = base.clone();
+        child.parent_thread_id = Some(ThreadId::new().to_string());
+        assert!(!thread_metadata_is_pinnable(&child, home, &provider, false));
+
+        let mut legacy_without_distinct_name = base.clone();
+        legacy_without_distinct_name.name = None;
+        assert_eq!(
+            pinned_thread_name(&legacy_without_distinct_name, "conversation preview"),
+            Some(String::from("conversation preview"))
+        );
+        let mut paginated_without_canonical_name = legacy_without_distinct_name.clone();
+        paginated_without_canonical_name.history_mode =
+            codex_app_server_protocol::ThreadHistoryMode::Paginated;
+        assert_eq!(
+            pinned_thread_name(&paginated_without_canonical_name, "stale index name"),
+            None
+        );
+
+        let mut archived = base.clone();
+        archived.path = Some(
+            home.join(codex_rollout::ARCHIVED_SESSIONS_SUBDIR)
+                .join("row.jsonl"),
+        );
+        assert!(!thread_metadata_is_pinnable(
+            &archived, home, &provider, false
+        ));
+
+        let exec = make_named_thread(ThreadId::new(), SessionSource::Exec);
+        assert!(!thread_metadata_is_pinnable(&exec, home, &provider, false));
+        assert!(thread_metadata_is_pinnable(&exec, home, &provider, true));
+
+        let subagent = make_named_thread(
+            ThreadId::new(),
+            SessionSource::SubAgent(codex_protocol::protocol::SubAgentSource::Other(
+                String::from("test"),
+            )),
+        );
+        assert!(!thread_metadata_is_pinnable(
+            &subagent, home, &provider, true
+        ));
+    }
