+/// Highlights the cache-hit suffix in terminal output when ANSI color is enabled.
+pub fn format_token_usage_for_terminal(text: String, color_enabled: bool) -> String {
+    if !color_enabled {
+        return text;
+    }
+    let Some(hit_suffix_start) = text.find("% hit") else {
+        return text;
+    };
+    let mut marker_start = hit_suffix_start;
+    while marker_start > 0 {
+        let byte = text.as_bytes()[marker_start - 1];
+        if byte.is_ascii_digit() || byte == b'.' {
+            marker_start -= 1;
+        } else {
+            break;
+        }
+    }
+    let marker_end = hit_suffix_start + "% hit".len();
+    let numeric = &text[marker_start..hit_suffix_start];
+    let mut parts = numeric.split('.');
+    let Some(integer) = parts.next() else {
+        return text;
+    };
+    let fraction = parts.next();
+    let valid = !integer.is_empty()
+        && integer.bytes().all(|byte| byte.is_ascii_digit())
+        && fraction.is_none_or(|digits| {
+            !digits.is_empty() && digits.bytes().all(|byte| byte.is_ascii_digit())
+        })
+        && parts.next().is_none();
+    if !valid {
+        return text;
+    }
+    format!(
+        "{}\u{1b}[33m{}\u{1b}[39m{}",
+        &text[..marker_start],
+        &text[marker_start..marker_end],
+        &text[marker_end..]
+    )
+}
