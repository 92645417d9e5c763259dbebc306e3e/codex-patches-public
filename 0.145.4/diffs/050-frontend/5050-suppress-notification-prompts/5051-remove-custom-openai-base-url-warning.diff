+#[tokio::test]
+async fn model_selection_popup_hides_custom_base_url_warning() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(Some("gpt-5.2")).await;
+    chat.thread_id = Some(ThreadId::new());
+    chat.config.model_provider.base_url = Some("https://example.com/v1".to_string());
+    chat.open_model_popup();
+
+    let popup = render_bottom_popup(&chat, /*width*/ 80);
+    assert!(
+        !popup.contains("Warning: OpenAI base URL is overridden"),
+        "expected custom base URL warning to be hidden; popup: {popup}"
+    );
+}
