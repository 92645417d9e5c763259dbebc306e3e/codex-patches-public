+fn instant_from_unix_timestamp_secs(started_at: i64) -> Option<Instant> {
+    let started_at = u64::try_from(started_at).ok()?;
+    let started_at = UNIX_EPOCH.checked_add(Duration::from_secs(started_at))?;
+    let now_system = SystemTime::now();
+    let now_instant = Instant::now();
+    match now_system.duration_since(started_at) {
+        Ok(age) => now_instant.checked_sub(age).or(Some(now_instant)),
+        Err(_) => Some(now_instant),
+    }
+}
+
+fn elapsed_seconds_from_duration_ms(duration_ms: Option<i64>) -> Option<u64> {
+    duration_ms
+        .and_then(|duration_ms| u64::try_from(duration_ms).ok())
+        .map(|duration_ms| duration_ms / 1_000)
+}
