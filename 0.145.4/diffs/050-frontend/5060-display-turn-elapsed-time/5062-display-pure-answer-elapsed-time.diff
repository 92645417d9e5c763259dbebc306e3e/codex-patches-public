+#[tokio::test]
+async fn completed_turn_without_visible_answer_has_no_answer_footer() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+
+    handle_turn_completed(&mut chat, "turn-1", Some(125_000));
+
+    let combined = drain_insert_history(&mut rx)
+        .iter()
+        .map(|lines| lines_to_single_string(lines))
+        .collect::<String>();
+    assert!(!combined.contains("Answered in"), "{combined}");
+}
+
+#[tokio::test]
+async fn subsecond_pure_answer_has_no_unlabeled_timing_separator() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+    complete_assistant_message(
+        &mut chat,
+        "msg-final",
+        "Fast answer.",
+        Some(MessagePhase::FinalAnswer),
+    );
+
+    handle_turn_completed(&mut chat, "turn-1", /*duration_ms*/ None);
+
+    let cells = drain_insert_history(&mut rx);
+    assert!(
+        cells
+            .iter()
+            .any(|lines| lines_to_single_string(lines).contains("Fast answer."))
+    );
+    assert!(cells.iter().all(|lines| {
+        let rendered = lines_to_single_string(lines);
+        !rendered.contains("Answered in")
+            && !rendered.lines().any(|line| {
+                let trimmed = line.trim();
+                !trimmed.is_empty() && trimmed.chars().all(|ch| ch == '─')
+            })
+    }));
+}
