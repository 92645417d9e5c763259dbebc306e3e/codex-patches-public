+#[tokio::test]
+async fn pure_answer_footer_uses_local_elapsed_without_work_label() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    handle_turn_started(&mut chat, "turn-1");
+    let local_started_at = std::time::Instant::now() - std::time::Duration::from_secs(125);
+    chat.turn_lifecycle.active_turn_started_at = Some(local_started_at);
+    chat.bottom_pane
+        .set_status_timer_started_at(local_started_at);
+
+    complete_assistant_message(
+        &mut chat,
+        "msg-final",
+        "Direct answer.",
+        Some(MessagePhase::FinalAnswer),
+    );
+    handle_turn_completed(&mut chat, "turn-1", Some(597_000));
+
+    let combined = drain_insert_history(&mut rx)
+        .iter()
+        .map(|lines| lines_to_single_string(lines))
+        .collect::<String>();
+    assert!(combined.contains("Answered in 2m 05s"), "{combined}");
+    assert!(!combined.contains("Worked for"), "{combined}");
+    assert!(!combined.contains("Answered in 9m 57s"), "{combined}");
+}
