+#[test]
+fn live_agent_surfaces_fill_rows_without_a_closing_rule() {
+    for channel in [
+        AgentMessageChannel::Commentary,
+        AgentMessageChannel::FinalAnswer,
+    ] {
+        let stable = AgentMessageCell::new_hyperlink_lines_with_channel(
+            vec![HyperlinkLine::from("first"), HyperlinkLine::from("")],
+            /*is_first_line*/ true,
+            channel,
+        );
+        let tail = StreamingAgentTailCell::new_with_channel(
+            vec![HyperlinkLine::from("second"), HyperlinkLine::from("")],
+            /*is_first_line*/ false,
+            channel,
+        );
+
+        assert_eq!(stable.fill_background_style(), Some(user_input_style()));
+        assert_eq!(tail.fill_background_style(), Some(user_input_style()));
+        let stable_lines = stable.display_lines(/*width*/ 20);
+        let tail_lines = tail.display_lines(/*width*/ 20);
+        for line in stable_lines.iter().chain(&tail_lines) {
+            assert_eq!(line.width(), 20);
+        }
+        let is_rule = |line: &Line<'_>| {
+            line.spans
+                .iter()
+                .any(|span| !span.content.is_empty() && span.content.chars().all(|ch| ch == '─'))
+        };
+        assert!(is_rule(&stable_lines[0]));
+        assert!(!stable_lines.last().is_some_and(is_rule));
+        assert!(tail_lines.iter().all(|line| !is_rule(line)));
+    }
+}
