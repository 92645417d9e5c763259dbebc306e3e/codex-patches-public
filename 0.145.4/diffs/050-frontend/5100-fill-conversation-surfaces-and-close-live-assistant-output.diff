+#[tokio::test]
+async fn live_assistant_channels_fill_one_open_surface_until_completion() {
+    for (phase, expected_channel) in [
+        (
+            MessagePhase::Commentary,
+            history_cell::AgentMessageChannel::Commentary,
+        ),
+        (
+            MessagePhase::FinalAnswer,
+            history_cell::AgentMessageChannel::FinalAnswer,
+        ),
+    ] {
+        let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+        handle_turn_started(&mut chat, "turn-1");
+        chat.handle_server_notification(
+            ServerNotification::ItemStarted(ItemStartedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                started_at_ms: 0,
+                item: AppServerThreadItem::AgentMessage {
+                    id: "msg-1".to_string(),
+                    text: String::new(),
+                    phase: Some(phase.clone()),
+                    memory_citation: None,
+                },
+            }),
+            /*replay_kind*/ None,
+        );
+        for delta in ["first paragraph\n\n", "second paragraph\n"] {
+            handle_agent_message_delta(&mut chat, delta);
+            chat.on_commit_tick();
+        }
+
+        let mut provisional_cells = 0;
+        while let Ok(event) = rx.try_recv() {
+            if let AppEvent::InsertHistoryCell(cell) = event
+                && cell.as_any().is::<history_cell::AgentMessageCell>()
+            {
+                provisional_cells += 1;
+                assert_eq!(cell.fill_background_style(), Some(user_input_style()));
+                let lines = cell.display_lines(/*width*/ 40);
+                assert_eq!(lines.last().map(Line::width), Some(40));
+                assert!(!lines.last().is_some_and(|line| {
+                    line.spans.iter().any(|span| {
+                        !span.content.is_empty()
+                            && span.content.chars().all(|character| character == '─')
+                    })
+                }));
+            }
+        }
+        assert!(provisional_cells > 0, "no provisional {phase:?} cells");
+        if let Some(active) = chat.transcript.active_cell.as_ref() {
+            assert_eq!(active.fill_background_style(), Some(user_input_style()));
+        }
+
+        complete_assistant_message(
+            &mut chat,
+            "msg-1",
+            "first paragraph\n\nsecond paragraph\n",
+            Some(phase.clone()),
+        );
+        let mut finalized = false;
+        while let Ok(event) = rx.try_recv() {
+            if let AppEvent::ConsolidateAgentMessage {
+                source,
+                cwd,
+                channel,
+                ..
+            } = event
+            {
+                assert_eq!(channel, expected_channel);
+                let cell = history_cell::AgentMarkdownCell::new_with_channel(source, &cwd, channel);
+                let lines = cell.display_lines(/*width*/ 40);
+                assert!(lines.last().is_some_and(|line| {
+                    line.spans.iter().any(|span| {
+                        !span.content.is_empty()
+                            && span.content.chars().all(|character| character == '─')
+                    })
+                }));
+                finalized = true;
+            }
+        }
+        assert!(finalized, "{phase:?} stream was not consolidated");
+    }
+}
