+fn filled_surface_height(lines: Vec<Line<'static>>, width: u16) -> u16 {
+    let width = width.max(1);
+    if lines.iter().all(|line| line.width() <= usize::from(width)) {
+        return lines.len().try_into().unwrap_or(u16::MAX);
+    }
