+#[tokio::test]
+async fn status_line_uses_submitted_model_context_until_turn_completion() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(Some("gpt-5")).await;
+    chat.config.tui_status_line = Some(vec!["model-with-reasoning".to_string()]);
+    chat.input_queue.submitted_turn_context =
+        Some(crate::chatwidget::input_queue::SubmittedTurnContext {
+            model: "gpt-5".to_string(),
+            reasoning_effort: Some(ReasoningEffortConfig::High),
+        });
+    chat.set_model("gpt-5.4");
+    chat.set_reasoning_effort(Some(ReasoningEffortConfig::Low));
+    chat.refresh_status_line();
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5 high".to_string()));
+    let line = chat.model_with_reasoning_display_line();
+    assert_eq!(
+        line.spans[0].style,
+        crate::model_color::model_style("gpt-5")
+    );
+    assert_eq!(
+        line.spans[2].style.fg,
+        Some(ratatui::style::Color::Rgb(255, 128, 0))
+    );
+
+    chat.config.tui_status_line_use_colors = false;
+    let monochrome = chat.model_with_reasoning_display_line();
+    assert_eq!(monochrome.spans[0].style, ratatui::style::Style::default());
+    assert_eq!(monochrome.spans[2].style, ratatui::style::Style::default());
+
+    chat.on_task_complete(
+        /*last_agent_message*/ None, /*duration_ms*/ None, false,
+    );
+    assert!(chat.input_queue.submitted_turn_context.is_none());
+}
