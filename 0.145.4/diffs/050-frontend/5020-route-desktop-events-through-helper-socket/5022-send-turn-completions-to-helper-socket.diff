+
+fn is_primary_or_bootstrap_thread(
+    primary_thread_id: Option<ThreadId>,
+    thread_id: ThreadId,
+) -> bool {
+    primary_thread_id == Some(thread_id) || primary_thread_id.is_none()
+}
+
+fn completion_request_for_notification(
+    notification: &ServerNotification,
+    is_primary_thread: bool,
+    working_dir: &Path,
+    created_at: chrono::DateTime<chrono::Utc>,
+) -> Option<CompletionRequest> {
+    if !is_primary_thread {
+        return None;
+    }
+    let ServerNotification::TurnCompleted(notification) = notification else {
+        return None;
+    };
+    if notification.turn.status != TurnStatus::Completed {
+        return None;
+    }
+
+    let session_id = Uuid::parse_str(&notification.thread_id).ok()?.to_string();
+    let duration_ms = notification
+        .turn
+        .duration_ms
+        .and_then(|duration_ms| u64::try_from(duration_ms).ok())
+        .unwrap_or_default();
+
+    Some(CompletionRequest::new(
+        session_id.clone(),
+        stable_turn_id(&notification.turn.id),
+        "Completed".to_string(),
+        duration_ms,
+        working_dir.display().to_string(),
+        "Codex task finished".to_string(),
+        format!(
+            "Thread {session_id} turn {} completed.",
+            notification.turn.id
+        ),
+        created_at.to_rfc3339_opts(chrono::SecondsFormat::Secs, true),
+    ))
+}
+
+fn stable_turn_id(turn_id: &str) -> u64 {
+    if let Some(turn_id) = trailing_positive_number(turn_id) {
+        return turn_id;
+    }
+
+    let mut hasher = DefaultHasher::new();
+    turn_id.hash(&mut hasher);
+    (hasher.finish() % (i64::MAX as u64)).max(1)
+}
+
+fn trailing_positive_number(value: &str) -> Option<u64> {
+    let digits = value
+        .chars()
+        .rev()
+        .take_while(|character| character.is_ascii_digit())
+        .collect::<Vec<_>>();
+    if digits.is_empty() {
+        return None;
+    }
+
+    digits
+        .into_iter()
+        .rev()
+        .collect::<String>()
+        .parse::<u64>()
+        .ok()
+        .filter(|number| *number > 0)
+}
