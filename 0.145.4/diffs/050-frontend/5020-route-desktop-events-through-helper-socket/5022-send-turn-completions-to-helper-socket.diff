+#[cfg(test)]
+mod tests {
+    use super::*;
+    use codex_app_server_protocol::Turn;
+    use codex_app_server_protocol::TurnCompletedNotification;
+    use codex_app_server_protocol::TurnItemsView;
+
+    fn turn_completed_notification(
+        status: TurnStatus,
+        thread_id: &str,
+        turn_id: &str,
+    ) -> ServerNotification {
+        ServerNotification::TurnCompleted(TurnCompletedNotification {
+            thread_id: thread_id.to_string(),
+            turn: Turn {
+                id: turn_id.to_string(),
+                items: Vec::new(),
+                items_view: TurnItemsView::NotLoaded,
+                status,
+                error: None,
+                started_at: Some(1),
+                completed_at: Some(3),
+                duration_ms: Some(2_000),
+            },
+        })
+    }
+
+    #[test]
+    fn completion_request_maps_completed_primary_turn() {
+        let notification = turn_completed_notification(
+            TurnStatus::Completed,
+            "123e4567-e89b-12d3-a456-426614174000",
+            "turn-9",
+        );
+        let created_at = chrono::DateTime::parse_from_rfc3339("2026-06-12T10:11:12Z")
+            .expect("valid timestamp")
+            .with_timezone(&chrono::Utc);
+
+        let request = completion_request_for_notification(
+            &notification,
+            true,
+            Path::new("/repo"),
+            created_at,
+        )
+        .expect("completion request");
+
+        assert_eq!(request.session_id, "123e4567-e89b-12d3-a456-426614174000");
+        assert_eq!(request.turn_id, 9);
+        assert_eq!(request.status, "Completed");
+        assert_eq!(request.duration_ms, 2_000);
+        assert_eq!(request.working_dir, "/repo");
+        assert_eq!(request.title, "Codex task finished");
+        assert_eq!(
+            request.body,
+            "Thread 123e4567-e89b-12d3-a456-426614174000 turn turn-9 completed."
+        );
+        assert_eq!(request.created_at, "2026-06-12T10:11:12Z");
+    }
+
+    #[test]
+    fn completion_request_skips_failed_or_secondary_turns() {
+        let completed = turn_completed_notification(
+            TurnStatus::Completed,
+            "123e4567-e89b-12d3-a456-426614174000",
+            "turn-9",
+        );
+        let failed = turn_completed_notification(
+            TurnStatus::Failed,
+            "123e4567-e89b-12d3-a456-426614174000",
+            "turn-9",
+        );
+        let created_at = chrono::Utc::now();
+
+        assert!(
+            completion_request_for_notification(&completed, false, Path::new("/repo"), created_at,)
+                .is_none()
+        );
+        assert!(
+            completion_request_for_notification(&failed, true, Path::new("/repo"), created_at,)
+                .is_none()
+        );
+    }
+
+    #[test]
+    fn completion_notifications_route_to_primary_or_bootstrap_thread_only() {
+        let primary_thread_id = ThreadId::new();
+        let secondary_thread_id = ThreadId::new();
+
+        assert!(is_primary_or_bootstrap_thread(
+            Some(primary_thread_id),
+            primary_thread_id
+        ));
+        assert!(is_primary_or_bootstrap_thread(None, secondary_thread_id));
+        assert!(!is_primary_or_bootstrap_thread(
+            Some(primary_thread_id),
+            secondary_thread_id
+        ));
+    }
+
+    #[test]
+    fn completion_request_skips_invalid_session_id() {
+        let notification =
+            turn_completed_notification(TurnStatus::Completed, "session-123", "turn-9");
+
+        assert!(
+            completion_request_for_notification(
+                &notification,
+                true,
+                Path::new("/repo"),
+                chrono::Utc::now(),
+            )
+            .is_none()
+        );
+    }
+
+    #[test]
+    fn stable_turn_id_uses_numeric_suffix_or_stable_fallback() {
+        assert_eq!(stable_turn_id("42"), 42);
+        assert_eq!(stable_turn_id("turn-9"), 9);
+        assert_eq!(
+            stable_turn_id("turn-without-number"),
+            stable_turn_id("turn-without-number")
+        );
+    }
+}
