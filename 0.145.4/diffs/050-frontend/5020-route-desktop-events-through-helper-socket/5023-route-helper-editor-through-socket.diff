+use crate::codex_socket::HelperEditorResult;
+
+#[derive(Debug, PartialEq, Eq)]
+enum HelperEditorAction {
+    Apply(String),
+    FallBack,
+}
+
+fn helper_editor_action(result: HelperEditorResult) -> HelperEditorAction {
+    match result {
+        HelperEditorResult::Edited(text) => HelperEditorAction::Apply(text.trim_end().to_string()),
+        HelperEditorResult::Unavailable
+        | HelperEditorResult::Disabled
+        | HelperEditorResult::Empty => HelperEditorAction::FallBack,
+    }
+}
 
