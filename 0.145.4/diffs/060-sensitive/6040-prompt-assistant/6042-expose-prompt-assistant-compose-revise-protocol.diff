+    #[test]
+    fn workspace_round_trip_preserves_generation_and_full_candidate() {
+        let workspace = PromptAssistantWorkspace {
+            thread_id: "thread".to_string(),
+            workspace_id: "workspace".to_string(),
+            generation: 3,
+            candidate_generation: 2,
+            candidate_hash: Some("hash".to_string()),
+            phase: PromptAssistantPhase::Ready,
+            active_operation: None,
+            selected_model: "model".to_string(),
+            selected_reasoning_effort: ReasoningEffort::High,
+            candidate: Some("full candidate".to_string()),
+            outcome: Some(PromptAssistantOutcome::Ready),
+            message: None,
+        };
+
+        let encoded = serde_json::to_value(&workspace).expect("serialize workspace");
+        let decoded: PromptAssistantWorkspace =
+            serde_json::from_value(encoded).expect("deserialize workspace");
+        assert_eq!(decoded, workspace);
+    }
