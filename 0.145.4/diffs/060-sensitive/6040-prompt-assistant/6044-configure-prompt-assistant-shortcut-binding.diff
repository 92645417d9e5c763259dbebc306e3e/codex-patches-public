+    #[test]
+    fn prompt_assistant_defaults_to_alt_p_and_rejects_app_conflicts() {
+        let runtime = RuntimeKeymap::from_config(&TuiKeymap::default()).expect("default keymap");
+        assert_eq!(
+            runtime.composer.prompt_assistant,
+            vec![key_hint::alt(KeyCode::Char('p'))]
+        );
+
+        let mut keymap = TuiKeymap::default();
+        keymap.global.open_transcript = Some(one("ctrl-k"));
+        keymap.composer.prompt_assistant = Some(one("ctrl-k"));
+        let err = RuntimeKeymap::from_config(&keymap).expect_err("expected shadowing conflict");
+        assert!(err.contains("composer.prompt_assistant"));
+        assert!(err.contains("open_transcript"));
+    }
