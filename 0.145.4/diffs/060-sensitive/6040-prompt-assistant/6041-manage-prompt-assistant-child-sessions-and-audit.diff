+    fn frozen_context_keeps_latest_summary_and_completed_conversation_only() {
+        let summary = format!("{}\nsummary", crate::compact::SUMMARY_PREFIX);
+        let items = vec![
+            message("user", "old user", None),
+            message("assistant", "old final", Some(MessagePhase::FinalAnswer)),
+            message("user", &summary, None),
+            message("assistant", "commentary", Some(MessagePhase::Commentary)),
+            message("assistant", "final", Some(MessagePhase::FinalAnswer)),
+            ResponseItem::Reasoning {
+                id: None,
+                summary: Vec::new(),
+                content: None,
+                encrypted_content: None,
+                internal_chat_message_metadata_passthrough: None,
+            },
+        ];
+
+        let snapshot = freeze_parent_context(&items);
+        assert_eq!(
+            snapshot
+                .entries
+                .iter()
+                .map(|entry| (entry.kind, entry.text.as_str()))
+                .collect::<Vec<_>>(),
+            vec![
+                (
+                    PromptAssistantContextKind::CompactionSummary,
+                    summary.as_str()
+                ),
+                (PromptAssistantContextKind::Commentary, "commentary"),
+                (PromptAssistantContextKind::Final, "final"),
+            ]
+        );
+    }
