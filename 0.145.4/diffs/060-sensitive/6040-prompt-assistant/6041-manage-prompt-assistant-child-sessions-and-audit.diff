+            )
+            .is_ok()
+        );
+        assert!(
+            parse_prompt_assistant_output(
+                r#"{"status":"blocked","candidate":null,"reason":"unsafe"}"#
+            )
+            .is_ok()
+        );
+        assert!(
+            parse_prompt_assistant_output(r#"{"status":"ready","candidate":null,"reason":null}"#)
+                .is_err()
+        );
+        assert!(
+            parse_prompt_assistant_output(
+                r#"{"status":"blocked","candidate":"partial","reason":"unsafe"}"#
+            )
+            .is_err()
+        );
+    }
