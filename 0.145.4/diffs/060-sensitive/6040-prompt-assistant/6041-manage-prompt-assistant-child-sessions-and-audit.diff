+        .start_thread(StartThreadOptions::new(config))
+        .await
+        .expect("parent thread should start");
+    let thread = manager
+        .start_prompt_assistant_child(
+            parent.thread_id,
+            "prompt-model",
+            None,
+            "Prompt Assistant instructions",
+        )
+        .await
+        .expect("Prompt Assistant thread should start");
+
+    assert_eq!(
+        thread.thread.config_snapshot().await.parent_thread_id,
+        Some(parent.thread_id)
+    );
+    assert_eq!(manager.list_thread_ids().await, vec![parent.thread_id]);
+    assert!(manager.get_thread(thread.thread_id).await.is_err());
+
+    let report = manager
+        .shutdown_all_threads_bounded(Duration::from_secs(10))
+        .await;
+    let mut expected = vec![parent.thread_id, thread.thread_id];
+    expected.sort_by_key(std::string::ToString::to_string);
+    assert_eq!(report.completed, expected);
