+pub fn prompt_assistant_output_schema() -> Value {
+    json!({
+        "type": "object",
+        "additionalProperties": false,
+        "required": ["status", "candidate", "reason"],
+        "properties": {
+            "status": {
+                "type": "string",
+                "enum": ["ready", "blocked"]
+            },
+            "candidate": {
+                "type": ["string", "null"]
+            },
+            "reason": {
+                "type": ["string", "null"]
+            }
+        }
+    })
+}
+
+pub fn parse_prompt_assistant_output(output: &str) -> Result<PromptAssistantModelOutput> {
+    let output: PromptAssistantModelOutput = serde_json::from_str(output)
+        .context("Prompt Assistant returned invalid structured output")?;
+    match output.status {
+        PromptAssistantOutputStatus::Ready => {
+            let candidate = output
+                .candidate
+                .as_deref()
+                .filter(|candidate| !candidate.trim().is_empty())
+                .context("Prompt Assistant ready output requires a candidate")?;
+            ensure!(
+                approx_token_count(candidate) <= MAX_CANDIDATE_TOKENS,
+                "Prompt Assistant candidate exceeds the {MAX_CANDIDATE_TOKENS}-token limit"
+            );
+            ensure!(
+                output.reason.is_none(),
+                "Prompt Assistant ready output cannot include a reason"
+            );
+        }
+        PromptAssistantOutputStatus::Blocked => {
+            ensure!(
+                output.candidate.is_none(),
+                "Prompt Assistant blocked output cannot include a candidate"
+            );
+            ensure!(
+                output
+                    .reason
+                    .as_deref()
+                    .is_some_and(|reason| !reason.trim().is_empty()),
+                "Prompt Assistant blocked output requires a reason"
+            );
+        }
+    }
+    Ok(output)
+}
