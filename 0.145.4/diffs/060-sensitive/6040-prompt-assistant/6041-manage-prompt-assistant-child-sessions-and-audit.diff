+pub async fn load_or_seed_prompt_assistant_instructions(codex_home: &Path) -> Result<String> {
+    let codex_home = codex_home.to_path_buf();
+    tokio::task::spawn_blocking(move || load_or_seed_instructions_sync(&codex_home))
+        .await
+        .context("Prompt Assistant instruction initialization task failed")?
+}
+
+fn load_or_seed_instructions_sync(codex_home: &Path) -> Result<String> {
+    let path = codex_home.join(INSTRUCTIONS_RELATIVE_PATH);
+    if let Ok(existing) = fs::read_to_string(&path)
+        && !existing.trim().is_empty()
+    {
+        return Ok(existing);
+    }
+    let parent = path
+        .parent()
+        .context("Prompt Assistant instruction path has no parent")?;
+    fs::create_dir_all(parent).with_context(|| {
+        format!(
+            "failed to create Prompt Assistant instruction directory {}",
+            parent.display()
+        )
+    })?;
+    let lock_path = path.with_extension("md.seed.lock");
+    let lock = match OpenOptions::new()
+        .write(true)
+        .create_new(true)
+        .open(&lock_path)
+    {
+        Ok(lock) => Some(SeedLock(lock_path.clone(), lock)),
+        Err(err) if err.kind() == ErrorKind::AlreadyExists => None,
+        Err(err) => return Err(err).context("failed to lock Prompt Assistant instruction seed"),
+    };
+    if lock.is_none() {
+        for _ in 0..100 {
+            std::thread::sleep(std::time::Duration::from_millis(10));
+            if let Ok(existing) = fs::read_to_string(&path)
+                && !existing.trim().is_empty()
+            {
+                return Ok(existing);
+            }
+        }
+        anyhow::bail!("timed out waiting for Prompt Assistant instruction initialization");
+    }
+    if let Ok(existing) = fs::read_to_string(&path)
+        && !existing.trim().is_empty()
+    {
+        return Ok(existing);
+    }
+
+    let sequence = SEED_SEQUENCE.fetch_add(1, Ordering::Relaxed);
+    let temp_path = parent.join(format!(
+        ".prompt-assistant.md.seed.{}.{sequence}",
+        std::process::id()
+    ));
+    let mut temp = OpenOptions::new()
+        .write(true)
+        .create_new(true)
+        .open(&temp_path)
+        .context("failed to stage Prompt Assistant instructions")?;
+    temp.write_all(DEFAULT_INSTRUCTIONS.as_bytes())
+        .context("failed to write Prompt Assistant instructions")?;
+    temp.sync_all()
+        .context("failed to sync Prompt Assistant instructions")?;
+    drop(temp);
+    fs::rename(&temp_path, &path).with_context(|| {
+        format!(
+            "failed to publish Prompt Assistant instructions at {}",
+            path.display()
+        )
+    })?;
+    Ok(DEFAULT_INSTRUCTIONS.to_string())
+}
+
+struct SeedLock(PathBuf, fs::File);
+
+impl Drop for SeedLock {
+    fn drop(&mut self) {
+        let _ = self.1.sync_all();
+        let _ = fs::remove_file(&self.0);
+    }
+}
