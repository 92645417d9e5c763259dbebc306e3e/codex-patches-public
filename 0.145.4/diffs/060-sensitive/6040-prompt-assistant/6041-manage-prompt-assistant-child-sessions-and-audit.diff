+pub(crate) fn prompt_cache_key_override(
+    session_source: &SessionSource,
+    parent_thread_id: Option<ThreadId>,
+) -> Option<String> {
+    is_prompt_assistant_source(session_source)
+        .then_some(parent_thread_id)
+        .flatten()
+        .map(|thread_id| format!("prompt-assistant:{thread_id}"))
+}
