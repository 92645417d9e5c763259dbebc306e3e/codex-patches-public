+    /// Returns the currently loaded peers that can send mailbox activity to `sender_thread_id`.
+    pub(crate) async fn list_live_agent_peer_thread_ids(
+        &self,
+        sender_thread_id: ThreadId,
+    ) -> CodexResult<Vec<ThreadId>> {
+        let state = self.upgrade()?;
+        let root_path = AgentPath::root();
+        let root_thread_id = self.state.agent_id_for_path(&root_path);
+        let mut candidates = self
+            .state
+            .live_agents()
+            .into_iter()
+            .filter_map(|metadata| metadata.agent_id.map(|thread_id| (metadata, thread_id)))
+            .collect::<Vec<_>>();
+
+        if let Some(root_thread_id) = root_thread_id
+            && let Some(root_metadata) = self.state.agent_metadata_for_thread(root_thread_id)
+        {
+            candidates.push((root_metadata, root_thread_id));
+        }
+
+        candidates.sort_by(
+            |(left_metadata, left_thread_id), (right_metadata, right_thread_id)| {
+                left_metadata
+                    .agent_path
+                    .as_deref()
+                    .unwrap_or_default()
+                    .cmp(right_metadata.agent_path.as_deref().unwrap_or_default())
+                    .then_with(|| left_thread_id.to_string().cmp(&right_thread_id.to_string()))
+            },
+        );
+
+        let mut peer_thread_ids = Vec::with_capacity(candidates.len());
+        for (_, thread_id) in candidates {
+            if thread_id != sender_thread_id && state.get_thread(thread_id).await.is_ok() {
+                peer_thread_ids.push(thread_id);
+            }
+        }
+        Ok(peer_thread_ids)
+    }
