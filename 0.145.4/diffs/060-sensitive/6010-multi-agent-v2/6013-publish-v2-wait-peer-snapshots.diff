+#[test]
+fn live_agent_peer_thread_ids_are_sorted_and_exclude_the_sender() {
+    let runtime = tokio::runtime::Builder::new_multi_thread()
+        .worker_threads(1)
+        .thread_stack_size(8 * 1024 * 1024)
+        .enable_all()
+        .build()
+        .expect("large-stack test runtime");
+    runtime.block_on(async {
+        let harness = AgentControlHarness::new().await;
+        let (root_thread_id, _root_thread) = harness.start_thread().await;
+        harness
+            .control
+            .register_session_root(root_thread_id, /*parent_thread_id*/ None);
+        let first_child = harness
+            .spawn_anonymous_child(root_thread_id, SpawnAgentOptions::default())
+            .await;
+        let second_child = harness
+            .spawn_anonymous_child(root_thread_id, SpawnAgentOptions::default())
+            .await;
+
+        let root_peers = harness
+            .control
+            .list_live_agent_peer_thread_ids(root_thread_id)
+            .await
+            .expect("root peer snapshot");
+        assert_eq!(root_peers, {
+            let mut expected = vec![first_child, second_child];
+            expected.sort_by_key(|thread_id| thread_id.to_string());
+            expected
+        });
+
+        let child_peers = harness
+            .control
+            .list_live_agent_peer_thread_ids(first_child)
+            .await
+            .expect("child peer snapshot");
+        assert_eq!(child_peers, vec![second_child, root_thread_id]);
+    });
+}
+
+#[tokio::test]
+async fn live_agent_peer_thread_ids_are_empty_without_other_live_agents() {
+    let harness = AgentControlHarness::new().await;
+    let (root_thread_id, _root_thread) = harness.start_thread().await;
+    harness
+        .control
+        .register_session_root(root_thread_id, /*parent_thread_id*/ None);
+
+    assert_eq!(
+        harness
+            .control
+            .list_live_agent_peer_thread_ids(root_thread_id)
+            .await
+            .expect("root peer snapshot"),
+        Vec::new()
+    );
+}
