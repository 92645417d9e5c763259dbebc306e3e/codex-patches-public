+#[tokio::test]
+async fn v2_agent_command_reports_only_running_agents_without_opening_picker() -> Result<()> {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let primary = ThreadId::new();
+    let running = ThreadId::new();
+    let retained = ThreadId::new();
+    let mut primary_session = test_thread_session(primary, test_path_buf("/tmp/project"));
+    primary_session.multi_agent_version = Some(MultiAgentVersion::V2);
+    app.enqueue_primary_thread_session(primary_session, Vec::new())
+        .await?;
+    while app_event_rx.try_recv().is_ok() {}
+
+    for (thread_id, nickname, is_running) in
+        [(running, "Parfit", true), (retained, "Hubble", false)]
+    {
+        app.upsert_authoritative_agent_picker_thread(
+            thread_id,
+            Some(nickname.to_string()),
+            Some("explorer".to_string()),
+            /*is_closed*/ false,
+        );
+        app.agent_navigation
+            .set_agent_path(thread_id, Some(format!("/root/{nickname}")));
+        app.agent_navigation
+            .mark_current_primary_tree_member(thread_id);
+        app.agent_navigation.set_running(thread_id, is_running);
+    }
+    app.sync_active_agent_label();
+    assert_eq!(
+        app.agent_navigation
+            .active_agent_label(Some(primary), Some(primary)),
+        Some("Main [default] +1".to_string())
+    );
+
+    let mut app_server = Box::pin(crate::start_embedded_app_server_for_picker(
+        app.chat_widget.config_ref(),
+    ))
+    .await
+    .expect("embedded app server");
+    Box::pin(app.open_agent_picker(&mut app_server)).await;
+
+    assert_eq!(
+        app.agent_navigation
+            .active_agent_label(Some(primary), Some(primary)),
+        Some("Main [default] +1".to_string())
+    );
+    assert!(
+        !render_bottom_popup(&app.chat_widget, /*width*/ 100).contains("Select an agent to watch")
+    );
+    let rendered = std::iter::from_fn(|| app_event_rx.try_recv().ok())
+        .filter_map(|event| match event {
+            AppEvent::InsertHistoryCell(cell) => {
+                Some(lines_to_single_string(&cell.display_lines(/*width*/ 100)))
+            }
+            _ => None,
+        })
+        .find(|rendered| rendered.contains("/agent"))
+        .expect("V2 agent status history");
+    assert!(rendered.contains("Parfit [explorer]"));
+    assert!(!rendered.contains("Hubble [explorer]"));
+    Ok(())
+}
