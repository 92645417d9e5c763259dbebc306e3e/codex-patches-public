+async fn route_active_notification(
+    app: &mut App,
+    thread_id: ThreadId,
+    notification: ServerNotification,
+) -> Result<()> {
+    app.enqueue_thread_notification(thread_id, notification)
+        .await?;
+    let event = app
+        .active_thread_rx
+        .as_mut()
+        .expect("active thread receiver")
+        .try_recv()
+        .expect("routed active notification");
+    app.handle_thread_event_now(event);
+    Ok(())
+}
