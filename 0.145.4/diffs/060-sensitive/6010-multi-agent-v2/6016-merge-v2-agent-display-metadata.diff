+#[tokio::test]
+async fn primary_thread_started_lineage_limits_navigation_after_primary_switch() -> Result<()> {
+    let mut app = make_test_app().await;
+    let primary_one = ThreadId::new();
+    let child = ThreadId::new();
+    let grandchild = ThreadId::new();
+    let unrelated = ThreadId::new();
+    app.enqueue_primary_thread_session(
+        test_thread_session(primary_one, test_path_buf("/tmp/project")),
+        Vec::new(),
+    )
+    .await?;
+    for (thread_id, parent_thread_id, nickname) in [
+        (child, Some(primary_one), "child"),
+        (grandchild, Some(child), "grandchild"),
+        (unrelated, None, "unrelated"),
+    ] {
+        app.enqueue_thread_notification(
+            thread_id,
+            thread_started_with_identity(thread_id, parent_thread_id, nickname, "worker"),
+        )
+        .await?;
+        app.agent_navigation
+            .record_sub_agent_activity(SubAgentActivityDisplay {
+                thread_id,
+                agent_path: format!("/root/{nickname}"),
+                is_running_hint: true,
+            });
+    }
+
+    assert_eq!(
+        app.agent_navigation.adjacent_thread_id(
+            Some(primary_one),
+            Some(primary_one),
+            AgentNavigationDirection::Next,
+        ),
+        Some(child)
+    );
+    assert_eq!(
+        app.agent_navigation.adjacent_thread_id(
+            Some(child),
+            Some(primary_one),
+            AgentNavigationDirection::Next,
+        ),
+        Some(grandchild)
+    );
+
+    app.store_active_thread_receiver().await;
+    app.active_thread_id = None;
+    let primary_two = ThreadId::new();
+    let second_child = ThreadId::new();
+    app.enqueue_primary_thread_session(
+        test_thread_session(primary_two, test_path_buf("/tmp/project")),
+        Vec::new(),
+    )
+    .await?;
+    app.enqueue_thread_notification(
+        second_child,
+        thread_started_with_identity(second_child, Some(primary_two), "second-child", "worker"),
+    )
+    .await?;
+    app.agent_navigation
+        .record_sub_agent_activity(SubAgentActivityDisplay {
+            thread_id: second_child,
+            agent_path: "/root/second-child".to_string(),
+            is_running_hint: true,
+        });
+
+    assert_eq!(
+        app.agent_navigation
+            .ordered_current_primary_tree_threads()
+            .into_iter()
+            .map(|(thread_id, _)| thread_id)
+            .collect::<Vec<_>>(),
+        vec![primary_two, second_child]
+    );
+    assert_eq!(
+        app.agent_navigation.adjacent_thread_id(
+            Some(primary_two),
+            Some(primary_two),
+            AgentNavigationDirection::Next,
