+    pub(crate) fn apply_v2_collab_wait_delta(&mut self, update: CollabWaitUpdate) {
+        if !matches!(self.multi_agent_version, Some(MultiAgentVersion::V2)) {
+            return;
+        }
+        match update {
+            CollabWaitUpdate::Started {
+                turn_id,
+                wait_id,
+                receiver_count,
+            } => {
+                if self.collab_waits.is_empty() {
+                    self.collab_wait_base_status = Some(self.status_state.current_status.clone());
+                }
+                self.collab_waits
+                    .retain(|(existing_turn_id, existing_wait_id, _)| {
+                        existing_turn_id != &turn_id || existing_wait_id != &wait_id
+                    });
+                self.collab_waits.push((turn_id, wait_id, receiver_count));
+            }
+            CollabWaitUpdate::Completed { turn_id, wait_id } => {
+                self.collab_waits
+                    .retain(|(existing_turn_id, existing_wait_id, _)| {
+                        existing_turn_id != &turn_id || existing_wait_id != &wait_id
+                    });
+            }
+            CollabWaitUpdate::TurnEnded { turn_id } => {
+                self.collab_waits
+                    .retain(|(existing_turn_id, _, _)| existing_turn_id != &turn_id);
+            }
+            CollabWaitUpdate::ThreadClosed => self.collab_waits.clear(),
+        }
+        self.update_collab_wait_status();
+    }
+
+    fn update_collab_wait_status(&mut self) {
+        if self.collab_waits.is_empty() {
