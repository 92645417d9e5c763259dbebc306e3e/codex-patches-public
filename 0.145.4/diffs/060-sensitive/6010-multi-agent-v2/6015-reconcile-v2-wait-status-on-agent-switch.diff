+    pub(crate) fn replace_v2_collab_waits(&mut self, waits: Vec<(String, String, usize)>) {
+        if !matches!(self.multi_agent_version, Some(MultiAgentVersion::V2)) {
+            return;
+        }
+        if self.collab_waits.is_empty() && !waits.is_empty() {
+            self.collab_wait_base_status = Some(self.status_state.current_status.clone());
