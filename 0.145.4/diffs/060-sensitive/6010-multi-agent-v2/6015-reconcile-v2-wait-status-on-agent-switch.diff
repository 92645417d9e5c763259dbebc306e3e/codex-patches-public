+                self.set_status(
+                    base_status.header,
+                    base_status.details,
+                    StatusDetailsCapitalization::Preserve,
+                    base_status.details_max_lines,
+                );
+            }
+        } else {
+            self.set_collab_wait_status();
+        }
+    }
