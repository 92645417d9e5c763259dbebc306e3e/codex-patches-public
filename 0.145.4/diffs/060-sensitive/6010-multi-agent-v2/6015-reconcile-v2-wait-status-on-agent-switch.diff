+async fn cached_wait_delta_preserves_active_wait_when_empty() {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let thread_id = ThreadId::new();
+    let mut session = test_thread_session(thread_id, test_path_buf("/tmp/project"));
+    session.multi_agent_version = Some(MultiAgentVersion::V2);
+    app.thread_event_channels.insert(
+        thread_id,
+        ThreadEventChannel::new_with_session(
+            /*capacity*/ 8,
+            session,
+            vec![test_turn(
+                "turn-1",
+                TurnStatus::InProgress,
+                vec![v2_wait_item(
+                    "wait-1",
+                    codex_app_server_protocol::CollabAgentToolCallStatus::InProgress,
+                    /*receiver_count*/ 1,
+                )],
+            )],
+        ),
+    );
+    app.activate_thread_channel(thread_id).await;
+    app.store_active_thread_receiver().await;
+    app.active_thread_id = None;
+
+    let (receiver, snapshot, _) = app
+        .activate_thread_for_replay(thread_id, None)
