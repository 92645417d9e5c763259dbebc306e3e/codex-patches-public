+#[derive(Clone, Copy)]
+enum CollabWaitReplayKind {
+    FullSnapshot,
+    CachedDelta,
+}
+
+fn collab_wait_updates(events: &[ThreadBufferedEvent]) -> Vec<CollabWaitUpdate> {
+    fn item_update(turn_id: &str, item: &ThreadItem) -> Option<CollabWaitUpdate> {
+        let ThreadItem::CollabAgentToolCall {
+            id,
+            tool: codex_app_server_protocol::CollabAgentTool::Wait,
+            status,
+            receiver_thread_ids,
+            ..
+        } = item
+        else {
+            return None;
+        };
+        match status {
+            codex_app_server_protocol::CollabAgentToolCallStatus::InProgress => {
+                Some(CollabWaitUpdate::Started {
+                    turn_id: turn_id.to_string(),
+                    wait_id: id.clone(),
+                    receiver_count: receiver_thread_ids.len(),
+                })
+            }
+            _ => Some(CollabWaitUpdate::Completed {
+                turn_id: turn_id.to_string(),
+                wait_id: id.clone(),
+            }),
+        }
+    }
+
+    events
+        .iter()
+        .filter_map(|event| match event {
+            ThreadBufferedEvent::Notification(ServerNotification::ItemStarted(notification)) => {
+                item_update(&notification.turn_id, &notification.item)
+            }
+            ThreadBufferedEvent::Notification(ServerNotification::ItemCompleted(notification)) => {
+                item_update(&notification.turn_id, &notification.item)
+            }
+            ThreadBufferedEvent::Notification(ServerNotification::TurnCompleted(notification)) => {
+                Some(CollabWaitUpdate::TurnEnded {
+                    turn_id: notification.turn.id.clone(),
+                })
+            }
+            ThreadBufferedEvent::Notification(ServerNotification::ThreadClosed(_)) => {
+                Some(CollabWaitUpdate::ThreadClosed)
+            }
+            ThreadBufferedEvent::Notification(_)
+            | ThreadBufferedEvent::Request(_)
+            | ThreadBufferedEvent::HistoryEntryResponse(_)
+            | ThreadBufferedEvent::FeedbackSubmission(_) => None,
+        })
+        .collect()
+}
+
+fn active_v2_collab_waits(
+    turns: &[Turn],
+    updates: &[CollabWaitUpdate],
+) -> Vec<(String, String, usize)> {
+    let mut waits = Vec::new();
+    for turn in turns {
+        if !matches!(turn.status, TurnStatus::InProgress) {
+            continue;
+        }
+        for item in &turn.items {
+            let ThreadItem::CollabAgentToolCall {
+                id,
+                tool: codex_app_server_protocol::CollabAgentTool::Wait,
+                status: codex_app_server_protocol::CollabAgentToolCallStatus::InProgress,
+                receiver_thread_ids,
+                ..
+            } = item
+            else {
+                continue;
+            };
+            waits.retain(|(existing_turn_id, wait_id, _)| {
+                existing_turn_id != &turn.id || wait_id != id
+            });
+            waits.push((turn.id.clone(), id.clone(), receiver_thread_ids.len()));
+        }
+    }
+    for update in updates {
+        match update {
+            CollabWaitUpdate::Started {
+                turn_id,
+                wait_id,
+                receiver_count,
+            } => {
+                waits.retain(|(existing_turn_id, existing_wait_id, _)| {
+                    existing_turn_id != turn_id || existing_wait_id != wait_id
+                });
+                waits.push((turn_id.clone(), wait_id.clone(), *receiver_count));
+            }
+            CollabWaitUpdate::Completed { turn_id, wait_id } => {
+                waits.retain(|(existing_turn_id, existing_wait_id, _)| {
+                    existing_turn_id != turn_id || existing_wait_id != wait_id
+                });
+            }
+            CollabWaitUpdate::TurnEnded { turn_id } => {
+                waits.retain(|(existing_turn_id, _, _)| existing_turn_id != turn_id);
+            }
+            CollabWaitUpdate::ThreadClosed => waits.clear(),
+        }
+    }
+    waits
+}
