+async fn cache_descendant_agent_identities(
+    app_server: &mut AppServerSession,
+    ancestor_thread_id: ThreadId,
+    cache: &mut HashMap<ThreadId, AgentMetadata>,
+) -> std::io::Result<()> {
+    let response = app_server
+        .thread_list(descendant_identity_list_params(ancestor_thread_id))
+        .await
+        .map_err(std::io::Error::other)?;
+    cache_agent_identities(response.data, cache);
+    Ok(())
+}
+
+fn should_load_descendant_identities(
+    completed_roots: &mut HashSet<ThreadId>,
+    root: ThreadId,
+) -> bool {
+    completed_roots.insert(root)
+}
+
+fn descendant_identity_list_params(ancestor_thread_id: ThreadId) -> ThreadListParams {
+    ThreadListParams {
+        cursor: None,
+        limit: Some(200),
+        sort_key: None,
+        sort_direction: None,
+        model_providers: None,
+        source_kinds: Some(vec![
+            ThreadSourceKind::SubAgent,
+            ThreadSourceKind::SubAgentReview,
+            ThreadSourceKind::SubAgentCompact,
+            ThreadSourceKind::SubAgentThreadSpawn,
+            ThreadSourceKind::SubAgentOther,
+        ]),
+        archived: Some(false),
+        is_pinned: None,
+        parent_thread_id: None,
+        ancestor_thread_id: Some(ancestor_thread_id.to_string()),
+        cwd: None,
+        use_state_db_only: false,
+        search_term: None,
+    }
+}
+
+fn cache_agent_identities(
+    threads: impl IntoIterator<Item = Thread>,
+    cache: &mut HashMap<ThreadId, AgentMetadata>,
+) {
+    for thread in threads {
+        if let Ok(thread_id) = ThreadId::from_string(&thread.id) {
+            let incoming = AgentMetadata {
+                agent_nickname: thread.agent_nickname,
+                agent_role: thread.agent_role,
+                agent_path: source_agent_path(&thread.source),
+            };
+            let merged = merge_agent_identity(cache.remove(&thread_id), incoming);
+            cache.insert(thread_id, merged);
+        }
+    }
+}
+
+fn merge_agent_identity(existing: Option<AgentMetadata>, incoming: AgentMetadata) -> AgentMetadata {
+    let existing = existing.unwrap_or_default();
+    AgentMetadata {
+        agent_nickname: incoming.agent_nickname.or(existing.agent_nickname),
+        agent_role: incoming.agent_role.or(existing.agent_role),
+        agent_path: incoming.agent_path.or(existing.agent_path),
+    }
+}
