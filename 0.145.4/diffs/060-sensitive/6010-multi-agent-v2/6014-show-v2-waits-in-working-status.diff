+#[tokio::test]
+async fn v2_collab_wait_session_reconfiguration_restores_status_and_ignores_old_completion() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let mut session = configured_thread_session(ThreadId::new());
+    session.multi_agent_version = Some(MultiAgentVersion::V2);
+    chat.handle_thread_session(session);
+    let _ = drain_insert_history(&mut rx);
+    chat.set_status(
+        "Working".to_string(),
+        Some("Inspecting files".to_string()),
+        StatusDetailsCapitalization::Preserve,
+        2,
+    );
+
+    let sender_thread_id = ThreadId::new().to_string();
+    let wait_item = |status| AppServerThreadItem::CollabAgentToolCall {
+        id: "wait-old-thread".to_string(),
+        tool: AppServerCollabAgentTool::Wait,
+        status,
+        sender_thread_id: sender_thread_id.clone(),
+        receiver_thread_ids: vec![ThreadId::new().to_string()],
+        prompt: None,
+        model: None,
+        reasoning_effort: None,
+        agents_states: HashMap::new(),
+    };
+    chat.on_collab_agent_tool_call(
+        wait_item(AppServerCollabAgentToolCallStatus::InProgress),
+        /*from_replay*/ false,
+    );
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Waiting for 1 agent")
+    );
+
+    let mut next_session = configured_thread_session(ThreadId::new());
+    next_session.multi_agent_version = Some(MultiAgentVersion::V2);
+    chat.handle_thread_session(next_session);
+    let _ = drain_insert_history(&mut rx);
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Inspecting files")
+    );
+    assert_eq!(chat.status_state.current_status.details_max_lines, 2);
+
+    let status_after_reconfiguration = chat.status_state.current_status.clone();
+    chat.on_collab_agent_tool_call(
+        wait_item(AppServerCollabAgentToolCallStatus::Completed),
+        /*from_replay*/ false,
+    );
+    assert_eq!(
+        chat.status_state.current_status,
+        status_after_reconfiguration
+    );
+    assert!(drain_insert_history(&mut rx).is_empty());
+}
