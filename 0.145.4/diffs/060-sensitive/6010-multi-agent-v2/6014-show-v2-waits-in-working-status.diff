+        id: id.to_string(),
+        tool: AppServerCollabAgentTool::Wait,
+        status,
+        sender_thread_id: sender_thread_id.clone(),
+        receiver_thread_ids: (0..agent_count)
+            .map(|_| ThreadId::new().to_string())
+            .collect(),
+        prompt: None,
+        model: None,
+        reasoning_effort: None,
+        agents_states: HashMap::new(),
+    };
+
+    chat.on_collab_agent_tool_call(
+        wait_item("wait-a", AppServerCollabAgentToolCallStatus::InProgress, 1),
+        /*from_replay*/ false,
+    );
+    chat.on_collab_agent_tool_call(
+        wait_item("wait-b", AppServerCollabAgentToolCallStatus::InProgress, 2),
+        /*from_replay*/ false,
+    );
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Waiting for 2 agents")
+    );
+
+    chat.on_collab_agent_tool_call(
+        wait_item("wait-a", AppServerCollabAgentToolCallStatus::Completed, 1),
+        /*from_replay*/ false,
+    );
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Waiting for 2 agents")
+    );
+
+    chat.on_collab_agent_tool_call(
+        wait_item("wait-b", AppServerCollabAgentToolCallStatus::Completed, 2),
+        /*from_replay*/ false,
+    );
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Inspecting files")
+    );
+    assert_eq!(chat.status_state.current_status.details_max_lines, 2);
+    assert!(drain_insert_history(&mut rx).is_empty());
+}
