+#[tokio::test]
+async fn v2_collab_wait_updates_working_status_without_transcript_and_restores_it() {
+    let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    let mut session = configured_thread_session(ThreadId::new());
+    session.multi_agent_version = Some(MultiAgentVersion::V2);
+    chat.handle_thread_session(session);
+    let _ = drain_insert_history(&mut rx);
+    chat.set_status(
+        "Working".to_string(),
+        Some("Inspecting files".to_string()),
+        StatusDetailsCapitalization::Preserve,
+        2,
+    );
+
+    let sender_thread_id = ThreadId::new();
+    let receiver_thread_id = ThreadId::new();
+    let wait_item = |id: &str, status, receiver_thread_ids: Vec<String>| {
+        AppServerThreadItem::CollabAgentToolCall {
+            id: id.to_string(),
+            tool: AppServerCollabAgentTool::Wait,
+            status,
+            sender_thread_id: sender_thread_id.to_string(),
+            receiver_thread_ids,
+            prompt: None,
+            model: None,
+            reasoning_effort: None,
+            agents_states: HashMap::new(),
+        }
+    };
+
+    chat.handle_server_notification(
+        ServerNotification::ItemStarted(ItemStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            started_at_ms: 0,
+            item: wait_item(
+                "wait-one",
+                AppServerCollabAgentToolCallStatus::InProgress,
+                vec![receiver_thread_id.to_string()],
+            ),
+        }),
+        None,
+    );
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Waiting for 1 agent")
+    );
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 0,
+            item: wait_item(
+                "wait-one",
+                AppServerCollabAgentToolCallStatus::Completed,
+                vec![receiver_thread_id.to_string()],
+            ),
+        }),
+        None,
+    );
+    assert_eq!(chat.status_state.current_status.header, "Working");
+    assert_eq!(
+        chat.status_state.current_status.details.as_deref(),
+        Some("Inspecting files")
+    );
+    assert_eq!(chat.status_state.current_status.details_max_lines, 2);
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    let status_before_unmatched_completion = chat.status_state.current_status.clone();
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 0,
+            item: wait_item(
+                "unmatched",
+                AppServerCollabAgentToolCallStatus::Completed,
+                vec![receiver_thread_id.to_string()],
+            ),
+        }),
+        None,
+    );
+    assert_eq!(
+        chat.status_state.current_status,
+        status_before_unmatched_completion
+    );
+    assert!(drain_insert_history(&mut rx).is_empty());
+}
