+    pub(super) fn flush_pending_sub_agent_activity(&mut self) {
+        loop {
+            let Some(thread_id) = self
+                .pending_sub_agent_activity
+                .front()
+                .and_then(multi_agents::sub_agent_activity_thread_id)
+            else {
+                return;
+            };
+            if !self.has_collab_agent_identity(thread_id) {
+                return;
+            }
+            let Some(item) = self.pending_sub_agent_activity.pop_front() else {
+                return;
+            };
+            if let Some(cell) = multi_agents::sub_agent_activity_history_cell(&item, |thread_id| {
+                self.collab_agent_metadata(thread_id)
+            }) {
+                self.on_collab_event(cell);
+            }
         }
     }
 
