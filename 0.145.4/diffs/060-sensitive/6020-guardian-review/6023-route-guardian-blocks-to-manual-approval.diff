+async fn request_user_review_after_guardian_block(
+    session: &Arc<Session>,
+    turn: &TurnContext,
+    request: &GuardianApprovalRequest,
+    rationale: &str,
+) -> ReviewDecision {
+    let (call_id, command, cwd, network_context, additional_permissions, detail) = match request {
+        GuardianApprovalRequest::Shell {
+            id,
+            command,
+            cwd,
+            additional_permissions,
+            ..
+        }
+        | GuardianApprovalRequest::ExecCommand {
+            id,
+            command,
+            cwd,
+            additional_permissions,
+            ..
+        } => (
+            id.clone(),
+            command.clone(),
+            cwd.clone(),
+            None,
+            additional_permissions.clone(),
+            None,
+        ),
+        #[cfg(unix)]
+        GuardianApprovalRequest::Execve {
+            id,
+            program,
+            argv,
+            cwd,
+            additional_permissions,
+            ..
+        } => (
+            id.clone(),
+            if argv.is_empty() {
+                vec![program.clone()]
+            } else {
+                argv.clone()
+            },
+            cwd.clone(),
+            None,
+            additional_permissions.clone(),
+            None,
+        ),
+        GuardianApprovalRequest::NetworkAccess {
+            id,
+            target,
+            host,
+            protocol,
+            trigger,
+            ..
+        } => (
+            id.clone(),
+            trigger.as_ref().map_or_else(
+                || vec!["network-access".to_string(), target.clone()],
+                |trigger| trigger.command.clone(),
+            ),
+            trigger.as_ref().map_or_else(
+                || {
+                    #[allow(deprecated)]
+                    turn.cwd.clone()
+                },
+                |trigger| trigger.cwd.clone(),
+            ),
+            Some(NetworkApprovalContext {
+                host: host.clone(),
+                protocol: *protocol,
+            }),
+            trigger
+                .as_ref()
+                .and_then(|trigger| trigger.additional_permissions.clone()),
+            Some(format!("network target: {target}")),
+        ),
+        GuardianApprovalRequest::ApplyPatch { id, cwd, files, .. } => {
+            let files = if files.is_empty() {
+                "no files listed".to_string()
+            } else {
+                files
+                    .iter()
+                    .map(|path| path.display().to_string())
+                    .collect::<Vec<_>>()
+                    .join(", ")
+            };
+            (
+                id.clone(),
+                vec!["apply_patch".to_string()],
+                cwd.clone(),
+                None,
+                None,
+                Some(format!("files: {files}")),
+            )
+        }
+        GuardianApprovalRequest::McpToolCall {
+            id,
+            server,
+            tool_name,
+            ..
+        } => (
+            id.clone(),
+            vec!["mcp-tool-call".to_string(), format!("{server}.{tool_name}")],
+            {
+                #[allow(deprecated)]
+                turn.cwd.clone()
+            },
+            None,
+            None,
+            None,
+        ),
+        GuardianApprovalRequest::RequestPermissions { id, reason, .. } => (
+            id.clone(),
+            reason.as_ref().map_or_else(
+                || vec!["request-permissions".to_string()],
+                |reason| vec!["request-permissions".to_string(), reason.clone()],
+            ),
+            {
+                #[allow(deprecated)]
+                turn.cwd.clone()
+            },
+            None,
+            None,
+            None,
+        ),
+    };
+    let reason = Some(match detail {
+        Some(detail) => format!("Auto-review did not approve this action. {rationale}\n{detail}"),
+        None => format!("Auto-review did not approve this action. {rationale}"),
+    });
+    match session
+        .request_command_approval(
+            turn,
+            call_id,
+            None,
+            None,
+            command,
+            cwd,
+            reason,
+            network_context,
+            None,
+            additional_permissions,
+            Some(vec![ReviewDecision::Approved, ReviewDecision::Abort]),
+        )
+        .await
+    {
+        ReviewDecision::Approved => ReviewDecision::Approved,
+        ReviewDecision::ApprovedExecpolicyAmendment { .. }
+        | ReviewDecision::ApprovedForSession
+        | ReviewDecision::NetworkPolicyAmendment { .. }
+        | ReviewDecision::Denied { .. }
+        | ReviewDecision::TimedOut
+        | ReviewDecision::Abort => ReviewDecision::Abort,
+    }
+}
