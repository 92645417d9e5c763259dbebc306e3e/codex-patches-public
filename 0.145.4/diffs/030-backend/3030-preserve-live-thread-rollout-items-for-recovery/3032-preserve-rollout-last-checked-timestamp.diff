+    let rollout_path = write_rollout_in_sessions(
+        codex_home.as_path(),
+        "2026-01-27T12-34-56",
+        "not-a-timestamp",
+        thread_uuid,
+        /*git*/ None,
+    );
+    let file = OpenOptions::new()
+        .write(true)
+        .open(&rollout_path)
+        .expect("open rollout");
+    let mtime = parse_timestamp_to_utc("2026-01-28T00:00:00Z").expect("mtime");
+    file.set_times(FileTimes::new().set_modified(mtime.into()))
+        .expect("set mtime");
+    drop(file);
+
+    let runtime = codex_state::StateRuntime::init(codex_home.clone(), "test-provider".to_string())
+        .await
+        .expect("initialize runtime");
+    backfill_sessions(runtime.as_ref(), codex_home.as_path(), "test-provider").await;
+
+    let stored = runtime
+        .get_thread(thread_id)
+        .await
+        .expect("get thread")
+        .expect("thread should be backfilled");
+    assert_eq!(stored.updated_at, mtime);
+    assert_eq!(stored.recency_at, mtime);
+}
