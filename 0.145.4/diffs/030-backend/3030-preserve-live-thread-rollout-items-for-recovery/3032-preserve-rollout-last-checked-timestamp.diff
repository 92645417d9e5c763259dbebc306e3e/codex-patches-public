+#[tokio::test]
+async fn backfill_sessions_uses_last_valid_rollout_timestamp_and_mtime_recency() {
+    let dir = tempdir().expect("tempdir");
+    let codex_home = dir.path().to_path_buf();
+    let thread_uuid = Uuid::new_v4();
+    let thread_id = ThreadId::from_string(&thread_uuid.to_string()).expect("thread id");
+    let rollout_path = write_rollout_in_sessions(
+        codex_home.as_path(),
+        "2026-01-27T12-34-56",
+        "2026-01-27T12:34:56Z",
+        thread_uuid,
+        /*git*/ None,
+    );
+    let mut file = OpenOptions::new()
+        .append(true)
+        .open(&rollout_path)
+        .expect("open rollout");
+    writeln!(
+        file,
+        r#"{{"timestamp":"2026-01-27T12:45:00Z","type":"unknown_future_item","payload":{{}}}}"#
+    )
+    .expect("write unknown rollout line");
+    writeln!(
+        file,
+        r#"{{"timestamp":"not-a-timestamp","type":"unknown_future_item","payload":{{}}}}"#
+    )
+    .expect("write invalid timestamp line");
+    let stale_mtime = parse_timestamp_to_utc("2026-01-28T00:00:00Z").expect("stale mtime");
+    file.set_times(FileTimes::new().set_modified(stale_mtime.into()))
+        .expect("set stale mtime");
+    drop(file);
+
+    let runtime = codex_state::StateRuntime::init(codex_home.clone(), "test-provider".to_string())
+        .await
+        .expect("initialize runtime");
+    backfill_sessions(runtime.as_ref(), codex_home.as_path(), "test-provider").await;
+
+    let stored = runtime
+        .get_thread(thread_id)
+        .await
+        .expect("get thread")
+        .expect("thread should be backfilled");
+    assert_eq!(
+        stored.updated_at,
+        parse_timestamp_to_utc("2026-01-27T12:45:00Z").expect("last timestamp")
+    );
+    assert_eq!(stored.recency_at, stale_mtime);
+    assert_eq!(
+        file_modified_time_utc(&rollout_path).await,
+        Some(stale_mtime)
+    );
+}
+
+#[tokio::test]
