+use crate::session::session::Session;
+use codex_protocol::error::CodexErr;
+use codex_protocol::error::Result as CodexResult;
+use std::sync::Arc;
+use std::sync::Mutex;
+use std::sync::Weak;
+use std::sync::atomic::AtomicBool;
+use std::sync::atomic::Ordering;
+
+const PERSISTENCE_UNAVAILABLE_MESSAGE: &str = "Conversation persistence stopped because durable storage is full. Free disk space, then restart or resume Codex before continuing.";
+
+/// Thread-manager-scoped health state for durable conversation persistence.
+pub(crate) struct PersistenceHealth {
+    failed: AtomicBool,
+    sessions: Mutex<Vec<Weak<Session>>>,
+}
+
+impl PersistenceHealth {
+    pub(crate) fn new() -> Arc<Self> {
+        Arc::new(Self {
+            failed: AtomicBool::new(false),
+            sessions: Mutex::new(Vec::new()),
+        })
+    }
+
+    pub(crate) fn register(self: &Arc<Self>, session: &Arc<Session>) -> CodexResult<()> {
+        let mut sessions = self
+            .sessions
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        sessions.retain(|registered| registered.strong_count() > 0);
+        self.ensure_healthy()?;
+        sessions.push(Arc::downgrade(session));
+        Ok(())
+    }
+
+    pub(crate) fn is_failed(&self) -> bool {
+        self.failed.load(Ordering::Acquire)
+    }
+
+    pub(crate) fn ensure_healthy(&self) -> CodexResult<()> {
+        if self.is_failed() {
+            Err(CodexErr::Fatal(PERSISTENCE_UNAVAILABLE_MESSAGE.to_string()))
+        } else {
+            Ok(())
+        }
+    }
+
+    /// Marks persistence unavailable and schedules one incident fan-out.
+    pub(crate) fn trip(self: &Arc<Self>) -> bool {
+        if self
+            .failed
+            .compare_exchange(false, true, Ordering::AcqRel, Ordering::Acquire)
+            .is_err()
+        {
+            return false;
+        }
+
+        let health = Arc::clone(self);
+        tokio::spawn(async move {
+            health.handle_incident().await;
+        });
+        true
+    }
+
+    async fn handle_incident(&self) {
+        let sessions = {
+            let mut registered = self
+                .sessions
+                .lock()
+                .unwrap_or_else(std::sync::PoisonError::into_inner);
+            let sessions = registered
+                .iter()
+                .filter_map(Weak::upgrade)
+                .collect::<Vec<_>>();
+            registered.retain(|session| session.strong_count() > 0);
+            sessions
+        };
+
+        futures::future::join_all(
+            sessions
+                .into_iter()
+                .map(|session| async move { session.handle_persistence_failure().await }),
+        )
+        .await;
+    }
+}
+
+pub(crate) fn persistence_unavailable_message() -> &'static str {
+    PERSISTENCE_UNAVAILABLE_MESSAGE
+}
