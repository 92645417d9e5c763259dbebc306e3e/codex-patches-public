+#[tokio::test]
+async fn storage_full_flush_and_persist_return_storage_full_and_trip_health() {
+    for persist in [false, true] {
+        let health = crate::persistence_health::PersistenceHealth::new();
+        let (mut session, _context) = make_session_and_context().await;
+        let store = attach_in_memory_thread_store(&mut session).await;
+        session.services.persistence_health = Arc::clone(&health);
+        let session = Arc::new(session);
+        health.register(&session).expect("register session");
+        store.fail_writes_with_storage_full().await;
+
+        let err = if persist {
+            session
+                .try_ensure_rollout_materialized()
+                .await
+                .expect_err("persist should report storage full")
+        } else {
+            session
+                .flush_rollout()
+                .await
+                .expect_err("flush should report storage full")
+        };
+
+        assert_eq!(err.kind(), std::io::ErrorKind::StorageFull);
+        assert!(health.is_failed());
+        if persist {
+            assert_eq!(store.calls().await.persist_thread, 1);
+        } else {
+            assert_eq!(store.calls().await.flush_thread, 1);
+        }
+    }
+}
