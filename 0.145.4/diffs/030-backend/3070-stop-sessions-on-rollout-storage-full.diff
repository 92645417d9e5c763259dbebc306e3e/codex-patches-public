+    let first_store = attach_in_memory_thread_store(&mut first).await;
+    let (first_tx, first_rx) = async_channel::unbounded();
+    first.tx_event = first_tx;
+    first.services.persistence_health = Arc::clone(&health);
+    let first = Arc::new(first);
+    health.register(&first).expect("register first session");
+
+    let (mut second, second_context) = make_session_and_context().await;
+    let second_store = attach_in_memory_thread_store(&mut second).await;
+    let (second_tx, second_rx) = async_channel::unbounded();
+    second.tx_event = second_tx;
+    second.services.persistence_health = Arc::clone(&health);
+    let second = Arc::new(second);
+    health.register(&second).expect("register second session");
+
+    first
+        .spawn_task(
+            Arc::new(first_context),
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+    second
+        .spawn_task(
+            Arc::new(second_context),
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+    first
+        .input_queue
+        .enqueue_mailbox_communication(InterAgentCommunication::new(
+            AgentPath::root(),
+            AgentPath::root(),
+            Vec::new(),
+            "pending trigger".to_string(),
+            /*trigger_turn*/ true,
+        ))
+        .await;
+
+    let first_append_calls = first_store.calls().await.append_items;
+    let second_append_calls = second_store.calls().await.append_items;
+    first_store.fail_writes_with_storage_full().await;
+    let item = persistence_test_item("persist me");
+    first
+        .persist_rollout_items(std::slice::from_ref(&item))
+        .await;
+
+    wait_for_persistence_incident(&first).await;
+    wait_for_persistence_incident(&second).await;
+    assert!(health.is_failed());
+    assert!(first.active_turn.lock().await.is_none());
+    assert!(second.active_turn.lock().await.is_none());
+    assert!(first.input_queue.has_trigger_turn_mailbox_items().await);
