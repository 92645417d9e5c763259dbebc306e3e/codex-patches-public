+impl ThreadStoreError {
+    /// Returns whether the operation failed because durable storage is full.
+    pub fn is_storage_full(&self) -> bool {
+        matches!(self, Self::StorageFull { .. })
+    }
+
+    pub(crate) fn from_io_error(err: io::Error) -> Self {
+        let message = err.to_string();
+        if err.kind() == io::ErrorKind::StorageFull {
+            Self::StorageFull { message }
+        } else {
+            Self::Internal { message }
+        }
+    }
+
+    pub(crate) fn from_io_error_with_context(context: &str, err: io::Error) -> Self {
+        let kind = err.kind();
+        Self::from_io_error(io::Error::new(kind, format!("{context}: {err}")))
+    }
+}
