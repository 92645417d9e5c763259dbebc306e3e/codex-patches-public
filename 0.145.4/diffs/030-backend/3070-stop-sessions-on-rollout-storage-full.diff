+async fn wait_for_persistence_incident(session: &Session) {
+    timeout(Duration::from_secs(2), async {
+        while session.active_turn.lock().await.is_some() {
+            tokio::task::yield_now().await;
+        }
+    })
+    .await
+    .expect("persistence incident should reach the session");
+}
+
+fn drain_persistence_failure_events(rx: &async_channel::Receiver<Event>) -> usize {
+    let mut count = 0;
+    while let Ok(event) = rx.try_recv() {
+        if matches!(
+            &event.msg,
+            EventMsg::Error(error)
+                if error.message == crate::persistence_health::persistence_unavailable_message()
+        ) {
+            count += 1;
+        }
+    }
+    count
+}
+
