+#[tokio::test]
+async fn concurrent_online_refreshes_share_successful_request() {
+    let remote_models = vec![remote_model("singleflight-success", "Singleflight", 0)];
+    let release = Arc::new(tokio::sync::Semaphore::new(0));
+    let (endpoint, mut started_rx) =
+        ControlledModelsEndpoint::new(vec![ControlledModelsFetch::blocked_success(
+            remote_models.clone(),
+            "singleflight-etag",
+            Arc::clone(&release),
+        )]);
+    let codex_home = tempdir().expect("temp dir");
+    let manager = Arc::new(openai_manager_for_tests(
+        codex_home.path().to_path_buf(),
+        endpoint.clone(),
+    ));
+    let first_factory = HttpClientFactory::new(OutboundProxyPolicy::RespectSystemProxy);
+
+    let mut first =
+        Box::pin(manager.refresh_available_models(RefreshStrategy::Online, &first_factory));
+    expect_pending_after_one_poll(first.as_mut()).await;
+    expect_fetch_started(&mut started_rx, 1).await;
+
+    let mut second = Box::pin(
+        manager.refresh_available_models(RefreshStrategy::Online, &DEFAULT_HTTP_CLIENT_FACTORY),
+    );
+    expect_pending_after_one_poll(second.as_mut()).await;
+
+    release.add_permits(1);
+    let (first_result, second_result) =
+        tokio::time::timeout(
+            ASYNC_TEST_TIMEOUT,
+            async move { tokio::join!(first, second) },
+        )
+        .await
+        .expect("timed out waiting for concurrent refreshes");
+    first_result.expect("first refresh succeeds");
+    second_result.expect("concurrent refresh joins the successful request");
+
+    let catalog = manager.catalog.read().await;
+    assert_eq!(catalog.models, remote_models);
+    assert_eq!(catalog.etag.as_deref(), Some("singleflight-etag"));
+    assert_eq!(catalog.successful_network_revision, 1);
+    assert_eq!(endpoint.fetch_count(), 1);
+    assert_eq!(
+        endpoint.observed_proxy_policies(),
+        vec![OutboundProxyPolicy::RespectSystemProxy],
+        "the waiter factory must not start another network flight"
+    );
+}
