+        tokio::select! {
+            biased;
+            result = &mut cache_miss => {
+                panic!("cache-miss waiter completed before the in-flight refresh: {result:?}")
+            },
+            permit = manager.cache_io_gate.acquire() => match permit {
+                Ok(permit) => permit,
+                Err(err) => panic!("models cache I/O gate unexpectedly closed: {err}"),
+            },
+        }
