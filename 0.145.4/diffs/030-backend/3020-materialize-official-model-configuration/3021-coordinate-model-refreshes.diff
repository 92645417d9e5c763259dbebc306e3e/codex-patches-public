+    ));
+    let cache_io_permit = match manager.cache_io_gate.acquire().await {
+        Ok(permit) => permit,
+        Err(err) => panic!("models cache I/O gate unexpectedly closed: {err}"),
+    };
+
+    let mut online = Box::pin(
+        manager.refresh_available_models(RefreshStrategy::Online, &DEFAULT_HTTP_CLIENT_FACTORY),
