+#[derive(Debug)]
+enum ControlledModelsResponse {
+    Success(Vec<ModelInfo>, Option<String>),
+    Error(&'static str),
+}
+
+#[derive(Debug)]
+struct ControlledModelsFetch {
+    release: Option<Arc<tokio::sync::Semaphore>>,
+    response: ControlledModelsResponse,
+}
+
+impl ControlledModelsFetch {
+    fn success(models: Vec<ModelInfo>, etag: &str) -> Self {
+        Self {
+            release: None,
+            response: ControlledModelsResponse::Success(models, Some(etag.to_string())),
+        }
+    }
+
+    fn blocked_success(
+        models: Vec<ModelInfo>,
+        etag: &str,
+        release: Arc<tokio::sync::Semaphore>,
+    ) -> Self {
+        Self {
+            release: Some(release),
+            response: ControlledModelsResponse::Success(models, Some(etag.to_string())),
+        }
+    }
+
+    fn blocked_error(message: &'static str, release: Arc<tokio::sync::Semaphore>) -> Self {
+        Self {
+            release: Some(release),
+            response: ControlledModelsResponse::Error(message),
+        }
+    }
+}
+
+#[derive(Debug)]
+struct ControlledModelsEndpoint {
+    fetches: Mutex<VecDeque<ControlledModelsFetch>>,
+    fetch_count: AtomicUsize,
+    uses_codex_backend: AtomicBool,
+    started_tx: tokio::sync::mpsc::UnboundedSender<usize>,
+    observed_proxy_policies: Mutex<Vec<OutboundProxyPolicy>>,
+}
+
+impl ControlledModelsEndpoint {
+    fn new(
+        fetches: Vec<ControlledModelsFetch>,
+    ) -> (Arc<Self>, tokio::sync::mpsc::UnboundedReceiver<usize>) {
+        let (started_tx, started_rx) = tokio::sync::mpsc::unbounded_channel();
+        (
+            Arc::new(Self {
+                fetches: Mutex::new(fetches.into()),
+                fetch_count: AtomicUsize::new(0),
+                uses_codex_backend: AtomicBool::new(true),
+                started_tx,
+                observed_proxy_policies: Mutex::new(Vec::new()),
+            }),
+            started_rx,
+        )
+    }
+
+    fn fetch_count(&self) -> usize {
+        self.fetch_count.load(Ordering::SeqCst)
+    }
+
+    fn set_uses_codex_backend(&self, uses_codex_backend: bool) {
+        self.uses_codex_backend
+            .store(uses_codex_backend, Ordering::SeqCst);
+    }
+
+    fn observed_proxy_policies(&self) -> Vec<OutboundProxyPolicy> {
+        self.observed_proxy_policies
+            .lock()
+            .expect("observed proxy policies lock should not be poisoned")
+            .clone()
+    }
+
+    async fn list_models(&self) -> CoreResult<(Vec<ModelInfo>, Option<String>)> {
+        let attempt = self.fetch_count.fetch_add(1, Ordering::SeqCst) + 1;
+        let fetch = self
+            .fetches
+            .lock()
+            .expect("controlled fetches lock should not be poisoned")
+            .pop_front()
+            .expect("unexpected model fetch");
+        self.started_tx
+            .send(attempt)
+            .expect("test should keep the fetch-start receiver open");
+
+        if let Some(release) = fetch.release {
+            let permit = release
+                .acquire_owned()
+                .await
+                .expect("test should keep the release semaphore open");
+            permit.forget();
+        }
+
+        match fetch.response {
+            ControlledModelsResponse::Success(models, etag) => Ok((models, etag)),
+            ControlledModelsResponse::Error(message) => {
+                Err(codex_protocol::error::CodexErr::Fatal(message.to_string()))
+            }
+        }
+    }
+}
+
+impl ModelsEndpointClient for ControlledModelsEndpoint {
+    fn has_command_auth(&self) -> bool {
+        false
+    }
+
+    fn uses_codex_backend(&self) -> ModelsEndpointFuture<'_, bool> {
+        Box::pin(async { self.uses_codex_backend.load(Ordering::SeqCst) })
+    }
+
+    fn list_models<'a>(
+        &'a self,
+        _client_version: &'a str,
+        http_client_factory: HttpClientFactory,
+    ) -> ModelsEndpointFuture<'a, CoreResult<(Vec<ModelInfo>, Option<String>)>> {
+        Box::pin(async move {
+            self.observed_proxy_policies
+                .lock()
+                .expect("observed proxy policies lock should not be poisoned")
+                .push(http_client_factory.outbound_proxy_policy());
+            ControlledModelsEndpoint::list_models(self).await
+        })
+    }
+}
+
+async fn expect_pending_after_one_poll<F>(future: std::pin::Pin<&mut F>)
+where
+    F: std::future::Future,
+{
+    tokio::select! {
+        biased;
+        _ = future => panic!("future unexpectedly completed on its first poll"),
+        () = async {} => {}
+    }
+}
+
+async fn expect_fetch_started(
+    started_rx: &mut tokio::sync::mpsc::UnboundedReceiver<usize>,
+    expected_attempt: usize,
+) {
+    let attempt = tokio::time::timeout(ASYNC_TEST_TIMEOUT, started_rx.recv())
+        .await
+        .expect("timed out waiting for model fetch to start");
+    assert_eq!(attempt, Some(expected_attempt));
+}
+
+fn assert_no_fetch_started(started_rx: &mut tokio::sync::mpsc::UnboundedReceiver<usize>) {
+    assert!(matches!(
+        started_rx.try_recv(),
+        Err(tokio::sync::mpsc::error::TryRecvError::Empty)
+    ));
+}
