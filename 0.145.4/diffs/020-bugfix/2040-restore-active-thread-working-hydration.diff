+#[tokio::test]
+async fn activate_thread_for_replay_restores_active_turn_with_unrelated_in_progress_turn() {
+    let mut app = make_test_app().await;
+    let thread_id = ThreadId::new();
+    let session = test_thread_session(thread_id, test_path_buf("/tmp/project"));
+    let channel = ThreadEventChannel::new_with_session(
+        /*capacity*/ 1,
+        session,
+        vec![test_turn("turn-other", TurnStatus::InProgress, Vec::new())],
+    );
+    {
+        let mut store = channel.store.lock().await;
+        store.push_notification(turn_started_notification(thread_id, "turn-1"));
+        store.push_notification(token_usage_notification(thread_id, "turn-1", Some(950_000)));
+    }
+    app.thread_event_channels.insert(thread_id, channel);
+
+    let (_receiver, snapshot) = app
+        .activate_thread_for_replay(thread_id)
+        .await
+        .expect("thread should activate");
+
+    assert!(
+        snapshot.turns.iter().any(|turn| {
+            turn.id == "turn-other" && matches!(turn.status, TurnStatus::InProgress)
+        })
+    );
+    assert_eq!(
+        snapshot
+            .turns
+            .iter()
+            .filter(|turn| { turn.id == "turn-1" && matches!(turn.status, TurnStatus::InProgress) })
+            .count(),
+        1
+    );
+}
+
+#[tokio::test]
+async fn activate_thread_for_replay_does_not_duplicate_buffered_active_turn_start() {
+    let mut app = make_test_app().await;
+    let thread_id = ThreadId::new();
+    let session = test_thread_session(thread_id, test_path_buf("/tmp/project"));
+    let channel =
+        ThreadEventChannel::new_with_session(THREAD_EVENT_CHANNEL_CAPACITY, session, Vec::new());
+    {
+        let mut store = channel.store.lock().await;
+        store.push_notification(turn_started_notification(thread_id, "turn-1"));
+    }
+    app.thread_event_channels.insert(thread_id, channel);
+
+    let (_receiver, snapshot) = app
+        .activate_thread_for_replay(thread_id)
+        .await
+        .expect("thread should activate");
+
+    assert_eq!(
+        snapshot
+            .events
+            .iter()
+            .filter(|event| {
+                matches!(
+                    event,
+                    ThreadBufferedEvent::Notification(ServerNotification::TurnStarted(
+                        notification
+                    )) if notification.turn.id == "turn-1"
+                )
+            })
+            .count(),
+        1
+    );
+    assert!(
+        !snapshot
+            .turns
+            .iter()
+            .any(|turn| { turn.id == "turn-1" && matches!(turn.status, TurnStatus::InProgress) })
+    );
+}
