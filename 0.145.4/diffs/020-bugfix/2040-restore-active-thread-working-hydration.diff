+#[tokio::test]
+async fn activate_thread_for_replay_restores_working_and_independent_token_updates() {
+    let mut app = make_test_app().await;
+    let thread_id = ThreadId::new();
+    let session = test_thread_session(thread_id, test_path_buf("/tmp/project"));
+    let channel =
+        ThreadEventChannel::new_with_session(/*capacity*/ 1, session.clone(), Vec::new());
+    {
+        let mut store = channel.store.lock().await;
+        store.push_notification(turn_started_notification(thread_id, "turn-1"));
+        store.push_notification(token_usage_notification(thread_id, "turn-1", Some(950_000)));
+        assert!(matches!(
+            store.buffer.front(),
+            Some(ThreadBufferedEvent::Notification(
+                ServerNotification::ThreadTokenUsageUpdated(_)
+            ))
+        ));
+    }
+    app.thread_event_channels.insert(thread_id, channel);
+
+    let (_receiver, snapshot) = app
+        .activate_thread_for_replay(thread_id)
+        .await
+        .expect("thread should activate");
+    assert!(
+        snapshot
+            .turns
+            .iter()
+            .any(|turn| { turn.id == "turn-1" && matches!(turn.status, TurnStatus::InProgress) })
+    );
+
+    app.chat_widget.handle_thread_session(session);
+    app.chat_widget.setup_status_line(
+        vec![crate::bottom_pane::StatusLineItem::ContextWindowSize],
+        /*use_theme_colors*/ true,
+    );
+    app.replay_thread_snapshot(snapshot, /*resume_restored_queue*/ false);
+
+    assert!(app.chat_widget.is_task_running_for_test());
+    assert_eq!(app.chat_widget.current_status_header_for_test(), "Working");
+    assert_eq!(
+        app.chat_widget.status_line_text(),
+        Some("950K window".into())
+    );
+}
