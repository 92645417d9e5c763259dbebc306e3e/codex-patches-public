 const UNIFIED_EXEC_OUTPUT_DELTA_MAX_BYTES: usize = 8192;
+const UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES: usize = 64 * 1024;
+const UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE: &[u8] =
+    b"\n[output capped in live view; command continues]\n";
+
+#[derive(Debug, Default)]
+struct LiveOutputLimiter {
+    emitted_bytes: usize,
+    emitted_deltas: usize,
+    notice_emitted: bool,
+}
+
+impl LiveOutputLimiter {
+    fn next_delta(&mut self, prefix: &[u8]) -> Option<Vec<u8>> {
+        if prefix.is_empty()
+            || self.notice_emitted
+            || self.emitted_deltas >= MAX_EXEC_OUTPUT_DELTAS_PER_CALL
+        {
+            return None;
+        }
+
+        let remaining = UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES.saturating_sub(self.emitted_bytes);
+        self.emitted_deltas = self.emitted_deltas.saturating_add(1);
+        if prefix.len() <= remaining {
+            self.emitted_bytes = self.emitted_bytes.saturating_add(prefix.len());
+            return Some(prefix.to_vec());
+        }
+
+        self.notice_emitted = true;
+        let emitted_prefix_len = std::str::from_utf8(prefix).ok().map_or(remaining, |text| {
+            let mut len = remaining;
+            while !text.is_char_boundary(len) {
+                len -= 1;
+            }
+            len
+        });
+        self.emitted_bytes = self.emitted_bytes.saturating_add(emitted_prefix_len);
+        let mut capped = Vec::with_capacity(
+            emitted_prefix_len.saturating_add(UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE.len()),
+        );
+        capped.extend_from_slice(&prefix[..emitted_prefix_len]);
+        capped.extend_from_slice(UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE);
+        Some(capped)
+    }
+}
 
