+fn resolve_wait_timeout_ms(
+    args: &WaitArgs,
+    options: WaitAgentTimeoutOptions,
+) -> Result<i64, FunctionCallError> {
+    let timeout_ms = args.timeout_ms.unwrap_or(options.default_timeout_ms);
+    match timeout_ms {
+        ms if ms <= 0 => Err(FunctionCallError::RespondToModel(
+            "timeout_ms must be greater than zero".to_owned(),
+        )),
+        ms => Ok(ms.clamp(options.min_timeout_ms, options.max_timeout_ms)),
+    }
+}
