+#[traced_test]
+async fn foreground_model_refresh_failure_uses_debug_noise() {
+    let codex_home = tempdir().expect("temp dir");
+    let endpoint = FailingModelsEndpoint::new();
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint.clone());
+
+    let catalog = manager.raw_model_catalog(RefreshStrategy::Online).await;
+
+    assert_eq!(endpoint.fetch_count(), 1);
+    assert!(
+        !catalog.models.is_empty(),
+        "foreground refresh failure should preserve existing bundled models"
+    );
+    logs_assert(|lines: &[&str]| {
+        let logs = lines.join("\n");
+        if !logs.contains("failed to refresh available models") {
+            return Err("missing foreground refresh failure debug log".to_string());
+        }
+        if logs.contains("ERROR") && logs.contains("failed to refresh available models") {
+            return Err("foreground refresh failure was logged as error".to_string());
+        }
+        Ok(())
+    });
+}
