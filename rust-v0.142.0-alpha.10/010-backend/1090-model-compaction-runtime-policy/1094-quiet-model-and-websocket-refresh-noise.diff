+#[tokio::test]
+#[traced_test]
+async fn background_refresh_failure_uses_debug_noise_after_cache_hit() {
+    let cached_models = vec![remote_model(
+        "cached-timeout",
+        "Cached Timeout",
+        /*priority*/ 1,
+    )];
+    let codex_home = tempdir().expect("temp dir");
+    let endpoint = FailingModelsEndpoint::new();
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint.clone());
+    manager
+        .cache_manager
+        .persist_cache(
+            &cached_models,
+            None,
+            format!("{}-mismatch", crate::client_version_to_whole()),
+        )
+        .await;
+
+    tokio::time::timeout(
+        Duration::from_millis(100),
+        manager.refresh_available_models(RefreshStrategy::OnlineIfUncached),
+    )
+    .await
+    .expect("cache hit should return before background refresh completes")
+    .expect("cached refresh succeeds");
+    assert_models_contain(&manager.get_remote_models().await, &cached_models);
+    tokio::time::timeout(Duration::from_secs(1), async {
+        loop {
+            if endpoint.fetch_count() >= 1 && !manager.refresh_in_progress.load(Ordering::Acquire) {
+                break;
+            }
+            tokio::time::sleep(Duration::from_millis(10)).await;
+        }
+    })
+    .await
+    .expect("timed out waiting for background refresh failure");
+
+    logs_assert(|lines: &[&str]| {
+        let logs = lines.join("\n");
+        if !logs.contains("models refresh: background refresh failed") {
+            return Err("missing background refresh failure debug log".to_string());
+        }
+        if logs.contains("ERROR") && logs.contains("models refresh: background refresh failed") {
+            return Err("background refresh failure was logged as error".to_string());
+        }
+        Ok(())
+    });
