diff --git a/codex-rs/core/src/agent/registry_tests.rs b/codex-rs/core/src/agent/registry_tests.rs
index fc172fb336..d69fdb4956 100644
--- a/codex-rs/core/src/agent/registry_tests.rs
+++ b/codex-rs/core/src/agent/registry_tests.rs
@@ -159,6 +159,26 @@ fn release_is_idempotent_for_registered_threads() {
     drop(reservation);
 }
 
+#[test]
+fn retained_thread_spawn_count_survives_release() {
+    let registry = Arc::new(AgentRegistry::default());
+    let parent_id = ThreadId::new();
+    let child_id = ThreadId::new();
+    let reservation = registry
+        .reserve_spawn_slot(/*max_threads*/ None)
+        .expect("reserve slot");
+    reservation.commit(AgentMetadata {
+        agent_id: Some(child_id),
+        parent_thread_id: Some(parent_id),
+        ..Default::default()
+    });
+
+    assert_eq!(registry.retained_thread_spawn_count(parent_id), 1);
+
+    registry.release_spawned_thread(child_id);
+    assert_eq!(registry.retained_thread_spawn_count(parent_id), 1);
+}
