+#[tokio::test]
+async fn status_line_approval_reviewer_shows_user_or_agent() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+
+    chat.config.approvals_reviewer = ApprovalsReviewer::User;
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::ApprovalReviewer),
+        Some("user".to_string())
+    );
+
+    chat.config.approvals_reviewer = ApprovalsReviewer::AutoReview;
+    assert_eq!(
+        chat.status_line_value_for_item(crate::bottom_pane::StatusLineItem::ApprovalReviewer),
+        Some("agent".to_string())
+    );
+}
