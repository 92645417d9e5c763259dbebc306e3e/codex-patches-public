+pub(crate) async fn edit_with_helper(
+    seed: &str,
+    session_id: Option<&str>,
+) -> Result<Option<String>, String> {
+    let payload = EditorPayload {
+        kind: "Editor",
+        source: "codex",
+        session_id: session_id.map(str::to_string),
+        seed: seed.to_string(),
+    };
+    let response = tokio::task::spawn_blocking(move || {
+        send_payload_to_path_with_read_timeout(&payload, &codex_socket_path(), None)
+    })
+    .await
+    .map_err(|err| err.to_string())?;
+
+    match response {
+        Ok(response) => response
+            .content
+            .map(Some)
+            .ok_or_else(|| "codex helper editor response did not include Content".to_string()),
+        Err(err) if is_helper_unavailable(&err) => Ok(None),
+        Err(err) => Err(err),
+    }
+}
