+                .and_then(|active_turn| active_turn.task.as_ref())
+                .filter(|active_task| active_task.turn_context.sub_id == turn_context.sub_id)
+                .map(|active_task| Arc::clone(&active_task.retry_now))
+        };
+        let Some(retry_now) = retry_now else {
+            tokio::time::sleep(delay).await;
+            return false;
+        };
+        tokio::select! {
+            _ = tokio::time::sleep(delay) => false,
+            _ = retry_now.notified() => true,
+        }
