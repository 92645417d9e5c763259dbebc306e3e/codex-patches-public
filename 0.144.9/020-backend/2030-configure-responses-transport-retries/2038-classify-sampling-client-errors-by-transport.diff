--- a/codex-rs/core/src/responses_retry.rs
+++ b/codex-rs/core/src/responses_retry.rs
@@ -42,6 +42,18 @@ pub(crate) fn external_limit_retry_delay(err: &CodexErr) -> Option<Duration> {
     external_limit_retry(err).map(|retry| retry.delay)
 }
 
+pub(crate) fn sampling_error_is_retryable(
+    err: &CodexErr,
+    responses_websocket_enabled: bool,
+) -> bool {
+    match err {
+        CodexErr::UnexpectedStatus(response) if response.status.is_client_error() => {
+            responses_websocket_enabled
+        }
+        _ => err.is_retryable(),
+    }
+}
+
 fn external_limit_retry(err: &CodexErr) -> Option<ExternalLimitRetry> {
     external_limit_retry_at(err, SystemTime::now())
 }
