+    /// Resolves request-local instructions without changing the active session.
+    ///
+    /// Previous-model compaction can retry with the current model, so each attempt must resolve
+    /// from its own turn context instead of sharing the session-level value.
+    pub(crate) async fn resolve_base_instructions_for_context_boundary(
+        &self,
+        turn_context: &TurnContext,
+    ) -> BaseInstructions {
+        let text = if let Some(base_instructions) = turn_context.config.base_instructions.clone() {
+            base_instructions
+        } else {
+            self.services
+                .models_manager
+                .get_model_info(
+                    turn_context.collaboration_mode().model(),
+                    &turn_context.config.to_models_manager_config(),
+                )
+                .await
+                .get_model_instructions(turn_context.personality)
+        };
+        BaseInstructions { text }
+    }
