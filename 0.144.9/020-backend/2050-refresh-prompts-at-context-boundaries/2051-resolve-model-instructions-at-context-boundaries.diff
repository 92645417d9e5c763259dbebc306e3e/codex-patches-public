+#[tokio::test]
+async fn context_boundary_resolve_uses_current_catalog_without_publishing() {
+    let (session, turn_context) = make_session_and_context().await;
+    assert!(turn_context.config.base_instructions.is_none());
+    let expected = session
+        .services
+        .models_manager
+        .get_model_info(
+            turn_context.collaboration_mode().model(),
+            &turn_context.config.to_models_manager_config(),
+        )
+        .await
+        .get_model_instructions(turn_context.personality);
+    {
+        let mut state = session.state.lock().await;
+        state.session_configuration.base_instructions =
+            "STALE_CONTEXT_BOUNDARY_INSTRUCTIONS".to_string();
+    }
+
+    let resolved = session
+        .resolve_base_instructions_for_context_boundary(&turn_context)
+        .await;
+
+    assert_eq!(resolved.text, expected);
+    assert_eq!(
+        session.get_base_instructions().await.text,
+        "STALE_CONTEXT_BOUNDARY_INSTRUCTIONS"
+    );
+}
+
+#[tokio::test]
+async fn context_boundary_resolve_prefers_explicit_config_without_publishing() {
+    let (session, mut turn_context) = make_session_and_context().await;
+    let explicit = "EXPLICIT_CONTEXT_BOUNDARY_INSTRUCTIONS";
+    let mut config = turn_context.config.as_ref().clone();
+    config.base_instructions = Some(explicit.to_string());
+    turn_context.config = Arc::new(config);
+    {
+        let mut state = session.state.lock().await;
+        state.session_configuration.base_instructions =
+            "STALE_CONTEXT_BOUNDARY_INSTRUCTIONS".to_string();
+    }
+
+    let resolved = session
+        .resolve_base_instructions_for_context_boundary(&turn_context)
+        .await;
+    assert_eq!(resolved.text, explicit);
+    assert_eq!(
+        session.get_base_instructions().await.text,
+        "STALE_CONTEXT_BOUNDARY_INSTRUCTIONS"
+    );
+}
