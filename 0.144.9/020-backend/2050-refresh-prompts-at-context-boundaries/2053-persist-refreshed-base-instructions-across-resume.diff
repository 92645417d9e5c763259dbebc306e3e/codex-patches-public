+#[tokio::test]
+async fn flushed_compaction_is_atomic_across_crash_snapshots() -> std::io::Result<()> {
+    let home = TempDir::new().expect("temp dir");
+    let config = test_config(home.path());
+    let thread_id = ThreadId::new();
+    let recorder = RolloutRecorder::new(
+        &config,
+        RolloutRecorderParams::new(
+            thread_id,
+            /*forked_from_id*/ None,
+            /*parent_thread_id*/ None,
+            SessionSource::Exec,
+            /*thread_source*/ None,
+            "test_originator".to_string(),
+            BaseInstructions {
+                text: "creation base".to_string(),
+            },
+            Vec::new(),
+        ),
+    )
+    .await?;
+    let rollout_path = recorder.rollout_path().to_path_buf();
+    recorder
+        .record_canonical_items(&[RolloutItem::Compacted(CompactedItem {
+            message: "summary".to_string(),
+            replacement_history: Some(Vec::new()),
+            base_instructions_update: Some(ThreadBaseInstructionsUpdate {
+                thread_id,
+                base_instructions: BaseInstructions {
+                    text: "refreshed base".to_string(),
+                },
+            }),
+            window_number: None,
+            first_window_id: None,
+            previous_window_id: None,
+            window_id: None,
+        })])
+        .await?;
+    recorder.flush().await?;
+
+    let persisted = fs::read_to_string(&rollout_path)?;
+    let mut persisted_lines = persisted.lines();
+    let session_meta_line = persisted_lines.next().expect("session metadata line");
+    let compacted_line = persisted_lines.next().expect("compacted line");
+    assert!(persisted_lines.next().is_none());
+
+    let complete_snapshot = home.path().join("complete-crash-snapshot.jsonl");
+    fs::copy(&rollout_path, &complete_snapshot)?;
+    let mut corrupt_tail = std::fs::OpenOptions::new()
+        .append(true)
+        .open(&complete_snapshot)?;
+    writeln!(corrupt_tail, "{{\"timestamp\":")?;
+    let (complete_items, complete_thread_id, complete_parse_errors) =
+        RolloutRecorder::load_rollout_items(&complete_snapshot).await?;
+    assert_eq!(complete_thread_id, Some(thread_id));
+    assert_eq!(complete_parse_errors, 1);
+    let complete_history = InitialHistory::Resumed(ResumedHistory {
+        conversation_id: thread_id,
+        history: std::sync::Arc::new(complete_items),
+        rollout_path: Some(complete_snapshot),
+    });
+    assert_eq!(
+        complete_history
+            .get_base_instructions()
+            .map(|base| base.text),
+        Some("refreshed base".to_string())
+    );
+
+    let torn_snapshot = home.path().join("torn-compaction-snapshot.jsonl");
+    let compacted_prefix = &compacted_line[..compacted_line.len() / 2];
+    fs::write(
+        &torn_snapshot,
+        format!("{session_meta_line}\n{compacted_prefix}\n"),
+    )?;
+    let (torn_items, torn_thread_id, torn_parse_errors) =
+        RolloutRecorder::load_rollout_items(&torn_snapshot).await?;
+    assert_eq!(torn_thread_id, Some(thread_id));
+    assert_eq!(torn_parse_errors, 1);
+    assert!(
+        torn_items
+            .iter()
+            .all(|item| !matches!(item, RolloutItem::Compacted(_)))
+    );
+    let torn_history = InitialHistory::Resumed(ResumedHistory {
+        conversation_id: thread_id,
+        history: std::sync::Arc::new(torn_items),
+        rollout_path: Some(torn_snapshot),
+    });
+    assert_eq!(
+        torn_history.get_base_instructions().map(|base| base.text),
+        Some("creation base".to_string())
+    );
+
+    recorder.shutdown().await?;
+    Ok(())
+}
