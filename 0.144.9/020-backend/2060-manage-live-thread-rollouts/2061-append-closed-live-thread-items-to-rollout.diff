+
+        let err = append_items_to_fallback_rollout(None, fallback_error, &[])
+            .await
+            .expect_err("missing local fallback must preserve the store error");
+
+        assert!(
+            matches!(err, ThreadStoreError::ThreadNotFound { thread_id: missing } if missing == thread_id)
+        );
+    }
+}
