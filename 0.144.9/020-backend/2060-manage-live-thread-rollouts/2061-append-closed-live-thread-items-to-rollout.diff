+async fn append_items_to_fallback_rollout(
+    rollout_path: Option<&Path>,
+    fallback_error: ThreadStoreError,
+    items: &[RolloutItem],
+) -> ThreadStoreResult<()> {
+    let Some(rollout_path) = rollout_path else {
+        return Err(fallback_error);
+    };
+    for item in items {
+        append_rollout_item_to_path(rollout_path, item)
+            .await
+            .map_err(|err| ThreadStoreError::Internal {
+                message: format!("failed to append closed live thread item: {err}"),
+            })?;
+    }
+    Ok(())
