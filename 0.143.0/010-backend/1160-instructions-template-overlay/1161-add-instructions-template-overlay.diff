diff --git a/codex-rs/models-manager/src/cache_overlay.rs b/codex-rs/models-manager/src/cache_overlay.rs
new file mode 100644
index 0000000000..2d664ea123
--- /dev/null
+++ b/codex-rs/models-manager/src/cache_overlay.rs
@@ -0,0 +1,203 @@
+use codex_protocol::openai_models::ModelInfo;
+use serde_json::Map;
+use serde_json::Value;
+use std::fs;
+use std::io;
+use std::io::ErrorKind;
+use std::path::Path;
+use std::path::PathBuf;
+use tracing::warn;
+
+pub(crate) const INSTRUCTIONS_OVERLAY_FILE: &str = "instructions.json";
+pub(crate) const INSTRUCTIONS_OVERLAY_DIR: &str = "instructions";
+
+#[derive(Debug, Clone)]
+pub(crate) struct ModelsCacheOverlay {
+    json_path: PathBuf,
+    dir_path: PathBuf,
+}
+
+impl ModelsCacheOverlay {
+    pub(crate) fn new(codex_home: PathBuf) -> Self {
+        Self {
+            json_path: codex_home.join(INSTRUCTIONS_OVERLAY_FILE),
+            dir_path: codex_home.join(INSTRUCTIONS_OVERLAY_DIR),
+        }
+    }
+
+    pub(crate) fn apply(&self, mut models: Vec<ModelInfo>) -> Vec<ModelInfo> {
+        self.apply_json_overlay(&mut models);
+        seed_overlay_dir(&models, &self.dir_path);
+        apply_overlay_dir(&mut models, &self.dir_path);
+        models
+    }
+
+    pub(crate) fn seed_dir(&self, mut models: Vec<ModelInfo>) {
+        self.apply_json_overlay(&mut models);
+        seed_overlay_dir(&models, &self.dir_path);
+    }
+
+    fn apply_json_overlay(&self, models: &mut [ModelInfo]) {
+        if let Some(overlay) = match load_overlay(&self.json_path) {
+            Ok(overlay) => overlay,
+            Err(err) => {
+                warn!(
+                    path = %self.json_path.display(),
+                    "failed to load instructions overlay: {err}"
+                );
+                return;
+            }
+        } {
+            for model in models {
+                let Some(overlay_model) = overlay_model(&overlay, &model.slug) else {
+                    continue;
+                };
+                apply_overlay_model(model, overlay_model, &self.json_path);
+            }
+        }
+    }
+}
+
+fn load_overlay(path: &Path) -> io::Result<Option<Value>> {
+    match fs::read(path) {
+        Ok(contents) => serde_json::from_slice::<Value>(&contents)
+            .map(Some)
+            .map_err(|err| io::Error::new(ErrorKind::InvalidData, err.to_string())),
+        Err(err) if err.kind() == ErrorKind::NotFound => Ok(None),
+        Err(err) => Err(err),
+    }
+}
+
+fn overlay_model<'a>(overlay: &'a Value, slug: &str) -> Option<&'a Map<String, Value>> {
+    overlay
+        .get("models")
+        .and_then(Value::as_object)
+        .and_then(|models| models.get(slug))
+        .and_then(Value::as_object)
+}
+
+fn template_value(model: &Map<String, Value>) -> Option<&Value> {
+    model
+        .get("model_messages")
+        .and_then(Value::as_object)
+        .and_then(|messages| messages.get("instructions_template"))
+}
+
+fn apply_overlay_model(model: &mut ModelInfo, overlay_model: &Map<String, Value>, path: &Path) {
+    let Some(messages) = model.model_messages.as_mut() else {
+        return;
+    };
+    let Some(template) = template_value(overlay_model) else {
+        return;
+    };
+    let Some(template) = template.as_str() else {
+        warn!(
+            model = %model.slug,
+            path = %path.display(),
+            "instructions overlay instructions_template must be a string"
+        );
+        return;
+    };
+    if template.is_empty() {
+        warn!(
+            model = %model.slug,
+            path = %path.display(),
+            "instructions overlay instructions_template must not be empty"
+        );
+        return;
+    }
+    messages.instructions_template = Some(template.to_string());
+}
+
+fn apply_overlay_dir(models: &mut [ModelInfo], dir_path: &Path) {
+    for model in models {
+        let Some(path) = overlay_dir_model_path(dir_path, &model.slug) else {
+            continue;
+        };
+        let template = match fs::read_to_string(&path) {
+            Ok(template) => template,
+            Err(err) if err.kind() == ErrorKind::NotFound => continue,
+            Err(err) => {
+                warn!(
+                    model = %model.slug,
+                    path = %path.display(),
+                    "failed to load instructions overlay file: {err}"
+                );
+                continue;
+            }
+        };
+        apply_template_string(model, &template, &path);
+    }
+}
+
+fn seed_overlay_dir(models: &[ModelInfo], dir_path: &Path) {
+    match fs::metadata(dir_path) {
+        Ok(metadata) if metadata.is_dir() => return,
+        Ok(_) => {
+            warn!(
+                path = %dir_path.display(),
+                "instructions overlay path is not a directory"
+            );
+            return;
+        }
+        Err(err) if err.kind() == ErrorKind::NotFound => {}
+        Err(err) => {
+            warn!(
+                path = %dir_path.display(),
+                "failed to inspect instructions overlay directory: {err}"
+            );
+            return;
+        }
+    }
+    if let Err(err) = fs::create_dir_all(dir_path) {
+        warn!(
+            path = %dir_path.display(),
+            "failed to create instructions overlay directory: {err}"
+        );
+        return;
+    }
+    for model in models {
+        let Some(path) = overlay_dir_model_path(dir_path, &model.slug) else {
+            continue;
+        };
+        let Some(template) = model
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref())
+        else {
+            continue;
+        };
+        if template.trim().is_empty() {
+            continue;
+        }
+        if let Err(err) = fs::write(&path, template) {
+            warn!(
+                model = %model.slug,
+                path = %path.display(),
+                "failed to seed instructions overlay file: {err}"
+            );
+        }
+    }
+}
+
+fn overlay_dir_model_path(dir_path: &Path, slug: &str) -> Option<PathBuf> {
+    if slug.is_empty() || slug.contains(std::path::MAIN_SEPARATOR) {
+        return None;
+    }
+    Some(dir_path.join(format!("{slug}.md")))
+}
+
+fn apply_template_string(model: &mut ModelInfo, template: &str, path: &Path) {
+    let Some(messages) = model.model_messages.as_mut() else {
+        return;
+    };
+    if template.trim().is_empty() {
+        warn!(
+            model = %model.slug,
+            path = %path.display(),
+            "instructions overlay file must not be empty"
+        );
+        return;
+    }
+    messages.instructions_template = Some(template.to_string());
+}
