+fn merge_runtime_env(handlers: &mut [ConfiguredHandler], runtime_env: &HashMap<String, String>) {
+    if runtime_env.is_empty() {
+        return;
+    }
+
+    for handler in handlers {
+        let handler_env = std::mem::take(&mut handler.env);
+        handler.env = runtime_env.clone();
+        handler.env.extend(handler_env);
+    }
+}
