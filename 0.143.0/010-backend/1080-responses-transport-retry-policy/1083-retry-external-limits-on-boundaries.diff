+#[cfg(test)]
+mod tests {
+    use super::*;
+    use codex_protocol::error::UsageLimitReachedError;
+
+    fn usage_limit_reached_error() -> CodexErr {
+        CodexErr::UsageLimitReached(UsageLimitReachedError {
+            plan_type: None,
+            resets_at: None,
+            rate_limits: None,
+            promo_message: None,
+            rate_limit_reached_type: None,
+        })
+    }
+
+    #[test]
+    fn external_limit_errors_have_boundary_retry_delays() {
+        let now = UNIX_EPOCH + Duration::from_secs(6 * 60 * 60 + 21 * 60 + 10);
+
+        assert_eq!(
+            external_limit_retry_at(&CodexErr::ServerOverloaded, now),
+            Some(ExternalLimitRetry {
+                kind: ExternalLimitRetryKind::Capacity,
+                delay: Duration::from_secs(3 * 60 + 50),
+                retry_at: now + Duration::from_secs(3 * 60 + 50),
+            })
+        );
+        assert_eq!(
+            external_limit_retry_at(&CodexErr::QuotaExceeded, now),
+            Some(ExternalLimitRetry {
+                kind: ExternalLimitRetryKind::AccountQuota,
+                delay: Duration::from_secs(8 * 60 + 50),
+                retry_at: now + Duration::from_secs(8 * 60 + 50),
+            })
+        );
+        assert_eq!(
+            external_limit_retry_at(&usage_limit_reached_error(), now),
+            Some(ExternalLimitRetry {
+                kind: ExternalLimitRetryKind::AccountQuota,
+                delay: Duration::from_secs(8 * 60 + 50),
+                retry_at: now + Duration::from_secs(8 * 60 + 50),
+            })
+        );
+        assert_eq!(
+            external_limit_retry_at(&CodexErr::UsageNotIncluded, now),
+            None
+        );
+        assert_eq!(
+            external_limit_retry_at(
+                &CodexErr::CyberPolicy {
+                    message: "blocked".to_string(),
+                },
+                now
+            ),
+            None
+        );
+        assert_eq!(
+            external_limit_retry_at(&CodexErr::Stream("stream failed".to_string(), None), now),
+            None
+        );
+    }
+
+    #[test]
+    fn boundary_retry_warning_messages_are_specific() {
+        let capacity = external_limit_retry_warning(ExternalLimitRetry {
+            kind: ExternalLimitRetryKind::Capacity,
+            delay: Duration::from_secs(230),
+            retry_at: SystemTime::now() + Duration::from_secs(230),
+        });
+        assert!(capacity.contains("External capacity limit reached"));
+        assert!(capacity.contains("Retrying at "));
+        assert!(capacity.contains("next 5-minute boundary"));
+        assert!(!capacity.contains("Retrying in"));
+        assert!(!capacity.contains("capacity or quota"));
+
+        let quota = external_limit_retry_warning(ExternalLimitRetry {
+            kind: ExternalLimitRetryKind::AccountQuota,
+            delay: Duration::from_secs(530),
+            retry_at: SystemTime::now() + Duration::from_secs(530),
+        });
+        assert!(quota.contains("Account quota limit reached"));
+        assert!(quota.contains("Retrying at "));
+        assert!(quota.contains("next 30-minute boundary"));
+        assert!(!quota.contains("Retrying in"));
+        assert!(!quota.contains("capacity or quota"));
+    }
+
+    #[test]
+    fn spark_model_uses_surface_error_external_limit_policy() {
+        assert_eq!(
+            external_limit_retry_policy_for_model("gpt-5.3-codex-spark"),
+            ExternalLimitRetryPolicy::SurfaceError
+        );
+        assert_eq!(
+            external_limit_retry_policy_for_model("gpt-5.3-codex"),
+            ExternalLimitRetryPolicy::RetryForever
+        );
+    }
+
+    #[test]
+    fn surface_error_policy_does_not_retry_external_limits() {
+        assert_eq!(
+            retryable_external_limit_for_policy(
+                &CodexErr::QuotaExceeded,
+                30,
+                ExternalLimitRetryPolicy::SurfaceError,
+            ),
+            None
+        );
+        assert!(
+            retryable_external_limit_for_policy(
+                &CodexErr::QuotaExceeded,
+                30,
+                ExternalLimitRetryPolicy::RetryForever,
+            )
+            .is_some()
+        );
+    }
+}
