+fn retryable_external_limit_for_policy(
+    err: &CodexErr,
+    max_retries: u64,
+    external_limit_retry_policy: ExternalLimitRetryPolicy,
+) -> Option<ExternalLimitRetry> {
+    if max_retries == 0 || external_limit_retry_policy == ExternalLimitRetryPolicy::SurfaceError {
+        return None;
+    }
+    external_limit_retry(err)
+}
+
+fn log_external_limit_retry_forever(
+    request: ResponsesStreamRequest,
+    turn_context: &TurnContext,
+    err: &CodexErr,
+    retry: ExternalLimitRetry,
+) {
+    match request {
+        ResponsesStreamRequest::Sampling => {
+            warn!(
+                error = %err,
+                retry_kind = ?retry.kind,
+                delay = ?retry.delay,
+                "external limit reached; retrying sampling request"
+            );
+        }
+        ResponsesStreamRequest::RemoteCompactionV2 => {
+            warn!(
+                turn_id = %turn_context.sub_id,
+                error = %err,
+                retry_kind = ?retry.kind,
+                delay = ?retry.delay,
+                "external limit reached; retrying remote compaction v2 request"
+            );
+        }
+    }
+}
