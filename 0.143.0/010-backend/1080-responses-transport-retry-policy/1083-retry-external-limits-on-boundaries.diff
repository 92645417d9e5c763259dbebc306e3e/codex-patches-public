+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub(crate) enum ExternalLimitRetryPolicy {
+    RetryForever,
+    SurfaceError,
+}
+
+const EXTERNAL_LIMIT_CAPACITY_RETRY_INTERVAL: Duration = Duration::from_secs(5 * 60);
+const EXTERNAL_LIMIT_ACCOUNT_QUOTA_RETRY_INTERVAL: Duration = Duration::from_secs(30 * 60);
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub(crate) enum ExternalLimitRetryKind {
+    Capacity,
+    AccountQuota,
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub(crate) struct ExternalLimitRetry {
+    pub(crate) kind: ExternalLimitRetryKind,
+    pub(crate) delay: Duration,
+    pub(crate) retry_at: SystemTime,
+}
+
+pub(crate) fn external_limit_retry_delay(err: &CodexErr) -> Option<Duration> {
+    external_limit_retry(err).map(|retry| retry.delay)
+}
+
+pub(crate) fn external_limit_retry_policy_for_model(model_slug: &str) -> ExternalLimitRetryPolicy {
+    if model_slug == "gpt-5.3-codex-spark" {
+        ExternalLimitRetryPolicy::SurfaceError
+    } else {
+        ExternalLimitRetryPolicy::RetryForever
+    }
+}
+
+fn external_limit_retry(err: &CodexErr) -> Option<ExternalLimitRetry> {
+    external_limit_retry_at(err, SystemTime::now())
+}
+
+fn external_limit_retry_at(err: &CodexErr, now: SystemTime) -> Option<ExternalLimitRetry> {
+    let (kind, interval) = match err {
+        CodexErr::ServerOverloaded => (
+            ExternalLimitRetryKind::Capacity,
+            EXTERNAL_LIMIT_CAPACITY_RETRY_INTERVAL,
+        ),
+        CodexErr::QuotaExceeded | CodexErr::UsageLimitReached(_) => (
+            ExternalLimitRetryKind::AccountQuota,
+            EXTERNAL_LIMIT_ACCOUNT_QUOTA_RETRY_INTERVAL,
+        ),
+        _ => return None,
+    };
+
+    let delay = delay_until_next_boundary(now, interval);
+    Some(ExternalLimitRetry {
+        kind,
+        delay,
+        retry_at: now + delay,
+    })
+}
+
+fn delay_until_next_boundary(now: SystemTime, interval: Duration) -> Duration {
+    let Ok(elapsed) = now.duration_since(UNIX_EPOCH) else {
+        return interval;
+    };
+    let interval_ms = interval.as_millis();
+    let elapsed_ms = elapsed.as_millis();
+    let remainder = elapsed_ms % interval_ms;
+    let delay_ms = if remainder == 0 {
+        interval_ms
+    } else {
+        interval_ms - remainder
+    };
+    Duration::from_millis(delay_ms.try_into().unwrap_or(u64::MAX))
+}
+
+fn format_retry_at_local_time(retry_at: SystemTime) -> String {
+    let retry_at: DateTime<Local> = retry_at.into();
+    retry_at.format("%H:%M").to_string()
+}
+
+fn external_limit_retry_warning(retry: ExternalLimitRetry) -> String {
+    let retry_at = format_retry_at_local_time(retry.retry_at);
+    match retry.kind {
+        ExternalLimitRetryKind::Capacity => format!(
+            "External capacity limit reached. Retrying at {retry_at} (next 5-minute boundary)."
+        ),
+        ExternalLimitRetryKind::AccountQuota => format!(
+            "Account quota limit reached. Retrying at {retry_at} (next 30-minute boundary)."
+        ),
+    }
+}
