--- /dev/null
+++ b/codex-rs/app-server/src/message_processor_thread_list_tests.rs
@@ -0,0 +1,81 @@
+use super::*;
+use codex_app_server_protocol::ThreadListResponse;
+use pretty_assertions::assert_eq;
+
+#[test]
+fn every_app_server_client_except_tui_thread_list_is_limited() {
+    assert_eq!(
+        should_limit_thread_list_for_client(Some("codex-tui")),
+        false
+    );
+    assert_eq!(
+        should_limit_thread_list_for_client(Some("codex-backend")),
+        true
+    );
+    assert_eq!(
+        should_limit_thread_list_for_client(Some("codex_app_server_daemon")),
+        true
+    );
+    assert_eq!(should_limit_thread_list_for_client(None), true);
+}
+
+#[test]
+fn non_tui_thread_list_request_is_forced_to_recent_five() {
+    let mut params = ThreadListParams {
+        cursor: Some("client-cursor".to_string()),
+        limit: Some(100),
+        sort_key: Some(ThreadSortKey::CreatedAt),
+        sort_direction: Some(SortDirection::Asc),
+        model_providers: None,
+        source_kinds: None,
+        archived: None,
+        cwd: None,
+        parent_thread_id: None,
+        ancestor_thread_id: None,
+        use_state_db_only: false,
+        search_term: None,
+    };
+
+    apply_non_tui_thread_list_limit(&mut params);
+
+    assert_eq!(
+        params,
+        ThreadListParams {
+            cursor: None,
+            limit: Some(NON_TUI_THREAD_LIST_LIMIT),
+            sort_key: Some(ThreadSortKey::UpdatedAt),
+            sort_direction: Some(SortDirection::Desc),
+            model_providers: None,
+            source_kinds: None,
+            archived: None,
+            cwd: None,
+            parent_thread_id: None,
+            ancestor_thread_id: None,
+            use_state_db_only: false,
+            search_term: None,
+        }
+    );
+}
+
+#[test]
+fn non_tui_thread_list_response_hides_pagination() {
+    let response = ClientResponsePayload::ThreadList(ThreadListResponse {
+        data: Vec::new(),
+        next_cursor: Some("next".to_string()),
+        backwards_cursor: Some("back".to_string()),
+    });
+
+    let ClientResponsePayload::ThreadList(response) = limit_non_tui_thread_list_response(response)
+    else {
+        panic!("expected thread list response");
+    };
+
+    assert_eq!(
+        response,
+        ThreadListResponse {
+            data: Vec::new(),
+            next_cursor: None,
+            backwards_cursor: None,
+        }
+    );
+}
