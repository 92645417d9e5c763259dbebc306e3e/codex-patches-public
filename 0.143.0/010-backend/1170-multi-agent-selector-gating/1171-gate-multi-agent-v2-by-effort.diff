+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn remote_multi_agent_selector_requires_ultra_for_v2_metadata() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let mut v2_model = remote_model("test-multi-agent-v2-non-ultra");
+    v2_model.multi_agent_version = Some(MultiAgentVersion::V2);
+    let v2_body = response_body_for_remote_model(v2_model, |config| {
+        config.model_reasoning_effort = Some(ReasoningEffort::High);
+        config
+            .features
+            .enable(Feature::MultiAgentV2)
+            .expect("test config should allow feature update");
+    })
+    .await?;
+    let tools = tool_names(&v2_body);
+    assert!(has_v1_tools(&tools));
+    assert!(!has_v2_tools(&tools));
+
+    Ok(())
+}
