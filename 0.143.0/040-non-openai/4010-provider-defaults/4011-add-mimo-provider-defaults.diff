+fn heal_provider_map(providers: &mut Map<String, Value>, defaults: &Map<String, Value>) {
+    for (provider_id, default_provider) in defaults {
+        match providers.get_mut(provider_id) {
+            Some(provider) => heal_provider_value(provider, default_provider),
+            None => {
+                providers.insert(provider_id.clone(), default_provider.clone());
+            }
+        }
+    }
+}
+
+fn heal_provider_value(provider: &mut Value, default_provider: &Value) {
+    let (Some(provider), Some(default_provider)) =
+        (provider.as_object_mut(), default_provider.as_object())
+    else {
+        *provider = default_provider.clone();
+        return;
+    };
+    for (key, default_child) in default_provider {
+        match key.as_str() {
+            "transport" | "capabilities" => {
+                heal_fixed_object_field(provider, key, default_child);
+            }
+            "models" => {
+                heal_models_field(provider, default_child);
+            }
+            _ => {
+                provider
+                    .entry(key.clone())
+                    .or_insert_with(|| default_child.clone());
+            }
+        }
+    }
+}
+
+fn heal_fixed_object_field(parent: &mut Map<String, Value>, key: &str, default_value: &Value) {
+    match parent.get_mut(key) {
+        Some(child) if child.is_object() && default_value.is_object() => {
+            merge_missing_value(child, default_value);
+        }
+        Some(child) if !child.is_object() && default_value.is_object() => {
+            *child = default_value.clone();
+        }
+        Some(_) => {}
+        None => {
+            parent.insert(key.to_string(), default_value.clone());
+        }
+    }
+}
+
+fn heal_models_field(parent: &mut Map<String, Value>, default_models: &Value) {
+    let default_model =
+        serde_json::to_value(ModelConfig::default()).unwrap_or_else(|_| Value::Object(Map::new()));
+    let Some(models) = parent.get_mut("models") else {
+        parent.insert("models".to_string(), default_models.clone());
+        return;
+    };
+    let Some(models) = models.as_object_mut() else {
+        *models = default_models.clone();
+        return;
+    };
+    let default_models = default_models.as_object();
+    for (model_id, model) in models.iter_mut() {
+        let model_default = default_models
+            .and_then(|defaults| defaults.get(model_id))
+            .unwrap_or(&default_model);
+        heal_model_value(model, model_default);
+    }
+    if let Some(default_models) = default_models {
+        for (model_id, default_model) in default_models {
+            models
+                .entry(model_id.clone())
+                .or_insert_with(|| default_model.clone());
+        }
+    }
+}
+
+fn heal_model_value(model: &mut Value, default_model: &Value) {
+    let (Some(model), Some(default_model)) = (model.as_object_mut(), default_model.as_object())
+    else {
+        *model = default_model.clone();
+        return;
+    };
+    for (key, default_child) in default_model {
+        match key.as_str() {
+            "reasoning" => heal_reasoning_field(model, default_child),
+            _ => {
+                model
+                    .entry(key.clone())
+                    .or_insert_with(|| default_child.clone());
+            }
+        }
+    }
+}
+
+fn heal_reasoning_field(parent: &mut Map<String, Value>, default_reasoning: &Value) {
+    let default_route = serde_json::to_value(ReasoningRouteConfig::default())
+        .unwrap_or_else(|_| Value::Object(Map::new()));
+    let Some(reasoning) = parent.get_mut("reasoning") else {
+        parent.insert("reasoning".to_string(), default_reasoning.clone());
+        return;
+    };
+    let Some(reasoning) = reasoning.as_object_mut() else {
+        *reasoning = default_reasoning.clone();
+        return;
+    };
+    let default_reasoning = default_reasoning.as_object();
+    if let Some(defaults) = default_reasoning {
+        if defaults.is_empty() {
+            let unsupported = reasoning
+                .keys()
+                .filter(|effort| effort.parse::<ReasoningEffort>().is_err())
+                .cloned()
+                .collect::<Vec<_>>();
+            for effort in unsupported {
+                reasoning.remove(&effort);
+            }
+        } else {
+            let unsupported = reasoning
+                .keys()
+                .filter(|effort| !defaults.contains_key(*effort))
+                .cloned()
+                .collect::<Vec<_>>();
+            for effort in unsupported {
+                reasoning.remove(&effort);
+            }
+            for (effort, route) in defaults {
+                reasoning
+                    .entry(effort.clone())
+                    .or_insert_with(|| route.clone());
+            }
+        }
+    }
+    for (effort, route) in reasoning {
+        let route_default = default_reasoning
+            .and_then(|defaults| defaults.get(effort))
+            .unwrap_or(&default_route);
+        heal_reasoning_route_value(route, route_default);
+    }
+}
+
+fn heal_reasoning_route_value(route: &mut Value, default_route: &Value) {
+    let (Some(route), Some(default_route)) = (route.as_object_mut(), default_route.as_object())
+    else {
+        *route = default_route.clone();
+        return;
+    };
+    for (key, default_child) in default_route {
+        route
+            .entry(key.clone())
+            .or_insert_with(|| default_child.clone());
+    }
+    if route
+        .get("upstream_reasoning_effort")
+        .is_some_and(|value| !valid_reasoning_effort_value(value))
+    {
+        route.remove("upstream_reasoning_effort");
+    }
+}
+
+fn valid_reasoning_effort_value(value: &Value) -> bool {
+    value
+        .as_str()
+        .is_some_and(|effort| effort.parse::<ReasoningEffort>().is_ok())
+}
