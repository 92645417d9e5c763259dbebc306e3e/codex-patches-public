 fn default_config() -> BTreeMap<String, ProviderConfig> {
-    BTreeMap::new()
+    let mut providers = BTreeMap::new();
+    providers.insert("mimo".to_string(), default_mimo_provider());
+    providers
+}
+
+fn default_mimo_provider() -> ProviderConfig {
+    let mut provider = ProviderConfig {
+        enabled: false,
+        api_key: DEFAULT_API_KEY.to_string(),
+        base_url: "https://api.xiaomimimo.com/v1".to_string(),
+        display_name: "MiMo".to_string(),
+        transport: TransportConfig {
+            http_sse: true,
+            websocket: false,
+        },
+        capabilities: CapabilityConfig {
+            json_schema_output: false,
+            plaintext_reasoning: true,
+            previous_response_id: false,
+        },
+        models: BTreeMap::new(),
+    };
+    let mut reasoning = BTreeMap::new();
+    reasoning.insert(
+        "low".to_string(),
+        ReasoningRouteConfig {
+            upstream_model: "mimo-v2.5".to_string(),
+            upstream_reasoning_effort: Some(ReasoningEffort::High),
+        },
+    );
+    reasoning.insert(
+        "high".to_string(),
+        ReasoningRouteConfig {
+            upstream_model: "mimo-v2.5-pro".to_string(),
+            upstream_reasoning_effort: Some(ReasoningEffort::High),
+        },
+    );
+    provider.models.insert(
+        "mimo-v2.5".to_string(),
+        ModelConfig {
+            display_name: "mimo-v2.5".to_string(),
+            description: Some("Cost-efficient model developed by Xiaomi.".to_string()),
+            text: true,
+            image: false,
+            web_search: false,
+            context_window: 512_000,
+            effective_context_window_percent: 95,
+            reasoning,
+        },
+    );
+    provider
 }
 
