+
+fn expanded_tab_byte_offset(text: &str, byte_offset: usize) -> usize {
+    let target = byte_offset.min(text.len());
+    let mut expanded = 0;
+    for (idx, ch) in text.char_indices() {
+        if idx >= target {
+            break;
+        }
+        expanded += if ch == '\t' {
+            TAB_EXPANSION.len()
+        } else {
+            ch.len_utf8()
+        };
+    }
+    expanded
+}
