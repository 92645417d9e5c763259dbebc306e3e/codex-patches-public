 }
@@ -86,9 +88,30 @@ impl RateLimitWindowDisplay {
         Self {
             used_percent: f64::from(window.used_percent),
             resets_at,
+            resets_at_time: resets_at_utc,
             window_minutes: window.window_duration_mins,
         }
     }
+
+    pub(crate) fn pace_percent(&self, now: DateTime<Local>) -> Option<i64> {
+        let resets_at = self.resets_at_time?;
+        let window_minutes = self.window_minutes?;
+        if window_minutes <= 0 {
+            return None;
+        }
+
+        let window = ChronoDuration::minutes(window_minutes);
+        let total_seconds = window.num_seconds();
+        if total_seconds <= 0 {
+            return None;
+        }
+
+        let starts_at = resets_at - window;
+        let elapsed_seconds = now.signed_duration_since(starts_at).num_seconds();
+        let elapsed_percent =
+            (elapsed_seconds as f64 / total_seconds as f64 * 100.0).clamp(0.0, 100.0);
+        Some((elapsed_percent - self.used_percent).round() as i64)
+    }
 }
 
