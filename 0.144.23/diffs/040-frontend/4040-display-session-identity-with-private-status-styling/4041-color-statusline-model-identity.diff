+#[tokio::test]
+async fn status_line_model_with_reasoning_uses_submitted_context_while_pending() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(Some("gpt-5")).await;
+    chat.thread_id = Some(ThreadId::new());
+    chat.config.tui_status_line = Some(vec!["model-with-reasoning".to_string()]);
+    chat.config.tui_terminal_title = Some(vec!["model-with-reasoning".to_string()]);
+    chat.set_reasoning_effort(Some(ReasoningEffortConfig::High));
+
+    chat.submit_user_message(UserMessage::from("run with gpt-5"));
+    chat.set_model("gpt-5.4");
+    chat.set_reasoning_effort(Some(ReasoningEffortConfig::Low));
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5 high".to_string()));
+    let line = chat.model_with_reasoning_display_line();
+    assert_eq!(
+        line.spans[0].style,
+        crate::model_color::model_style("gpt-5")
+    );
+    assert_eq!(
+        line.spans[2].style.fg,
+        Some(ratatui::style::Color::Rgb(255, 128, 0))
+    );
+    assert_eq!(chat.last_terminal_title, Some("gpt-5.4 low".to_string()));
+    assert_eq!(
+        chat.status_surface_preview_value_for_item(
+            crate::bottom_pane::StatusSurfacePreviewItem::ModelWithReasoning,
+        ),
+        Some("gpt-5.4 low".to_string())
+    );
+    chat.config.tui_status_line = Some(vec!["model".to_string(), "reasoning".to_string()]);
+    chat.refresh_status_line();
+    assert_eq!(status_line_text(&chat), Some("gpt-5 ▪ high".to_string()));
+    chat.config.tui_status_line = Some(vec!["model-with-reasoning".to_string()]);
+    chat.refresh_status_line();
+
+    chat.on_task_started();
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5 high".to_string()));
+
+    chat.on_task_complete(
+        /*last_agent_message*/ None, /*duration_ms*/ None, /*from_replay*/ false,
+    );
+
+    assert_eq!(status_line_text(&chat), Some("gpt-5.4 low".to_string()));
+}
