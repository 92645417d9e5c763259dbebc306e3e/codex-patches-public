+#[tokio::test]
+async fn status_line_branch_refreshes_after_command_completion() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    install_noop_workspace_command_runner(&mut chat);
+    chat.config.tui_status_line = Some(vec!["git-branch".to_string()]);
+    chat.status_line_branch_lookup_complete = true;
+    chat.status_line_branch_pending = false;
+    let command = vec!["git".to_string(), "switch".to_string(), "topic".to_string()];
+    let command_actions = codex_shell_command::parse_command::parse_command(&command)
+        .into_iter()
+        .map(|parsed| AppServerCommandAction::from_core_with_cwd(parsed, &chat.config.cwd))
+        .collect();
+    let cwd = chat.config.cwd.clone();
+
+    handle_exec_end(
+        &mut chat,
+        AppServerThreadItem::CommandExecution {
+            id: "branch-change".to_string(),
+            command: codex_shell_command::parse_command::shlex_join(&command),
+            cwd: cwd.into(),
+            process_id: None,
+            source: ExecCommandSource::Agent,
+            status: AppServerCommandExecutionStatus::Completed,
+            command_actions,
+            aggregated_output: None,
+            exit_code: Some(0),
+            duration_ms: Some(1),
+        },
+    );
+
+    assert!(chat.status_line_branch_pending);
+}
