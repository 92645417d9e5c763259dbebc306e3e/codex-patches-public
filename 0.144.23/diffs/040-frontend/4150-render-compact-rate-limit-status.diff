+
+fn status_line_limit_metric_spans(
+    window: &RateLimitWindowDisplay,
+    base_style: Style,
+    use_colors: bool,
+) -> Vec<Span<'static>> {
+    let remaining = (100.0f64 - window.used_percent).clamp(0.0f64, 100.0f64);
+    let mut spans = vec![Span::styled(format!("{remaining:.0}%"), base_style)];
+    if let Some(pace) = window.pace_percent {
+        spans.push(Span::styled(" ", base_style));
+        spans.push(Span::styled(
+            format!("{pace:+}%"),
+            limit_pace_style(pace, base_style, use_colors),
+        ));
+    }
+    spans
+}
+
+fn limit_pace_style(pace: i32, base_style: Style, use_colors: bool) -> Style {
+    if !use_colors {
+        return base_style;
+    }
+    let color = match pace {
+        ..=-21 => Color::Red,
+        -20..=-11 => Color::Rgb(255, 128, 0),
+        -10..=-1 => Color::Yellow,
+        _ => Color::Green,
+    };
+    base_style.fg(color).add_modifier(Modifier::BOLD)
+}
