+fn surface_separator_line(width: u16, border_style: Style) -> HyperlinkLine {
+    HyperlinkLine::new(Line::from(Span::styled(
+        "─".repeat(usize::from(width.max(1))),
+        border_style,
+    )))
+}
+
+fn surface_body_lines(
+    lines: Vec<HyperlinkLine>,
+    width: u16,
+    surface_style: Style,
+) -> Vec<HyperlinkLine> {
+    let frame_width = usize::from(width.max(1));
+    lines
+        .into_iter()
+        .map(|mut line| {
+            let left_padding = usize::from(frame_width > 1);
+            let content_width = left_padding.saturating_add(line.line.width());
+            let mut spans = Vec::with_capacity(line.line.spans.len().saturating_add(2));
+            if left_padding > 0 {
+                spans.push(Span::styled(" ", surface_style));
+            }
+            spans.extend(line.line.spans);
+            for hyperlink in &mut line.hyperlinks {
+                hyperlink.columns =
+                    hyperlink.columns.start + left_padding..hyperlink.columns.end + left_padding;
+            }
+            let right_padding = frame_width.saturating_sub(content_width);
+            if right_padding > 0 {
+                spans.push(Span::styled(" ".repeat(right_padding), surface_style));
+            }
+            line.line = Line::from(spans).style(line.line.style.patch(surface_style));
+            line
+        })
+        .collect()
+}
+
+fn framed_surface_lines(
+    lines: Vec<HyperlinkLine>,
+    width: u16,
+    border_style: Style,
+    surface_style: Style,
+    include_top: bool,
+    include_bottom: bool,
+) -> Vec<HyperlinkLine> {
+    let mut out = Vec::new();
+    if include_top {
+        out.push(surface_separator_line(width.max(1), border_style));
+    }
+    out.extend(surface_body_lines(lines, width, surface_style));
+    if include_bottom {
+        out.push(surface_separator_line(width.max(1), border_style));
+    }
+    out
+}
