+pub(crate) fn prewrap_history_line(
+    line: &HyperlinkLine,
+    wrap_width: usize,
+    wrap_policy: HistoryLineWrapPolicy,
+) -> Vec<HyperlinkLine> {
+    match wrap_policy {
+        HistoryLineWrapPolicy::Terminal => vec![line.clone()],
+        HistoryLineWrapPolicy::PreWrap if line.width() <= wrap_width => vec![line.clone()],
+        HistoryLineWrapPolicy::PreWrap
+            if line_contains_url_like(&line.line)
