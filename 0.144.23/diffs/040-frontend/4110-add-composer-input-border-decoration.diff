+pub(super) fn drain_transcript_updates(
+    rx: &mut tokio::sync::mpsc::UnboundedReceiver<AppEvent>,
+) -> Vec<Vec<ratatui::text::Line<'static>>> {
+    let mut cells: Vec<Box<dyn crate::history_cell::HistoryCell>> = Vec::new();
+    while let Ok(event) = rx.try_recv() {
+        match event {
+            AppEvent::InsertHistoryCell(cell) => cells.push(cell),
+            AppEvent::ConsolidateAgentMessage {
+                source,
+                cwd,
+                channel,
+                deferred_history_cell,
+            } => {
+                if let Some(cell) = deferred_history_cell {
+                    cells.push(cell);
+                }
+                let start = cells
+                    .iter()
+                    .rposition(|cell| !cell.as_any().is::<crate::history_cell::AgentMessageCell>())
+                    .map_or(0, |index| index + 1);
+                if start < cells.len() {
+                    cells.truncate(start);
+                    cells.push(Box::new(
+                        crate::history_cell::AgentMarkdownCell::new_with_channel(
+                            source, &cwd, channel,
+                        ),
+                    ));
+                }
+            }
+            _ => {}
+        }
+    }
+
+    let mut out = Vec::new();
+    for cell in cells {
+        let mut lines = cell.display_lines(/*width*/ 80);
+        if !cell.is_stream_continuation() && !out.is_empty() && !lines.is_empty() {
+            lines.insert(0, "".into());
+        }
+        out.push(lines);
+    }
+    out
+}
