+#[test]
+fn provisional_agent_chunks_fill_uncovered_rows_without_closing() {
+    for channel in [
+        AgentMessageChannel::Commentary,
+        AgentMessageChannel::FinalAnswer,
+    ] {
+        let cell = AgentMessageCell::new_hyperlink_lines_with_channel(
+            vec![HyperlinkLine::from("first"), HyperlinkLine::from("")],
+            /*is_first_line*/ true,
+            channel,
+        );
+        assert_eq!(cell.fill_background_style(), Some(user_input_style()));
+        assert!(
+            cell.display_lines(/*width*/ 20).iter().all(|line| line
+                .spans
+                .iter()
+                .all(|span| !span.content.contains('─'))
+                || line
+                    .spans
+                    .iter()
+                    .all(|span| span.content.chars().all(|ch| ch == '─'))),
+            "provisional chunk rendered an unexpected closing rule for {channel:?}"
+        );
+    }
+}
