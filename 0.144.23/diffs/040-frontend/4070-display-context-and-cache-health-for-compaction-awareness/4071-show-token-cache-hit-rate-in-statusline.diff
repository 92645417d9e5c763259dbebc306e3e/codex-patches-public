+#[tokio::test]
+async fn cache_hit_rate_status_line_item_uses_token_info() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.set_token_info(Some(TokenUsageInfo {
+        total_token_usage: TokenUsage {
+            input_tokens: 1_000,
+            cached_input_tokens: 800,
+            output_tokens: 50,
+            reasoning_output_tokens: 0,
+            total_tokens: 1_050,
+        },
+        last_token_usage: TokenUsage::default(),
+        model_context_window: Some(100_000),
+    }));
+
+    assert_eq!(
+        status_preview_line(&mut chat, &[StatusLineItem::CacheHitRate]),
+        "80.0% hit"
+    );
+}
+
+#[tokio::test]
+async fn cache_hit_rate_status_line_item_omits_missing_cache_data() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.set_token_info(Some(TokenUsageInfo {
+        total_token_usage: TokenUsage {
+            input_tokens: 1_000,
+            cached_input_tokens: 0,
+            output_tokens: 50,
+            reasoning_output_tokens: 0,
+            total_tokens: 1_050,
+        },
+        last_token_usage: TokenUsage::default(),
+        model_context_window: Some(100_000),
+    }));
+
+    assert_eq!(
+        chat.status_line_value_for_item(StatusLineItem::CacheHitRate),
+        None
+    );
+}
