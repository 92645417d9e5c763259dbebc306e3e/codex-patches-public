+#[test]
+fn remote_connection_requires_matching_server_version() {
+    let target = AppServerTarget::Remote {
+        endpoint: RemoteAppServerEndpoint::WebSocket {
+            websocket_url: "ws://127.0.0.1:4500".to_string(),
+            auth_token: None,
+        },
+    };
+
+    assert_eq!(compatible_remote_connection(&target, None), None);
+    assert_eq!(compatible_remote_connection(&target, Some("stale")), None);
+    assert_eq!(
+        compatible_remote_connection(&target, Some(CODEX_CLI_VERSION))
+            .and_then(|status| status.version),
+        Some(CODEX_CLI_VERSION.to_string())
+    );
+}
