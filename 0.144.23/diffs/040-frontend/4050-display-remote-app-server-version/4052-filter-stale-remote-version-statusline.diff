+fn compatible_remote_connection(
+    app_server_target: &AppServerTarget,
+    server_version: Option<&str>,
+) -> Option<crate::status::remote_connection::RemoteConnectionStatus> {
+    server_version
+        .filter(|version| *version == CODEX_CLI_VERSION)
+        .and_then(|version| {
+            crate::status::remote_connection::remote_connection_status_value(
+                app_server_target,
+                Some(version),
+            )
+        })
