--- /dev/null
+++ b/codex-rs/tui/src/chatwidget/status_surfaces_tests.rs
@@ -0,0 +1,19 @@
+use super::*;
+use pretty_assertions::assert_eq;
+use ratatui::style::Color;
+
+#[test]
+fn status_line_version_display_uses_remote_version_styles() {
+    let cases = [
+        (None, Color::Red),
+        (Some(None), Color::Red),
+        (Some(Some("0.144.8")), Color::Red),
+        (Some(Some("0.144.9")), Color::Green),
+        (Some(Some("v0.144.9")), Color::Green),
+    ];
+    for (remote, expected) in cases {
+        let line = status_line_version_display_line("0.144.9", remote);
+        assert_eq!(line.spans[0].content, "0.144.9");
+        assert_eq!(line.spans[0].style.fg, Some(expected));
+    }
+}
