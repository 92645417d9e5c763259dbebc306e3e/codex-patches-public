+    assert_eq!(legacy.id, "hidden-output");
+    assert_eq!(legacy.text, "[Hidden assistant output]");
+    assert_eq!(legacy.phase, Some(MessagePhase::Commentary));
+    assert_eq!(legacy.memory_citation, None);
+}
