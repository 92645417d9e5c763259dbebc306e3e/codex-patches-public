+        id: "hidden-output".to_string(),
+        text: "[Hidden assistant output]".to_string(),
+        phase: Some(MessagePhase::Commentary),
+        memory_citation: None,
+        continuation_notice: Some(
+            codex_protocol::items::ContinuationNoticeKind::HiddenAssistantOutput,
