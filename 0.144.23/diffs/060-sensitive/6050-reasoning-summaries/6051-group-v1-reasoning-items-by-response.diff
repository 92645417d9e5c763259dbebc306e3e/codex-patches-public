+async fn completed_reasoning_items_for_multi_agent_version(
+    multi_agent_version: MultiAgentVersion,
+) -> anyhow::Result<Vec<codex_protocol::items::ReasoningItem>> {
+    let server = start_mock_server().await;
+    let TestCodex { codex, .. } = test_codex()
+        .with_model_info_override("gpt-5.4", move |model| {
+            model.multi_agent_version = Some(multi_agent_version);
+        })
+        .with_config(move |config| {
+            config.model_reasoning_effort =
+                (multi_agent_version == MultiAgentVersion::V2).then_some(ReasoningEffort::Ultra);
+        })
+        .build(&server)
+        .await?;
+
+    mount_sse_once(
+        &server,
+        sse(vec![
+            ev_response_created("resp-1"),
+            ev_reasoning_item_added("reasoning-1", &[""]),
+            ev_reasoning_item("reasoning-1", &["first"], &[]),
+            ev_reasoning_item_added("reasoning-2", &[""]),
+            ev_reasoning_item("reasoning-2", &["second"], &[]),
+            serde_json::json!({
+                "type": "response.completed",
+                "response": {
+                    "id": "resp-1",
+                    "usage": {
+                        "input_tokens": 0,
+                        "input_tokens_details": null,
+                        "output_tokens": 37,
+                        "output_tokens_details": { "reasoning_tokens": 37 },
+                        "total_tokens": 37
+                    }
+                }
+            }),
+        ]),
+    )
+    .await;
+
+    codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "reason through it".into(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let mut reasoning_items = Vec::new();
+    loop {
+        match wait_for_event(&codex, |_| true).await {
+            EventMsg::ItemCompleted(ItemCompletedEvent {
+                item: TurnItem::Reasoning(item),
+                ..
+            }) => reasoning_items.push(item),
+            EventMsg::TurnComplete(_) => break,
+            _ => {}
+        }
+    }
+    Ok(reasoning_items)
+}
