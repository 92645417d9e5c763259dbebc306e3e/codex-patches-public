+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let mut completed = None;
+    loop {
+        match wait_for_event(&codex, |_| true).await {
+            EventMsg::ItemCompleted(ItemCompletedEvent {
+                item: TurnItem::Reasoning(item),
+                ..
+            }) => completed = Some(item),
+            EventMsg::TurnComplete(_) => break,
+            _ => {}
+        }
+    }
+    let completed = completed.expect("completed reasoning item");
+    assert_eq!(completed.summary_text, ["kept"]);
+    assert!(
+        completed
+            .response_id
+            .as_deref()
+            .is_some_and(|id| id.starts_with("local-response-"))
+    );
+    assert_eq!(completed.reasoning_output_tokens, None);
+    assert!(!completed.continued);
+    Ok(())
+}
