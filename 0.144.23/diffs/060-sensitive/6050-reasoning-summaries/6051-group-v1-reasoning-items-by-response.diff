+#[test]
+fn reasoning_item_metadata_defaults_are_wire_compatible() {
+    let value = json!({
+        "type": "reasoning",
+        "id": "reasoning-1",
+        "summary": [],
+        "content": [],
+    });
+
+    let item: ThreadItem = serde_json::from_value(value.clone()).expect("deserialize reasoning");
+    assert_eq!(
+        item,
+        ThreadItem::Reasoning {
+            id: "reasoning-1".to_string(),
+            summary: Vec::new(),
+            content: Vec::new(),
+            response_id: None,
+            reasoning_output_tokens: None,
+            continued: false,
+        }
+    );
+    assert_eq!(
