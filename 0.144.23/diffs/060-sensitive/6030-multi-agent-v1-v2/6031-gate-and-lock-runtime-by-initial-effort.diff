+#[tokio::test]
+async fn first_model_runtime_selection_stays_locked_across_effort_changes() {
+    let (mut session, turn_context) = make_session_and_context().await;
+    session.multi_agent_version = OnceLock::new();
+    let mut model_info = turn_context.model_info.clone();
+    model_info.multi_agent_version = Some(MultiAgentVersion::V2);
+
+    assert_eq!(
+        session.resolve_multi_agent_version_for_model(
+            &model_info,
+            turn_context.config.as_ref(),
+            Some(&ReasoningEffortConfig::Ultra),
+        ),
+        MultiAgentVersion::V2
+    );
+    assert_eq!(
+        session.resolve_multi_agent_version_for_model(
+            &model_info,
+            turn_context.config.as_ref(),
+            Some(&ReasoningEffortConfig::Low),
+        ),
+        MultiAgentVersion::V2,
+        "later effort changes must not switch a live session back to V1"
+    );
+}
