+#[tokio::test]
+async fn v1_spawn_promotes_ultra_child_to_v2_with_canonical_path() {
+    let (mut session, mut turn) = make_session_and_context().await;
+    configure_v1_ultra_promotion(&mut session, &mut turn).await;
+    let manager = thread_manager();
+    session.services.agent_control = manager.agent_control();
+
+    let output = SpawnAgentHandler::default()
+        .handle(invocation(
+            Arc::new(session),
+            Arc::new(turn),
+            "spawn_agent",
+            function_payload(json!({
+                "message": "inspect this repo",
+                "task_name": "ultra_worker"
+            })),
+        ))
+        .await
+        .expect("V1 should promote an eligible Ultra child");
+    let (content, success) = expect_text_output(output);
+    let result: serde_json::Value =
+        serde_json::from_str(&content).expect("spawn_agent result should be json");
+    let child_id = parse_agent_id(
+        result["agent_id"]
+            .as_str()
+            .expect("V1 result should retain the UUID control surface"),
+    );
+    let child = manager
+        .get_thread(child_id)
+        .await
+        .expect("promoted child should remain registered");
+
+    assert_eq!(success, Some(true));
+    assert_eq!(child.multi_agent_version(), Some(MultiAgentVersion::V2));
+    assert_eq!(
+        child
+            .config_snapshot()
+            .await
+            .session_source
+            .get_agent_path()
+            .map(String::from)
+            .as_deref(),
+        Some("/root/ultra_worker")
+    );
+}
