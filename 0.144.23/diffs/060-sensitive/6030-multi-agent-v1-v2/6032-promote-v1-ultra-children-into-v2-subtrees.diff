+async fn promote_ultra_child_runtime(
+    session: &Session,
+    config: &mut crate::config::Config,
+    task_name: Option<&str>,
+) -> Result<Option<String>, FunctionCallError> {
+    let Some(model) = config.model.as_deref() else {
+        return Ok(None);
+    };
+    let model_info = session
+        .services
+        .models_manager
+        .get_model_info(model, &config.to_models_manager_config())
+        .await;
+    let effective_reasoning_effort = config
+        .model_reasoning_effort
+        .as_ref()
+        .or(model_info.default_reasoning_level.as_ref());
+    if model_info.multi_agent_version != Some(MultiAgentVersion::V2)
+        || effective_reasoning_effort != Some(&ReasoningEffort::Ultra)
+    {
+        return Ok(None);
+    }
+
+    let task_name = task_name
+        .map(str::trim)
+        .filter(|task_name| !task_name.is_empty())
+        .ok_or_else(|| {
+            FunctionCallError::RespondToModel(
+                "task_name is required when an Ultra child is promoted to Multi-Agent V2"
+                    .to_string(),
+            )
+        })?;
+    config
+        .features
+        .enable(Feature::MultiAgentV2)
+        .map_err(|error| {
+            FunctionCallError::RespondToModel(format!(
+                "Multi-Agent V2 could not be enabled for the Ultra child: {error}"
+            ))
+        })?;
+
+    Ok(Some(task_name.to_string()))
+}
