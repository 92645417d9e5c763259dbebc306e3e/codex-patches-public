+async fn configure_v1_ultra_promotion(
+    session: &mut crate::session::session::Session,
+    turn: &mut TurnContext,
+) {
+    let model = "gpt-5.6-sol";
+    let mut config = turn.config.as_ref().clone();
+    config.model = Some(model.to_string());
+    config.model_reasoning_effort = Some(ReasoningEffort::Ultra);
+    config
+        .features
+        .enable(Feature::Collab)
+        .expect("test config should allow V1");
+    config
+        .features
+        .disable(Feature::MultiAgentV2)
+        .expect("test config should leave the parent on V1");
+    let model_info = session
+        .services
+        .models_manager
+        .get_model_info(model, &config.to_models_manager_config())
+        .await;
+    assert_eq!(model_info.multi_agent_version, Some(MultiAgentVersion::V2));
+
+    turn.config = Arc::new(config);
+    turn.model_info = model_info;
+    turn.reasoning_effort = Some(ReasoningEffort::Ultra);
+    turn.multi_agent_version = MultiAgentVersion::V1;
+    assert_eq!(session.multi_agent_version(), Some(MultiAgentVersion::V1));
+}
