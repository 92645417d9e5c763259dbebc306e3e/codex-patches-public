+#[derive(Clone, Debug, Default)]
+pub struct ResponsePerformanceTiming {
+    request_started_at: Arc<OnceLock<Instant>>,
+    first_response_byte_at: Arc<OnceLock<Instant>>,
+}
+
+impl ResponsePerformanceTiming {
+    pub fn observe_request_started(&self) {
+        let _ = self.request_started_at.set(Instant::now());
+    }
+
+    pub fn observe_first_response_bytes(&self, byte_count: usize) {
+        if byte_count > 0 {
+            let _ = self.first_response_byte_at.set(Instant::now());
+        }
+    }
+
+    pub fn request_started_at(&self) -> Option<Instant> {
+        self.request_started_at.get().copied()
+    }
+
+    pub fn first_response_byte_at(&self) -> Option<Instant> {
+        self.first_response_byte_at.get().copied()
+    }
+}
