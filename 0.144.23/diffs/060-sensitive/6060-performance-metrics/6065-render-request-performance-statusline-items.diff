+#[tokio::test]
+async fn request_performance_freshness_expires_independently_at_five_seconds() {
+    let (mut chat, _rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let observed_at = Instant::now();
+    assert!(chat.merge_request_performance_at(
+        codex_app_server_protocol::RequestPerformanceSnapshot {
+            ttfb: Some(0.125),
+            output_tokens_per_second: None,
+        },
+        observed_at,
+    ));
+    assert!(chat.merge_request_performance_at(
+        codex_app_server_protocol::RequestPerformanceSnapshot {
+            ttfb: None,
+            output_tokens_per_second: Some(42.5),
+        },
+        observed_at + Duration::from_secs(2),
+    ));
+
+    let just_before_ttfb_stale = observed_at + Duration::from_millis(4_999);
+    assert!(!chat.request_performance_freshness_due_at(just_before_ttfb_stale));
+    let fresh_ttfb = chat
+        .request_performance_line_at(StatusLineItem::RequestTtfb, just_before_ttfb_stale)
+        .expect("fresh TTFB line");
+    let fresh_tps = chat
+        .request_performance_line_at(StatusLineItem::RequestTps, just_before_ttfb_stale)
+        .expect("fresh TPS line");
+    assert_eq!(fresh_ttfb.spans[0].style, Style::default());
+    assert_eq!(fresh_tps.spans[0].style, Style::default());
+
+    let ttfb_stale_at = observed_at + Duration::from_secs(5);
+    assert!(chat.request_performance_freshness_due_at(ttfb_stale_at));
+    assert_eq!(
+        chat.request_performance.next_freshness_refresh_at,
+        Some(observed_at + Duration::from_secs(7))
+    );
+    let stale_ttfb = chat
+        .request_performance_line_at(StatusLineItem::RequestTtfb, ttfb_stale_at)
+        .expect("stale TTFB line");
+    let still_fresh_tps = chat
+        .request_performance_line_at(StatusLineItem::RequestTps, ttfb_stale_at)
+        .expect("still-fresh TPS line");
+    assert_eq!(stale_ttfb.spans[0].style.fg, Some(Color::DarkGray));
+    assert!(
+        stale_ttfb.spans[0]
+            .style
+            .add_modifier
+            .contains(Modifier::DIM)
+    );
+    assert_eq!(still_fresh_tps.spans[0].style, Style::default());
+
+    let tps_stale_at = observed_at + Duration::from_secs(7);
+    assert!(chat.request_performance_freshness_due_at(tps_stale_at));
+    assert_eq!(chat.request_performance.next_freshness_refresh_at, None);
+    let stale_tps = chat
+        .request_performance_line_at(StatusLineItem::RequestTps, tps_stale_at)
+        .expect("stale TPS line");
+    assert_eq!(stale_tps.spans[0].style.fg, Some(Color::DarkGray));
+    assert!(
+        stale_tps.spans[0]
+            .style
+            .add_modifier
+            .contains(Modifier::DIM)
+    );
+    assert!(!chat.request_performance_freshness_due_at(tps_stale_at + Duration::from_secs(1)));
 }
 
