+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn multi_agent_v2_preemption_keeps_ttfb_without_publishing_preempted_tps() {
+    let (gate_reasoning_done_tx, gate_reasoning_done_rx) = oneshot::channel();
+    let first_chunks = vec![
+        chunk(ev_response_created("resp-preempted")),
+        chunk(ev_reasoning_item_added("reason-preempted", &["thinking"])),
+        gated_chunk(
+            gate_reasoning_done_rx,
+            vec![
+                ev_reasoning_item("reason-preempted", &["thinking"], &[]),
+                ev_completed_with_output_tokens("resp-preempted", 20),
+            ],
+        ),
+    ];
+    let second_chunks = vec![
+        chunk(ev_response_created("resp-follow-up")),
+        chunk(ev_completed_with_output_tokens("resp-follow-up", 20)),
+    ];
+    let (server, _completions) =
+        start_streaming_sse_server(vec![first_chunks, second_chunks]).await;
+    let codex = test_codex()
+        .with_model("gpt-5.4")
+        .with_config(|config| {
+            config
+                .features
+                .enable(Feature::MultiAgentV2)
+                .expect("test config should allow multi-agent v2");
+        })
+        .build_with_streaming_server(&server)
+        .await
+        .expect("build streaming Codex test session")
+        .codex;
+
+    submit_user_input(&codex, "first prompt").await;
+    let mut updates = Vec::new();
+    let first_request_id = loop {
+        let event = timeout(Duration::from_secs(10), codex.next_event())
+            .await
+            .expect("timeout waiting for first request events")
+            .expect("first request event stream open");
+        match event.msg {
+            EventMsg::ResponseOutputBytesDelta(update) => {
+                let first_byte_request_id =
+                    update.ttfb.is_some().then(|| update.request_id.clone());
+                updates.push(update);
+                if let Some(request_id) = first_byte_request_id {
+                    break request_id;
+                }
+            }
+            _ => {}
+        }
+    };
+    wait_for_reasoning_item_started(&codex).await;
+    submit_queue_only_agent_mail(&codex, "queued child update").await;
+    let _ = gate_reasoning_done_tx.send(());
+
+    loop {
+        let event = timeout(Duration::from_secs(10), codex.next_event())
+            .await
+            .expect("timeout waiting for preempted turn completion")
+            .expect("preempted turn event stream open");
+        match event.msg {
+            EventMsg::ResponseOutputBytesDelta(update) => updates.push(update),
+            EventMsg::TurnComplete(_) => break,
+            _ => {}
+        }
+    }
+
+    assert!(
+        updates
+            .iter()
+            .any(|update| update.request_id == first_request_id && update.ttfb.is_some()),
+        "the preempted request must retain its fixed first-byte update"
+    );
+    assert!(
+        updates.iter().all(|update| {
+            update.request_id != first_request_id || update.output_tokens_per_second.is_none()
+        }),
+        "a completion buffered behind the v2 preemption boundary must not publish TPS"
+    );
+    let follow_up_request_id = updates
+        .iter()
+        .find(|update| update.reset && update.request_id != first_request_id)
+        .map(|update| update.request_id.as_str())
+        .expect("follow-up request reset");
+    assert!(
+        updates.iter().any(|update| {
+            update.request_id == follow_up_request_id && update.output_tokens_per_second.is_some()
+        }),
+        "the completed follow-up request must still publish TPS"
+    );
+
+    server.shutdown().await;
+}
