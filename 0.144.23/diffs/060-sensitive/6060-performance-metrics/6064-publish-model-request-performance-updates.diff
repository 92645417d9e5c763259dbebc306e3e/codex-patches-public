+fn response_output_progress_performance_fields_are_independently_nullable() {
+    let notification = serde_json::from_value::<ResponseOutputBytesDeltaNotification>(json!({
+        "threadId": "thread-1",
+        "turnId": "turn-1",
+        "requestId": "request-1",
+        "byteCount": 42,
+        "reset": false
+    }))
+    .expect("deserialize response byte notification");
+
+    assert_eq!(
+        notification,
+        ResponseOutputBytesDeltaNotification {
+            thread_id: "thread-1".to_string(),
+            turn_id: "turn-1".to_string(),
+            request_id: "request-1".to_string(),
+            byte_count: 42,
+            ttfb: None,
+            output_tokens_per_second: None,
+            reset: false,
+        }
+    );
+    let serialized = serde_json::to_value(notification).expect("serialize byte notification");
+    assert_eq!(serialized["ttfb"], serde_json::Value::Null);
+    assert_eq!(serialized["outputTokensPerSecond"], serde_json::Value::Null);
+
+    let completion = serde_json::to_value(ResponseOutputBytesDeltaNotification {
+        thread_id: "thread-1".to_string(),
+        turn_id: "turn-1".to_string(),
+        request_id: "request-1".to_string(),
+        byte_count: 0,
+        ttfb: None,
+        output_tokens_per_second: Some(42.5),
+        reset: false,
+    })
+    .expect("serialize completion performance notification");
+    assert_eq!(completion["ttfb"], JsonValue::Null);
+    assert_eq!(completion["outputTokensPerSecond"], json!(42.5));
+}
