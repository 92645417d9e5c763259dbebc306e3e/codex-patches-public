+    /// Returns the currently loaded peers that can send mailbox activity to `sender_thread_id`.
+    pub(crate) async fn list_live_agent_peers(
+        &self,
+        sender_thread_id: ThreadId,
+    ) -> CodexResult<Vec<AgentMetadata>> {
+        let state = self.upgrade()?;
+        let mut candidates = self.state.live_agents();
+        let root_path = AgentPath::root();
+        if let Some(root_thread_id) = self.state.agent_id_for_path(&root_path)
+            && let Some(root_metadata) = self.state.agent_metadata_for_thread(root_thread_id)
+        {
+            candidates.push(root_metadata);
+        }
+
+        let mut peers = Vec::with_capacity(candidates.len());
+        for metadata in candidates {
+            let Some(thread_id) = metadata.agent_id else {
+                continue;
+            };
+            if thread_id != sender_thread_id && state.get_thread(thread_id).await.is_ok() {
+                peers.push(metadata);
+            }
+        }
+        peers.sort_by(|left, right| {
+            left.agent_path
+                .as_deref()
+                .unwrap_or_default()
+                .cmp(right.agent_path.as_deref().unwrap_or_default())
+                .then_with(|| {
+                    left.agent_id
+                        .map(|id| id.to_string())
+                        .unwrap_or_default()
+                        .cmp(&right.agent_id.map(|id| id.to_string()).unwrap_or_default())
+                })
+        });
+        Ok(peers)
+    }
