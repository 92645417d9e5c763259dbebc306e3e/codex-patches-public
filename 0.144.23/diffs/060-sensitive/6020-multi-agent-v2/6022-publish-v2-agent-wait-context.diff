+#[tokio::test]
+async fn model_selected_multi_agent_v2_wait_items_carry_effective_version() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    const PARENT_PROMPT: &str = "wait briefly";
+    const WAIT_CALL_ID: &str = "wait-call-model-selected-v2";
+    const MODEL: &str = "gpt-5.6-sol";
+
+    let server = responses::start_mock_server().await;
+    let wait_args = serde_json::to_string(&json!({"timeout_ms": 0}))?;
+    let _parent_turn = responses::mount_sse_once_match(
+        &server,
+        |req: &wiremock::Request| body_contains(req, PARENT_PROMPT),
+        responses::sse(vec![
+            responses::ev_response_created("resp-wait-1"),
+            responses::ev_function_call_with_namespace(
+                WAIT_CALL_ID,
+                MULTI_AGENT_V2_NAMESPACE,
+                "wait_agent",
+                &wait_args,
+            ),
+            responses::ev_completed("resp-wait-1"),
+        ]),
+    )
+    .await;
+    let _parent_follow_up = responses::mount_sse_once_match(
+        &server,
+        |req: &wiremock::Request| body_contains(req, WAIT_CALL_ID),
+        responses::sse(vec![
+            responses::ev_response_created("resp-wait-2"),
+            responses::ev_assistant_message("msg-wait-2", "done"),
+            responses::ev_completed("resp-wait-2"),
+        ]),
+    )
+    .await;
+
+    let codex_home = TempDir::new()?;
+    create_config_toml(
+        codex_home.path(),
+        &server.uri(),
+        "never",
+        &BTreeMap::from([(Feature::Collab, true)]),
+    )?;
+    let config_path = codex_home.path().join("config.toml");
+    let base_config = std::fs::read_to_string(&config_path)?;
+    std::fs::write(
+        &config_path,
+        format!(
+            r#"{base_config}
+
+[features.multi_agent_v2]
+enabled = false
+min_wait_timeout_ms = 0
+max_wait_timeout_ms = 0
+default_wait_timeout_ms = 0
+"#,
+        ),
+    )?;
+    let model = codex_models_manager::bundled_models_response()?
+        .models
+        .into_iter()
+        .find(|model| model.slug == MODEL)
+        .context("bundled model-selected V2 model should exist")?;
+    assert_eq!(model.multi_agent_version, Some(MultiAgentVersion::V2));
+    write_models_cache_with_models(codex_home.path(), vec![model])?;
+
+    let mut mcp = TestAppServer::builder()
+        .with_codex_home(codex_home.path())
+        .build()
+        .await?;
+    timeout(DEFAULT_READ_TIMEOUT, mcp.initialize()).await??;
+
+    let thread_req = mcp
+        .send_thread_start_request_with_auto_env(ThreadStartParams {
+            model: Some(MODEL.to_string()),
+            ..Default::default()
+        })
+        .await?;
+    let thread_resp: JSONRPCResponse = timeout(
+        DEFAULT_READ_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(thread_req)),
+    )
+    .await??;
+    let ThreadStartResponse { thread, .. } = to_response::<ThreadStartResponse>(thread_resp)?;
+
+    let turn_req = mcp
+        .send_turn_start_request(TurnStartParams {
+            thread_id: thread.id.clone(),
+            input: vec![V2UserInput::Text {
+                text: PARENT_PROMPT.to_string(),
+                text_elements: Vec::new(),
+            }],
+            ..Default::default()
+        })
+        .await?;
+    let turn_resp: JSONRPCResponse = timeout(
+        DEFAULT_READ_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(turn_req)),
+    )
+    .await??;
+    let _: TurnStartResponse = to_response(turn_resp)?;
+
+    let wait_started = timeout(DEFAULT_READ_TIMEOUT, async {
+        loop {
+            let notification = mcp
+                .read_stream_until_notification_message("item/started")
+                .await?;
+            let notification: ItemStartedNotification =
+                serde_json::from_value(notification.params.context("item/started params")?)?;
+            if notification.item.id() == WAIT_CALL_ID {
+                return Ok::<ThreadItem, anyhow::Error>(notification.item);
+            }
+        }
+    })
+    .await??;
+    assert_eq!(
+        wait_started,
+        ThreadItem::CollabAgentToolCall {
+            id: WAIT_CALL_ID.to_string(),
+            tool: CollabAgentTool::Wait,
+            status: CollabAgentToolCallStatus::InProgress,
+            multi_agent_version: Some(MultiAgentVersion::V2),
+            sender_thread_id: thread.id.clone(),
+            receiver_thread_ids: Vec::new(),
+            prompt: None,
+            model: None,
+            reasoning_effort: None,
+            agents_states: HashMap::new(),
+        }
+    );
+
+    let wait_completed = timeout(DEFAULT_READ_TIMEOUT, async {
+        loop {
+            let notification = mcp
+                .read_stream_until_notification_message("item/completed")
+                .await?;
+            let notification: ItemCompletedNotification =
+                serde_json::from_value(notification.params.context("item/completed params")?)?;
+            if notification.item.id() == WAIT_CALL_ID {
+                return Ok::<ThreadItem, anyhow::Error>(notification.item);
+            }
+        }
+    })
+    .await??;
+    assert_eq!(
+        wait_completed,
+        ThreadItem::CollabAgentToolCall {
+            id: WAIT_CALL_ID.to_string(),
+            tool: CollabAgentTool::Wait,
+            status: CollabAgentToolCallStatus::Completed,
+            multi_agent_version: Some(MultiAgentVersion::V2),
+            sender_thread_id: thread.id,
+            receiver_thread_ids: Vec::new(),
+            prompt: None,
+            model: None,
+            reasoning_effort: None,
+            agents_states: HashMap::new(),
+        }
+    );
+
+    Ok(())
+}
