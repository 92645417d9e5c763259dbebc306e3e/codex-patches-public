+#[tokio::test]
+async fn running_thread_replay_uses_item_nickname_without_populating_agent_navigation() {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let sender_thread_id = ThreadId::new();
+    let receiver_thread_id =
+        ThreadId::from_string("019cff70-2599-75e2-af72-b958ce5dc1cc").expect("valid thread");
+    let receiver_id = receiver_thread_id.to_string();
+    let events = [
+        (
+            "spawn-1",
+            codex_app_server_protocol::CollabAgentTool::SpawnAgent,
+            codex_app_server_protocol::CollabAgentStatus::Running,
+        ),
+        (
+            "close-1",
+            codex_app_server_protocol::CollabAgentTool::CloseAgent,
+            codex_app_server_protocol::CollabAgentStatus::Shutdown,
+        ),
+    ]
+    .into_iter()
+    .map(|(id, tool, agent_status)| {
+        ThreadBufferedEvent::Notification(ServerNotification::ItemCompleted(
+            codex_app_server_protocol::ItemCompletedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                completed_at_ms: 0,
+                item: ThreadItem::CollabAgentToolCall {
+                    id: id.to_string(),
+                    tool,
+                    status: codex_app_server_protocol::CollabAgentToolCallStatus::Completed,
+                    sender_thread_id: sender_thread_id.to_string(),
+                    receiver_thread_ids: vec![receiver_id.clone()],
+                    prompt: None,
+                    model: None,
+                    reasoning_effort: None,
+                    agents_states: HashMap::from([(
+                        receiver_id.clone(),
+                        codex_app_server_protocol::CollabAgentState {
+                            status: agent_status,
+                            message: None,
+                            agent_nickname: Some("Ampere".to_string()),
+                            agent_role: Some("explorer".to_string()),
+                        },
+                    )]),
+                },
+            },
+        ))
+    })
+    .collect();
+
+    app.replay_thread_snapshot(
+        ThreadEventSnapshot {
+            session: None,
+            turns: Vec::new(),
+            events,
+            input_state: None,
+        },
+        /*resume_restored_queue*/ false,
+    );
+
+    let mut transcript = Vec::new();
+    while let Ok(event) = app_event_rx.try_recv() {
+        if let AppEvent::InsertHistoryCell(cell) = event {
+            transcript.push(lines_to_single_string(
+                &cell.transcript_lines(/*width*/ 120),
+            ));
+        }
+    }
+    let transcript = transcript.join("\n");
+
+    assert!(transcript.contains("Spawned Ampere [explorer]"));
+    assert!(transcript.contains("Closed Ampere [explorer]"));
+    assert!(!transcript.contains(&receiver_id));
+    assert!(app.agent_navigation.get(&receiver_thread_id).is_none());
+}
