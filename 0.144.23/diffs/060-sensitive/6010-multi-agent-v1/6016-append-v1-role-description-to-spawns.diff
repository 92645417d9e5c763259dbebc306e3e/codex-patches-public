+#[tokio::test]
+async fn v2_collab_metadata_does_not_resolve_role_description() {
+    let (mut chat, _rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let spawned_thread_id = ThreadId::new();
+    let _ = chat.config.features.enable(Feature::Collab);
+    let _ = chat.config.features.disable(Feature::MultiAgentV2);
+    chat.config.agent_roles.insert(
+        "explorer".to_string(),
+        crate::legacy_core::config::AgentRoleConfig {
+            description: Some("Explore the codebase.".to_string()),
+            ..Default::default()
+        },
+    );
+
+    chat.set_collab_agent_metadata(
+        spawned_thread_id,
+        Some("Robie".to_string()),
+        Some("explorer".to_string()),
+    );
+    assert_eq!(
+        chat.collab_agent_metadata(spawned_thread_id)
+            .agent_description
+            .as_deref(),
+        Some("Explore the codebase.")
+    );
+
+    let _ = chat.config.features.enable(Feature::MultiAgentV2);
+
+    assert_eq!(
+        chat.collab_agent_metadata(spawned_thread_id)
+            .agent_description,
+        None
+    );
+}
