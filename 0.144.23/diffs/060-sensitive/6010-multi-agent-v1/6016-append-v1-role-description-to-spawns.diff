+    fn collab_agent_metadata_for_item(
+        &self,
+        thread_id: ThreadId,
+        item: &ThreadItem,
+    ) -> AgentMetadata {
+        let mut metadata = self.collab_agent_metadata(thread_id);
+        if metadata.agent_description.is_some() {
+            return metadata;
+        }
+        let item_role = match item {
+            ThreadItem::CollabAgentToolCall { agents_states, .. } => agents_states
+                .get(&thread_id.to_string())
+                .and_then(|state| state.agent_role.as_deref()),
+            _ => None,
+        };
+        metadata.agent_description =
+            self.v1_agent_description(metadata.agent_role.as_deref().or(item_role));
+        metadata
+    }
+
+    fn v1_agent_description(&self, role: Option<&str>) -> Option<String> {
+        if !self.v1_agent_descriptions_enabled() {
+            return None;
+        }
+        role.and_then(|role| self.config.agent_roles.get(role))
+            .and_then(|role| role.description.clone())
+    }
+
+    fn v1_agent_descriptions_enabled(&self) -> bool {
+        self.config.features.enabled(Feature::Collab)
+            && !self.config.features.enabled(Feature::MultiAgentV2)
