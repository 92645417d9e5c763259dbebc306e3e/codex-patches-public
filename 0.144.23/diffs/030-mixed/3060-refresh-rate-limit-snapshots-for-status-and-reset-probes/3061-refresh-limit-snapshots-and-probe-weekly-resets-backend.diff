+#[test]
+fn model_request_started_is_transient_in_all_history_modes() {
+    let item = RolloutItem::EventMsg(EventMsg::ModelRequestStarted(ModelRequestStartedEvent {
+        auth_revision: Some(7),
+        account_id: Some("sensitive-account-id".to_string()),
+        request_started_at_ms: 1_700_000_000_000,
+    }));
+
+    for history_mode in [ThreadHistoryMode::Legacy, ThreadHistoryMode::Paginated] {
+        let (persisted, measurement) =
+            measure_and_filter_rollout_items(std::slice::from_ref(&item), history_mode);
+
+        assert!(persisted.is_empty());
+        assert_eq!(measurement.pre_filter.items, 1);
+        assert_eq!(measurement.post_filter.items, 0);
+        assert_eq!(measurement.items.len(), 1);
+        assert_eq!(
+            measurement.items[0].decision,
+            super::PersistenceDecision::Dropped
+        );
+        assert_eq!(
+            measurement.items[0].rollout_item_type,
+            "event.model_request_started"
+        );
+    }
+}
