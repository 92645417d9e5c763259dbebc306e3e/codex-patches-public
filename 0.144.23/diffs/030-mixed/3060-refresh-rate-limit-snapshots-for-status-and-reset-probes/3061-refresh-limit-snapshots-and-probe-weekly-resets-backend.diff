+async fn wait_for_rate_limit_poll_wake(
+    shutdown: &CancellationToken,
+    auth_revision: &mut tokio::sync::watch::Receiver<u64>,
+    query_completed_rx: &mut tokio::sync::mpsc::UnboundedReceiver<Option<CachedAccountRateLimits>>,
+    query_in_flight: bool,
+    query_requested: &tokio::sync::Notify,
+    model_request_activity: &Mutex<tokio::sync::mpsc::UnboundedReceiver<ModelRequestActivity>>,
+    delay: Option<Duration>,
+) -> Option<RateLimitPollWake> {
+    tokio::select! {
+        biased;
+        _ = shutdown.cancelled() => None,
+        changed = auth_revision.changed() => {
+            changed.ok().map(|()| RateLimitPollWake::AuthChanged)
+        }
+        cached = query_completed_rx.recv(), if query_in_flight => {
+            Some(RateLimitPollWake::QueryCompleted(cached.flatten()))
+        }
+        _ = query_requested.notified() => Some(RateLimitPollWake::QueryRequested),
+        observed_at = async {
+            let mut receiver = model_request_activity.lock().await;
+            let first = receiver.recv().await?;
+            Some(drain_model_request_activity(&mut receiver, first))
+        } => observed_at.map(RateLimitPollWake::RequestsObserved),
+        _ = wait_for_rate_limit_schedule(delay) => Some(RateLimitPollWake::Timer),
+    }
+}
