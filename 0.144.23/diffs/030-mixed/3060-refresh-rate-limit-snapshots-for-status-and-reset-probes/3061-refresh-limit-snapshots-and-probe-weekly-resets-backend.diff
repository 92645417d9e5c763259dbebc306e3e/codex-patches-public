+fn drain_model_request_activity(
+    receiver: &mut tokio::sync::mpsc::UnboundedReceiver<ModelRequestActivity>,
+    first: ModelRequestActivity,
+) -> Vec<ModelRequestActivity> {
+    let mut observed_at = Vec::with_capacity(MODEL_REQUEST_ACTIVITY_BATCH_LIMIT);
+    observed_at.push(first);
+    while observed_at.len() < MODEL_REQUEST_ACTIVITY_BATCH_LIMIT {
+        let Ok(next) = receiver.try_recv() else {
+            break;
+        };
+        observed_at.push(next);
+    }
+    observed_at
+}
