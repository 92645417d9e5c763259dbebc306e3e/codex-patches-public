+        base64::engine::general_purpose::URL_SAFE_NO_PAD
+            .encode(serde_json::to_vec(value).expect("JWT component should serialize"))
+    };
+    let header = encode(&json!({ "alg": "none", "typ": "JWT" }));
+    let payload = encode(&json!({
+        "sub": subject,
+        "exp": (chrono::Utc::now() + chrono::Duration::hours(1)).timestamp(),
+    }));
+    let signature = base64::engine::general_purpose::URL_SAFE_NO_PAD.encode(b"sig");
+    format!("{header}.{payload}.{signature}")
