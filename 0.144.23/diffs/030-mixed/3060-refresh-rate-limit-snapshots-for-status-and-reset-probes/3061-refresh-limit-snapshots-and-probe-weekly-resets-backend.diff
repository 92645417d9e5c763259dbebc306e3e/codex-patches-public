+    #[test]
+    fn reset_probe_retries_only_transport_and_retryable_statuses() {
+        let status_failure = |status| {
+            RateLimitProbeFailure::from_request(BackendRequestError::UnexpectedStatus {
+                method: "POST".to_string(),
+                url: "https://example.test/api/codex/responses".to_string(),
+                status,
+                content_type: "application/json".to_string(),
+                body: "{}".to_string(),
+            })
+        };
+
+        for status in [
+            reqwest::StatusCode::REQUEST_TIMEOUT,
+            reqwest::StatusCode::TOO_MANY_REQUESTS,
+            reqwest::StatusCode::INTERNAL_SERVER_ERROR,
+            reqwest::StatusCode::BAD_GATEWAY,
+        ] {
+            assert!(status_failure(status).retryable, "status {status}");
+        }
+        for status in [
+            reqwest::StatusCode::BAD_REQUEST,
+            reqwest::StatusCode::UNAUTHORIZED,
+            reqwest::StatusCode::FORBIDDEN,
+            reqwest::StatusCode::NOT_FOUND,
+        ] {
+            assert!(!status_failure(status).retryable, "status {status}");
+        }
+
+        let transport = RateLimitProbeFailure::from_request(BackendRequestError::Other(
+            anyhow::anyhow!("transport dropped"),
+        ));
+        assert!(transport.retryable);
+        let terminal = RateLimitProbeFailure::from_request(
+            BackendRequestError::ResponsesProbeTerminalFailure {
+                reason: "response.failed: rejected".to_string(),
+            },
+        );
+        assert_eq!(terminal.kind, "terminal_response");
+        assert!(!terminal.retryable);
+    }
