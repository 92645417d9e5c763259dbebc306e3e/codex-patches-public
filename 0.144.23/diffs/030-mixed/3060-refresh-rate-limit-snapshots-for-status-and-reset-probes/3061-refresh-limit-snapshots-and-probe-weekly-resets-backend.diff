+async fn request_count(server: &MockServer, request_method: &str, request_path: &str) -> usize {
+    server.received_requests().await.map_or(0, |requests| {
+        requests
+            .iter()
+            .filter(|request| {
+                request.method == request_method && request.url.path() == request_path
+            })
+            .count()
+    })
+}
+
+struct UsageBeforeAndAfterSuccessfulConsume {
+    calls: AtomicUsize,
+    refresh_gate: Arc<UsageRefreshGate>,
+}
+
+impl Respond for UsageBeforeAndAfterSuccessfulConsume {
+    fn respond(&self, _: &Request) -> ResponseTemplate {
+        let call = self.calls.fetch_add(1, Ordering::SeqCst);
+        let used_percent = if call == 0 { 82 } else { 9 };
+        let response = ResponseTemplate::new(200).set_body_json(json!({
+            "plan_type": "pro",
+            "rate_limit": {
+                "allowed": true,
+                "limit_reached": false,
+                "primary_window": {
+                    "used_percent": used_percent,
+                    "limit_window_seconds": 18000,
+                    "reset_after_seconds": 3600,
+                    "reset_at": 1735689720,
+                }
+            },
+            "rate_limit_reset_credits": { "available_count": 1 }
+        }));
+        if call == 1 {
+            self.refresh_gate.second_request_started.notify_one();
+            self.refresh_gate.wait_for_second_response_release();
+        }
+        response
+    }
+}
+
+#[derive(Default)]
+struct UsageRefreshGate {
+    second_request_started: Notify,
+    second_response_released: Mutex<bool>,
+    second_response_release: Condvar,
+}
+
+impl UsageRefreshGate {
+    fn wait_for_second_response_release(&self) {
+        let mut released = self
+            .second_response_released
+            .lock()
+            .expect("usage refresh gate must not be poisoned");
+        while !*released {
+            released = self
+                .second_response_release
+                .wait(released)
+                .expect("usage refresh gate must not be poisoned");
+        }
+    }
+
+    fn release_second_response(&self) {
+        *self
+            .second_response_released
+            .lock()
+            .expect("usage refresh gate must not be poisoned") = true;
+        self.second_response_release.notify_all();
+    }
+}
+
+struct ReleaseUsageResponseOnDrop(Arc<UsageRefreshGate>);
+
+impl Drop for ReleaseUsageResponseOnDrop {
+    fn drop(&mut self) {
+        self.0.release_second_response();
+    }
+}
