+fn next_rate_limit_poll_boundary(
+    now: std::time::SystemTime,
+    interval: Duration,
+) -> std::time::SystemTime {
+    let elapsed = now
+        .duration_since(std::time::UNIX_EPOCH)
+        .unwrap_or_default();
+    let interval_nanos = interval.as_nanos();
+    let next_nanos = (elapsed.as_nanos() / interval_nanos + 1) * interval_nanos;
+    let delay_nanos = next_nanos.saturating_sub(elapsed.as_nanos());
+    let delay_nanos = u64::try_from(delay_nanos).unwrap_or(u64::MAX);
+    now + Duration::from_nanos(delay_nanos)
+}
+
+fn ceil_rate_limit_poll_boundary(
+    now: std::time::SystemTime,
+    interval: Duration,
+) -> std::time::SystemTime {
+    let elapsed = now
+        .duration_since(std::time::UNIX_EPOCH)
+        .unwrap_or_default();
+    let interval_nanos = interval.as_nanos();
+    let elapsed_nanos = elapsed.as_nanos();
+    let next_nanos = elapsed_nanos.div_ceil(interval_nanos) * interval_nanos;
+    let delay_nanos = next_nanos.saturating_sub(elapsed_nanos);
+    let delay_nanos = u64::try_from(delay_nanos).unwrap_or(u64::MAX);
+    now + Duration::from_nanos(delay_nanos)
+}
+
+fn next_rate_limit_poll_boundary_with_override(
+    now: std::time::SystemTime,
+    interval: Duration,
+    interval_override: Option<Duration>,
+) -> std::time::SystemTime {
+    interval_override
+        .and_then(|interval| now.checked_add(interval))
+        .unwrap_or_else(|| {
+            if interval == IDLE_ACCOUNT_RATE_LIMITS_POLL_INTERVAL {
+                let target = now.checked_add(interval).unwrap_or(now);
+                ceil_rate_limit_poll_boundary(target, ACCOUNT_RATE_LIMITS_ALIGNMENT)
+            } else {
+                next_rate_limit_poll_boundary(now, interval)
+            }
+        })
+}
