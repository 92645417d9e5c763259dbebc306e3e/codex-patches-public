+fn assemble_account_rate_limits(
+    snapshots: Vec<CoreRateLimitSnapshot>,
+) -> Result<
+    (
+        CoreRateLimitSnapshot,
+        HashMap<String, CoreRateLimitSnapshot>,
+    ),
+    String,
+> {
+    if snapshots.is_empty() {
+        return Err("no snapshots returned".to_string());
+    }
+
+    let keyed_snapshots = snapshots
+        .into_iter()
+        .map(|snapshot| {
+            let limit_id = account_rate_limit_key(&snapshot);
+            (limit_id, snapshot)
+        })
+        .collect::<Vec<_>>();
+    let reserved_limit_ids = keyed_snapshots
+        .iter()
+        .filter_map(|(limit_id, _)| limit_id.clone())
+        .collect::<HashSet<_>>();
+
+    let mut used_limit_ids = HashSet::new();
+    let mut first_snapshot = None;
+    let mut first_codex_snapshot = None;
+    let mut by_limit_id = HashMap::with_capacity(keyed_snapshots.len());
+    for (index, (candidate_limit_id, mut snapshot)) in keyed_snapshots.into_iter().enumerate() {
+        let limit_id = match candidate_limit_id {
+            Some(limit_id) if used_limit_ids.insert(limit_id.clone()) => limit_id,
+            _ => anonymous_rate_limit_key(index, &reserved_limit_ids, &mut used_limit_ids),
+        };
+        snapshot.limit_id = Some(limit_id.clone());
+        first_snapshot.get_or_insert_with(|| snapshot.clone());
+        if limit_id == "codex" {
+            first_codex_snapshot.get_or_insert_with(|| snapshot.clone());
+        }
+        by_limit_id.insert(limit_id, snapshot);
+    }
+
+    let primary = first_codex_snapshot
+        .or(first_snapshot)
+        .ok_or_else(|| "no snapshots returned".to_string())?;
+    Ok((primary, by_limit_id))
+}
+
+fn rate_limit_probe_boundaries(cached: &CachedAccountRateLimits) -> Vec<RateLimitProbeBoundary> {
+    cached
+        .by_limit_id
+        .iter()
+        .flat_map(|(limit_id, snapshot)| {
+            [
+                ("primary", snapshot.primary.as_ref()),
+                ("secondary", snapshot.secondary.as_ref()),
+            ]
+            .into_iter()
+            .filter_map(move |(window_name, window)| {
+                let window = window?;
+                let reset_at = window.resets_at?;
+                let window_minutes = window.window_minutes?;
+                (reset_at > 0 && window_minutes == WEEKLY_RATE_LIMIT_WINDOW_MINUTES).then(|| {
+                    RateLimitProbeBoundary {
+                        account_id: cached.account_id.clone(),
+                        limit_id: limit_id.clone(),
+                        window: window_name,
+                        reset_at,
+                        window_minutes,
+                        detected_at: cached.captured_at,
+                    }
+                })
+            })
+        })
+        .collect()
+}
+
+fn rate_limit_paces_by_limit_id(
+    snapshots: &HashMap<String, CoreRateLimitSnapshot>,
+    captured_at: std::time::SystemTime,
+) -> HashMap<String, RateLimitWindowPace> {
+    let captured_at = captured_at
+        .duration_since(std::time::UNIX_EPOCH)
+        .ok()
+        .and_then(|elapsed| i64::try_from(elapsed.as_secs()).ok());
+    snapshots
+        .iter()
+        .filter_map(|(limit_id, snapshot)| {
+            let captured_at = captured_at?;
+            let pace = RateLimitWindowPace {
+                primary: rate_limit_window_pace(snapshot.primary.as_ref(), captured_at),
+                secondary: rate_limit_window_pace(snapshot.secondary.as_ref(), captured_at),
+            };
+            (pace.primary.is_some() || pace.secondary.is_some()).then(|| (limit_id.clone(), pace))
+        })
+        .collect()
+}
+
+fn rate_limit_window_pace(
+    window: Option<&codex_protocol::protocol::RateLimitWindow>,
+    captured_at: i64,
+) -> Option<i32> {
+    let window = window?;
+    let duration_secs = window.window_minutes?.checked_mul(60)?;
+    if duration_secs <= 0 {
+        return None;
+    }
+    let started_at = window.resets_at?.checked_sub(duration_secs)?;
+    let elapsed_secs = captured_at.checked_sub(started_at)?;
+    let elapsed_percent = (elapsed_secs as f64 / duration_secs as f64 * 100.0).clamp(0.0, 100.0);
+    let used_percent = window.used_percent.clamp(0.0, 100.0);
+    Some((elapsed_percent - used_percent).round() as i32)
+}
+
+fn account_rate_limit_key(snapshot: &CoreRateLimitSnapshot) -> Option<String> {
+    if let Some(limit_id) = snapshot
+        .limit_id
+        .as_deref()
+        .filter(|limit_id| !limit_id.trim().is_empty())
+    {
+        return Some(limit_id.to_string());
+    }
+
+    snapshot
+        .limit_name
+        .as_deref()
+        .filter(|limit_name| !limit_name.trim().eq_ignore_ascii_case("codex"))
+        .and_then(derive_rate_limit_id_from_name)
+}
+
+fn derive_rate_limit_id_from_name(value: &str) -> Option<String> {
+    let value = value.trim();
+    if value.is_empty() {
+        return None;
+    }
+    Some(value.to_ascii_lowercase().replace(['-', ' '], "_"))
+}
+
+fn anonymous_rate_limit_key(
+    index: usize,
+    reserved_limit_ids: &HashSet<String>,
+    used_limit_ids: &mut HashSet<String>,
+) -> String {
+    let mut ordinal = index;
+    loop {
+        let limit_id = format!("unknown_{ordinal}");
+        if !reserved_limit_ids.contains(&limit_id) && used_limit_ids.insert(limit_id.clone()) {
+            return limit_id;
+        }
+        ordinal += 1;
+    }
+}
