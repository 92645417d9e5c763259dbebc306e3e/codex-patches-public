+fn responses_probe_body(model: &str, prompt: &str) -> serde_json::Value {
+    serde_json::json!({
+        "model": model,
+        "instructions": RESPONSES_PROBE_INSTRUCTIONS,
+        "input": [{
+            "type": "message",
+            "role": "user",
+            "content": [{"type": "input_text", "text": prompt}],
+        }],
+        "stream": true,
+        "store": false,
+        "tools": [],
+        "tool_choice": "auto",
+        "parallel_tool_calls": false,
+        "reasoning": null,
+        "include": [],
+    })
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+enum ResponsesProbeState {
+    Pending,
+    Completed(String),
+    Failed(String),
+}
+
+fn responses_probe_state(body: &str, at_eof: bool) -> ResponsesProbeState {
+    let normalized = body.replace("\r\n", "\n").replace('\r', "\n");
+    let complete_end = if at_eof {
+        normalized.len()
+    } else {
+        normalized.rfind("\n\n").map_or(0, |index| index + 2)
+    };
+    let mut output_deltas = String::new();
+    let mut completed_output_parts = String::new();
+    for frame in normalized[..complete_end].split("\n\n") {
+        let data = frame
+            .lines()
+            .filter_map(|line| line.strip_prefix("data:").map(str::trim_start))
+            .collect::<Vec<_>>()
+            .join("\n");
+        if data.is_empty() || data == "[DONE]" {
+            continue;
+        }
+        let Ok(event) = serde_json::from_str::<serde_json::Value>(&data) else {
+            continue;
+        };
+        let state =
+            responses_probe_event_state(&event, &mut output_deltas, &mut completed_output_parts);
+        if state != ResponsesProbeState::Pending {
+            return state;
+        }
+    }
+
+    if let Ok(event) = serde_json::from_str::<serde_json::Value>(body) {
+        return responses_probe_event_state(
+            &event,
+            &mut output_deltas,
+            &mut completed_output_parts,
+        );
+    }
+
+    ResponsesProbeState::Pending
+}
+
+fn responses_probe_event_state(
+    event: &serde_json::Value,
+    output_deltas: &mut String,
+    completed_output_parts: &mut String,
+) -> ResponsesProbeState {
+    let Some(kind) = event.get("type").and_then(serde_json::Value::as_str) else {
+        return ResponsesProbeState::Pending;
+    };
+    match kind {
+        "response.output_text.delta" => {
+            if let Some(delta) = event.get("delta").and_then(serde_json::Value::as_str) {
+                output_deltas.push_str(delta);
+            }
+            ResponsesProbeState::Pending
+        }
+        "response.output_text.done" => {
+            if let Some(text) = event.get("text").and_then(serde_json::Value::as_str) {
+                completed_output_parts.push_str(text);
+            }
+            ResponsesProbeState::Pending
+        }
+        "response.completed" => ResponsesProbeState::Completed(
+            responses_probe_completed_output(event)
+                .or_else(|| {
+                    (!completed_output_parts.is_empty()).then(|| completed_output_parts.clone())
+                })
+                .unwrap_or_else(|| output_deltas.clone()),
+        ),
+        "response.failed" | "response.incomplete" => {
+            ResponsesProbeState::Failed(responses_probe_failure_reason(event, kind))
+        }
+        _ => ResponsesProbeState::Pending,
+    }
+}
+
+fn responses_probe_completed_output(event: &serde_json::Value) -> Option<String> {
+    let output = event
+        .get("response")?
+        .get("output")?
+        .as_array()?
+        .iter()
+        .filter_map(|item| item.get("content").and_then(serde_json::Value::as_array))
+        .flatten()
+        .filter(|part| part.get("type").and_then(serde_json::Value::as_str) == Some("output_text"))
+        .filter_map(|part| part.get("text").and_then(serde_json::Value::as_str))
+        .collect::<String>();
+    (!output.is_empty()).then_some(output)
+}
+
+fn responses_probe_failure_reason(event: &serde_json::Value, kind: &str) -> String {
+    let reason = match kind {
+        "response.failed" => event
+            .pointer("/response/error/message")
+            .or_else(|| event.pointer("/error/message")),
+        "response.incomplete" => event.pointer("/response/incomplete_details/reason"),
+        _ => None,
+    }
+    .and_then(serde_json::Value::as_str);
+    match reason {
+        Some(reason) => format!("{kind}: {reason}"),
+        None => kind.to_string(),
+    }
+}
