+#[derive(Clone, Debug)]
+struct RateLimitSchedule {
+    active_query_at: Option<std::time::SystemTime>,
+    idle_query_at: Option<std::time::SystemTime>,
+    last_query_at: Option<std::time::SystemTime>,
+    query_interval_override: Option<Duration>,
+    probes: HashMap<RateLimitProbeIdentity, RateLimitProbeBoundary>,
+    observed_probe_resets: HashMap<RateLimitProbeIdentity, i64>,
+}
+
+impl RateLimitSchedule {
+    fn new(query_interval_override: Option<Duration>) -> Self {
+        Self {
+            active_query_at: None,
+            idle_query_at: None,
+            last_query_at: None,
+            query_interval_override,
+            probes: HashMap::new(),
+            observed_probe_resets: HashMap::new(),
+        }
+    }
+
+    fn observe_request(&mut self, now: std::time::SystemTime) {
+        let idle_query_at = next_rate_limit_poll_boundary_with_override(
+            now,
+            IDLE_ACCOUNT_RATE_LIMITS_POLL_INTERVAL,
+            self.query_interval_override,
+        );
+        self.idle_query_at = Some(
+            self.idle_query_at
+                .map_or(idle_query_at, |current| current.max(idle_query_at)),
+        );
+        if self
+            .last_query_at
+            .is_some_and(|queried_at| now <= queried_at)
+        {
+            return;
+        }
+        self.active_query_at.get_or_insert_with(|| {
+            next_rate_limit_poll_boundary_with_override(
+                now,
+                ACTIVE_ACCOUNT_RATE_LIMITS_POLL_INTERVAL,
+                self.query_interval_override,
+            )
+        });
+    }
+
+    fn mark_query_started(&mut self, now: std::time::SystemTime) {
+        self.last_query_at = Some(self.last_query_at.map_or(now, |current| current.max(now)));
+    }
+
+    fn observe_requests(
+        &mut self,
+        observed_at: impl IntoIterator<Item = std::time::SystemTime>,
+    ) -> bool {
+        let mut query_is_due = false;
+        for observed_at in observed_at {
+            if self
+                .active_query_at
+                .is_some_and(|deadline| observed_at >= deadline)
+            {
+                self.active_query_at = None;
+                query_is_due = true;
+            }
+            self.observe_request(observed_at);
+        }
+        query_is_due
+    }
+
+    fn clear_probes(&mut self) {
+        self.probes.clear();
+        self.observed_probe_resets.clear();
+    }
+
+    fn clear_query_deadlines(&mut self) {
+        self.active_query_at = None;
+        self.idle_query_at = None;
+        self.last_query_at = None;
+    }
+
+    fn retain_for_auth_identity_change(
+        &mut self,
+        previous_account_id: Option<&str>,
+        current_account_id: Option<&str>,
+    ) -> bool {
+        let same_account =
+            previous_account_id.is_some() && previous_account_id == current_account_id;
+        if !same_account {
+            self.clear_probes();
+            self.clear_query_deadlines();
+        }
+        same_account
+    }
+
+    fn next_wake_at(&self) -> Option<std::time::SystemTime> {
+        self.probes
+            .values()
+            .filter_map(RateLimitProbeBoundary::first_attempt_at)
+            .chain(self.active_query_at)
+            .chain(self.idle_query_at)
+            .min()
+    }
+
+    fn delay_from(&self, now: std::time::SystemTime) -> Option<Duration> {
+        self.next_wake_at()
+            .map(|wake_at| wake_at.duration_since(now).unwrap_or_default())
+    }
+
+    fn register_probe_boundaries(&mut self, boundaries: Vec<RateLimitProbeBoundary>) {
+        let mut changed_boundary = None;
+        for boundary in boundaries {
+            let identity = boundary.identity();
+            match self.observed_probe_resets.get(&identity).copied() {
+                None => {
+                    self.observed_probe_resets
+                        .insert(identity, boundary.reset_at);
+                }
+                Some(previous_reset_at)
+                    if previous_reset_at.abs_diff(boundary.reset_at)
+                        <= RATE_LIMIT_RESET_AT_TOLERANCE.as_secs() => {}
+                Some(_) => {
+                    self.observed_probe_resets
+                        .insert(identity.clone(), boundary.reset_at);
+                    changed_boundary.get_or_insert(boundary);
+                }
+            }
+        }
+        if let Some(boundary) = changed_boundary {
+            self.probes.clear();
+            self.probes.insert(boundary.identity(), boundary);
+        }
+    }
+
+    fn take_due(&mut self, now: std::time::SystemTime) -> Vec<RateLimitScheduleAction> {
+        let mut actions = Vec::new();
+        let active_due = self.active_query_at.is_some_and(|deadline| now >= deadline);
+        let idle_due = self.idle_query_at.is_some_and(|deadline| now >= deadline);
+        if active_due || idle_due {
+            actions.push(RateLimitScheduleAction::Query);
+        }
+        if active_due {
+            self.active_query_at = None;
+        }
+        if idle_due {
+            self.idle_query_at = Some(next_rate_limit_poll_boundary_with_override(
+                now,
+                IDLE_ACCOUNT_RATE_LIMITS_POLL_INTERVAL,
+                self.query_interval_override,
+            ));
+        }
+        let due = self
+            .probes
+            .iter()
+            .filter_map(|(identity, boundary)| {
+                boundary
+                    .first_attempt_at()
+                    .is_some_and(|first_attempt| first_attempt <= now)
+                    .then(|| identity.clone())
+            })
+            .collect::<Vec<_>>();
+        for identity in due {
+            if let Some(boundary) = self.probes.remove(&identity) {
+                actions.push(RateLimitScheduleAction::Probe(boundary));
+            }
+        }
+        actions
+    }
