+
+impl RateLimitProbeFailure {
+    fn permanent(kind: &'static str) -> Self {
+        Self {
+            kind,
+            status: None,
+            retryable: false,
+        }
+    }
+
+    fn from_request(err: BackendRequestError) -> Self {
+        if matches!(
+            &err,
+            BackendRequestError::ResponsesProbeTerminalFailure { .. }
+        ) {
+            return Self::permanent("terminal_response");
+        }
+        let status = err.status().map(|status| status.as_u16());
+        Self {
+            kind: if status.is_some() {
+                "http_status"
+            } else {
+                "transport_or_stream"
+            },
+            status,
+            retryable: status.is_none_or(|status| {
+                status == 408 || status == 429 || (500..=599).contains(&status)
+            }),
+        }
+    }
+}
