+#[tokio::test]
+async fn account_rate_limit_event_keeps_bucket_pace_on_status_surfaces() {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    while app_event_rx.try_recv().is_ok() {}
+    app.chat_widget.setup_status_line(
+        vec![
+            crate::bottom_pane::StatusLineItem::FiveHourLimit,
+            crate::bottom_pane::StatusLineItem::WeeklyLimit,
+        ],
+        /*use_theme_colors*/ false,
+    );
+    app.chat_widget.setup_terminal_title(vec![
+        crate::bottom_pane::TerminalTitleItem::FiveHourLimit,
+        crate::bottom_pane::TerminalTitleItem::WeeklyLimit,
+    ]);
+
+    let snapshot =
+        |limit_id: &str, limit_name: &str, primary_used, secondary_used| RateLimitSnapshot {
+            limit_id: Some(limit_id.to_string()),
+            limit_name: Some(limit_name.to_string()),
+            primary: Some(RateLimitWindow {
+                used_percent: primary_used,
+                window_duration_mins: Some(5 * 60),
+                resets_at: None,
+            }),
+            secondary: Some(RateLimitWindow {
+                used_percent: secondary_used,
+                window_duration_mins: Some(7 * 24 * 60),
+                resets_at: None,
+            }),
+            credits: None,
+            individual_limit: None,
+            spend_control_reached: None,
+            plan_type: None,
+            rate_limit_reached_type: None,
+        };
+    let codex = snapshot("codex", "codex", 20, 30);
+    let spark = snapshot("codex_spark", "GPT-5.3-Codex-Spark", 65, 75);
+    let notification = AccountRateLimitsUpdatedNotification {
+        rate_limits: codex.clone(),
+        rate_limits_by_limit_id: Some(HashMap::from([
+            ("codex".to_string(), codex),
+            ("codex_spark".to_string(), spark),
+        ])),
+        rate_limit_pace_by_limit_id: Some(HashMap::from([
+            (
+                "codex".to_string(),
+                RateLimitWindowPace {
+                    primary: Some(37),
+                    secondary: Some(-29),
+                },
+            ),
+            (
+                "codex_spark".to_string(),
+                RateLimitWindowPace {
+                    primary: Some(-88),
+                    secondary: Some(91),
+                },
+            ),
+        ])),
+        rate_limit_reset_credits: None,
+    };
+    let app_server = crate::start_embedded_app_server_for_picker(app.chat_widget.config_ref())
+        .await
+        .expect("embedded app server");
+
+    app.handle_app_server_event(
+        &app_server,
+        codex_app_server_client::AppServerEvent::ServerNotification(
+            ServerNotification::AccountRateLimitsUpdated(notification),
+        ),
+    )
+    .await;
+
+    assert_eq!(
+        app.chat_widget.status_line_text(),
+        Some("5H 80% +37% ▪ 7D 70% -29%".to_string())
+    );
+    assert_eq!(
+        app.chat_widget.last_terminal_title,
+        Some("5H 80% +37% | 7D 70% -29%".to_string())
+    );
+    assert_matches!(
+        app_event_rx.try_recv(),
+        Ok(AppEvent::CommitPendingUsageOutput)
+    );
+    assert!(app_event_rx.try_recv().is_err());
+
+    app.handle_app_server_event(
+        &app_server,
+        codex_app_server_client::AppServerEvent::ServerNotification(
+            ServerNotification::AccountRateLimitsUpdated(AccountRateLimitsUpdatedNotification {
+                rate_limits: snapshot("codex", "codex", 99, 98),
+                rate_limits_by_limit_id: None,
+                rate_limit_pace_by_limit_id: None,
+                rate_limit_reset_credits: None,
+            }),
+        ),
+    )
+    .await;
+
+    assert_eq!(
+        app.chat_widget.status_line_text(),
+        Some("5H 80% +37% ▪ 7D 70% -29%".to_string())
+    );
+    assert_eq!(
+        app.chat_widget.last_terminal_title,
+        Some("5H 80% +37% | 7D 70% -29%".to_string())
+    );
+}
