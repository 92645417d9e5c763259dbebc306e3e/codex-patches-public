+async fn append_rate_limit_probe_audit_log(
+    log_dir: &std::path::Path,
+    reset: &RateLimitResetAuditRecord,
+    records: &[RateLimitProbeAuditRecord],
+) -> std::io::Result<()> {
+    use tokio::io::AsyncWriteExt as _;
+
+    tokio::fs::create_dir_all(log_dir).await?;
+    let mut output = Vec::new();
+    serde_json::to_writer(&mut output, reset)?;
+    output.push(b'\n');
+    for record in records {
+        serde_json::to_writer(&mut output, record)?;
+        output.push(b'\n');
+    }
+    let mut file = tokio::fs::OpenOptions::new()
+        .create(true)
+        .append(true)
+        .open(log_dir.join(RATE_LIMIT_RESET_PROBE_LOG))
+        .await?;
+    file.write_all(&output).await
+}
