+#[tokio::test]
+async fn committed_live_steer_is_not_an_editable_prompt() {
+    let (mut chat, mut rx, mut op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.thread_id = Some(ThreadId::new());
+    chat.on_task_started();
+    drain_insert_history(&mut rx);
+
+    chat.bottom_pane
+        .set_composer_text("persisted steer".to_string(), Vec::new(), Vec::new());
+    chat.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+
+    let client_user_message_id = match next_submit_op(&mut op_rx) {
+        Op::UserTurn {
+            client_user_message_id,
+            ..
+        } => client_user_message_id,
+        other => panic!("expected Op::UserTurn for the steer, got {other:?}"),
+    };
+    uuid::Uuid::parse_str(&client_user_message_id)
+        .expect("TUI steer submission should carry a stable client message id");
+    assert_eq!(chat.input_queue.pending_steers.len(), 1);
+    assert!(std::iter::from_fn(|| rx.try_recv().ok()).all(|event| {
+        !matches!(
+            event,
+            AppEvent::InsertHistoryCell(cell)
+                if cell.as_any().downcast_ref::<UserHistoryCell>().is_some()
+        )
+    }));
+
+    chat.handle_server_notification(
+        ServerNotification::ItemCompleted(ItemCompletedNotification {
+            thread_id: chat.thread_id.map(|id| id.to_string()).unwrap_or_default(),
+            turn_id: "turn-1".to_string(),
+            completed_at_ms: 0,
+            item: AppServerThreadItem::UserMessage {
+                id: "user-steer".to_string(),
+                client_id: Some(client_user_message_id.clone()),
+                content: vec![AppServerUserInput::Text {
+                    text: "persisted steer".to_string(),
+                    text_elements: Vec::new(),
+                }],
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+
+    assert!(chat.input_queue.pending_steers.is_empty());
+    let identity = std::iter::from_fn(|| rx.try_recv().ok())
+        .find_map(|event| match event {
+            AppEvent::InsertHistoryCell(cell) => cell
+                .as_any()
+                .downcast_ref::<UserHistoryCell>()
+                .map(|cell| cell.prompt_identity.clone()),
+            _ => None,
+        })
+        .expect("committed steer should render one history cell");
+    assert_eq!(identity, None);
+}
