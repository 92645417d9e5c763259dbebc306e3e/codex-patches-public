+fn initial_messages_for_session(
+    initial_history: &InitialHistory,
+    history_mode: ThreadHistoryMode,
+) -> Option<Vec<EventMsg>> {
+    let events = initial_history.get_event_msgs()?;
+    if history_mode != ThreadHistoryMode::Legacy {
+        return Some(events);
+    }
+
+    let mut canonical_user_messages = Vec::<(String, UserMessageEvent)>::new();
+    let mut projected = Vec::with_capacity(events.len());
+    for event in events {
+        match &event {
+            EventMsg::ItemCompleted(completed) => {
+                if let TurnItem::UserMessage(user_message) = &completed.item {
+                    let legacy = user_message.as_legacy_user_message_event();
+                    canonical_user_messages.push((completed.turn_id.clone(), legacy.clone()));
+                    projected.push(EventMsg::UserMessage(legacy));
+                    continue;
+                }
+            }
+            EventMsg::UserMessage(user_message)
+                if canonical_user_messages
+                    .iter()
+                    .any(|(_, canonical)| canonical == user_message) =>
+            {
+                continue;
+            }
+            EventMsg::TurnStarted(started) => {
+                canonical_user_messages.retain(|(turn_id, _)| turn_id != &started.turn_id)
+            }
+            EventMsg::TurnComplete(completed) => {
+                canonical_user_messages.retain(|(turn_id, _)| turn_id != &completed.turn_id)
+            }
+            EventMsg::TurnAborted(aborted) => {
+                if let Some(aborted_turn_id) = aborted.turn_id.as_ref() {
+                    canonical_user_messages.retain(|(turn_id, _)| turn_id != aborted_turn_id);
+                } else {
+                    canonical_user_messages.clear();
+                }
+            }
+            EventMsg::ThreadRolledBack(_) => canonical_user_messages.clear(),
+            _ => {}
+        }
+        projected.push(event);
+    }
+    Some(projected)
+}
