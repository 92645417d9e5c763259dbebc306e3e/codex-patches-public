+    let turn_id = turn_context
+        .turn_id
+        .clone()
+        .expect("proven compaction turn context has a turn id");
+    let turn_started = original_turn_started.unwrap_or(TurnStartedEvent {
+        turn_id,
+        trace_id: None,
+        started_at: None,
+        model_context_window: None,
+        collaboration_mode_kind: Default::default(),
+    });
+    let mut items = Vec::with_capacity(tail_reversed.len().saturating_add(5));
+    if let Some(token_count) = token_count_before_compaction {
+        items.push(token_count);
+    }
+    items.push(RolloutItem::EventMsg(EventMsg::TurnStarted(turn_started)));
+    items.push(user_boundary);
+    if !turn_context_is_in_tail {
+        items.push(RolloutItem::TurnContext(turn_context));
+    }
+    if let Some(started) = standalone_compaction_started {
+        items.push(RolloutItem::EventMsg(EventMsg::TurnStarted(started)));
+    }
+    items.push(RolloutItem::Compacted(compacted));
+    tail_reversed.reverse();
+    items.extend(tail_reversed);
+    LatestCompactionRollout {
+        items,
+        source_bytes_read,
+    }
