+async fn load_bounded_full_fallback_items(
+    physical_path: &std::path::Path,
+    requested_path: &std::path::Path,
+) -> ThreadStoreResult<Vec<codex_protocol::protocol::RolloutItem>> {
+    let scan_path = physical_path.to_path_buf();
+    let items = tokio::task::spawn_blocking(move || {
+        RolloutRecorder::load_rollout_items_for_bounded_resume(scan_path.as_path())
+    })
+    .await
+    .map_err(|err| ThreadStoreError::Internal {
+        message: format!(
+            "failed to read bounded fallback history {}: {err}",
+            requested_path.display()
+        ),
+    })?
+    .map_err(|err| ThreadStoreError::Internal {
+        message: format!(
+            "failed to read bounded fallback history {}: {err}",
+            requested_path.display()
+        ),
+    })?;
+    items.ok_or_else(|| ThreadStoreError::InvalidRequest {
+        message: format!(
+            "bounded fallback history exceeded {} bytes for {}; retry with historyWindow=full",
+            MAX_RESUME_FULL_FALLBACK_BYTES,
+            requested_path.display()
+        ),
+    })
+}
