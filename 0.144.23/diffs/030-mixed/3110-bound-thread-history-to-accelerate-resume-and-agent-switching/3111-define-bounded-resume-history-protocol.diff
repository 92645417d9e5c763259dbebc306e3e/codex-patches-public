+    #[test]
+    fn display_history_window_uses_latest_effective_replacement_compaction() {
+        let turn_started = |turn_id: &str| {
+            RolloutItem::EventMsg(codex_protocol::protocol::EventMsg::TurnStarted(
+                codex_protocol::protocol::TurnStartedEvent {
+                    turn_id: turn_id.to_string(),
+                    trace_id: None,
+                    started_at: None,
+                    model_context_window: None,
+                    collaboration_mode_kind: ModeKind::default(),
+                },
+            ))
+        };
+        let before = RolloutItem::Compacted(codex_protocol::protocol::CompactedItem {
+            message: "legacy".to_string(),
+            replacement_history: None,
+            base_instructions_update: None,
+            window_number: None,
+            first_window_id: None,
+            previous_window_id: None,
+            window_id: None,
+        });
+        let compacted = RolloutItem::Compacted(codex_protocol::protocol::CompactedItem {
+            message: String::new(),
+            replacement_history: Some(Vec::new()),
+            base_instructions_update: None,
+            window_number: Some(65),
+            first_window_id: None,
+            previous_window_id: None,
+            window_id: None,
+        });
+        let context_compacted =
+            RolloutItem::EventMsg(codex_protocol::protocol::EventMsg::ContextCompacted(
+                codex_protocol::protocol::ContextCompactedEvent {},
+            ));
+        let rolled_back =
+            RolloutItem::EventMsg(codex_protocol::protocol::EventMsg::ThreadRolledBack(
+                codex_protocol::protocol::ThreadRolledBackEvent { num_turns: 1 },
+            ));
+        let oversized_old_prefix = RolloutItem::EventMsg(EventMsg::AgentMessage(
+            codex_protocol::protocol::AgentMessageEvent {
+                message: "x".repeat(2 * 1024 * 1024),
+                phase: None,
+                memory_citation: None,
+            },
+        ));
+        let items = vec![
+            oversized_old_prefix,
+            before,
+            turn_started("baseline"),
+            compacted,
+            context_compacted,
+            turn_started("removed"),
+            rolled_back,
+            turn_started("replacement"),
+        ];
+
+        assert_eq!(
+            display_history_items(&items, ThreadHistoryWindow::Full).len(),
+            8
+        );
+        let window = display_history_window(&items, ThreadHistoryWindow::SinceLatestCompaction);
+        assert_eq!(window.metadata.loaded_context_windows, 1);
+        assert_eq!(window.metadata.omitted_context_windows, 64);
+        assert!(window.metadata.baseline_compaction);
+        assert!(!window.metadata.baseline_compaction_rendered);
+        assert!(
+            matches!(
+                &window.items[0],
+                RolloutItem::EventMsg(codex_protocol::protocol::EventMsg::TurnStarted(started))
+                    if started.turn_id == "baseline"
+            ),
+            "window should start at the turn boundary before the latest replacement-history compaction"
+        );
+        assert!(
+            !window.items.iter().any(|item| {
+                matches!(
+                    item,
+                    RolloutItem::EventMsg(codex_protocol::protocol::EventMsg::ContextCompacted(_))
+                )
+            }),
+            "baseline compaction marker should not replay as a visible banner"
+        );
+
+        let bounded_window =
+            display_history_window(&items[2..], ThreadHistoryWindow::SinceLatestCompaction);
+        assert_eq!(bounded_window.metadata, window.metadata);
+        assert_eq!(
+            serde_json::to_value(&bounded_window.items).expect("serialize bounded items"),
+            serde_json::to_value(&window.items).expect("serialize full-source items")
+        );
+        let source_bytes = serde_json::to_vec(&items)
+            .expect("serialize source items")
+            .len();
+        let outbound_turns = build_legacy_api_turns_from_rollout_items(&bounded_window.items);
+        let outbound_bytes = serde_json::to_vec(&outbound_turns)
+            .expect("serialize outbound turns")
+            .len();
+        assert!(outbound_bytes < source_bytes / 8);
+    }
 }
