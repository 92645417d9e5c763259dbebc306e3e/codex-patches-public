+/// Locate a rollout for bounded resume without reading rollout contents.
+///
+/// The caller must validate the canonical first SessionMeta record with a bounded reader.
+pub async fn find_thread_path_by_id_str_for_bounded_resume(
+    codex_home: &Path,
+    id_str: &str,
+    state_db_ctx: Option<&codex_state::StateRuntime>,
+    include_archived: bool,
+) -> io::Result<Option<PathBuf>> {
+    let thread_id = ThreadId::from_string(id_str).ok();
+    if thread_id.is_none() {
+        return Ok(None);
+    }
+    if let (Some(state_db_ctx), Some(thread_id)) = (state_db_ctx, thread_id) {
+        let archived_filter = (!include_archived).then_some(false);
+        if let Some(path) = state_db_ctx
+            .find_rollout_path_by_id(thread_id, archived_filter)
+            .await
+            .map_err(io::Error::other)?
+            && let Some(path) = compression::existing_rollout_path(path.as_path()).await
+        {
+            return Ok(Some(path));
+        }
+    }
+
+    let active_root = codex_home.join(SESSIONS_SUBDIR);
+    if let Some(path) =
+        find_rollout_path_by_id_from_filenames(active_root.as_path(), id_str).await?
+    {
+        return Ok(Some(path));
+    }
+    if include_archived {
+        let archived_root = codex_home.join(ARCHIVED_SESSIONS_SUBDIR);
+        return find_rollout_path_by_id_from_filenames(archived_root.as_path(), id_str).await;
+    }
+    Ok(None)
+}
