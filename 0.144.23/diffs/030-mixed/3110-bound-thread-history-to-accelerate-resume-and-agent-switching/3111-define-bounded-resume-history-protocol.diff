+async fn load_history_items_since_latest_compaction(
+    path: &std::path::Path,
+    session_meta: Option<SessionMetaLine>,
+) -> ThreadStoreResult<Vec<codex_protocol::protocol::RolloutItem>> {
+    let Some(physical_path) = codex_rollout::existing_rollout_path(path).await else {
+        return Err(ThreadStoreError::InvalidRequest {
+            message: format!(
+                "rollout {} disappeared during bounded resume",
+                path.display()
+            ),
+        });
+    };
+    let scan_path = physical_path.clone();
+    let scan = tokio::task::spawn_blocking(move || {
+        RolloutRecorder::load_latest_compaction_rollout(scan_path.as_path())
+    })
+    .await
+    .map_err(|err| ThreadStoreError::Internal {
+        message: format!("failed to scan thread history {}: {err}", path.display()),
+    })?
+    .map_err(|err| ThreadStoreError::Internal {
+        message: format!("failed to scan thread history {}: {err}", path.display()),
+    })?;
+    let bounded = match scan {
+        LatestCompactionRolloutScan::Found(bounded) => bounded,
+        LatestCompactionRolloutScan::FullFallback {
+            source_bytes_read: _,
+        } => {
+            return load_bounded_full_fallback_items(physical_path.as_path(), path).await;
+        }
+        LatestCompactionRolloutScan::LimitExceeded { source_bytes_read } => {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!(
+                    "cannot prove a bounded latest-compaction resume for {} after reading {source_bytes_read} bytes; retry with historyWindow=full",
+                    path.display()
+                ),
+            });
+        }
+    };
+
+    let session_meta = match session_meta {
+        Some(session_meta) => session_meta,
+        None => read_bounded_resume_session_meta_line(physical_path.as_path()).await?,
+    };
+    let mut items = Vec::with_capacity(bounded.items.len().saturating_add(1));
+    items.push(codex_protocol::protocol::RolloutItem::SessionMeta(
+        session_meta,
+    ));
+    items.extend(bounded.items);
+    Ok(items)
+}
