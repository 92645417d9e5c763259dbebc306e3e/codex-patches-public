+fn build_latest_compaction_rollout(
+    compacted: codex_protocol::protocol::CompactedItem,
+    turn_context: TurnContextItem,
+    turn_context_is_in_tail: bool,
+    user_boundary: RolloutItem,
+    token_count_before_compaction: Option<RolloutItem>,
+    original_turn_started: Option<TurnStartedEvent>,
+    standalone_compaction_started: Option<TurnStartedEvent>,
+    mut tail_reversed: Vec<RolloutItem>,
