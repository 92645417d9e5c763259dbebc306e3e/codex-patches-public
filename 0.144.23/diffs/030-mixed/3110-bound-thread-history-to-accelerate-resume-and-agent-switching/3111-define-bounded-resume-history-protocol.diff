+        let home = TempDir::new().expect("temp dir");
+        let store = LocalThreadStore::new(test_config(home.path()), /*state_db*/ None);
+
+        let small_uuid = Uuid::from_u128(7016);
+        let small_path = write_session_file(home.path(), "2025-01-03T13-40-00", small_uuid)
+            .expect("small session file");
+        compress_rollout(&small_path).expect("compress small rollout");
+        let small = ThreadStore::read_thread_for_resume_by_rollout_path(
+            &store,
+            ReadThreadForResumeByRolloutPathParams {
+                rollout_path: small_path,
+                include_archived: false,
+                history_window: ResumeHistoryWindow::SinceLatestCompaction,
+            },
+        )
+        .await
+        .expect("small compressed bounded resume");
+        assert!(
+            small
+                .history
+                .is_some_and(|history| !history.items.is_empty())
+        );
+
+        let large_uuid = Uuid::from_u128(7017);
+        let large_path = write_session_file(home.path(), "2025-01-03T13-50-00", large_uuid)
+            .expect("large session file");
+        let mut large_file = std::fs::OpenOptions::new()
+            .append(true)
+            .open(&large_path)
+            .expect("open large rollout");
+        append_rollout_item(
+            &mut large_file,
+            RolloutItem::EventMsg(EventMsg::AgentMessage(AgentMessageEvent {
+                message: "x".repeat((MAX_RESUME_FULL_FALLBACK_BYTES as usize) + 1),
+                phase: None,
+                memory_citation: None,
+            })),
+        )
+        .expect("append decompressed oversized record");
+        drop(large_file);
+        compress_rollout(&large_path).expect("compress large rollout");
+        let error = ThreadStore::read_thread_for_resume_by_rollout_path(
+            &store,
+            ReadThreadForResumeByRolloutPathParams {
+                rollout_path: large_path,
+                include_archived: false,
+                history_window: ResumeHistoryWindow::SinceLatestCompaction,
+            },
+        )
+        .await
+        .expect_err("large decompressed rollout must stay bounded");
+        assert!(matches!(error, ThreadStoreError::InvalidRequest { .. }));
+        assert!(error.to_string().contains("historyWindow=full"));
+    }
