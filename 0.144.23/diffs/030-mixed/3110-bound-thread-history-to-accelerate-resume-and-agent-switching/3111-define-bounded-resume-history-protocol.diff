+        let valid_path =
+            write_session_file(home.path(), "2025-01-03T13-30-00", Uuid::from_u128(7015))
+                .expect("session file");
+        let valid_tail = std::fs::read(&valid_path).expect("read valid rollout");
+
+        let corrupt_path = home.path().join("corrupt-first-record.jsonl");
+        let mut corrupt = b"not-json\n".to_vec();
+        corrupt.extend_from_slice(&valid_tail);
+        std::fs::write(&corrupt_path, corrupt).expect("write corrupt rollout");
+
+        let oversized_path = home.path().join("oversized-first-record.jsonl");
+        let mut oversized =
+            vec![b'x'; codex_rollout::RESUME_HISTORY_SCAN_LIMITS.max_record_bytes + 1];
+        oversized.push(b'\n');
+        oversized.extend_from_slice(&valid_tail);
+        std::fs::write(&oversized_path, oversized).expect("write oversized rollout");
+
+        for rollout_path in [corrupt_path, oversized_path] {
+            let error = ThreadStore::read_thread_for_resume_by_rollout_path(
