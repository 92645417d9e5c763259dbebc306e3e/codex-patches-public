+        "turn-1".to_string(),
+        ReplayKind::ResumeInitialMessages,
+    );
+
+    let inserted = drain_insert_history(&mut rx);
+    assert_eq!(inserted.len(), 1);
+    let rendered = lines_to_single_string(&inserted[0]);
+    assert!(rendered.contains("Context compacted"));
+    assert!(
+        !rendered.contains("Context window unknown"),
+        "resume replay should not synthesize live-only context usage"
+    );
+    assert!(
+        !rendered.contains("Used"),
+        "resume replay should not show live-only context usage"
+    );
+}
