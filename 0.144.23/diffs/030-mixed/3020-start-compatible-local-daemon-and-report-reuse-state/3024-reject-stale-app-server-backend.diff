+fn ensure_running_version_is_current_for_attach(
+    info: &client::ProbeInfo,
+    managed_version: Option<&str>,
+) -> Result<()> {
+    if running_version_is_stale(info, managed_version) {
+        let managed_version = managed_version.unwrap_or("unknown");
+        bail!(
+            "app server {} is still active but managed Codex is {}; refusing to attach to stale daemon",
+            info.app_server_version,
+            managed_version
+        );
+    }
+    Ok(())
+}
+
+fn running_version_is_stale(info: &client::ProbeInfo, managed_version: Option<&str>) -> bool {
+    managed_version.is_some_and(|managed_version| info.app_server_version != managed_version)
