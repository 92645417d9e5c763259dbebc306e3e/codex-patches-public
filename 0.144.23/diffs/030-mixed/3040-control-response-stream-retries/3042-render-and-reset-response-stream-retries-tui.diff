+async fn retry_discards_only_trailing_provisional_agent_cells() {
+    let mut app = make_test_app().await;
+    app.transcript_cells = vec![
+        Arc::new(UserHistoryCell {
+            message: "keep".to_string(),
+            text_elements: Vec::new(),
+            local_image_paths: Vec::new(),
+            remote_image_urls: Vec::new(),
+        }) as Arc<dyn HistoryCell>,
+        Arc::new(AgentMessageCell::new(
+            vec![Line::from("partial one")],
+            /*is_first_line*/ true,
+        )) as Arc<dyn HistoryCell>,
+        Arc::new(AgentMessageCell::new(
+            vec![Line::from("partial two")],
+            /*is_first_line*/ false,
+        )) as Arc<dyn HistoryCell>,
+    ];
+    app.overlay = Some(Overlay::new_transcript(
+        app.transcript_cells.clone(),
+        app.keymap.pager.clone(),
+    ));
+
+    assert!(app.discard_incomplete_agent_message());
+    assert_eq!(app.transcript_cells.len(), 1);
+    assert!(app.transcript_cells[0].as_any().is::<UserHistoryCell>());
+    let overlay_cell_count = match app.overlay.as_ref() {
+        Some(Overlay::Transcript(transcript)) => transcript.committed_cell_count(),
+        _ => panic!("expected transcript overlay"),
+    };
+    assert_eq!(overlay_cell_count, 1);
+    assert!(!app.discard_incomplete_agent_message());
+}
