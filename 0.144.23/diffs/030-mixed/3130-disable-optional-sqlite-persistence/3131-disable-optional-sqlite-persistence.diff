+        use_goals: true,
+        persist_feedback_logs: false,
+        generate_memories: true,
+    };
+
+    let runtime = try_init(&config).await?;
+    assert!(
+        runtime
+            .query_logs(&codex_state::LogQuery::default())
+            .await?
+            .is_empty()
+    );
+    assert_eq!(std::fs::read(&logs_path)?, b"not a sqlite database");
+    runtime.close().await;
+
+    Ok(())
+}
