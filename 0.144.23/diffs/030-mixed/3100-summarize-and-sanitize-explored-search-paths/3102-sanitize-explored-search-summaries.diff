+fn search_query_display_text(query: &str) -> String {
+    let mut display = String::with_capacity(query.len());
+    let mut chars = query.chars().peekable();
+    while let Some(ch) = chars.next() {
+        if ch == '\\' {
+            if let Some(&next) = chars.peek() {
+                if next == '\\' {
+                    display.push('\\');
+                    chars.next();
+                    continue;
+                }
+                if !next.is_alphanumeric() && !next.is_whitespace() {
+                    display.push(next);
+                    chars.next();
+                    continue;
+                }
+            }
+        }
+        display.push(ch);
+    }
+    truncate_text(&display, MAX_SEARCH_QUERY_DISPLAY_GRAPHEMES)
+}
