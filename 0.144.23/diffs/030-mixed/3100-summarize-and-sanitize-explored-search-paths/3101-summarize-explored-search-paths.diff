+fn summarize_search_paths<'a, I>(paths: I) -> Option<String>
+where
+    I: IntoIterator<Item = &'a String>,
+{
+    let mut iter = paths.into_iter();
+    let first = iter.next()?;
+    let first = short_display_path(first);
+    let remaining = iter.count();
+    if remaining == 0 {
+        Some(first)
+    } else {
+        Some(format!("{first} +{remaining} more"))
+    }
+}
