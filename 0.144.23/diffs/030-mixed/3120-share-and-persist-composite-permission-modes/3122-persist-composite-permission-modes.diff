+#[tokio::test]
+async fn composite_permission_selection_persists_before_runtime_application() -> Result<()> {
+    let (mut app, mut app_event_rx, _op_rx) = make_test_app_with_channels().await;
+    let codex_home = tempdir()?;
+    app.config.codex_home = codex_home.path().to_path_buf().abs();
+    let app_server = start_config_write_test_app_server(&app).await?;
+    let selection = PermissionProfileSelection {
+        profile_id: BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS.to_string(),
+        approval_policy: Some(AskForApproval::Never),
+        approvals_reviewer: Some(ApprovalsReviewer::AutoReview),
+        display_label: "YOLO".to_string(),
+    };
+    let original_profile = app.config.permissions.permission_profile().clone();
+
+    assert!(
+        app.persist_permission_profile_selection(&app_server, &selection)
+            .await
+    );
+    assert_eq!(
+        app.config.permissions.permission_profile(),
+        &original_profile,
+        "persistence must complete before runtime state changes"
+    );
+    let config = std::fs::read_to_string(codex_home.path().join("config.toml"))?;
+    assert!(config.contains("default_permissions = \":danger-full-access\""));
+    assert!(config.contains("approval_policy = \"never\""));
+    assert!(config.contains("approvals_reviewer = \"auto_review\""));
+
+    assert!(app.apply_permission_profile_selection(selection).await);
+    assert_eq!(
+        app.config.permissions.permission_profile(),
+        &PermissionProfile::Disabled
+    );
+    assert_eq!(
+        AskForApproval::from(app.config.permissions.approval_policy.value()),
+        AskForApproval::Never
+    );
+    assert_eq!(app.config.approvals_reviewer, ApprovalsReviewer::AutoReview);
+    let _override = app_event_rx
+        .try_recv()
+        .expect("runtime application should emit an override");
+    let history = app_event_rx
+        .try_recv()
+        .expect("runtime application should emit history after persistence");
+    let AppEvent::InsertHistoryCell(cell) = history else {
+        panic!("expected permission history after durable application: {history:?}");
+    };
+    assert!(
+        cell.display_lines(/*width*/ 120)
+            .iter()
+            .any(|line| line.to_string().contains("Permissions updated to YOLO"))
+    );
+
+    app_server.shutdown().await?;
+    Ok(())
+}
