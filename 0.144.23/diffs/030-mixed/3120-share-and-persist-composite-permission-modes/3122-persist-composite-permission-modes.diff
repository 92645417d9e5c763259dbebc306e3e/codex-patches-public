+#[tokio::test]
+async fn profile_permissions_preserve_agent_review_and_yolo_as_distinct_modes() {
+    for (down_count, expected_policy, expected_label) in [
+        (3, AskForApproval::OnRequest, "Full Access + Auto Review"),
+        (4, AskForApproval::Never, "YOLO"),
+    ] {
+        let (mut chat, mut rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+        chat.config.explicit_permission_profile_mode = true;
+        chat.set_feature_enabled(Feature::GuardianApproval, /*enabled*/ true);
+        chat.open_permissions_popup();
+        chat.handle_key_event(KeyEvent::from(KeyCode::Home));
+        for _ in 0..down_count {
+            chat.handle_key_event(KeyEvent::from(KeyCode::Down));
+        }
+        chat.handle_key_event(KeyEvent::from(KeyCode::Enter));
+
+        let AppEvent::OpenFullAccessConfirmation {
+            preset,
+            return_to_permissions,
+            profile_selection,
+        } = rx
+            .try_recv()
+            .expect("full-access mode should require confirmation")
+        else {
+            panic!("expected full-access confirmation");
+        };
+        chat.open_full_access_confirmation(preset, return_to_permissions, profile_selection);
+        chat.handle_key_event(KeyEvent::from(KeyCode::Enter));
+
+        assert!(matches!(
+            rx.try_recv(),
+            Ok(AppEvent::SelectPermissionProfile(PermissionProfileSelection {
+                profile_id,
+                approval_policy: Some(policy),
+                approvals_reviewer: Some(ApprovalsReviewer::AutoReview),
+                display_label,
+            })) if profile_id == BUILT_IN_PERMISSION_PROFILE_DANGER_FULL_ACCESS
+                && policy == expected_policy
+                && display_label == expected_label
+        ));
+    }
+}
