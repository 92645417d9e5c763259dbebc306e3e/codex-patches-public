+#[tokio::test]
+async fn queued_message_edit_shortcut_requests_pending_steer_clear() {
+    let (mut chat, _rx, mut op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.chat_keymap.edit_queued_message = vec![crate::key_hint::alt(KeyCode::Up)];
+    chat.queued_message_edit_hint_binding = Some(crate::key_hint::alt(KeyCode::Up));
+    chat.bottom_pane
+        .set_queued_message_edit_binding(chat.queued_message_edit_hint_binding);
+    chat.input_queue
+        .pending_steers
+        .push_back(pending_steer("first"));
+    chat.input_queue
+        .pending_steers
+        .push_back(pending_steer("second"));
+    chat.refresh_pending_input_preview();
+
+    chat.handle_key_event(KeyEvent::new(KeyCode::Up, KeyModifiers::ALT));
+
+    assert!(matches!(op_rx.try_recv(), Ok(Op::ClearPendingSteers)));
+    assert_eq!(chat.input_queue.pending_steers.len(), 2);
+
+    chat.clear_pending_steers();
+    assert!(chat.input_queue.pending_steers.is_empty());
+}
+
+#[tokio::test]
+async fn queued_message_edit_shortcut_clears_pending_steers_before_editing_queue() {
+    let (mut chat, _rx, mut op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.chat_keymap.edit_queued_message = vec![crate::key_hint::alt(KeyCode::Up)];
+    chat.queued_message_edit_hint_binding = Some(crate::key_hint::alt(KeyCode::Up));
+    chat.bottom_pane
+        .set_queued_message_edit_binding(chat.queued_message_edit_hint_binding);
+    chat.bottom_pane.set_task_running(/*running*/ true);
+    chat.input_queue
+        .pending_steers
+        .push_back(pending_steer("pending"));
+    chat.input_queue
+        .queued_user_messages
+        .push_back(UserMessage::from("queued".to_string()).into());
+    chat.refresh_pending_input_preview();
+
+    chat.handle_key_event(KeyEvent::new(KeyCode::Up, KeyModifiers::ALT));
+
+    assert!(matches!(op_rx.try_recv(), Ok(Op::ClearPendingSteers)));
+    assert!(chat.bottom_pane.composer_text().is_empty());
+    assert_eq!(chat.input_queue.pending_steers.len(), 1);
+    assert_eq!(chat.input_queue.queued_user_messages.len(), 1);
+
+    chat.clear_pending_steers();
+    chat.handle_key_event(KeyEvent::new(KeyCode::Up, KeyModifiers::ALT));
+
+    assert_eq!(chat.bottom_pane.composer_text(), "queued".to_string());
+    assert!(chat.input_queue.pending_steers.is_empty());
+    assert!(chat.input_queue.queued_user_messages.is_empty());
+}
