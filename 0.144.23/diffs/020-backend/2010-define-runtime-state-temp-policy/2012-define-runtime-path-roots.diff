+/// Returns the Codex runtime temp root under the system temp parent.
+pub fn find_codex_tmp_root() -> std::io::Result<AbsolutePathBuf> {
+    Ok(find_system_tmp_root()?.join("codex"))
+}
+
+/// Returns the system temp root resolved from the process environment.
+pub fn find_system_tmp_root() -> std::io::Result<AbsolutePathBuf> {
+    system_tmp_root_from_env(
+        std::env::var_os("TMPDIR"),
+        std::env::var_os("TMP"),
+        std::env::var_os("TEMP"),
+    )
+}
+
+/// Resolves and creates the project scratch root under the shared Codex temp
+/// root for a local working directory.
+pub fn find_project_scratch_root(cwd: &Path) -> std::io::Result<AbsolutePathBuf> {
+    create_project_scratch_root(&find_codex_tmp_root()?, cwd)
+}
+
+fn create_project_scratch_root(
+    codex_tmp_root: &AbsolutePathBuf,
+    cwd: &Path,
+) -> std::io::Result<AbsolutePathBuf> {
+    let root = project_scratch_root_for(codex_tmp_root, cwd)?;
+    std::fs::create_dir_all(root.as_path())?;
+    Ok(root)
+}
+
+/// Returns the project working root for a local working directory.
+pub fn find_project_working_root(cwd: &Path) -> std::io::Result<AbsolutePathBuf> {
+    AbsolutePathBuf::from_absolute_path(project_root_for(cwd))
+}
+
+/// Returns the project name used by the current local runtime layout.
+pub fn find_project_name(cwd: &Path) -> String {
+    project_name(project_root_for(cwd).as_path())
+}
+
+/// Returns the runtime temp root for the current local runtime layout.
+pub fn find_runtime_tmp_root(cwd: &Path) -> std::io::Result<AbsolutePathBuf> {
+    Ok(find_system_tmp_root()?.join(find_project_name(cwd)))
+}
+
+/// Returns the persistent runtime state root for the current local runtime
+/// layout.
+pub fn find_runtime_state_root(cwd: &Path) -> std::io::Result<AbsolutePathBuf> {
+    let mut root = home_dir().ok_or_else(|| {
+        std::io::Error::new(
+            std::io::ErrorKind::NotFound,
+            "Could not find home directory",
+        )
+    })?;
+    root.push(find_project_name(cwd));
+    AbsolutePathBuf::from_absolute_path(root)
+}
+
+fn codex_tmp_parent_from_env(
+    tmpdir: Option<OsString>,
+    tmp: Option<OsString>,
+    temp: Option<OsString>,
+) -> Option<PathBuf> {
+    [tmpdir, tmp, temp]
+        .into_iter()
+        .flatten()
+        .find(|value| !value.is_empty())
+        .map(PathBuf::from)
+}
+
+fn system_tmp_root_from_env(
+    tmpdir: Option<OsString>,
+    tmp: Option<OsString>,
+    temp: Option<OsString>,
+) -> std::io::Result<AbsolutePathBuf> {
+    let root = codex_tmp_parent_from_env(tmpdir, tmp, temp).unwrap_or_else(std::env::temp_dir);
+    AbsolutePathBuf::from_absolute_path(root)
+}
+
+fn project_scratch_root_for(
+    codex_tmp_root: &AbsolutePathBuf,
+    cwd: &Path,
+) -> std::io::Result<AbsolutePathBuf> {
+    let project_root = project_root_for(cwd);
+    AbsolutePathBuf::from_absolute_path(project_runtime_path(codex_tmp_root, &project_root))
+}
+
+fn project_root_for(cwd: &Path) -> PathBuf {
+    find_git_project_root(cwd).unwrap_or_else(|| cwd.to_path_buf())
+}
+
+fn find_git_project_root(cwd: &Path) -> Option<PathBuf> {
+    cwd.ancestors()
+        .find(|candidate| candidate.join(".git").exists())
+        .map(Path::to_path_buf)
+}
+
+fn project_runtime_path(codex_tmp_root: &AbsolutePathBuf, project_root: &Path) -> PathBuf {
+    let parent_name = path_leaf(project_root.parent(), "root");
+    let working_name = project_name(project_root);
+    codex_tmp_root
+        .as_path()
+        .join(parent_name)
+        .join(working_name)
+}
+
+fn project_name(project_root: &Path) -> String {
+    path_leaf(Some(project_root), "workspace")
+}
+
+fn path_leaf(path: Option<&Path>, fallback: &str) -> String {
+    let Some(path) = path else {
+        return fallback.to_string();
+    };
+    let Some(name) = path.file_name() else {
+        return fallback.to_string();
+    };
+    let rendered = name.to_string_lossy();
+    if rendered.is_empty() {
+        fallback.to_string()
+    } else {
+        rendered.into_owned()
+    }
+}
