+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn websocket_first_turn_reconnects_after_startup_prewarm_timeout() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = start_websocket_server_with_event_delays(vec![
+        (
+            vec![
+                vec![
+                    ev_response_created("warm-timeout"),
+                    ev_assistant_message("warm-msg", "still warming"),
+                    ev_completed("warm-timeout"),
+                ],
+                vec![
+                    ev_response_created("stale-response"),
+                    ev_assistant_message("stale-msg", "stale"),
+                    ev_completed("stale-response"),
+                ],
+            ],
+            Some(Duration::from_millis(400)),
+        ),
+        (
+            vec![vec![
+                ev_response_created("resp-1"),
+                ev_assistant_message("msg-1", "hello"),
+                ev_completed("resp-1"),
+            ]],
+            None,
+        ),
+    ])
+    .await;
+
+    let mut builder = test_codex().with_config(|config| {
+        config.model_provider.websocket_connect_timeout_ms = Some(1_000);
+        config.model_provider.stream_max_retries = Some(0);
+    });
+    let test = builder.build_with_websocket_server(&server).await?;
+    let warmup = tokio::time::timeout(
+        Duration::from_secs(2),
+        server.wait_for_request(/*connection_index*/ 0, /*request_index*/ 0),
+    )
+    .await
+    .expect("startup prewarm request should arrive")
+    .body_json();
+    assert_eq!(warmup["type"].as_str(), Some("response.create"));
+    assert_eq!(warmup["generate"].as_bool(), Some(false));
+
+    test.submit_turn_with_policy("hello", test.config.legacy_sandbox_policy())
+        .await?;
+
+    assert_eq!(server.handshakes().len(), 2);
+    let connections = server.connections();
+    assert_eq!(connections.len(), 2);
+    assert_eq!(connections[0].len(), 1);
+    assert_eq!(connections[1].len(), 1);
+    let turn = connections[1][0].body_json();
+    assert_eq!(turn["type"].as_str(), Some("response.create"));
+    assert_eq!(turn.get("previous_response_id"), None);
+
+    server.shutdown().await;
+    Ok(())
+}
