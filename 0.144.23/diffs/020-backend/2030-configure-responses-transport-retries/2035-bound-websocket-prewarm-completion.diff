+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn responses_websocket_prewarm_completion_timeout_resets_cached_session() {
+    skip_if_no_network!();
+
+    let server = start_websocket_server_with_event_delays(vec![
+        (
+            vec![vec![
+                ev_response_created("warm-timeout"),
+                ev_assistant_message("warm-msg", "still warming"),
+                ev_completed("warm-timeout"),
+            ]],
+            Some(Duration::from_millis(1_100)),
+        ),
+        (
+            vec![vec![
+                ev_response_created("resp-after-timeout"),
+                ev_completed("resp-after-timeout"),
+            ]],
+            None,
+        ),
+    ])
+    .await;
+
+    let harness = websocket_harness_with_options(&server, /*runtime_metrics_enabled*/ true).await;
+    let mut client_session = harness.client.new_session();
+    let prompt = prompt_with_input(vec![message_item("hello")]);
+    let responses_metadata = prewarm_metadata(&harness, /*turn_id*/ None);
+    let err = client_session
+        .prewarm_websocket(
+            &prompt,
+            &harness.model_info,
+            &harness.session_telemetry,
+            harness.effort.clone(),
+            harness.summary,
+            /*service_tier*/ None,
+            &responses_metadata,
+        )
+        .await
+        .expect_err("websocket prewarm should exceed its completion deadline");
+    assert!(matches!(
+        &err,
+        codex_protocol::error::CodexErr::Stream(message, None)
+            if message == "websocket prewarm timed out waiting for response.completed"
+    ));
+
+    drop(client_session);
+    let mut next_session = harness.client.new_session();
+    stream_until_complete(&mut next_session, &harness, &prompt).await;
+
+    assert_eq!(server.handshakes().len(), 2);
+    let connections = server.connections();
+    assert_eq!(connections.len(), 2);
+    assert_eq!(connections[0].len(), 1);
+    assert_eq!(connections[1].len(), 1);
+    let follow_up = connections[1][0].body_json();
+    assert_eq!(follow_up["type"].as_str(), Some("response.create"));
+    assert_eq!(follow_up.get("previous_response_id"), None);
+
+    server.shutdown().await;
+}
