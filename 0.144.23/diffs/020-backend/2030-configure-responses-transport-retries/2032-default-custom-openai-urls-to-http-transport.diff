+fn validate_openai_provider_override(provider: &ConfiguredModelProvider) -> Result<(), String> {
+    let mut unsupported = Vec::new();
+    if provider.name.is_some() {
+        unsupported.push("`name`");
+    }
+    if provider.base_url.is_some() {
+        unsupported.push("`base_url`");
+    }
+    if provider.env_key.is_some() {
+        unsupported.push("`env_key`");
+    }
+    if provider.env_key_instructions.is_some() {
+        unsupported.push("`env_key_instructions`");
+    }
+    if provider.experimental_bearer_token.is_some() {
+        unsupported.push("`experimental_bearer_token`");
+    }
+    if provider.auth.is_some() {
+        unsupported.push("`auth`");
+    }
+    if provider.aws.is_some() {
+        unsupported.push("`aws`");
+    }
+    if provider.wire_api.is_some() {
+        unsupported.push("`wire_api`");
+    }
+    if provider.query_params.is_some() {
+        unsupported.push("`query_params`");
+    }
+    if provider.http_headers.is_some() {
+        unsupported.push("`http_headers`");
+    }
+    if provider.env_http_headers.is_some() {
+        unsupported.push("`env_http_headers`");
+    }
+    if provider.requires_openai_auth.is_some() {
+        unsupported.push("`requires_openai_auth`");
+    }
+
+    if unsupported.is_empty() {
+        return Ok(());
+    }
+
+    let mut message = format!(
+        "model_providers.{OPENAI_PROVIDER_ID} only supports changing \
+`request_max_retries`, `stream_max_retries`, `stream_idle_timeout_ms`, \
+`websocket_connect_timeout_ms`, and `supports_websockets`; unsupported fields: {}",
+        unsupported.join(", ")
+    );
+    if provider.base_url.is_some() {
+        message.push_str("; use `openai_base_url` for `base_url`");
+    }
+    Err(message)
+}
