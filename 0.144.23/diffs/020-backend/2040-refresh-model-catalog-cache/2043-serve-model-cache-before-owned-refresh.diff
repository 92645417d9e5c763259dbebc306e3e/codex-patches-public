+async fn repeated_cache_hits_are_bounded_and_manager_drop_aborts_background_refresh() {
+    let cached_models = vec![remote_model("drop-cache", "Drop Cache", 0)];
+    let (endpoint, mut started_rx, dropped_rx) = PendingModelsEndpoint::new();
+    let codex_home = tempdir().expect("temp dir");
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint);
+    manager
+        .cache_manager
+        .as_ref()
+        .expect("cached model manager")
+        .persist_cache(
+            &cached_models,
+            Some("drop-cache-etag".to_string()),
+            crate::client_version_to_whole(),
+        )
+        .await;
+
+    manager
+        .refresh_available_models(
+            RefreshStrategy::OnlineIfUncached,
+            &DEFAULT_HTTP_CLIENT_FACTORY,
+        )
+        .await
+        .expect("cache hit succeeds");
+    tokio::time::timeout(ASYNC_TEST_TIMEOUT, started_rx.recv())
+        .await
+        .expect("timed out waiting for pending background request")
+        .expect("background request should start");
+
+    for _ in 0..16 {
+        manager
+            .refresh_available_models(
+                RefreshStrategy::OnlineIfUncached,
+                &DEFAULT_HTTP_CLIENT_FACTORY,
+            )
+            .await
+            .expect("repeated cache hit succeeds");
+    }
+    {
+        let state = manager
+            .background_refresh
+            .lock()
+            .expect("background refresh state lock should not be poisoned");
+        assert!(state.running);
+        assert!(state.task.is_some(), "only the active task should be owned");
+        assert!(
+            state.pending.is_some(),
+            "repeated hits should coalesce into one trailing refresh"
+        );
+    }
+    assert!(matches!(
+        started_rx.try_recv(),
+        Err(tokio::sync::mpsc::error::TryRecvError::Empty)
+    ));
+
+    drop(manager);
+    tokio::time::timeout(ASYNC_TEST_TIMEOUT, dropped_rx)
+        .await
+        .expect("timed out waiting for pending request cancellation")
+        .expect("pending request should be dropped with the manager");
+}
