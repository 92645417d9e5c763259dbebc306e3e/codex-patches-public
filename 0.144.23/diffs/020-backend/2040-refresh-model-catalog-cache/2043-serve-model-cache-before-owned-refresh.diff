+#[tokio::test]
+async fn list_models_returns_cached_models_before_background_refresh() -> Result<()> {
+    let server = MockServer::start().await;
+    let cached_model: ModelInfo = serde_json::from_value(json!({
+        "slug": "cached-startup-model",
+        "display_name": "Cached Startup Model",
+        "description": "Cached model should be returned immediately",
+        "default_reasoning_level": "medium",
+        "supported_reasoning_levels": [{"effort": "medium", "description": "Medium"}],
+        "shell_type": "shell_command",
+        "visibility": "list",
+        "minimal_client_version": [0, 1, 0],
+        "supported_in_api": true,
+        "priority": 0,
+        "upgrade": null,
+        "base_instructions": "base instructions",
+        "supports_reasoning_summaries": false,
+        "support_verbosity": false,
+        "default_verbosity": null,
+        "availability_nux": null,
+        "apply_patch_tool_type": null,
+        "truncation_policy": {"mode": "bytes", "limit": 10_000},
+        "supports_parallel_tool_calls": false,
+        "supports_image_detail_original": false,
+        "context_window": 272_000,
+        "max_context_window": 272_000,
+        "experimental_supported_tools": [],
+    }))?;
+    let mut remote_model = cached_model.clone();
+    remote_model.slug = "remote-delayed-model".to_string();
+    remote_model.display_name = "Remote Delayed Model".to_string();
+    remote_model.description = Some("Delayed model should not block model/list".to_string());
+    let models_mock = mount_models_once_with_delay(
+        &server,
+        ModelsResponse {
+            models: vec![remote_model],
+        },
+        Duration::from_secs(2),
+    )
+    .await;
+
+    let codex_home = TempDir::new()?;
+    write_models_cache_with_models(codex_home.path(), vec![cached_model])?;
+    let cache_path = codex_home.path().join("models_cache.json");
+    let mut cache: Value = serde_json::from_slice(&std::fs::read(&cache_path)?)?;
+    cache["client_version"] = Value::String("older-client-version".to_string());
+    std::fs::write(&cache_path, serde_json::to_vec_pretty(&cache)?)?;
+
+    let server_uri = server.uri();
+    std::fs::write(
+        codex_home.path().join("config.toml"),
+        format!(
+            r#"
+model = "mock-model"
+approval_policy = "never"
+sandbox_mode = "read-only"
+openai_base_url = "{server_uri}/v1"
+"#
+        ),
+    )?;
+    write_chatgpt_auth(
+        codex_home.path(),
+        ChatGptAuthFixture::new("chatgpt-access-token").plan_type("pro"),
+        AuthCredentialsStoreMode::File,
+    )?;
+
+    let mut mcp = TestAppServer::builder()
+        .with_codex_home(codex_home.path())
+        .without_auto_env()
+        .with_env_overrides(&[("OPENAI_API_KEY", None)])
+        .build()
+        .await?;
+    timeout(DEFAULT_TIMEOUT, mcp.initialize()).await??;
+    timeout(DEFAULT_TIMEOUT, async {
+        while models_mock.requests().is_empty() {
+            tokio::task::yield_now().await;
+        }
+    })
+    .await
+    .expect("startup worker should begin the delayed /models request");
+    assert_eq!(models_mock.requests().len(), 1);
+    let request_id = mcp
+        .send_list_models_request(ModelListParams {
+            limit: Some(100),
+            cursor: None,
+            include_hidden: None,
+        })
+        .await?;
+
+    let response: JSONRPCResponse = timeout(
+        CACHED_MODELS_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(request_id)),
+    )
+    .await??;
+    let ModelListResponse { data, .. } = to_response::<ModelListResponse>(response)?;
+    assert!(
+        data.iter().any(|model| model.id == "cached-startup-model"),
+        "model/list should return cached models without waiting for /models"
+    );
+    assert_eq!(
+        models_mock.requests().len(),
+        1,
+        "model/list should not start another request while the startup refresh is blocked"
+    );
+
+    Ok(())
+}
