+        let refresh_context = self.refresh_context();
+        let background_refresh = Arc::downgrade(&self.background_refresh);
+        let task = tokio::spawn(async move {
+            run_background_model_refresh(refresh_context, background_refresh, request).await;
+        });
+        state.task = Some(AbortOnDropHandle::new(task));
