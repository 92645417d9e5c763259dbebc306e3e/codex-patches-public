+async fn run_background_model_refresh(
+    refresh_context: ModelsRefreshContext,
+    background_refresh: std::sync::Weak<Mutex<BackgroundRefreshState>>,
+    mut request: BackgroundRefreshRequest,
+) {
+    loop {
+        if let Err(err) = refresh_context
+            .fetch_and_update_models_if_unchanged(
+                request.observed_revision,
+                &request.http_client_factory,
+            )
+            .await
+        {
+            error!("failed to refresh available models: {err}");
+        }
+
+        let Some(background_refresh) = background_refresh.upgrade() else {
+            return;
+        };
+        let mut state = background_refresh
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        match state.pending.take() {
+            Some(pending) => request = pending,
+            None => {
+                state.running = false;
+                return;
+            }
+        }
+    }
+}
