+    let (endpoint, mut started_rx) = ControlledModelsEndpoint::new(vec![
+        ControlledModelsFetch::success(initial_models, "network-etag-a"),
+        ControlledModelsFetch::blocked_error(
+            "background refresh failed",
+            Arc::clone(&error_release),
+        ),
+        ControlledModelsFetch::success(refreshed_models.clone(), "network-etag-c"),
+    ]);
+    let codex_home = tempdir().expect("temp dir");
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint.clone());
+
+    manager
+        .refresh_available_models(RefreshStrategy::Online, &DEFAULT_HTTP_CLIENT_FACTORY)
+        .await
+        .expect("initial refresh succeeds");
+    expect_fetch_started(&mut started_rx, 1).await;
+    manager
+        .cache_manager
+        .as_ref()
+        .expect("cached model manager")
+        .mutate_cache_for_test(|cache| {
+            cache.etag = Some("disk-etag-b".to_string());
+            cache.models.clone_from(&cached_models);
+        })
+        .await
+        .expect("cache mutation succeeds");
+
+    manager
+        .refresh_available_models(
+            RefreshStrategy::OnlineIfUncached,
+            &DEFAULT_HTTP_CLIENT_FACTORY,
+        )
+        .await
+        .expect("cache hit succeeds");
+    let background = manager
+        .take_background_refresh_task_for_test()
+        .expect("cache hit should own a background refresh task");
+    expect_fetch_started(&mut started_rx, 2).await;
+    error_release.add_permits(1);
+    tokio::time::timeout(ASYNC_TEST_TIMEOUT, background)
+        .await
+        .expect("timed out waiting for failed background refresh")
+        .expect("failed refresh should be contained by the background task");
+
+    {
+        let catalog = manager.catalog.read().await;
+        assert_eq!(catalog.models, cached_models);
+        assert_eq!(catalog.etag.as_deref(), Some("network-etag-a"));
+    }
+
+    manager
+        .refresh_if_new_etag("disk-etag-b".to_string(), DEFAULT_HTTP_CLIENT_FACTORY)
+        .await;
+
+    expect_fetch_started(&mut started_rx, 3).await;
+    assert_eq!(manager.get_remote_models().await, refreshed_models);
+    assert_eq!(endpoint.fetch_count(), 3);
+}
