+    }
+
+    async fn try_load_cache_at_revision(&self, observed_revision: u64) -> bool {
+        let Some(cache_manager) = self.cache_manager.as_ref() else {
+            return false;
+        };
+        let _timer =
+            codex_otel::start_global_timer("codex.remote_models.load_cache.duration_ms", &[]);
+        let client_version = crate::client_version_to_whole();
+        info!(client_version, "models cache: evaluating cache eligibility");
+        // TODO(celia-oai): Include provider identity in cache eligibility so switching
+        // providers does not reuse a fresh models_cache.json entry from another provider.
+        let loaded_cache = {
+            let _cache_io_permit = match self.cache_io_gate.acquire().await {
+                Ok(permit) => permit,
+                Err(err) => {
+                    error!("failed to acquire models cache I/O gate: {err}");
+                    return false;
+                }
+            };
+            cache_manager.load_fresh(&client_version).await
+        };
+        let cache = match loaded_cache {
+            Some(cache) => cache,
+            None => {
+                info!("models cache: no usable cache entry");
+                return false;
+            }
+        };
+        let models_count = cache.models.len();
+        let etag = cache.etag.clone();
+        if !self
+            .apply_cached_models_if_revision_matches(observed_revision, cache)
+            .await
+        {
+            info!("models cache: newer network catalog kept instead of cached models");
+            return true;
+        }
+        info!(
+            models_count,
+            etag = ?etag,
+            "models cache: cache entry applied"
+        );
+        true
+    }
+
+    async fn try_load_any_cache_at_revision(&self, observed_revision: u64) -> bool {
+        let Some(cache_manager) = self.cache_manager.as_ref() else {
+            return false;
+        };
+        let _timer =
+            codex_otel::start_global_timer("codex.remote_models.load_cache.duration_ms", &[]);
+        let client_version = crate::client_version_to_whole();
+        info!(client_version, "models cache: evaluating any cache entry");
+        // TODO(celia-oai): Include provider identity in cache eligibility so switching
+        // providers does not reuse a models_cache.json entry from another provider.
+        let loaded_cache = {
+            let _cache_io_permit = match self.cache_io_gate.acquire().await {
+                Ok(permit) => permit,
+                Err(err) => {
+                    error!("failed to acquire models cache I/O gate: {err}");
+                    return false;
+                }
+            };
+            cache_manager.load_any(&client_version).await
+        };
+        let ModelsCacheLoad {
+            cache,
+            client_version_matches,
+            is_fresh,
+        } = match loaded_cache {
+            Some(cache) => cache,
+            None => {
+                info!("models cache: no readable cache entry");
+                return false;
+            }
+        };
+        let models_count = cache.models.len();
+        let etag = cache.etag.clone();
+        if !self
+            .apply_cached_models_if_revision_matches(observed_revision, cache)
+            .await
+        {
+            info!("models cache: newer network catalog kept instead of cached models");
+            return true;
+        }
+        info!(
+            models_count,
+            etag = ?etag,
+            client_version_matches,
+            is_fresh,
+            "models cache: cache entry applied"
+        );
+        true
+    }
+
+    async fn apply_cached_models_if_revision_matches(
+        &self,
+        observed_revision: u64,
+        cache: ModelsCache,
+    ) -> bool {
+        let merged_models = self.merge_remote_models(cache.models);
+        {
+            let mut catalog = self.catalog.write().await;
+            if catalog.successful_network_revision != observed_revision {
+                return false;
+            }
+            catalog.models = merged_models;
+        }
+        true
+    }
+}
