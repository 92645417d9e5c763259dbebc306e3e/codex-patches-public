+        observed_revision: u64,
+        http_client_factory: HttpClientFactory,
+    ) {
+        let request = BackgroundRefreshRequest {
+            observed_revision,
+            http_client_factory,
+        };
+        let mut state = self
+            .background_refresh
+            .lock()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        if state.running
+            && state
+                .task
+                .as_ref()
+                .is_some_and(AbortOnDropHandle::is_finished)
+        {
+            state.running = false;
+        }
+        if state.running {
+            state.pending = Some(match state.pending.take() {
+                Some(pending) => pending.coalesce(request),
+                None => request,
+            });
+            return;
+        }
+        let request = match state.pending.take() {
+            Some(pending) => pending.coalesce(request),
+            None => request,
+        };
+        state.running = true;
