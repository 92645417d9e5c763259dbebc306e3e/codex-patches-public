+        _client_version: &'a str,
+        _http_client_factory: HttpClientFactory,
+    ) -> ModelsEndpointFuture<'a, CoreResult<(Vec<ModelInfo>, Option<String>)>> {
+        Box::pin(async move {
+            let drop_signal = RequestDropSignal(
+                self.dropped_tx
+                    .lock()
+                    .expect("drop signal lock should not be poisoned")
+                    .take(),
+            );
+            self.started_tx
+                .send(())
+                .expect("test should keep the fetch-start receiver open");
+            let result = std::future::pending().await;
+            drop(drop_signal);
+            result
+        })
+    }
+}
