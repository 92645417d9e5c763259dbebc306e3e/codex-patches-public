+struct PendingModelsEndpoint {
+    started_tx: tokio::sync::mpsc::UnboundedSender<()>,
+    dropped_tx: Mutex<Option<oneshot::Sender<()>>>,
+}
+
+impl std::fmt::Debug for PendingModelsEndpoint {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        f.debug_struct("PendingModelsEndpoint")
+            .finish_non_exhaustive()
+    }
+}
+
+impl PendingModelsEndpoint {
+    fn new() -> (
+        Arc<Self>,
+        tokio::sync::mpsc::UnboundedReceiver<()>,
+        oneshot::Receiver<()>,
+    ) {
+        let (started_tx, started_rx) = tokio::sync::mpsc::unbounded_channel();
+        let (dropped_tx, dropped_rx) = oneshot::channel();
+        (
+            Arc::new(Self {
+                started_tx,
+                dropped_tx: Mutex::new(Some(dropped_tx)),
+            }),
+            started_rx,
+            dropped_rx,
+        )
+    }
+}
+
+struct RequestDropSignal(Option<oneshot::Sender<()>>);
+
+impl Drop for RequestDropSignal {
+    fn drop(&mut self) {
+        if let Some(dropped_tx) = self.0.take() {
+            let _ = dropped_tx.send(());
+        }
+    }
+}
+
+impl ModelsEndpointClient for PendingModelsEndpoint {
+    fn has_command_auth(&self) -> bool {
+        false
+    }
+
+    fn uses_codex_backend(&self) -> ModelsEndpointFuture<'_, bool> {
+        Box::pin(async { true })
+    }
