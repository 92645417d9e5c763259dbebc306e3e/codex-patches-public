+use super::LiveOutputLimiter;
+use super::UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE;
+use super::UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES;
 use super::split_valid_utf8_prefix_with_max;
 
 use pretty_assertions::assert_eq;
@@ -37,3 +40,61 @@ fn split_valid_utf8_prefix_makes_progress_on_invalid_utf8() {
     assert_eq!(first, vec![0xff]);
     assert_eq!(buf, b"ab".to_vec());
 }
+
+#[test]
+fn live_output_limiter_emits_cap_notice_once() {
+    let mut limiter = LiveOutputLimiter::default();
+    let first = vec![b'a'; UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES - 3];
+    assert_eq!(limiter.next_delta(&first), Some(first));
+
+    let capped = limiter
+        .next_delta(b"abcdef")
+        .expect("expected cap notice delta");
+    let mut expected = b"abc".to_vec();
+    expected.extend_from_slice(UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE);
+    assert_eq!(capped, expected);
+    assert_eq!(limiter.next_delta(b"later"), None);
+}
+
+#[test]
+fn live_output_limiter_does_not_split_valid_utf8_at_cap() {
+    let mut limiter = LiveOutputLimiter::default();
+    let first = vec![b'a'; UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES - 1];
+    assert_eq!(limiter.next_delta(&first), Some(first));
+
+    let capped = limiter
+        .next_delta("é".as_bytes())
+        .expect("expected cap notice delta");
+    assert_eq!(capped, UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE);
+    assert!(std::str::from_utf8(&capped).is_ok());
+}
+
+#[test]
+fn live_output_limiter_exact_limit_does_not_emit_cap_notice() {
+    let mut limiter = LiveOutputLimiter::default();
+    let exact = vec![b'a'; UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES];
+
+    let delta = limiter.next_delta(&exact).expect("expected exact delta");
+    assert_eq!(delta.len(), UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES);
+    assert_eq!(delta.first(), Some(&b'a'));
+    assert_eq!(delta.last(), Some(&b'a'));
+    assert!(!limiter.notice_emitted);
+}
+
+#[test]
+fn live_output_limiter_exact_limit_waits_for_nonempty_overflow() {
+    let mut limiter = LiveOutputLimiter::default();
+    let exact = vec![b'a'; UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES];
+
+    let delta = limiter.next_delta(&exact).expect("expected exact delta");
+    assert_eq!(delta.len(), UNIFIED_EXEC_LIVE_OUTPUT_MAX_BYTES);
+    assert_eq!(delta.first(), Some(&b'a'));
+    assert_eq!(delta.last(), Some(&b'a'));
+    assert_eq!(limiter.next_delta(b""), None);
+    assert!(!limiter.notice_emitted);
+    assert_eq!(
+        limiter.next_delta(b"later"),
+        Some(UNIFIED_EXEC_LIVE_OUTPUT_CAP_NOTICE.to_vec())
+    );
+    assert_eq!(limiter.next_delta(b"ignored"), None);
+}
