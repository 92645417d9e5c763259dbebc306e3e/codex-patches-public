+#[cfg(test)]
+mod error_tests {
+    use super::thread_store_io_error;
+    use crate::ThreadStoreError;
+
+    #[test]
+    fn storage_full_io_error_keeps_a_typed_classification() {
+        let err = std::io::Error::from(std::io::ErrorKind::StorageFull);
+
+        assert!(matches!(
+            thread_store_io_error(err),
+            ThreadStoreError::StorageFull { .. }
+        ));
+    }
+
+    #[test]
+    fn unrelated_io_error_stays_internal() {
+        let err = std::io::Error::from(std::io::ErrorKind::PermissionDenied);
+
+        assert!(matches!(
+            thread_store_io_error(err),
+            ThreadStoreError::Internal { .. }
+        ));
     }
