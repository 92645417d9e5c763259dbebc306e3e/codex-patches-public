+async fn wait_for_persistence_incident(session: &Session) {
+    timeout(Duration::from_secs(2), async {
+        while session.active_turn.lock().await.is_some() {
+            tokio::task::yield_now().await;
+        }
+    })
+    .await
+    .expect("persistence incident should reach the session");
+}
+
+fn drain_persistence_failure_events(rx: &async_channel::Receiver<Event>) -> usize {
+    let mut count = 0;
+    while let Ok(event) = rx.try_recv() {
+        if matches!(
+            &event.msg,
+            EventMsg::Error(error)
+                if error.message == crate::persistence_health::persistence_unavailable_message()
+        ) {
+            count += 1;
+        }
+    }
+    count
+}
+
+#[tokio::test]
+async fn storage_full_append_stops_all_registered_sessions_once_without_restarting_pending_work() {
+    let health = crate::persistence_health::PersistenceHealth::new();
+
+    let (mut first, first_context) = make_session_and_context().await;
+    let first_store = attach_in_memory_thread_store(&mut first).await;
+    let (first_tx, first_rx) = async_channel::unbounded();
+    first.tx_event = first_tx;
+    first.services.persistence_health = Arc::clone(&health);
+    let first = Arc::new(first);
+    health.register(&first);
+
+    let (mut second, second_context) = make_session_and_context().await;
+    let second_store = attach_in_memory_thread_store(&mut second).await;
+    let (second_tx, second_rx) = async_channel::unbounded();
+    second.tx_event = second_tx;
+    second.services.persistence_health = Arc::clone(&health);
+    let second = Arc::new(second);
+    health.register(&second);
+
+    first
+        .spawn_task(
+            Arc::new(first_context),
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+    second
+        .spawn_task(
+            Arc::new(second_context),
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+    first
+        .input_queue
+        .enqueue_mailbox_communication(InterAgentCommunication::new(
+            AgentPath::root(),
+            AgentPath::root(),
+            Vec::new(),
+            "pending trigger".to_string(),
+            /*trigger_turn*/ true,
+        ))
+        .await;
+
+    first_store.fail_appends_with_storage_full().await;
+    second_store.fail_appends_with_storage_full().await;
+    let item = RolloutItem::EventMsg(EventMsg::Warning(WarningEvent {
+        message: "persist me".to_string(),
+    }));
+    tokio::join!(
+        first.persist_rollout_items(std::slice::from_ref(&item)),
+        second.persist_rollout_items(std::slice::from_ref(&item)),
+    );
+
+    wait_for_persistence_incident(&first).await;
+    wait_for_persistence_incident(&second).await;
+    assert!(health.is_failed());
+    assert!(first.active_turn.lock().await.is_none());
+    assert!(second.active_turn.lock().await.is_none());
+    assert!(first.input_queue.has_trigger_turn_mailbox_items().await);
+
+    let first_append_calls = first_store.calls().await.append_items;
+    let second_append_calls = second_store.calls().await.append_items;
+    assert_eq!(first_append_calls + second_append_calls, 1);
+
+    health.trip();
+    first
+        .persist_rollout_items(std::slice::from_ref(&item))
+        .await;
+    second
+        .persist_rollout_items(std::slice::from_ref(&item))
+        .await;
+    tokio::task::yield_now().await;
+
+    assert_eq!(first_store.calls().await.append_items, first_append_calls);
+    assert_eq!(second_store.calls().await.append_items, second_append_calls);
+    let first_fatal_count = drain_persistence_failure_events(&first_rx);
+    let second_fatal_count = drain_persistence_failure_events(&second_rx);
+    assert_eq!(first_fatal_count, 1);
+    assert_eq!(second_fatal_count, 1);
+
+    let rejected_context = first.new_default_turn().await;
+    first
+        .start_task(
+            rejected_context,
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+    assert!(first.active_turn.lock().await.is_none());
+    assert_eq!(drain_persistence_failure_events(&first_rx), 1);
+}
