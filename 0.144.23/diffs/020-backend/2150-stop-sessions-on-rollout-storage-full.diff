+async fn unrelated_thread_store_error_does_not_trip_global_persistence_health() {
+    let health = crate::persistence_health::PersistenceHealth::new();
+    let (mut session, context) = make_session_and_context().await;
+    let store = attach_in_memory_thread_store(&mut session).await;
+    session.services.persistence_health = Arc::clone(&health);
+    let session = Arc::new(session);
+    health.register(&session);
+    session
+        .spawn_task(
+            Arc::new(context),
+            Vec::new(),
+            NeverEndingTask {
+                kind: TaskKind::Regular,
+                listen_to_cancellation_token: true,
+            },
+        )
+        .await;
+
+    store.fail_appends_with_internal_error().await;
+    session
+        .persist_rollout_items(&[RolloutItem::EventMsg(EventMsg::Warning(WarningEvent {
+            message: "ordinary failure".to_string(),
+        }))])
+        .await;
+
+    assert!(!health.is_failed());
+    assert!(session.active_turn.lock().await.is_some());
+    assert_eq!(store.calls().await.append_items, 1);
+    session.abort_all_tasks(TurnAbortReason::Replaced).await;
+}
