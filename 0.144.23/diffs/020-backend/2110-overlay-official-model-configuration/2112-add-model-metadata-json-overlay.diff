+#[tokio::test]
+async fn models_overlay_precedes_markdown_and_does_not_mutate_official_cache() {
+    let codex_home = tempdir().expect("temp dir");
+    write_models_overlay(
+        codex_home.path(),
+        json!({
+            "models": [{
+                "slug": "overlay-order",
+                "context_window": 372000,
+                "max_context_window": 372000,
+                "supported_reasoning_levels": [
+                    {"effort": "high", "description": "High"}
+                ]
+            }]
+        }),
+    );
+    write_instructions_overlay(codex_home.path(), "overlay-order", "Markdown instructions");
+    let official = remote_model_with_prompt("overlay-order", "official instructions");
+    let endpoint = TestModelsEndpoint::new(vec![vec![official.clone()]]);
+    let manager = openai_manager_for_tests(codex_home.path().to_path_buf(), endpoint);
+
+    let catalog = manager
+        .raw_model_catalog(RefreshStrategy::Online, DEFAULT_HTTP_CLIENT_FACTORY)
+        .await;
+    let overlaid = catalog
+        .models
+        .iter()
+        .find(|model| model.slug == "overlay-order")
+        .expect("overlaid model should remain visible");
+    assert_eq!(overlaid.context_window, Some(372_000));
+    assert_eq!(overlaid.max_context_window, Some(372_000));
+    assert_eq!(overlaid.supported_reasoning_levels.len(), 1);
+    assert_eq!(
+        overlaid
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("official instructions")
+    );
+
+    let selected = manager
+        .get_model_info(
+            "overlay-order",
+            &ModelsManagerConfig {
+                personality_enabled: true,
+                ..Default::default()
+            },
+        )
+        .await;
+    assert_eq!(selected.context_window, Some(372_000));
+    assert_eq!(
+        selected
+            .model_messages
+            .as_ref()
+            .and_then(|messages| messages.instructions_template.as_deref()),
+        Some("Markdown instructions")
+    );
+
+    let persisted: serde_json::Value = serde_json::from_slice(
+        &std::fs::read(codex_home.path().join(MODEL_CACHE_FILE))
+            .expect("official cache should be persisted"),
+    )
+    .expect("official cache should parse");
+    let cached = persisted["models"]
+        .as_array()
+        .and_then(|models| models.iter().find(|model| model["slug"] == "overlay-order"))
+        .expect("official model should be cached");
+    assert_eq!(cached["context_window"], json!(272_000));
+    assert_eq!(
+        cached["model_messages"]["instructions_template"],
+        json!("official instructions")
+    );
+
+    let cached_manager = openai_manager_for_tests(
+        codex_home.path().to_path_buf(),
+        TestModelsEndpoint::new(Vec::new()),
+    );
+    let cached_catalog = cached_manager
+        .raw_model_catalog(RefreshStrategy::Offline, DEFAULT_HTTP_CLIENT_FACTORY)
+        .await;
+    let cached_overlaid = cached_catalog
+        .models
+        .iter()
+        .find(|model| model.slug == "overlay-order")
+        .expect("cached model should receive the local overlay");
+    assert_eq!(cached_overlaid.context_window, Some(372_000));
+}
