+use codex_protocol::openai_models::ModelInfo;
+use serde::Deserialize;
+use serde_json::Map;
+use serde_json::Value;
+use std::collections::BTreeSet;
+use std::fs;
+use std::io::ErrorKind;
+use std::path::Path;
+use std::path::PathBuf;
+use tracing::warn;
+
+const MODELS_OVERLAY_FILE: &str = "models_overlay.json";
+
+#[derive(Debug, Deserialize)]
+#[serde(deny_unknown_fields)]
+struct ModelsOverlay {
+    #[serde(default)]
+    models: Vec<OfficialModelOverlay>,
+}
+
+#[derive(Debug, Deserialize)]
+struct OfficialModelOverlay {
+    slug: String,
+    #[serde(default = "default_enabled")]
+    enabled: bool,
+    #[serde(flatten)]
+    fields: Map<String, Value>,
+}
+
+const fn default_enabled() -> bool {
+    true
+}
+
+pub(crate) fn path(codex_home: &Path) -> PathBuf {
+    codex_home.join(MODELS_OVERLAY_FILE)
+}
+
+pub(crate) fn apply_to_official_models(path: &Path, models: Vec<ModelInfo>) -> Vec<ModelInfo> {
+    let contents = match fs::read_to_string(path) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == ErrorKind::NotFound => return models,
+        Err(err) => {
+            warn!(
+                path = %path.display(),
+                "failed to load models overlay: {err}"
+            );
+            return models;
+        }
+    };
+    let overlay = match serde_json::from_str::<ModelsOverlay>(&contents) {
+        Ok(overlay) => overlay,
+        Err(err) => {
+            warn!(
+                path = %path.display(),
+                "failed to parse models overlay: {err}"
+            );
+            return models;
+        }
+    };
+
+    let mut seen = BTreeSet::new();
+    if let Some(duplicate) = overlay
+        .models
+        .iter()
+        .map(|model| model.slug.as_str())
+        .find(|slug| !seen.insert(*slug))
+    {
+        warn!(
+            path = %path.display(),
+            model = duplicate,
+            "models overlay contains a duplicate slug"
+        );
+        return models;
+    }
+
+    apply_entries(path, models, overlay.models)
+}
+
+fn apply_entries(
+    path: &Path,
+    mut models: Vec<ModelInfo>,
+    overlays: Vec<OfficialModelOverlay>,
+) -> Vec<ModelInfo> {
+    for overlay in overlays {
+        let Some(index) = models.iter().position(|model| model.slug == overlay.slug) else {
+            warn!(
+                path = %path.display(),
+                model = overlay.slug,
+                "models overlay target is not present in the official catalog"
+            );
+            continue;
+        };
+        if !overlay.enabled {
+            models.remove(index);
+            continue;
+        }
+        if overlay.fields.is_empty() {
+            continue;
+        }
+        if overlay.fields.contains_key("base_instructions")
+            || overlay.fields.contains_key("model_messages")
+        {
+            warn!(
+                model = overlay.slug,
+                "models overlay cannot replace instruction content; use the per-model Markdown overlay"
+            );
+            continue;
+        }
+
+        let original = models[index].clone();
+        let mut value = match serde_json::to_value(&original) {
+            Ok(value) => value,
+            Err(err) => {
+                warn!(
+                    model = overlay.slug,
+                    "failed to prepare models overlay: {err}"
+                );
+                continue;
+            }
+        };
+        let Some(object) = value.as_object_mut() else {
+            warn!(
+                model = overlay.slug,
+                "models overlay target is not an object"
+            );
+            continue;
+        };
+        merge_object(object, &overlay.fields);
+        let patched = match serde_json::from_value::<ModelInfo>(value) {
+            Ok(patched) => patched,
+            Err(err) => {
+                warn!(model = overlay.slug, "invalid models overlay: {err}");
+                continue;
+            }
+        };
+        if patched.slug != original.slug || !patch_is_reflected(&overlay.fields, &patched) {
+            warn!(
+                model = overlay.slug,
+                "models overlay contains an unknown or non-round-tripping field"
+            );
+            continue;
+        }
+        models[index] = patched;
+    }
+    models
+}
+
+fn merge_object(target: &mut Map<String, Value>, patch: &Map<String, Value>) {
+    for (key, patch_value) in patch {
+        match (target.get_mut(key), patch_value) {
+            (Some(Value::Object(target)), Value::Object(patch)) => merge_object(target, patch),
+            _ => {
+                target.insert(key.clone(), patch_value.clone());
+            }
+        }
+    }
+}
+
+fn patch_is_reflected(patch: &Map<String, Value>, model: &ModelInfo) -> bool {
+    let Ok(Value::Object(actual)) = serde_json::to_value(model) else {
+        return false;
+    };
+    patch.iter().all(|(key, expected)| {
+        expected.is_null()
+            || actual
+                .get(key)
+                .is_some_and(|actual| value_is_reflected(expected, actual))
+    })
+}
+
+fn value_is_reflected(expected: &Value, actual: &Value) -> bool {
+    match expected {
+        Value::Null => true,
+        Value::Object(expected) => actual.as_object().is_some_and(|actual| {
+            expected.iter().all(|(key, expected)| {
+                expected.is_null()
+                    || actual
+                        .get(key)
+                        .is_some_and(|actual| value_is_reflected(expected, actual))
+            })
+        }),
+        _ => expected == actual,
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use serde_json::json;
+    use tempfile::tempdir;
+
+    fn bundled_model(slug: &str) -> ModelInfo {
+        crate::bundled_models_response()
+            .expect("bundled catalog should parse")
+            .models
+            .into_iter()
+            .find(|model| model.slug == slug)
+            .expect("bundled model should exist")
+    }
+
+    fn write_overlay(path: &Path, document: Value) {
+        fs::create_dir_all(path.parent().expect("overlay path should have a parent"))
+            .expect("create overlay directory");
+        fs::write(
+            path,
+            serde_json::to_vec_pretty(&document).expect("serialize overlay"),
+        )
+        .expect("write overlay");
+    }
+
+    #[test]
+    fn partial_overlay_replaces_context_and_reasoning_levels_only() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({
+                "models": [{
+                    "slug": "gpt-5.6-sol",
+                    "context_window": 372000,
+                    "max_context_window": 372000,
+                    "supported_reasoning_levels": [
+                        {"effort": "high", "description": "High"}
+                    ]
+                }]
+            }),
+        );
+        let mut official = bundled_model("gpt-5.6-sol");
+        official.context_window = Some(272_000);
+        official.max_context_window = Some(272_000);
+        let display_name = official.display_name.clone();
+
+        let models = apply_to_official_models(&overlay_path, vec![official]);
+
+        assert_eq!(models[0].context_window, Some(372_000));
+        assert_eq!(models[0].max_context_window, Some(372_000));
+        assert_eq!(models[0].display_name, display_name);
+        assert_eq!(models[0].supported_reasoning_levels.len(), 1);
+        assert_eq!(
+            models[0].supported_reasoning_levels[0].effort.to_string(),
+            "high"
+        );
+    }
+
+    #[test]
+    fn disabled_overlay_removes_model_from_active_catalog() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({"models": [{"slug": "gpt-5.4", "enabled": false}]}),
+        );
+
+        let models = apply_to_official_models(
+            &overlay_path,
+            vec![bundled_model("gpt-5.4"), bundled_model("gpt-5.6-sol")],
+        );
+
+        assert_eq!(models.len(), 1);
+        assert_eq!(models[0].slug, "gpt-5.6-sol");
+    }
+
+    #[test]
+    fn overlay_controls_automatic_limit_retry() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({"models": [{
+                "slug": "gpt-5.6-sol",
+                "automatic_limit_retry": false
+            }]}),
+        );
+
+        let models = apply_to_official_models(&overlay_path, vec![bundled_model("gpt-5.6-sol")]);
+
+        assert!(!models[0].automatic_limit_retry);
+    }
+
+    #[test]
+    fn unknown_field_rejects_only_its_model_overlay() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({
+                "models": [{
+                    "slug": "gpt-5.6-sol",
+                    "context_window": 372000,
+                    "unknown_field": true
+                }]
+            }),
+        );
+        let mut official = bundled_model("gpt-5.6-sol");
+        official.context_window = Some(272_000);
+
+        let models = apply_to_official_models(&overlay_path, vec![official]);
+
+        assert_eq!(models[0].context_window, Some(272_000));
+    }
+
+    #[test]
+    fn instruction_content_is_owned_only_by_markdown_overlay() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({
+                "models": [{
+                    "slug": "gpt-5.6-sol",
+                    "context_window": 272000,
+                    "base_instructions": "must not apply"
+                }]
+            }),
+        );
+        let official = bundled_model("gpt-5.6-sol");
+        let expected_context_window = official.context_window;
+        let expected_instructions = official.base_instructions.clone();
+
+        let models = apply_to_official_models(&overlay_path, vec![official]);
+
+        assert_eq!(models[0].context_window, expected_context_window);
+        assert_eq!(models[0].base_instructions, expected_instructions);
+    }
+
+    #[test]
+    fn duplicate_slug_rejects_the_overlay_document() {
+        let codex_home = tempdir().expect("temp dir");
+        let overlay_path = path(codex_home.path());
+        write_overlay(
+            &overlay_path,
+            json!({
+                "models": [
+                    {"slug": "gpt-5.6-sol", "context_window": 372000},
+                    {"slug": "gpt-5.6-sol", "enabled": false}
+                ]
+            }),
+        );
+        let mut official = bundled_model("gpt-5.6-sol");
+        official.context_window = Some(272_000);
+
+        let models = apply_to_official_models(&overlay_path, vec![official]);
+
+        assert_eq!(models.len(), 1);
+        assert_eq!(models[0].context_window, Some(272_000));
+    }
+}
