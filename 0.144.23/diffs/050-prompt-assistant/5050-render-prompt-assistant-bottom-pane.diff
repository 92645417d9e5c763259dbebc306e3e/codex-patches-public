+        }
+        view.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        assert_eq!(
+            rx.recv().expect("refine"),
+            PromptAssistantViewAction::Refine {
+                context: context(1),
+                instruction: "add a constraint".to_string(),
+            }
+        );
+        assert!(handle.complete_operation(&context(1), context(2), candidate("refined")));
+
+        view.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        assert_eq!(
+            rx.recv().expect("apply"),
+            PromptAssistantViewAction::Apply {
+                context: context(2),
+                candidate_hash: "sha256:candidate".to_string(),
+                candidate: "refined".to_string(),
+            }
+        );
+        assert!(!view.is_complete());
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Applying);
+    }
