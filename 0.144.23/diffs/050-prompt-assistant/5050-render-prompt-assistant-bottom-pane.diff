+    fn view(
+        original: &str,
+    ) -> (
+        PromptAssistantView,
+        PromptAssistantViewHandle,
+        mpsc::Receiver<PromptAssistantViewAction>,
+    ) {
+        let (tx, rx) = mpsc::channel();
+        let view = PromptAssistantView::new(
+            original.to_string(),
+            context(1),
+            "translate",
+            move |action| tx.send(action).expect("receive Prompt Assistant action"),
+        );
+        let handle = view.handle();
+        (view, handle, rx)
+    }
