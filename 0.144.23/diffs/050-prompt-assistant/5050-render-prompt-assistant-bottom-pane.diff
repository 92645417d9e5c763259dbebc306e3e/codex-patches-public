+    fn failed_apply_returns_to_ready_and_can_retry_the_same_candidate() {
+        let (mut view, handle, rx) = view("initial");
+        view.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        let _ = rx.recv().expect("choose model");
+        assert!(handle.begin_initial_operation(&context(0), "translate (hidden)"));
+        assert!(handle.complete_operation(&context(0), context(1), candidate("candidate")));
+
+        view.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        let apply = rx.recv().expect("initial apply");
+        assert!(handle.set_failed(&context(1), "temporary apply failure"));
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Ready);
+
+        view.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        assert_eq!(rx.recv().expect("retried apply"), apply);
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Applying);
+    }
