+    fn candidate(text: impl Into<String>) -> PromptAssistantCandidate {
+        PromptAssistantCandidate {
+            text: text.into(),
+            hash: "sha256:candidate".to_string(),
+            apply_allowed: true,
+            review_summary: Some("Review passed".to_string()),
+        }
+    }
