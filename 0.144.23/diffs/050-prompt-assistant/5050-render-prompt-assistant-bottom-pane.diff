+    #[test]
+    fn active_elapsed_time_uses_the_current_operation_start() {
+        let started = Instant::now();
+        let (tx, _rx) = mpsc::channel();
+        let view = PromptAssistantView::new_at(
+            composer("draft"),
+            context(0),
+            "translate",
+            move |action| tx.send(action).expect("send action"),
+            started,
+        );
+        let handle = view.handle();
+        {
+            let mut model = lock_model(&handle.model);
+            model.phase = PromptAssistantViewPhase::Running;
+        }
+        handle.observe_at(started + Duration::from_millis(1_500));
+        assert!(
+            header_line(&lock_model(&handle.model))
+                .to_string()
+                .contains("1.5s")
+        );
+    }
