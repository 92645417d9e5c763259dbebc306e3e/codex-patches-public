+    #[test]
+    fn structured_review_and_candidate_render_with_the_input_composer() {
+        let (view, handle, _rx) = view("draft");
+        {
+            let mut model = lock_model(&handle.model);
+            model.phase = PromptAssistantViewPhase::Running;
+        }
+        assert!(handle.complete_operation(&context(0), context(1), candidate("candidate")));
+        let width = 160;
+        let height = view.desired_height(width);
+        let area = Rect::new(0, 0, width, height);
+        let mut buffer = Buffer::empty(area);
+        view.render(area, &mut buffer);
+        let rendered = (0..height)
+            .map(|y| {
+                (0..width)
+                    .map(|x| buffer[(x, y)].symbol())
+                    .collect::<String>()
+            })
+            .collect::<Vec<_>>()
+            .join("\n");
+        assert!(rendered.contains("Review: Pass"));
+        assert!(rendered.contains("risk low"));
+        assert!(rendered.contains("authorization high"));
+        assert!(rendered.contains("Intent: Preserve the requested task."));
+        assert!(rendered.contains("Rationale: Intent preserved."));
+        assert!(rendered.contains("candidate"));
+        assert!(rendered.contains("Enter refine"));
+    }
