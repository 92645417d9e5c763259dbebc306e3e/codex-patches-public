+use super::bottom_pane_view::BottomPaneView;
+use super::bottom_pane_view::ViewCompletion;
+
+pub(crate) const PROMPT_ASSISTANT_VIEW_ID: &str = "prompt-assistant";
+
+const MAX_PREVIEW_ROWS: usize = 8;
+const MAX_PREVIEW_CHARS: usize = 32 * 1024;
+const MAX_WRAPPED_PREVIEW_ROWS: usize = 2 * 1024;
+const MAX_REVIEW_FIELD_ROWS: usize = 2;
+const ACTIVE_FRAME_INTERVAL: Duration = Duration::from_millis(250);
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct PromptAssistantActionContext {
+    pub(crate) workspace_id: String,
+    pub(crate) operation_generation: u64,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct PromptAssistantCandidate {
+    pub(crate) text: String,
+    pub(crate) hash: String,
+    pub(crate) apply_allowed: bool,
+    pub(crate) review: Option<PromptAssistantReview>,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) enum PromptAssistantViewAction {
+    ChooseModel {
+        context: PromptAssistantActionContext,
+        input: String,
+    },
+    Apply {
+        context: PromptAssistantActionContext,
+        candidate_hash: String,
+        candidate: String,
+    },
+    Copy {
+        candidate: String,
+    },
+    Refine {
+        context: PromptAssistantActionContext,
+        instruction: String,
+    },
+    Cancel {
+        context: PromptAssistantActionContext,
+    },
+    Restore,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub(crate) enum PromptAssistantViewPhase {
+    EditingInitial,
+    SelectingModel,
+    Running,
+    Ready,
+    Applying,
+    Cancelling,
+    Failed,
+}
+
+type ActionCallback = Arc<dyn Fn(PromptAssistantViewAction) + Send + Sync>;
+
+#[derive(Clone)]
+struct PromptAssistantViewModel {
+    phase: PromptAssistantViewPhase,
+    context: PromptAssistantActionContext,
+    operation_label: String,
+    candidate: Option<PromptAssistantCandidate>,
+    candidate_revision: u64,
+    error: Option<String>,
+    started_at: Instant,
+    observed_at: Instant,
+    response_bytes: u64,
+    apply_requested: bool,
+    completion: Option<ViewCompletion>,
+    pending_input: Option<String>,
+}
+
+#[derive(Clone)]
+pub(crate) struct PromptAssistantViewHandle {
+    model: Arc<Mutex<PromptAssistantViewModel>>,
+}
+
+impl PromptAssistantViewHandle {
+    pub(crate) fn begin_initial_operation(
+        &self,
+        expected_context: &PromptAssistantActionContext,
+        operation_label: impl Into<String>,
+    ) -> bool {
+        let mut model = lock_model(&self.model);
+        if model.context != *expected_context
+            || model.phase != PromptAssistantViewPhase::SelectingModel
+            || model.completion.is_some()
+        {
+            return false;
+        }
+        let now = Instant::now();
+        model.phase = PromptAssistantViewPhase::Running;
+        model.operation_label = operation_label.into();
+        model.started_at = now;
+        model.observed_at = now;
+        model.response_bytes = 0;
+        model.error = None;
+        true
+    }
+
+    /// Atomically finish one request and install the generation returned by the server.
+    pub(crate) fn complete_operation(
+        &self,
+        expected_context: &PromptAssistantActionContext,
+        returned_context: PromptAssistantActionContext,
+        candidate: PromptAssistantCandidate,
+    ) -> bool {
+        self.complete_operation_at(
+            expected_context,
+            returned_context,
+            candidate,
+            Instant::now(),
+        )
+    }
+
+    fn complete_operation_at(
+        &self,
+        expected_context: &PromptAssistantActionContext,
+        returned_context: PromptAssistantActionContext,
+        candidate: PromptAssistantCandidate,
+        now: Instant,
+    ) -> bool {
+        let mut model = lock_model(&self.model);
+        if model.context != *expected_context
+            || model.phase != PromptAssistantViewPhase::Running
+            || model.completion.is_some()
+        {
+            return false;
+        }
+        if candidate.apply_allowed {
+            model.pending_input = None;
+        }
+        model.phase = PromptAssistantViewPhase::Ready;
+        model.context = returned_context;
+        model.candidate = Some(candidate);
+        model.candidate_revision = model.candidate_revision.saturating_add(1);
+        model.error = None;
+        model.observed_at = now;
+        model.apply_requested = false;
+        true
+    }
+
+    pub(crate) fn set_failed(
+        &self,
+        context: &PromptAssistantActionContext,
+        error: impl Into<String>,
+    ) -> bool {
+        let mut model = lock_model(&self.model);
+        let may_fail = matches!(
+            model.phase,
+            PromptAssistantViewPhase::Running
+                | PromptAssistantViewPhase::Applying
+                | PromptAssistantViewPhase::Cancelling
+        );
+        if model.context != *context || !may_fail || model.completion.is_some() {
+            return false;
+        }
+        model.phase = if model.phase == PromptAssistantViewPhase::Applying {
+            PromptAssistantViewPhase::Ready
+        } else {
+            PromptAssistantViewPhase::Failed
+        };
+        model.error = Some(error.into());
+        model.observed_at = Instant::now();
+        model.apply_requested = false;
+        true
+    }
+
+    /// Replace request byte progress without coupling it to any other metric lifecycle.
+    pub(crate) fn set_response_bytes(
+        &self,
+        context: &PromptAssistantActionContext,
+        response_bytes: u64,
+    ) -> bool {
+        let mut model = lock_model(&self.model);
+        if model.context != *context
+            || model.phase != PromptAssistantViewPhase::Running
+            || model.completion.is_some()
+        {
+            return false;
+        }
+        model.response_bytes = response_bytes;
+        true
+    }
+
+    pub(crate) fn finish_applied(&self, context: &PromptAssistantActionContext) -> bool {
+        let mut model = lock_model(&self.model);
+        if model.context != *context
+            || model.phase != PromptAssistantViewPhase::Applying
+            || !model.apply_requested
+            || model.completion.is_some()
+        {
+            return false;
+        }
+        model.completion = Some(ViewCompletion::Accepted);
+        true
+    }
+
+    pub(crate) fn finish_cancelled(&self, context: &PromptAssistantActionContext) -> bool {
+        let mut model = lock_model(&self.model);
+        if model.context != *context
+            || model.phase != PromptAssistantViewPhase::Cancelling
+            || model.completion.is_some()
+        {
+            return false;
+        }
+        model.completion = Some(ViewCompletion::Cancelled);
+        true
+    }
+
+    #[cfg(test)]
+    fn phase(&self) -> PromptAssistantViewPhase {
+        lock_model(&self.model).phase
+    }
+
+    #[cfg(test)]
+    fn context(&self) -> PromptAssistantActionContext {
+        lock_model(&self.model).context.clone()
+    }
+
+    #[cfg(test)]
+    fn observe_at(&self, now: Instant) {
+        lock_model(&self.model).observed_at = now;
+    }
+
+    pub(crate) fn is_cancelling(&self) -> bool {
+        lock_model(&self.model).phase == PromptAssistantViewPhase::Cancelling
+    }
+}
+
+#[derive(Default)]
+struct PreviewViewport {
+    candidate_revision: u64,
+    width: u16,
+    lines: Vec<Line<'static>>,
+    top: usize,
+    visible_rows: usize,
+    follow_tail: bool,
+}
+
+impl PreviewViewport {
+    fn sync(
+        &mut self,
+        candidate_revision: u64,
+        candidate: Option<&PromptAssistantCandidate>,
+        width: u16,
+        visible_rows: usize,
+    ) {
+        let needs_rebuild = self.candidate_revision != candidate_revision || self.width != width;
+        if needs_rebuild {
+            self.lines = candidate
+                .map(|candidate| wrapped_preview_lines(&candidate.text, width))
+                .unwrap_or_default();
+            self.candidate_revision = candidate_revision;
+            self.width = width;
+        }
+        self.visible_rows = visible_rows;
+        let max_top = self.lines.len().saturating_sub(visible_rows);
+        if self.follow_tail || needs_rebuild && self.top > max_top {
+            self.top = max_top;
+        } else {
+            self.top = self.top.min(max_top);
+        }
+    }
+
+    fn scroll_up(&mut self, rows: usize) {
+        self.top = self.top.saturating_sub(rows.max(1));
+        self.follow_tail = false;
+    }
+
+    fn scroll_down(&mut self, rows: usize) {
+        let max_top = self.lines.len().saturating_sub(self.visible_rows);
+        self.top = self.top.saturating_add(rows.max(1)).min(max_top);
+        self.follow_tail = self.top == max_top;
+    }
+}
+
+pub(crate) struct PromptAssistantView {
+    composer: ChatComposer,
+    model: Arc<Mutex<PromptAssistantViewModel>>,
+    on_action: ActionCallback,
+    preview: RefCell<PreviewViewport>,
+}
+
+impl PromptAssistantView {
+    pub(crate) fn new(
+        composer: ChatComposer,
+        context: PromptAssistantActionContext,
+        operation_label: impl Into<String>,
+        on_action: impl Fn(PromptAssistantViewAction) + Send + Sync + 'static,
+    ) -> Self {
+        Self::new_at(
+            composer,
+            context,
+            operation_label,
+            on_action,
+            Instant::now(),
+        )
+    }
+
+    fn new_at(
+        composer: ChatComposer,
+        context: PromptAssistantActionContext,
+        operation_label: impl Into<String>,
+        on_action: impl Fn(PromptAssistantViewAction) + Send + Sync + 'static,
+        now: Instant,
+    ) -> Self {
+        Self {
+            composer,
+            model: Arc::new(Mutex::new(PromptAssistantViewModel {
+                phase: PromptAssistantViewPhase::EditingInitial,
+                context,
+                operation_label: operation_label.into(),
+                candidate: None,
+                candidate_revision: 0,
+                error: None,
+                started_at: now,
+                observed_at: now,
+                response_bytes: 0,
+                apply_requested: false,
+                completion: None,
+                pending_input: None,
+            })),
+            on_action: Arc::new(on_action),
+            preview: RefCell::new(PreviewViewport {
+                follow_tail: true,
+                ..PreviewViewport::default()
+            }),
+        }
+    }
+
+    pub(crate) fn handle(&self) -> PromptAssistantViewHandle {
+        PromptAssistantViewHandle {
+            model: Arc::clone(&self.model),
+        }
+    }
+
+    fn emit(&self, action: PromptAssistantViewAction) {
+        (self.on_action)(action);
+    }
+
+    fn input_is_editable(phase: PromptAssistantViewPhase) -> bool {
+        matches!(
+            phase,
+            PromptAssistantViewPhase::EditingInitial
+                | PromptAssistantViewPhase::Ready
+                | PromptAssistantViewPhase::Failed
+        )
+    }
+
+    fn handle_composer_result(&mut self, result: InputResult) {
+        let InputResult::Submitted { text, .. } = result else {
+            return;
+        };
+        if text.trim().is_empty() {
+            return;
+        }
+        let action = {
+            let mut model = lock_model(&self.model);
+            if model.completion.is_some() {
+                return;
+            }
+            model.pending_input = Some(text.clone());
+            model.error = None;
+            model.response_bytes = 0;
+            match model.phase {
+                PromptAssistantViewPhase::EditingInitial | PromptAssistantViewPhase::Failed
+                    if model.context.operation_generation == 0 =>
+                {
+                    model.phase = PromptAssistantViewPhase::SelectingModel;
+                    PromptAssistantViewAction::ChooseModel {
+                        context: model.context.clone(),
+                        input: text,
+                    }
+                }
+                PromptAssistantViewPhase::Ready | PromptAssistantViewPhase::Failed => {
+                    let now = Instant::now();
+                    model.phase = PromptAssistantViewPhase::Running;
+                    model.operation_label = "refine".to_string();
+                    model.started_at = now;
+                    model.observed_at = now;
+                    model.apply_requested = false;
+                    PromptAssistantViewAction::Refine {
+                        context: model.context.clone(),
+                        instruction: text,
+                    }
+                }
+                _ => return,
+            }
+        };
+        self.emit(action);
+    }
+
+    fn request_apply(&mut self) {
+        let action = {
+            let mut model = lock_model(&self.model);
+            if model.phase != PromptAssistantViewPhase::Ready
+                || model.apply_requested
+                || model.completion.is_some()
+            {
+                return;
+            }
+            let Some(candidate) = model.candidate.as_ref() else {
+                return;
+            };
+            if !candidate.apply_allowed {
+                return;
+            }
+            let action = PromptAssistantViewAction::Apply {
+                context: model.context.clone(),
+                candidate_hash: candidate.hash.clone(),
+                candidate: candidate.text.clone(),
+            };
+            model.apply_requested = true;
+            model.phase = PromptAssistantViewPhase::Applying;
+            model.operation_label = "apply".to_string();
+            action
+        };
+        self.emit(action);
+    }
+
+    fn request_copy(&self) {
+        let action = lock_model(&self.model).candidate.as_ref().map(|candidate| {
+            PromptAssistantViewAction::Copy {
+                candidate: candidate.text.clone(),
+            }
+        });
+        if let Some(action) = action {
+            self.emit(action);
+        }
+    }
+
+    fn cancel_or_restore(&mut self) {
+        let action = {
+            let mut model = lock_model(&self.model);
+            if model.completion.is_some() {
+                return;
+            }
+            match model.phase {
+                PromptAssistantViewPhase::Running => {
+                    model.phase = PromptAssistantViewPhase::Cancelling;
+                    Some(PromptAssistantViewAction::Cancel {
+                        context: model.context.clone(),
+                    })
+                }
+                PromptAssistantViewPhase::Applying | PromptAssistantViewPhase::Cancelling => None,
+                PromptAssistantViewPhase::EditingInitial
+                | PromptAssistantViewPhase::SelectingModel
+                | PromptAssistantViewPhase::Ready
+                | PromptAssistantViewPhase::Failed => {
+                    model.completion = Some(ViewCompletion::Cancelled);
+                    Some(PromptAssistantViewAction::Restore)
+                }
+            }
+        };
+        if let Some(action) = action {
+            self.emit(action);
+        }
+    }
+
+    fn restore_pending_input(&mut self) -> bool {
+        let pending = {
+            let mut model = lock_model(&self.model);
+            let should_restore = model.phase == PromptAssistantViewPhase::Failed
+                || model.phase == PromptAssistantViewPhase::Ready
+                    && model
+                        .candidate
+                        .as_ref()
+                        .is_none_or(|candidate| !candidate.apply_allowed);
+            should_restore.then(|| model.pending_input.take()).flatten()
+        };
+        let Some(pending) = pending else {
+            return false;
+        };
+        if self.composer.current_text_with_pending().is_empty() {
+            self.composer.apply_external_edit(pending);
+            true
+        } else {
+            false
+        }
+    }
+
+    fn scroll_preview(&self, up: bool) {
+        let mut preview = self.preview.borrow_mut();
+        let rows = preview.visible_rows.max(1);
+        if up {
+            preview.scroll_up(rows);
+        } else {
+            preview.scroll_down(rows);
+        }
+    }
+
+    fn sync_preview(&self, model: &PromptAssistantViewModel, width: u16, visible_rows: usize) {
+        self.preview.borrow_mut().sync(
+            model.candidate_revision,
+            model.candidate.as_ref(),
+            width.max(1),
+            visible_rows,
+        );
+    }
+
+    fn review_lines(&self, model: &PromptAssistantViewModel, width: u16) -> Vec<Line<'static>> {
+        if let Some(error) = &model.error {
+            return vec![Line::from(vec!["  ".into(), error.clone().red()])];
+        }
+        let Some(candidate) = &model.candidate else {
+            let status = match model.phase {
+                PromptAssistantViewPhase::EditingInitial => "Edit the prompt, then press Enter",
+                PromptAssistantViewPhase::SelectingModel => "Choose a hidden functional model",
+                PromptAssistantViewPhase::Running => "Generating and reviewing the candidate",
+                PromptAssistantViewPhase::Applying => "Applying prompt candidate",
+                PromptAssistantViewPhase::Cancelling => "Waiting for cancellation",
+                PromptAssistantViewPhase::Failed => "Prompt Assistant failed",
+                PromptAssistantViewPhase::Ready => "Candidate ready",
+            };
+            return vec![Line::from(vec!["  ".into(), status.dim()])];
+        };
+        let Some(review) = candidate.review.as_ref() else {
+            return vec![Line::from(vec![
+                "  Review: ".into(),
+                "missing; apply disabled".red(),
+            ])];
+        };
+
+        let mut lines = vec![Line::from(vec![
+            "  Review: ".into(),
+            review_status_label(review.status),
+            " ▪ risk ".dim(),
+            risk_label(review.risk_level),
+            " ▪ authorization ".dim(),
+            authorization_label(review.user_authorization),
+        ])];
+        lines.extend(wrapped_review_field(
+            "Intent",
+            &review.intent_summary,
+            width,
+        ));
+        lines.extend(wrapped_review_field("Rationale", &review.rationale, width));
+        lines
+    }
+
+    fn composer_height(&self, width: u16) -> u16 {
+        self.composer.desired_height(width).clamp(3, 9)
+    }
+
+    fn composer_area(&self, area: Rect) -> Rect {
+        let model = lock_model(&self.model).clone();
+        let review_rows = self.review_lines(&model, area.width).len() as u16;
+        let composer_height = self.composer_height(area.width).min(area.height);
+        let footer_height = u16::from(area.height > 0);
+        Rect {
+            x: area.x,
+            y: area
+                .y
+                .saturating_add(area.height.saturating_sub(composer_height + footer_height)),
+            width: area.width,
+            height: composer_height.min(
+                area.height.saturating_sub(
+                    1u16.saturating_add(review_rows)
+                        .saturating_add(footer_height),
+                ),
+            ),
+        }
+    }
+}
+
+impl BottomPaneView for PromptAssistantView {
+    fn handle_key_event(&mut self, key_event: KeyEvent) {
+        if matches!(key_event.code, KeyCode::Esc) {
+            self.cancel_or_restore();
+            return;
+        }
+        if key_event.modifiers.contains(KeyModifiers::ALT) {
+            match key_event.code {
+                KeyCode::Char('c' | 'C') => {
+                    self.request_copy();
+                    return;
+                }
+                KeyCode::Up | KeyCode::PageUp => {
+                    self.scroll_preview(/*up*/ true);
+                    return;
+                }
+                KeyCode::Down | KeyCode::PageDown => {
+                    self.scroll_preview(/*up*/ false);
+                    return;
+                }
+                _ => {}
+            }
+        }
+
+        let phase = lock_model(&self.model).phase;
+        if Self::input_is_editable(phase)
+            && key_event.code == KeyCode::Tab
+            && key_event.modifiers == KeyModifiers::NONE
+        {
+            self.composer.handle_paste("\t".to_string());
+            return;
+        }
+        if phase == PromptAssistantViewPhase::Ready
+            && matches!(key_event.code, KeyCode::Enter)
+            && matches!(
+                key_event.modifiers,
+                KeyModifiers::NONE | KeyModifiers::SHIFT
+            )
+            && self.composer.current_text_with_pending().trim().is_empty()
+        {
+            self.request_apply();
+            return;
+        }
+        if Self::input_is_editable(phase) {
+            let (result, _) = self.composer.handle_key_event(key_event);
+            self.handle_composer_result(result);
+        }
+    }
+
+    fn is_complete(&self) -> bool {
+        lock_model(&self.model).completion.is_some()
+    }
+
+    fn completion(&self) -> Option<ViewCompletion> {
+        lock_model(&self.model).completion
+    }
+
+    fn clear_dismiss_after_child_accept(&mut self) {
+        let pending = {
+            let mut model = lock_model(&self.model);
+            if model.phase != PromptAssistantViewPhase::SelectingModel {
+                return;
+            }
+            model.phase = PromptAssistantViewPhase::EditingInitial;
+            model.pending_input.take()
+        };
+        if let Some(pending) = pending {
+            self.composer.apply_external_edit(pending);
+        }
+    }
+
+    fn view_id(&self) -> Option<&'static str> {
+        Some(PROMPT_ASSISTANT_VIEW_ID)
+    }
+
+    fn on_ctrl_c(&mut self) -> CancellationEvent {
+        self.cancel_or_restore();
+        CancellationEvent::Handled
+    }
+
+    fn terminal_title_requires_action(&self) -> bool {
+        matches!(
+            lock_model(&self.model).phase,
+            PromptAssistantViewPhase::EditingInitial
+                | PromptAssistantViewPhase::SelectingModel
+                | PromptAssistantViewPhase::Ready
+                | PromptAssistantViewPhase::Failed
+        )
+    }
+
+    fn allows_priority_overlay(&self) -> bool {
+        true
+    }
+
+    fn handle_paste(&mut self, pasted: String) -> bool {
+        Self::input_is_editable(lock_model(&self.model).phase) && self.composer.handle_paste(pasted)
+    }
+
+    fn flush_paste_burst_if_due(&mut self) -> bool {
+        self.composer.flush_paste_burst_if_due()
+    }
+
+    fn is_in_paste_burst(&self) -> bool {
+        self.composer.is_in_paste_burst()
+    }
+
+    fn external_editor_text(&self) -> Option<String> {
+        Self::input_is_editable(lock_model(&self.model).phase)
+            .then(|| self.composer.current_text_with_pending())
+    }
+
+    fn apply_external_editor_text(&mut self, text: String) -> bool {
+        if !Self::input_is_editable(lock_model(&self.model).phase) {
+            return false;
+        }
+        self.composer.apply_external_edit(text);
+        true
+    }
+
+    fn has_editable_composer(&self) -> bool {
+        Self::input_is_editable(lock_model(&self.model).phase)
+    }
+
+    fn pre_draw_tick(&mut self, now: Instant) -> bool {
+        let restored = self.restore_pending_input();
+        let mut model = lock_model(&self.model);
+        model.observed_at = now;
+        restored
+            || matches!(
+                model.phase,
+                PromptAssistantViewPhase::Running
+                    | PromptAssistantViewPhase::Applying
+                    | PromptAssistantViewPhase::Cancelling
+            )
+    }
+
+    fn next_frame_delay(&self) -> Option<Duration> {
+        matches!(
+            lock_model(&self.model).phase,
+            PromptAssistantViewPhase::Running
+                | PromptAssistantViewPhase::Applying
+                | PromptAssistantViewPhase::Cancelling
+        )
+        .then_some(ACTIVE_FRAME_INTERVAL)
+    }
+}
