+impl Renderable for PromptAssistantView {
+    fn desired_height(&self, width: u16) -> u16 {
+        if width == 0 {
+            return 0;
+        }
+        let model = lock_model(&self.model).clone();
+        let review_rows = self.review_lines(&model, width).len() as u16;
+        let preview_width = width.saturating_sub(2).max(1);
+        self.sync_preview(&model, preview_width, MAX_PREVIEW_ROWS);
+        let preview_rows = self.preview.borrow().lines.len().min(MAX_PREVIEW_ROWS) as u16;
+        2u16.saturating_add(review_rows)
+            .saturating_add(preview_rows)
+            .saturating_add(self.composer_height(width))
+    }
+
+    fn render(&self, area: Rect, buf: &mut Buffer) {
+        if area.is_empty() {
+            return;
+        }
+        let model = lock_model(&self.model).clone();
+        Paragraph::new(header_line(&model)).render(
+            Rect::new(area.x, area.y, area.width, 1).intersection(area),
+            buf,
+        );
+
+        let review_lines = self.review_lines(&model, area.width);
+        let review_height = review_lines.len() as u16;
+        if review_height > 0 {
+            Paragraph::new(review_lines).render(
+                Rect::new(area.x, area.y.saturating_add(1), area.width, review_height)
+                    .intersection(area),
+                buf,
+            );
+        }
+
+        let composer_area = self.composer_area(area);
+        let footer_y = area.y.saturating_add(area.height.saturating_sub(1));
+        let candidate_y = area.y.saturating_add(1).saturating_add(review_height);
+        let candidate_height = composer_area.y.saturating_sub(candidate_y);
+        let preview_width = area.width.saturating_sub(2).max(1);
+        self.sync_preview(&model, preview_width, candidate_height as usize);
+        if candidate_height > 0 {
+            let preview = self.preview.borrow();
+            let visible = preview
+                .lines
+                .iter()
+                .skip(preview.top)
+                .take(candidate_height as usize)
+                .cloned()
+                .collect::<Vec<_>>();
+            Paragraph::new(visible).render(
+                Rect::new(
+                    area.x.saturating_add(2),
+                    candidate_y,
+                    area.width.saturating_sub(2),
+                    candidate_height,
+                )
+                .intersection(area),
+                buf,
+            );
+        }
+
+        self.composer.render(composer_area, buf);
+        Paragraph::new(self.footer_line(&model)).render(
+            Rect::new(area.x, footer_y, area.width, 1).intersection(area),
+            buf,
+        );
+    }
+
+    fn cursor_pos(&self, area: Rect) -> Option<(u16, u16)> {
+        Self::input_is_editable(lock_model(&self.model).phase)
+            .then(|| self.composer.cursor_pos(self.composer_area(area)))
+            .flatten()
+    }
+}
