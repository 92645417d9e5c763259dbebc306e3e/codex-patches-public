+        assert_eq!(
+            rx.recv().expect("refine action"),
+            PromptAssistantViewAction::Refine {
+                context: context(2),
+                instruction: "make it shorter".to_string(),
+            }
+        );
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Running);
+
+        assert!(!handle.complete_operation(
+            &provisional,
+            context(2),
+            candidate("late first candidate")
+        ));
+        assert!(!handle.set_response_bytes(&provisional, 999));
+        assert!(handle.complete_operation(
+            &context(2),
+            second_server_generation.clone(),
+            candidate("second candidate")
+        ));
+        assert_eq!(handle.context(), second_server_generation);
+        assert_eq!(handle.candidate_text().as_deref(), Some("second candidate"));
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Ready);
+    }
+
+    #[test]
+    fn cancelling_rejects_late_updates_and_cancel_failure_becomes_restorable() {
+        let (mut view, handle, rx) = view("original");
+        let active = context(1);
+        view.on_ctrl_c();
+        assert_eq!(
+            rx.recv().expect("cancel action"),
+            PromptAssistantViewAction::Cancel {
+                context: active.clone(),
+            }
+        );
+
+        assert!(!handle.complete_operation(&active, context(2), candidate("late candidate")));
+        assert!(handle.set_failed(&active, "cancel failed"));
+        assert!(!handle.set_response_bytes(&active, 999));
+        view.handle_key_event(KeyEvent::from(KeyCode::Char('v')));
+        assert!(rx.try_recv().is_err());
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Failed);
+
+        view.on_ctrl_c();
+        assert_eq!(
+            rx.recv().expect("restore action"),
+            PromptAssistantViewAction::Restore {
+                original_draft: "original".to_string(),
+            }
+        );
+        assert_eq!(view.completion(), Some(ViewCompletion::Cancelled));
+    }
+
+    #[test]
+    fn printable_preview_shortcuts_are_plain_text_inside_prompt_editors() {
+        let submitted = Arc::new(Mutex::new(None));
+        let submitted_clone = Arc::clone(&submitted);
+        let mut intent = CustomPromptView::new(
+            "Generate a prompt".to_string(),
+            "Describe intent".to_string(),
+            String::new(),
+            None,
+            Box::new(move |text| {
+                *submitted_clone
+                    .lock()
+                    .unwrap_or_else(|error| error.into_inner()) = Some(text);
+            }),
+        );
+        intent.handle_key_event(KeyEvent::from(KeyCode::Char('r')));
+        intent.handle_key_event(KeyEvent::from(KeyCode::Char('c')));
+        assert!(!intent.is_complete());
+        // End the paste-burst window without changing the entered text. Enter
+        // can then exercise submission rather than paste-newline handling.
+        intent.handle_key_event(KeyEvent::from(KeyCode::Right));
+        intent.handle_key_event(KeyEvent::from(KeyCode::Enter));
+        assert_eq!(
+            submitted
+                .lock()
+                .unwrap_or_else(|error| error.into_inner())
+                .as_deref(),
+            Some("rc")
+        );
+
+        let (mut view, handle, rx) = view("original");
+        assert!(complete_same(&handle, &context(1), candidate("candidate")));
+        view.handle_key_event(KeyEvent::from(KeyCode::Char('r')));
+        let mut refinement = view.take_pending_child_view().expect("refinement editor");
+        refinement.handle_key_event(KeyEvent::from(KeyCode::Char('r')));
+        refinement.handle_key_event(KeyEvent::from(KeyCode::Char('c')));
+        assert!(
+            rx.try_recv().is_err(),
+            "editor text cannot fire preview actions"
+        );
+        refinement.handle_key_event(KeyEvent::from(KeyCode::Right));
+        refinement.handle_key_event(KeyEvent::from(KeyCode::Enter));
+        assert_eq!(
+            rx.recv().expect("refine action"),
+            PromptAssistantViewAction::Refine {
+                context: context(1),
+                instruction: "rc".to_string(),
+            }
+        );
+    }
+
+    #[test]
+    fn running_ready_reviewing_and_failed_render_compactly() {
+        let started_at = Instant::now();
+        let (tx, rx) = mpsc::channel();
+        let mut view = PromptAssistantView::new_at(
+            "original".to_string(),
+            context(1),
+            "translate",
+            move |action| tx.send(action).expect("send action"),
+            started_at,
+        );
+        let handle = view.handle();
+        handle.observe_at(started_at + Duration::from_millis(1500));
+        assert!(handle.set_response_bytes(&context(1), 2048));
+        let running = render_lines(&view, 72);
+
+        assert!(handle.complete_operation_at(
+            &context(1),
+            context(1),
+            candidate("first line\nsecond line"),
+            started_at + Duration::from_millis(1500),
+        ));
+        let ready = render_lines(&view, 72);
+
+        view.handle_key_event(KeyEvent::from(KeyCode::Char('v')));
+        assert_eq!(
+            rx.recv().expect("review action"),
+            PromptAssistantViewAction::Review {
+                context: context(1),
+                candidate_hash: "sha256:candidate".to_string(),
+            }
+        );
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Reviewing);
+        let reviewing = render_lines(&view, 72);
+
+        assert!(handle.set_failed(&context(1), "review service unavailable"));
+        let failed = render_lines(&view, 72);
+
+        insta::assert_snapshot!(
+            [
+                "RUNNING",
+                &running,
+                "READY",
+                &ready,
+                "REVIEWING",
+                &reviewing,
+                "FAILED",
+                &failed,
+            ]
+            .join("\n---\n"),
+            @r###"
+        RUNNING
+        ---
+        Prompt Assistant ▪ translate ▪ Running ▪ 1.5s ▪ ~2048 bytes
+          Generating prompt candidate
+          Esc cancel
+        ---
+        READY
+        ---
+        Prompt Assistant ▪ translate ▪ Ready ▪ 1.5s ▪ ~2048 bytes
+          Review passed
+          first line
+          second line
+          Enter apply ▪ r refine ▪ v review ▪ c copy ▪ Esc restore
+        ---
+        REVIEWING
+        ---
+        Prompt Assistant ▪ review ▪ Reviewing ▪ 0.0s
+          Review passed
+          first line
+          second line
+          Esc cancel
+        ---
+        FAILED
+        ---
+        Prompt Assistant ▪ review ▪ Failed ▪ 0.0s
+          review service unavailable
+          first line
+          second line
+          r refine ▪ c copy ▪ Esc restore
+        "###
+        );
+    }
+
+    fn render_lines(view: &PromptAssistantView, width: u16) -> String {
+        let height = view.desired_height(width);
+        let area = Rect::new(0, 0, width, height);
+        let mut buffer = Buffer::empty(area);
+        view.render(area, &mut buffer);
+        (0..area.height)
+            .map(|row| {
+                (0..area.width)
+                    .map(|column| buffer[(column, row)].symbol())
+                    .collect::<String>()
+                    .trim_end()
+                    .to_string()
+            })
+            .collect::<Vec<_>>()
+            .join("\n")
+    }
+}
