+    #[test]
+    fn apply_is_local_and_waits_for_backend_confirmation() {
+        let (mut view, handle, rx) = view("original composer draft");
+        assert!(complete_same(
+            &handle,
+            &context(1),
+            candidate("candidate text")
+        ));
+
+        view.handle_key_event(KeyEvent::from(KeyCode::Enter));
+
+        assert_eq!(
+            rx.recv().expect("apply action"),
+            PromptAssistantViewAction::Apply {
+                context: context(1),
+                candidate_hash: "sha256:candidate".to_string(),
+                candidate: "candidate text".to_string(),
+            }
+        );
+        assert!(!view.is_complete(), "local apply must not submit or close");
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Applying);
+        assert!(rx.try_recv().is_err());
+
+        view.handle_key_event(KeyEvent::from(KeyCode::Esc));
+        assert_eq!(handle.phase(), PromptAssistantViewPhase::Applying);
+        assert!(
+            !view.is_complete(),
+            "Esc cannot restore while apply is in flight"
+        );
+        assert!(rx.try_recv().is_err());
+
+        assert!(handle.finish_applied(&context(1)));
+        assert_eq!(view.completion(), Some(ViewCompletion::Accepted));
+    }
+
+    #[test]
+    fn escape_restores_exact_bytes_and_running_escape_waits_for_cancel() {
+        let original = "  原始 draft\nwith trailing bytes  \n";
+        let (mut ready, ready_handle, ready_rx) = view(original);
+        assert!(complete_same(
+            &ready_handle,
+            &context(1),
+            candidate("candidate")
+        ));
+
+        ready.on_ctrl_c();
+
+        let PromptAssistantViewAction::Restore { original_draft } =
+            ready_rx.recv().expect("restore action")
+        else {
+            panic!("expected restore action");
+        };
+        assert_eq!(original_draft.as_bytes(), original.as_bytes());
+        assert_eq!(ready.completion(), Some(ViewCompletion::Cancelled));
+
+        let (mut running, running_handle, running_rx) = view(original);
+        running.on_ctrl_c();
+        assert_eq!(
+            running_rx.recv().expect("cancel action"),
+            PromptAssistantViewAction::Cancel {
+                context: context(1),
+            }
+        );
+        assert_eq!(running_handle.phase(), PromptAssistantViewPhase::Cancelling);
+        assert!(!running.is_complete());
+        assert!(running_handle.finish_cancelled(&context(1)));
+        assert_eq!(running.completion(), Some(ViewCompletion::Cancelled));
+    }
