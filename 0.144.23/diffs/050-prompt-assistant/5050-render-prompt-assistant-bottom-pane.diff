+impl PromptAssistantView {
+    fn footer_line(&self, model: &PromptAssistantViewModel) -> Line<'static> {
+        let has_input = !self.composer.current_text_with_pending().trim().is_empty();
+        let text = match model.phase {
+            PromptAssistantViewPhase::EditingInitial => {
+                "Enter send ▪ Ctrl+G external editor ▪ Esc restore"
+            }
+            PromptAssistantViewPhase::SelectingModel => "Choose model ▪ Esc back",
+            PromptAssistantViewPhase::Running => "Esc cancel",
+            PromptAssistantViewPhase::Applying => "Applying",
+            PromptAssistantViewPhase::Cancelling => "Cancelling",
+            PromptAssistantViewPhase::Ready if has_input => {
+                "Enter refine ▪ Alt+C copy ▪ Ctrl+G external editor ▪ Esc restore"
+            }
+            PromptAssistantViewPhase::Ready
+                if model
+                    .candidate
+                    .as_ref()
+                    .is_some_and(|candidate| candidate.apply_allowed) =>
+            {
+                "Enter apply ▪ type to refine ▪ Alt+C copy ▪ Ctrl+G external editor ▪ Esc restore"
+            }
+            PromptAssistantViewPhase::Ready => {
+                "Revise the blocked prompt ▪ Alt+C copy ▪ Ctrl+G external editor ▪ Esc restore"
+            }
+            PromptAssistantViewPhase::Failed => {
+                "Edit and Enter retry ▪ Ctrl+G external editor ▪ Esc restore"
+            }
+        };
+        Line::from(vec![
+            "  ".into(),
+            Span::styled(text, Style::default().dim()),
+        ])
+    }
+}
+
+fn lock_model(
+    model: &Arc<Mutex<PromptAssistantViewModel>>,
+) -> MutexGuard<'_, PromptAssistantViewModel> {
+    model
+        .lock()
+        .unwrap_or_else(std::sync::PoisonError::into_inner)
+}
+
+fn wrapped_preview_lines(text: &str, width: u16) -> Vec<Line<'static>> {
+    let mut chars = text.chars();
+    let mut preview = chars.by_ref().take(MAX_PREVIEW_CHARS).collect::<String>();
+    if chars.next().is_some() {
+        preview.push_str("\n[preview truncated; copy preserves the complete candidate]");
+    }
+    let mut lines = word_wrap_lines(
+        preview.split('\n').map(|line| Line::from(line.to_string())),
+        RtOptions::new(width.max(1) as usize),
+    );
+    if lines.len() > MAX_WRAPPED_PREVIEW_ROWS {
+        lines.truncate(MAX_WRAPPED_PREVIEW_ROWS.saturating_sub(1));
+        lines.push(Line::from(
+            "[preview row limit reached; copy preserves the complete candidate]".dim(),
+        ));
+    }
+    lines
+}
+
+fn wrapped_review_field(label: &str, value: &str, width: u16) -> Vec<Line<'static>> {
+    word_wrap_lines(
+        std::iter::once(Line::from(format!("  {label}: {value}"))),
+        RtOptions::new(width.max(1) as usize),
+    )
+    .into_iter()
+    .take(MAX_REVIEW_FIELD_ROWS)
+    .collect()
+}
+
+fn header_line(model: &PromptAssistantViewModel) -> Line<'static> {
+    let mut spans = vec!["Prompt Assistant".bold(), " ▪ ".dim()];
+    spans.push(model.operation_label.clone().cyan());
+    spans.push(" ▪ ".dim());
+    spans.push(phase_label(model.phase));
+    spans.push(" ▪ ".dim());
+    spans.push(format_elapsed(model).dim());
+    if model.response_bytes > 0 {
+        spans.push(" ▪ ".dim());
+        spans.push(format!("~{} bytes", model.response_bytes).dim());
+    }
+    Line::from(spans)
+}
+
+fn phase_label(phase: PromptAssistantViewPhase) -> Span<'static> {
+    match phase {
+        PromptAssistantViewPhase::EditingInitial => "Editing".yellow(),
+        PromptAssistantViewPhase::SelectingModel => "Selecting model".yellow(),
+        PromptAssistantViewPhase::Running => "Running".cyan(),
+        PromptAssistantViewPhase::Ready => "Ready".green(),
+        PromptAssistantViewPhase::Applying => "Applying".cyan(),
+        PromptAssistantViewPhase::Cancelling => "Cancelling".yellow(),
+        PromptAssistantViewPhase::Failed => "Failed".red(),
+    }
+}
+
+fn review_status_label(status: PromptAssistantReviewStatus) -> Span<'static> {
+    match status {
+        PromptAssistantReviewStatus::Pass => "Pass".green(),
+        PromptAssistantReviewStatus::Revised => "Revised".yellow(),
+        PromptAssistantReviewStatus::Blocked => "Blocked".red(),
+    }
+}
+
+fn risk_label(risk: GuardianRiskLevel) -> Span<'static> {
+    match risk {
+        GuardianRiskLevel::Low => "low".green(),
+        GuardianRiskLevel::Medium => "medium".yellow(),
+        GuardianRiskLevel::High => "high".light_red(),
+        GuardianRiskLevel::Critical => "critical".red(),
+    }
+}
+
+fn authorization_label(authorization: GuardianUserAuthorization) -> Span<'static> {
+    match authorization {
+        GuardianUserAuthorization::Unknown => "unknown".dim(),
+        GuardianUserAuthorization::Low => "low".red(),
+        GuardianUserAuthorization::Medium => "medium".yellow(),
+        GuardianUserAuthorization::High => "high".green(),
+    }
+}
+
+fn format_elapsed(model: &PromptAssistantViewModel) -> String {
+    let elapsed = model
+        .observed_at
+        .saturating_duration_since(model.started_at);
+    let seconds = elapsed.as_secs_f64();
+    if seconds < 10.0 {
+        format!("{seconds:.1}s")
+    } else if seconds < 60.0 {
+        format!("{}s", elapsed.as_secs())
+    } else {
+        format!("{}m {:02}s", elapsed.as_secs() / 60, elapsed.as_secs() % 60)
+    }
+}
