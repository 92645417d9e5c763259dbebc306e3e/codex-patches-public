+    fn complete_same(
+        handle: &PromptAssistantViewHandle,
+        context: &PromptAssistantActionContext,
+        candidate: PromptAssistantCandidate,
+    ) -> bool {
+        handle.complete_operation(context, context.clone(), candidate)
+    }
