+#[ts(export_to = "v2/")]
+pub struct PromptAssistantProgressNotification {
+    pub thread_id: String,
+    pub workspace_id: String,
+    #[ts(type = "number")]
+    pub generation: u64,
+    pub byte_count: u64,
+    pub reset: bool,
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+    use serde_json::Value;
+    use serde_json::json;
+
+    fn workspace() -> PromptAssistantWorkspace {
+        PromptAssistantWorkspace {
+            thread_id: "parent-thread".to_string(),
+            workspace_id: "workspace-1".to_string(),
+            child_thread_id: "child-thread".to_string(),
+            operation: PromptAssistantOperation::Generate,
+            model: "hidden-functional-model".to_string(),
+            reasoning_effort: None,
+            generation: 3,
+            candidate: "candidate".to_string(),
+            candidate_hash: "sha256:candidate".to_string(),
+            usage: None,
+            review: None,
+        }
+    }
+
+    #[test]
+    fn workspace_serializes_absent_usage_and_review_as_null() {
+        let value = serde_json::to_value(workspace()).expect("serialize workspace");
+        assert_eq!(value["usage"], Value::Null);
+        assert_eq!(value["review"], Value::Null);
+    }
+
+    #[test]
+    fn start_workspace_id_is_an_optional_request_field() {
+        let value = serde_json::to_value(PromptAssistantStartParams {
+            thread_id: "parent-thread".to_string(),
+            operation: PromptAssistantStartOperation::Translate,
+            input: "source".to_string(),
+            model: None,
+            workspace_id: None,
+        })
+        .expect("serialize start params");
+        assert_eq!(
+            value,
+            json!({
+                "threadId": "parent-thread",
+                "operation": "translate",
+                "input": "source"
+            })
+        );
+    }
+
+    #[test]
+    fn start_can_select_one_hidden_functional_model_explicitly() {
+        let value = serde_json::to_value(PromptAssistantStartParams {
+            thread_id: "parent-thread".to_string(),
+            operation: PromptAssistantStartOperation::Generate,
+            input: "intent".to_string(),
+            model: Some("hidden-functional-model".to_string()),
+            workspace_id: Some("workspace-1".to_string()),
+        })
+        .expect("serialize start params");
+        assert_eq!(value["model"], json!("hidden-functional-model"));
+    }
+
+    #[test]
+    fn progress_is_scoped_to_parent_workspace_and_generation() {
+        let value = serde_json::to_value(PromptAssistantProgressNotification {
+            thread_id: "parent-thread".to_string(),
+            workspace_id: "workspace-1".to_string(),
+            generation: 3,
+            byte_count: 137,
+            reset: false,
+        })
+        .expect("serialize progress");
+        assert_eq!(value["threadId"], json!("parent-thread"));
+        assert_eq!(value["workspaceId"], json!("workspace-1"));
+        assert_eq!(value["generation"], json!(3));
+        assert_eq!(value["byteCount"], json!(137));
+    }
+
+    #[test]
+    fn apply_requires_the_exact_candidate_generation_and_hash() {
+        let value = serde_json::to_value(PromptAssistantApplyParams {
+            thread_id: "parent-thread".to_string(),
+            workspace_id: "workspace-1".to_string(),
+            generation: 3,
+            candidate_hash: "sha256:candidate".to_string(),
+        })
+        .expect("serialize apply params");
+        assert_eq!(value["generation"], json!(3));
+        assert_eq!(value["candidateHash"], json!("sha256:candidate"));
+    }
+}
