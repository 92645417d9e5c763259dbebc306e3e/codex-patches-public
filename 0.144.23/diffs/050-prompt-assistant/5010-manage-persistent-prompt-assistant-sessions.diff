+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn resumed_parent_recovers_workspace_before_refine_and_apply() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    mount_response_once(
+        &server,
+        sse_response(successful_response(
+            "initial-response",
+            "initial candidate",
+            &TokenUsage::default(),
+        )),
+    )
+    .await;
+    let mut builder = configured_builder();
+    let initial = builder.build(&server).await?;
+    let started = initial
+        .codex
+        .start_prompt_assistant(PromptAssistantRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            operation: PromptAssistantOperation::Generate,
+            source: "initial source".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+        })
+        .await?;
+    let parent_rollout_path = initial.codex.rollout_path().expect("parent rollout path");
+    let home = Arc::clone(&initial.home);
+    initial.codex.flush_rollout().await?;
+    initial.codex.shutdown_and_wait().await?;
+
+    let refined_response = mount_response_once(
+        &server,
+        sse_response(successful_response(
+            "refined-response",
+            "refined candidate",
+            &TokenUsage::default(),
+        )),
+    )
+    .await;
+    let mut resume_builder = configured_builder();
+    let resumed = resume_builder
+        .resume(&server, home, parent_rollout_path)
+        .await?;
+    let refined = resumed
+        .codex
+        .refine_prompt_assistant(PromptAssistantRefineRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: started.generation,
+            instruction: "refine after resume".to_string(),
+        })
+        .await?;
+    assert_eq!(refined.child_thread_id, started.child_thread_id);
+    assert_eq!(refined.candidate, "refined candidate");
+    let refine_request = refined_response.single_request().body_json().to_string();
+    assert!(refine_request.contains("initial source"));
+    assert!(refine_request.contains("initial candidate"));
+
+    let resumed_rollout_path = resumed.codex.rollout_path().expect("resumed rollout path");
+    let home = Arc::clone(&resumed.home);
+    resumed.codex.flush_rollout().await?;
+    resumed.codex.shutdown_and_wait().await?;
+
+    let mut apply_builder = configured_builder();
+    let apply_session = apply_builder
+        .resume(&server, home, resumed_rollout_path)
+        .await?;
+    let applied = apply_session
+        .codex
+        .apply_prompt_assistant(PromptAssistantApplyRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: refined.generation,
+            candidate_hash: refined.candidate_hash.clone(),
+        })
+        .await?;
+    assert_eq!(applied, refined);
+    apply_session.codex.shutdown_and_wait().await?;
+    Ok(())
+}
