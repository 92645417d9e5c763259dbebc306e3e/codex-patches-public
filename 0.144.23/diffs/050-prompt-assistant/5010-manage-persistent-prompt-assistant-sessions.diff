+++ b/codex-rs/core/src/prompt_assistant/projection.rs
@@ -0,0 +1,89 @@
+use codex_protocol::models::MessagePhase;
+use codex_protocol::models::ResponseItem;
+use codex_utils_output_truncation::TruncationPolicy;
+use codex_utils_output_truncation::approx_token_count;
+use codex_utils_output_truncation::truncate_text;
+use serde::Serialize;
+
+use crate::compact::content_items_to_text;
+use crate::compact::is_summary_message;
+use crate::event_mapping::is_contextual_user_message_content;
+
+const MAX_CONTEXT_TOKENS: usize = 8_000;
+const MAX_ENTRY_TOKENS: usize = 2_000;
+const MAX_ENTRIES: usize = 32;
+
+#[derive(Clone, Copy, Debug, PartialEq, Eq, Serialize)]
+#[serde(rename_all = "snake_case")]
+enum EntryKind {
+    CompactionSummary,
+    User,
+    AssistantFinal,
+}
+
+#[derive(Serialize)]
+struct Entry<'a> {
+    kind: EntryKind,
+    text: &'a str,
+}
+
+pub(super) fn project_parent_context(items: &[ResponseItem]) -> String {
+    let mut selected = Vec::<(EntryKind, String)>::new();
+    let mut retained_summary = false;
+    for item in items.iter().rev() {
+        let Some((kind, text)) = entry_from_item(item) else {
+            continue;
+        };
+        if kind == EntryKind::CompactionSummary && retained_summary {
+            continue;
+        }
+        let text = truncate_text(&text, TruncationPolicy::Tokens(MAX_ENTRY_TOKENS));
+        selected.push((kind, text));
+        let rendered = render_entries(selected.iter().rev());
+        if selected.len() > MAX_ENTRIES || approx_token_count(&rendered) > MAX_CONTEXT_TOKENS {
+            selected.pop();
+            break;
+        }
+        retained_summary |= kind == EntryKind::CompactionSummary;
+    }
+    render_entries(selected.iter().rev())
+}
+
+fn entry_from_item(item: &ResponseItem) -> Option<(EntryKind, String)> {
+    match item {
+        ResponseItem::Message { role, content, .. }
+            if role == "user" && !is_contextual_user_message_content(content) =>
+        {
+            let text = content_items_to_text(content)?;
+            let kind = if is_summary_message(&text) {
+                EntryKind::CompactionSummary
+            } else {
+                EntryKind::User
+            };
+            Some((kind, text))
+        }
+        ResponseItem::Message {
+            role,
+            content,
+            phase: Some(MessagePhase::FinalAnswer),
+            ..
+        } if role == "assistant" => {
+            Some((EntryKind::AssistantFinal, content_items_to_text(content)?))
+        }
+        _ => None,
+    }
+}
+
+fn render_entries<'a>(entries: impl Iterator<Item = &'a (EntryKind, String)>) -> String {
+    entries
+        .map(|(kind, text)| {
+            serde_json::to_string(&Entry { kind: *kind, text })
+                .expect("Prompt Assistant context entry serialization must succeed")
+        })
+        .collect::<Vec<_>>()
+        .join("\n")
+}
+
