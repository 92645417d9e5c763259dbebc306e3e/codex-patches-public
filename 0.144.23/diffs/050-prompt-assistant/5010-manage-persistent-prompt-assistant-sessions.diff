+
+use crate::config::Config;
+use crate::session::turn_context::TurnContext;
+
+const MAX_FIXED_INSTRUCTION_TOKENS: usize = 10_000;
+const POLICY_RELATIVE_PATH: &str = "instructions/prompt-assistant.md";
+
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub(super) struct ModelSelection {
+    pub(super) model: String,
+    pub(super) reasoning_effort: Option<ReasoningEffort>,
+}
+
+pub(super) fn load_policy(codex_home: &Path) -> Result<String> {
+    let path = codex_home.join(POLICY_RELATIVE_PATH);
+    let policy = match fs::read_to_string(&path) {
+        Ok(policy) => policy,
+        Err(err) if err.kind() == ErrorKind::NotFound => {
+            ensure_policy_file(codex_home)?;
+            fs::read_to_string(&path).with_context(|| {
+                format!(
+                    "failed to read seeded Prompt Assistant policy at {}",
+                    path.display()
+                )
+            })?
+        }
+        Err(err) => {
+            return Err(err).with_context(|| {
+                format!(
+                    "failed to read Prompt Assistant policy at {}",
+                    path.display()
+                )
+            });
+        }
+    };
+    ensure!(
+        !policy.trim().is_empty(),
+        "Prompt Assistant policy at {} must not be empty",
+        path.display()
+    );
+    Ok(policy)
+}
+
+pub(crate) fn ensure_policy_file(codex_home: &Path) -> Result<()> {
+    let path = codex_home.join(POLICY_RELATIVE_PATH);
+    match path.try_exists() {
+        Ok(true) => return Ok(()),
+        Ok(false) => {}
+        Err(err) => {
+            return Err(err).with_context(|| {
+                format!(
+                    "failed to inspect Prompt Assistant policy at {}",
+                    path.display()
+                )
+            });
+        }
+    }
+
+    let parent = path.parent().with_context(|| {
+        format!(
+            "Prompt Assistant policy path {} has no parent directory",
+            path.display()
+        )
+    })?;
+    fs::create_dir_all(parent).with_context(|| {
+        format!(
+            "failed to create Prompt Assistant policy directory at {}",
+            parent.display()
+        )
+    })?;
+
+    let mut temporary = tempfile::NamedTempFile::new_in(parent).with_context(|| {
+        format!(
+            "failed to create temporary Prompt Assistant policy beside {}",
+            path.display()
+        )
+    })?;
+    temporary
+        .write_all(super::prompt::FIXED_INSTRUCTIONS.as_bytes())
+        .with_context(|| {
+            format!(
+                "failed to write temporary Prompt Assistant policy beside {}",
+                path.display()
+            )
+        })?;
+    temporary.as_file().sync_all().with_context(|| {
+        format!(
+            "failed to sync temporary Prompt Assistant policy beside {}",
+            path.display()
+        )
+    })?;
+
+    match temporary.persist_noclobber(&path) {
+        Ok(_) => Ok(()),
+        Err(err) if err.error.kind() == ErrorKind::AlreadyExists => Ok(()),
+        Err(err) => Err(err.error).with_context(|| {
+            format!(
+                "failed to install Prompt Assistant policy at {}",
+                path.display()
+            )
+        }),
+    }
+}
+
+pub(super) fn build_child_config(
+    parent_context: &TurnContext,
+    fixed_instructions: &str,
+    selection: &ModelSelection,
+) -> Result<Config> {
+    ensure!(
+        !fixed_instructions.trim().is_empty(),
+        "Prompt Assistant instructions must not be empty"
+    );
+    ensure!(
+        approx_token_count(fixed_instructions) <= MAX_FIXED_INSTRUCTION_TOKENS,
+        "Prompt Assistant instructions exceed the {MAX_FIXED_INSTRUCTION_TOKENS}-token limit"
+    );
+    ensure!(
+        !selection.model.trim().is_empty(),
+        "Prompt Assistant model must not be empty"
+    );
+
+    let mut config = parent_context.config.as_ref().clone();
+    config.model = Some(selection.model.clone());
+    config.model_reasoning_effort = selection.reasoning_effort.clone();
+    config.model_reasoning_summary = Some(ReasoningSummary::None);
+    config.model_verbosity = None;
+    config.service_tier = None;
+    config.model_context_window = None;
+    config.model_auto_compact_token_limit = None;
+    config.compact_prompt = None;
+    // Keep the selected model's catalog/Markdown instructions as the system layer. Prompt
+    // Assistant policy follows as a distinct developer layer.
+    config.base_instructions = None;
+    config.developer_instructions = Some(fixed_instructions.to_string());
+    config.personality = None;
+    config.notify = None;
+    config.ephemeral = false;
+    config.project_doc_max_bytes = 0;
+    config.include_environment_context = false;
+    config.include_permissions_instructions = false;
+    config.include_collaboration_mode_instructions = false;
+    config.include_skill_instructions = false;
+    config.include_apps_instructions = false;
+    config.orchestrator_skills_enabled = false;
+    config.orchestrator_mcp_enabled = false;
+    config
+        .permissions
+        .approval_policy
+        .set(AskForApproval::Never)
+        .context("Prompt Assistant could not disable approval prompts")?;
+    config
+        .permissions
+        .set_permission_profile(PermissionProfile::read_only())
+        .context("Prompt Assistant could not install read-only permissions")?;
+    config
+        .mcp_servers
+        .set(HashMap::new())
+        .context("Prompt Assistant could not clear MCP servers")?;
+    config
+        .web_search_mode
+        .set(WebSearchMode::Disabled)
+        .context("Prompt Assistant could not disable web search")?;
+    config.memories.generate_memories = false;
+    config.memories.use_memories = false;
+    config.memories.dedicated_tools = false;
+    config.token_budget = None;
+    config.rollout_budget = None;
+    config.current_time_reminder = None;
+
+    for feature in [
+        Feature::CodexHooks,
+        Feature::EnableMcpApps,
+        Feature::Apps,
+        Feature::Plugins,
+        Feature::ToolSuggest,
+        Feature::SpawnCsv,
+        Feature::MultiAgentV2,
+        Feature::Collab,
+        Feature::WebSearchRequest,
+        Feature::WebSearchCached,
+        Feature::StandaloneWebSearch,
+        Feature::MemoryTool,
+        Feature::Goals,
+        Feature::TokenBudget,
+        Feature::RolloutBudget,
+        Feature::CurrentTimeReminder,
+        Feature::Personality,
+        Feature::RemoteCompactionV2,
+    ] {
+        config.features.disable(feature).with_context(|| {
+            format!(
+                "Prompt Assistant could not disable `features.{}`",
+                feature.key()
+            )
+        })?;
+        ensure!(
+            !config.features.enabled(feature),
+            "Prompt Assistant could not disable pinned `features.{}`",
+            feature.key()
+        );
+    }
+
+    Ok(config)
+}
