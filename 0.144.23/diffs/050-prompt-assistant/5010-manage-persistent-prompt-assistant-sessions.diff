@@ -0,0 +1,827 @@
+use std::collections::HashMap;
+use std::sync::Arc;
+
+use codex_protocol::prompt_assistant::PromptAssistantLifecycleStatus;
+use codex_protocol::protocol::TokenUsage;
+use codex_utils_cache::sha1_digest;
+use codex_utils_output_truncation::approx_token_count;
+use tokio::sync::Mutex;
+use tokio::sync::Semaphore;
+use tokio_util::sync::CancellationToken;
+use uuid::Uuid;
+
+use crate::context_manager::ContextManager;
+use crate::session::session::Session;
+
+use super::PromptAssistantApplyRequest;
+use super::PromptAssistantCancelRequest;
+use super::PromptAssistantError;
+use super::PromptAssistantOperation;
+use super::PromptAssistantRefineRequest;
+use super::PromptAssistantRequest;
+use super::PromptAssistantResult;
+use super::PromptAssistantReviewRequest;
+use super::PromptAssistantReviewStatus;
+use super::child_config::ModelSelection;
+use super::child_config::build_child_config;
+use super::child_config::load_policy;
+use super::lifecycle::persist_error;
+use super::lifecycle::persist_result;
+use super::projection::project_parent_context;
+use super::prompt;
+use super::recovery::latest_session_model;
+use super::recovery::recover_latest_session;
+use super::runtime::PromptAssistantTrunk;
+use super::runtime::ReuseKey;
+use super::runtime::shutdown_trunk;
+use super::runtime::spawn_trunk;
+use super::runtime::submit_operation;
+use super::runtime::wait_for_operation;
+
+const MAX_SOURCE_TOKENS: usize = 8_000;
+const MAX_CANDIDATE_TOKENS: usize = 10_000;
+const MAX_SUCCESSFUL_TURNS: usize = 16;
+const MAX_WORKSPACE_TOKENS: usize = 48_000;
+
+pub(crate) struct PromptAssistantSessionManager {
+    state: Mutex<ManagerState>,
+    operation_gate: Arc<Semaphore>,
+    shutdown: CancellationToken,
+}
+
+#[derive(Default)]
+struct ManagerState {
+    trunk: Option<Arc<PromptAssistantTrunk>>,
+    workspaces: HashMap<String, WorkspaceState>,
+    next_generation: u64,
+    active: Option<ActiveOperation>,
+    recovery_attempted: bool,
+}
+
+struct ActiveOperation {
+    workspace_id: String,
+    generation: u64,
+    cancel: CancellationToken,
+}
+
+struct WorkspaceState {
+    frozen_context: String,
+    model: String,
+    child_history: Option<ContextManager>,
+    successful_turns: usize,
+    successful_tokens: usize,
+    latest: Option<PromptAssistantResult>,
+    applied_generation: Option<u64>,
+}
+
+impl Default for PromptAssistantSessionManager {
+    fn default() -> Self {
+        Self {
+            state: Mutex::new(ManagerState::default()),
+            operation_gate: Arc::new(Semaphore::new(/*permits*/ 1)),
+            shutdown: CancellationToken::new(),
+        }
+    }
+}
+
+impl PromptAssistantSessionManager {
+    pub(crate) async fn start(
+        &self,
+        parent_session: Arc<Session>,
+        request: PromptAssistantRequest,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        canonical_workspace_id(&request.workspace_id)?;
+        if !matches!(
+            request.operation,
+            PromptAssistantOperation::Translate | PromptAssistantOperation::Generate
+        ) {
+            return Err(PromptAssistantError::InvalidInput(
+                "start requires a translate or generate operation".to_string(),
+            ));
+        }
+        validate_text("source", &request.source, MAX_SOURCE_TOKENS)?;
+        let model = parent_session
+            .services
+            .models_manager
+            .resolve_prompt_assistant_model(request.model.as_deref())
+            .await
+            .map_err(PromptAssistantError::InvalidInput)?;
+        let frozen_context =
+            project_parent_context(parent_session.clone_history().await.raw_items());
+        {
+            let mut state = self.state.lock().await;
+            if state.workspaces.contains_key(&request.workspace_id) {
+                return Err(PromptAssistantError::InvalidInput(format!(
+                    "workspace `{}` already exists",
+                    request.workspace_id
+                )));
+            }
+            state.workspaces.insert(
+                request.workspace_id.clone(),
+                WorkspaceState {
+                    frozen_context,
+                    model,
+                    child_history: None,
+                    successful_turns: 0,
+                    successful_tokens: 0,
+                    latest: None,
+                    applied_generation: None,
+                },
+            );
+        }
+        self.run_operation(
+            parent_session,
+            request,
+            /*expected_generation*/ None,
+            /*expected_candidate_hash*/ None,
+        )
+        .await
+    }
+
+    pub(crate) async fn refine(
+        &self,
+        parent_session: Arc<Session>,
+        request: PromptAssistantRefineRequest,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        canonical_workspace_id(&request.workspace_id)?;
+        validate_text("refinement", &request.instruction, MAX_SOURCE_TOKENS)?;
+        self.run_operation(
+            parent_session,
+            PromptAssistantRequest {
+                workspace_id: request.workspace_id,
+                operation: PromptAssistantOperation::Refine,
+                source: request.instruction,
+                model: None,
+            },
+            Some(request.generation),
+            /*expected_candidate_hash*/ None,
+        )
+        .await
+    }
+
+    pub(crate) async fn review(
+        &self,
+        parent_session: Arc<Session>,
+        request: PromptAssistantReviewRequest,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        canonical_workspace_id(&request.workspace_id)?;
+        self.run_operation(
+            parent_session,
+            PromptAssistantRequest {
+                workspace_id: request.workspace_id,
+                operation: PromptAssistantOperation::Review,
+                source: String::new(),
+                model: None,
+            },
+            Some(request.generation),
+            Some(request.candidate_hash),
+        )
+        .await
+    }
+
+    pub(crate) async fn apply(
+        &self,
+        parent_session: Arc<Session>,
+        request: PromptAssistantApplyRequest,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        canonical_workspace_id(&request.workspace_id)?;
+        let _permit = Arc::clone(&self.operation_gate)
+            .acquire_owned()
+            .await
+            .map_err(|_| PromptAssistantError::Cancelled)?;
+        if self.shutdown.is_cancelled() {
+            return Err(PromptAssistantError::Cancelled);
+        }
+        self.recover_before_workspace_lookup(Arc::clone(&parent_session))
+            .await?;
+        let (result, should_record) = {
+            let mut state = self.state.lock().await;
+            let workspace = state
+                .workspaces
+                .get_mut(&request.workspace_id)
+                .ok_or_else(|| {
+                    PromptAssistantError::WorkspaceNotFound(request.workspace_id.clone())
+                })?;
+            let result = workspace.latest.clone().ok_or_else(|| {
+                PromptAssistantError::InvalidInput("workspace has no candidate".to_string())
+            })?;
+            if result.review.status == PromptAssistantReviewStatus::Blocked {
+                return Err(PromptAssistantError::Blocked);
+            }
+            if result.generation != request.generation
+                || result.candidate_hash != request.candidate_hash
+            {
+                return Err(PromptAssistantError::InvalidInput(
+                    "candidate generation or hash no longer matches the active workspace"
+                        .to_string(),
+                ));
+            }
+            let should_record = workspace.applied_generation != Some(result.generation);
+            workspace.applied_generation = Some(result.generation);
+            (result, should_record)
+        };
+        if should_record {
+            persist_result(
+                &parent_session,
+                &result,
+                PromptAssistantLifecycleStatus::Applied,
+                /*applied*/ true,
+                /*usage*/ None,
+                /*error*/ None,
+            )
+            .await;
+        }
+        Ok(result)
+    }
+
+    pub(crate) async fn cancel(
+        &self,
+        request: PromptAssistantCancelRequest,
+    ) -> Result<(), PromptAssistantError> {
+        canonical_workspace_id(&request.workspace_id)?;
+        let mut state = self.state.lock().await;
+        if !state.workspaces.contains_key(&request.workspace_id) {
+            return Err(PromptAssistantError::WorkspaceNotFound(
+                request.workspace_id,
+            ));
+        }
+        let Some(active) = state.active.as_ref() else {
+            return Err(PromptAssistantError::InvalidInput(
+                "workspace has no active operation to cancel".to_string(),
+            ));
+        };
+        if active.workspace_id != request.workspace_id || active.generation != request.generation {
+            return Err(PromptAssistantError::InvalidInput(
+                "cancel generation no longer matches the active operation".to_string(),
+            ));
+        }
+        let active = state
+            .active
+            .take()
+            .expect("validated active Prompt Assistant operation must exist");
+        state.next_generation = state.next_generation.saturating_add(1);
+        active.cancel.cancel();
+        Ok(())
+    }
+
+    pub(crate) async fn shutdown(&self) {
+        self.shutdown.cancel();
+        if let Some(active) = self.state.lock().await.active.as_ref() {
+            active.cancel.cancel();
+        }
+        let Ok(_permit) = Arc::clone(&self.operation_gate).acquire_owned().await else {
+            return;
+        };
+        if let Some(trunk) = self.state.lock().await.trunk.take() {
+            shutdown_trunk(&trunk).await;
+        }
+    }
+
+    async fn run_operation(
+        &self,
+        parent_session: Arc<Session>,
+        mut request: PromptAssistantRequest,
+        expected_generation: Option<u64>,
+        expected_candidate_hash: Option<String>,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        let _permit = Arc::clone(&self.operation_gate)
+            .acquire_owned()
+            .await
+            .map_err(|_| PromptAssistantError::Cancelled)?;
+        if self.shutdown.is_cancelled() {
+            return Err(PromptAssistantError::Cancelled);
+        }
+        if let Some(expected_generation) = expected_generation {
+            self.recover_before_workspace_lookup(Arc::clone(&parent_session))
+                .await?;
+            let candidate = self
+                .require_candidate(
+                    &request.workspace_id,
+                    expected_generation,
+                    expected_candidate_hash.as_deref(),
+                    request.operation == PromptAssistantOperation::Refine,
+                )
+                .await?;
+            if request.operation == PromptAssistantOperation::Review {
+                request.source = candidate;
+            }
+        }
+        let (frozen_context, model, generation, operation_cancel) = {
+            let mut state = self.state.lock().await;
+            let workspace = state.workspaces.get(&request.workspace_id).ok_or_else(|| {
+                PromptAssistantError::WorkspaceNotFound(request.workspace_id.clone())
+            })?;
+            ensure_workspace_capacity(workspace, &request.source)?;
+            let frozen_context = workspace.frozen_context.clone();
+            let model = workspace.model.clone();
+            state.next_generation = state.next_generation.saturating_add(1);
+            let generation = state.next_generation;
+            let operation_cancel = self.shutdown.child_token();
+            state.active = Some(ActiveOperation {
+                workspace_id: request.workspace_id.clone(),
+                generation,
+                cancel: operation_cancel.clone(),
+            });
+            (frozen_context, model, generation, operation_cancel)
+        };
+        let trunk = match self.ensure_trunk(Arc::clone(&parent_session), &model).await {
+            Ok(trunk) => trunk,
+            Err(err) => {
+                self.clear_active(&request.workspace_id, generation).await;
+                self.remove_empty_start_workspace(&request).await;
+                return Err(err);
+            }
+        };
+        let history_before = {
+            let state = self.state.lock().await;
+            state
+                .workspaces
+                .get(&request.workspace_id)
+                .and_then(|workspace| workspace.child_history.clone())
+                .unwrap_or_else(|| trunk.base_history.clone())
+        };
+        trunk
+            .session
+            .restore_prompt_assistant_history(&history_before)
+            .await;
+        let usage_before = trunk.session.total_token_usage().await.unwrap_or_default();
+        let rendered = match prompt::render_operation(
+            request.operation,
+            &request.workspace_id,
+            generation,
+            &frozen_context,
+            &request.source,
+        ) {
+            Ok(rendered) => rendered,
+            Err(err) => {
+                return self
+                    .finish_failure(
+                        &parent_session,
+                        &trunk,
+                        &request,
+                        generation,
+                        history_before,
+                        PromptAssistantError::InvalidInput(err.to_string()),
+                        /*usage*/ None,
+                    )
+                    .await;
+            }
+        };
+        let run = async {
+            let turn_id = submit_operation(&trunk, rendered).await?;
+            wait_for_operation(
+                &trunk,
+                &parent_session,
+                &request.workspace_id,
+                generation,
+                &turn_id,
+                &operation_cancel,
+                &self.shutdown,
+            )
+            .await
+        }
+        .await;
+
+        let output = match run {
+            Ok(Some(output)) => output,
+            Ok(None) => {
+                return self
+                    .finish_failure(
+                        &parent_session,
+                        &trunk,
+                        &request,
+                        generation,
+                        history_before,
+                        PromptAssistantError::Failed(
+                            "completed operation returned no candidate".to_string(),
+                        ),
+                        /*usage*/ None,
+                    )
+                    .await;
+            }
+            Err(err) => {
+                return self
+                    .finish_failure(
+                        &parent_session,
+                        &trunk,
+                        &request,
+                        generation,
+                        history_before,
+                        err,
+                        /*usage*/ None,
+                    )
+                    .await;
+            }
+        };
+        let usage = trunk
+            .session
+            .total_token_usage()
+            .await
+            .map(|usage_after| token_usage_delta(&usage_before, &usage_after));
+        let (candidate, review) = match prompt::parse_output(&output) {
+            Ok(parsed) => parsed,
+            Err(err) => {
+                return self
+                    .finish_failure(
+                        &parent_session,
+                        &trunk,
+                        &request,
+                        generation,
+                        history_before,
+                        PromptAssistantError::Failed(format!("{err:#}")),
+                        usage,
+                    )
+                    .await;
+            }
+        };
+        if let Err(error) = validate_candidate(&candidate, review.status) {
+            return self
+                .finish_failure(
+                    &parent_session,
+                    &trunk,
+                    &request,
+                    generation,
+                    history_before,
+                    error,
+                    usage,
+                )
+                .await;
+        }
+        let result = PromptAssistantResult {
+            workspace_id: request.workspace_id.clone(),
+            child_thread_id: trunk.session.thread_id(),
+            operation: request.operation,
+            generation,
+            candidate_hash: candidate_hash(&candidate),
+            candidate,
+            review,
+            model: trunk.reuse_key.model.clone(),
+            reasoning_effort: trunk.reuse_key.reasoning_effort.clone(),
+            usage,
+            policy_hash: candidate_hash(&trunk.reuse_key.effective_policy),
+        };
+        let history_after = trunk.session.clone_history().await;
+        if result.review.status == PromptAssistantReviewStatus::Blocked {
+            trunk
+                .session
+                .restore_prompt_assistant_history(&history_before)
+                .await;
+        }
+        {
+            let mut state = self.state.lock().await;
+            if !active_matches(&state, &request.workspace_id, generation) {
+                drop(state);
+                return self
+                    .finish_failure(
+                        &parent_session,
+                        &trunk,
+                        &request,
+                        generation,
+                        history_before,
+                        PromptAssistantError::Cancelled,
+                        result.usage.clone(),
+                    )
+                    .await;
+            }
+            let workspace = state
+                .workspaces
+                .get_mut(&request.workspace_id)
+                .expect("active Prompt Assistant workspace must exist");
+            if result.review.status != PromptAssistantReviewStatus::Blocked {
+                workspace.successful_turns = workspace.successful_turns.saturating_add(1);
+                workspace.successful_tokens = workspace
+                    .successful_tokens
+                    .saturating_add(approx_token_count(&request.source))
+                    .saturating_add(approx_token_count(&result.candidate));
+                workspace.child_history = Some(history_after);
+            }
+            workspace.latest = Some(result.clone());
+            workspace.applied_generation = None;
+            state.active = None;
+        }
+        let status = if result.review.status == PromptAssistantReviewStatus::Blocked {
+            PromptAssistantLifecycleStatus::Blocked
+        } else {
+            PromptAssistantLifecycleStatus::Completed
+        };
+        persist_result(
+            &parent_session,
+            &result,
+            status,
+            /*applied*/ false,
+            result.usage.clone(),
+            /*error*/ None,
+        )
+        .await;
+        Ok(result)
+    }
+
+    async fn ensure_trunk(
+        &self,
+        parent_session: Arc<Session>,
+        model: &str,
+    ) -> Result<Arc<PromptAssistantTrunk>, PromptAssistantError> {
+        let parent_turn = parent_session
+            .new_default_turn_with_sub_id(format!("prompt-assistant-{}", Uuid::now_v7()))
+            .await;
+        let model_info = parent_session
+            .services
+            .models_manager
+            .get_model_info(model, &parent_turn.config.to_models_manager_config())
+            .await;
+        let reasoning_effort = model_info
+            .supported_reasoning_levels
+            .iter()
+            .find(|preset| preset.effort == codex_protocol::openai_models::ReasoningEffort::Low)
+            .map(|preset| preset.effort.clone())
+            .or_else(|| model_info.default_reasoning_level.clone());
+        let model_instructions = model_info.get_model_instructions(/*personality*/ None);
+        let selection = ModelSelection {
+            model: model.to_string(),
+            reasoning_effort,
+        };
+        let effective_policy = load_policy(parent_turn.config.codex_home.as_path())
+            .map_err(|err| PromptAssistantError::Failed(format!("{err:#}")))?;
+        let config = build_child_config(&parent_turn, &effective_policy, &selection)
+            .map_err(|err| PromptAssistantError::Failed(format!("{err:#}")))?;
+        let reuse_key = ReuseKey::new(
+            &config,
+            &selection.model,
+            selection.reasoning_effort.clone(),
+            &model_instructions,
+            &effective_policy,
+        );
+        let (stale, attempt_recovery) = {
+            let mut state = self.state.lock().await;
+            match state.trunk.as_ref() {
+                Some(trunk) if trunk.reuse_key == reuse_key => return Ok(Arc::clone(trunk)),
+                Some(_) => (state.trunk.take(), false),
+                None => {
+                    let attempt_recovery = !state.recovery_attempted;
+                    state.recovery_attempted = true;
+                    (None, attempt_recovery)
+                }
+            }
+        };
+        if let Some(stale) = stale {
+            shutdown_trunk(&stale).await;
+        }
+        let recovered = if attempt_recovery {
+            recover_latest_session(
+                &parent_session,
+                &selection.model,
+                &config.model_provider_id,
+                &model_instructions,
+                &candidate_hash(&effective_policy),
+            )
+            .await
+        } else {
+            None
+        };
+        let initial_history = recovered
+            .as_ref()
+            .map(|recovered| recovered.initial_history.clone());
+        let trunk = match spawn_trunk(
+            config.clone(),
+            Arc::clone(&parent_session),
+            Arc::clone(&parent_turn),
+            reuse_key.clone(),
+            initial_history,
+            &self.shutdown,
+        )
+        .await
+        {
+            Ok(trunk) => Arc::new(trunk),
+            Err(_) if recovered.is_some() => Arc::new(
+                spawn_trunk(
+                    config,
+                    Arc::clone(&parent_session),
+                    parent_turn,
+                    reuse_key,
+                    /*initial_history*/ None,
+                    &self.shutdown,
+                )
+                .await?,
+            ),
+            Err(err) => return Err(err),
+        };
+        let mut state = self.state.lock().await;
+        if let Some(recovered) = recovered
+            && trunk.session.thread_id() == recovered.child_thread_id
+        {
+            for workspace in recovered.workspaces {
+                state.next_generation = state.next_generation.max(workspace.latest.generation);
+                state
+                    .workspaces
+                    .entry(workspace.workspace_id)
+                    .or_insert(WorkspaceState {
+                        frozen_context: workspace.frozen_context,
+                        model: workspace.latest.model.clone(),
+                        child_history: Some(workspace.history),
+                        successful_turns: workspace.successful_turns,
+                        successful_tokens: workspace.successful_tokens,
+                        latest: Some(workspace.latest),
+                        applied_generation: workspace.applied_generation,
+                    });
+            }
+        }
+        state.trunk = Some(Arc::clone(&trunk));
+        Ok(trunk)
+    }
+
+    async fn recover_before_workspace_lookup(
+        &self,
+        parent_session: Arc<Session>,
+    ) -> Result<(), PromptAssistantError> {
+        let should_attempt = {
+            let state = self.state.lock().await;
+            state.workspaces.is_empty() && !state.recovery_attempted
+        };
+        if !should_attempt {
+            return Ok(());
+        }
+        let Some(model) = latest_session_model(&parent_session).await else {
+            self.state.lock().await.recovery_attempted = true;
+            return Ok(());
+        };
+        let model = parent_session
+            .services
+            .models_manager
+            .resolve_prompt_assistant_model(Some(&model))
+            .await
+            .map_err(PromptAssistantError::InvalidInput)?;
+        self.ensure_trunk(parent_session, &model).await?;
+        Ok(())
+    }
+
+    async fn finish_failure(
+        &self,
+        parent_session: &Session,
+        trunk: &PromptAssistantTrunk,
+        request: &PromptAssistantRequest,
+        generation: u64,
+        history_before: crate::context_manager::ContextManager,
+        error: PromptAssistantError,
+        usage: Option<TokenUsage>,
+    ) -> Result<PromptAssistantResult, PromptAssistantError> {
+        trunk
+            .session
+            .restore_prompt_assistant_history(&history_before)
+            .await;
+        self.clear_active(&request.workspace_id, generation).await;
+        self.remove_empty_start_workspace(request).await;
+        persist_error(
+            parent_session,
+            trunk.session.thread_id(),
+            request,
+            generation,
+            &trunk.reuse_key.model,
+            trunk.reuse_key.reasoning_effort.clone(),
+            candidate_hash(&trunk.reuse_key.effective_policy),
+            usage,
+            &error,
+        )
+        .await;
+        Err(error)
+    }
+
+    async fn clear_active(&self, workspace_id: &str, generation: u64) {
+        let mut state = self.state.lock().await;
+        if active_matches(&state, workspace_id, generation) {
+            state.active = None;
+        }
+    }
+
+    async fn remove_empty_start_workspace(&self, request: &PromptAssistantRequest) {
+        if !matches!(
+            request.operation,
+            PromptAssistantOperation::Translate | PromptAssistantOperation::Generate
+        ) {
+            return;
+        }
+        let mut state = self.state.lock().await;
+        if state
+            .workspaces
+            .get(&request.workspace_id)
+            .is_some_and(|workspace| workspace.latest.is_none())
+        {
+            state.workspaces.remove(&request.workspace_id);
+        }
+    }
+
+    async fn require_candidate(
+        &self,
+        workspace_id: &str,
+        expected_generation: u64,
+        expected_candidate_hash: Option<&str>,
+        allow_blocked: bool,
+    ) -> Result<String, PromptAssistantError> {
+        let state = self.state.lock().await;
+        let result = state
+            .workspaces
+            .get(workspace_id)
+            .ok_or_else(|| PromptAssistantError::WorkspaceNotFound(workspace_id.to_string()))?
+            .latest
+            .as_ref()
+            .ok_or_else(|| {
+                PromptAssistantError::InvalidInput("workspace has no candidate".to_string())
+            })?;
+        if result.generation != expected_generation
+            || expected_candidate_hash.is_some_and(|expected| result.candidate_hash != expected)
+        {
+            return Err(PromptAssistantError::InvalidInput(
+                "candidate generation or hash no longer matches the active workspace".to_string(),
+            ));
+        }
+        if !allow_blocked && result.review.status == PromptAssistantReviewStatus::Blocked {
+            return Err(PromptAssistantError::Blocked);
+        }
+        Ok(result.candidate.clone())
+    }
+}
+
+fn active_matches(state: &ManagerState, workspace_id: &str, generation: u64) -> bool {
+    state.active.as_ref().is_some_and(|active| {
+        active.workspace_id == workspace_id && active.generation == generation
+    })
+}
+
+fn canonical_workspace_id(workspace_id: &str) -> Result<(), PromptAssistantError> {
+    let parsed = Uuid::parse_str(workspace_id)
+        .map_err(|err| PromptAssistantError::InvalidInput(err.to_string()))?;
+    if parsed.hyphenated().to_string() != workspace_id {
+        return Err(PromptAssistantError::InvalidInput(
+            "workspace id must be a canonical lowercase UUID".to_string(),
+        ));
+    }
+    Ok(())
+}
+
+fn validate_text(label: &str, text: &str, max_tokens: usize) -> Result<(), PromptAssistantError> {
+    if text.trim().is_empty() {
+        return Err(PromptAssistantError::InvalidInput(format!(
+            "{label} must not be empty"
+        )));
+    }
+    if approx_token_count(text) > max_tokens {
+        return Err(PromptAssistantError::InvalidInput(format!(
+            "{label} exceeds the {max_tokens}-token limit"
+        )));
+    }
+    Ok(())
+}
+
+fn validate_candidate(
+    candidate: &str,
+    status: PromptAssistantReviewStatus,
+) -> Result<(), PromptAssistantError> {
+    if status != PromptAssistantReviewStatus::Blocked {
+        validate_text("candidate", candidate, MAX_CANDIDATE_TOKENS)?;
+    }
+    Ok(())
+}
+
+fn ensure_workspace_capacity(
+    workspace: &WorkspaceState,
+    source: &str,
+) -> Result<(), PromptAssistantError> {
+    if workspace.successful_turns >= MAX_SUCCESSFUL_TURNS {
+        return Err(PromptAssistantError::InvalidInput(format!(
+            "workspace reached the {MAX_SUCCESSFUL_TURNS}-turn limit"
+        )));
+    }
+    if workspace
+        .successful_tokens
+        .saturating_add(approx_token_count(source))
+        > MAX_WORKSPACE_TOKENS
+    {
+        return Err(PromptAssistantError::InvalidInput(format!(
+            "workspace exceeds the {MAX_WORKSPACE_TOKENS}-token aggregate limit"
+        )));
+    }
+    Ok(())
+}
+
+pub(super) fn candidate_hash(candidate: &str) -> String {
+    sha1_digest(candidate.as_bytes())
+        .iter()
+        .map(|byte| format!("{byte:02x}"))
+        .collect()
+}
+
+fn token_usage_delta(start: &TokenUsage, end: &TokenUsage) -> TokenUsage {
+    TokenUsage {
+        input_tokens: (end.input_tokens - start.input_tokens).max(0),
+        cached_input_tokens: (end.cached_input_tokens - start.cached_input_tokens).max(0),
+        cache_write_input_tokens: (end.cache_write_input_tokens - start.cache_write_input_tokens)
+            .max(0),
+        output_tokens: (end.output_tokens - start.output_tokens).max(0),
+        reasoning_output_tokens: (end.reasoning_output_tokens - start.reasoning_output_tokens)
+            .max(0),
+        total_tokens: (end.total_tokens - start.total_tokens).max(0),
+    }
+}
