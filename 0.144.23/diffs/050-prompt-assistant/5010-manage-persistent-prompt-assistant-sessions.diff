+#[test]
+fn parent_lifecycle_is_the_resume_index_without_thread_list_discovery() {
+    let parent_thread_id = codex_protocol::ThreadId::new();
+    let older_child = codex_protocol::ThreadId::new();
+    let latest_child = codex_protocol::ThreadId::new();
+    let lifecycle = |child_thread_id, generation, model: &str| {
+        RolloutItem::PromptAssistantLifecycle(PromptAssistantLifecycleItem {
+            parent_thread_id,
+            child_thread_id,
+            workspace_id: format!("00000000-0000-4000-8000-{generation:012}"),
+            operation: PromptAssistantOperation::Generate,
+            generation,
+            model: model.to_string(),
+            reasoning_effort: None,
+            policy_hash: "policy-hash".to_string(),
+            status: PromptAssistantLifecycleStatus::Completed,
+            applied: false,
+            candidate_hash: Some(format!("hash-{generation}")),
+            usage: None,
+            error: None,
+        })
+    };
+    let parent_items = vec![
+        lifecycle(older_child, 1, "older-model"),
+        lifecycle(latest_child, 2, "latest-model"),
+    ];
+
+    let indexed = latest_session_lifecycle(parent_thread_id, &parent_items, None, None)
+        .expect("latest parent lifecycle");
+    assert_eq!(indexed.child_thread_id, latest_child);
+    assert_eq!(indexed.model, "latest-model");
+    assert!(
+        latest_session_lifecycle(
+            parent_thread_id,
+            &parent_items,
+            Some("older-model"),
+            Some("policy-hash"),
+        )
+        .is_some_and(|item| item.child_thread_id == older_child)
+    );
+}
