+        state.next_generation = 12;
+        state
+            .workspaces
+            .insert(WORKSPACE_ID.to_string(), workspace());
+        state.active = Some(ActiveOperation {
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: 12,
+            cancel: cancel.clone(),
+        });
+    }
+
+    let error = manager
+        .cancel(PromptAssistantCancelRequest {
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: 11,
+        })
+        .await
+        .expect_err("stale cancel generation must be rejected");
+
+    assert!(matches!(error, PromptAssistantError::InvalidInput(_)));
+    assert!(!cancel.is_cancelled());
+    let state = manager.state.lock().await;
+    assert!(active_matches(&state, WORKSPACE_ID, 12));
+    assert_eq!(state.next_generation, 12);
+}
+
+#[test]
+fn workspace_and_candidate_boundaries_are_explicit() {
+    assert!(canonical_workspace_id(WORKSPACE_ID).is_ok());
+    assert!(canonical_workspace_id("not-a-workspace").is_err());
+    assert!(validate_text("source", "text", MAX_SOURCE_TOKENS).is_ok());
+    assert_eq!(candidate_hash("candidate"), candidate_hash("candidate"));
+    assert_ne!(candidate_hash("candidate"), candidate_hash("other"));
+}
+
+#[tokio::test]
+async fn effective_policy_bytes_are_part_of_the_trunk_reuse_key() {
+    let (_session, parent_context) = crate::session::tests::make_session_and_context().await;
+    let selection = ModelSelection {
+        model: "hidden-specialist".to_string(),
+        reasoning_effort: None,
+    };
+    let config =
+        build_child_config(&parent_context, "policy one", &selection).expect("build child config");
+    let first = ReuseKey::new(
+        &config,
+        &selection.model,
+        selection.reasoning_effort.clone(),
+        "selected model instructions",
+        "policy one",
+    );
+    let second = ReuseKey::new(
+        &config,
+        &selection.model,
+        selection.reasoning_effort,
+        "selected model instructions",
+        "policy two",
+    );
+    let changed_model_instructions = ReuseKey::new(
+        &config,
+        &selection.model,
+        None,
+        "changed model instructions",
+        "policy one",
+    );
+
+    assert_ne!(first, second);
+    assert_ne!(first, changed_model_instructions);
+}
