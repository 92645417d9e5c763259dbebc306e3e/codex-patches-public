+#[test]
+fn missing_policy_is_seeded_from_bundled_policy_without_replacing_model_instructions() {
+    let codex_home = tempfile::tempdir().expect("codex home");
+    assert_eq!(
+        load_policy(codex_home.path()).expect("load bundled policy"),
+        super::super::prompt::FIXED_INSTRUCTIONS
+    );
+
+    let path = codex_home.path().join(POLICY_RELATIVE_PATH);
+    assert_eq!(
+        std::fs::read_to_string(&path).expect("read seeded policy"),
+        super::super::prompt::FIXED_INSTRUCTIONS
+    );
+
+    std::fs::write(&path, "local Prompt Assistant policy").expect("write policy");
+
+    assert_eq!(
+        load_policy(codex_home.path()).expect("load local policy"),
+        "local Prompt Assistant policy"
+    );
+    assert_eq!(
+        std::fs::read_to_string(&path).expect("read retained local policy"),
+        "local Prompt Assistant policy"
+    );
+}
+
+#[test]
+fn startup_seed_is_idempotent_and_does_not_validate_or_clobber_existing_policy() {
+    let codex_home = tempfile::tempdir().expect("codex home");
+    ensure_policy_file(codex_home.path()).expect("seed policy");
+    ensure_policy_file(codex_home.path()).expect("repeat seed");
+    let path = codex_home.path().join(POLICY_RELATIVE_PATH);
+    assert_eq!(
+        std::fs::read_to_string(&path).expect("read seeded policy"),
+        super::super::prompt::FIXED_INSTRUCTIONS
+    );
+
+    std::fs::write(&path, "").expect("replace with user-owned empty policy");
+    ensure_policy_file(codex_home.path()).expect("retain existing policy");
+    assert_eq!(
