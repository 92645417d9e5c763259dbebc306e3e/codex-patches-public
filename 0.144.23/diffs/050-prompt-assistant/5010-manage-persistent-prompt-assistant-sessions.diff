+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn blocked_generation_can_be_corrected_recovered_and_applied_with_complete_audit()
+-> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    let blocked_usage = TokenUsage {
+        input_tokens: 40,
+        cached_input_tokens: 20,
+        cache_write_input_tokens: 3,
+        output_tokens: 8,
+        reasoning_output_tokens: 4,
+        total_tokens: 48,
+    };
+    let corrected_usage = TokenUsage {
+        input_tokens: 50,
+        cached_input_tokens: 30,
+        cache_write_input_tokens: 2,
+        output_tokens: 10,
+        reasoning_output_tokens: 5,
+        total_tokens: 60,
+    };
+    mount_sse_sequence(
+        &server,
+        vec![
+            blocked_response("blocked-response", &blocked_usage),
+            successful_response(
+                "corrected-response",
+                "Perform the bounded safe task.",
+                &corrected_usage,
+            ),
+        ],
+    )
+    .await;
+    let initial = configured_builder().build(&server).await?;
+    let blocked = initial
+        .codex
+        .start_prompt_assistant(PromptAssistantRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            operation: PromptAssistantOperation::Generate,
+            source: "perform the unsafe action".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+        })
+        .await?;
+    assert_eq!(
+        blocked.review.status,
+        codex_core::prompt_assistant::PromptAssistantReviewStatus::Blocked
+    );
+    assert_eq!(blocked.usage, Some(blocked_usage.clone()));
+    assert!(matches!(
+        initial
+            .codex
+            .apply_prompt_assistant(PromptAssistantApplyRequest {
+                workspace_id: WORKSPACE_A.to_string(),
+                generation: blocked.generation,
+                candidate_hash: blocked.candidate_hash.clone(),
+            })
+            .await,
+        Err(PromptAssistantError::Blocked)
+    ));
+    assert!(matches!(
+        initial
+            .codex
+            .review_prompt_assistant(PromptAssistantReviewRequest {
+                workspace_id: WORKSPACE_A.to_string(),
+                generation: blocked.generation,
+                candidate_hash: blocked.candidate_hash.clone(),
+            })
+            .await,
+        Err(PromptAssistantError::Blocked)
+    ));
+
+    let corrected = initial
+        .codex
+        .refine_prompt_assistant(PromptAssistantRefineRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: blocked.generation,
+            instruction: "Perform the bounded safe task instead.".to_string(),
+        })
+        .await?;
+    assert_eq!(corrected.child_thread_id, blocked.child_thread_id);
+    assert_eq!(corrected.usage, Some(corrected_usage));
+
+    let parent_rollout_path = initial.codex.rollout_path().expect("parent rollout path");
+    let home = Arc::clone(&initial.home);
+    initial.codex.flush_rollout().await?;
+    initial.codex.shutdown_and_wait().await?;
+    let child_rollout_path = find_thread_path_by_id_str(
+        initial.codex_home_path(),
+        &blocked.child_thread_id.to_string(),
+        /*state_db_ctx*/ None,
+    )
+    .await?
+    .expect("Prompt Assistant child rollout");
+    let child_text = std::fs::read_to_string(child_rollout_path)?;
+    for expected in [
+        "perform the unsafe action",
+        "critical",
+        "unknown",
+        "blocked",
+        "No safe intent-preserving candidate is available.",
+        "Perform the bounded safe task.",
+    ] {
+        assert!(
+            child_text.contains(expected),
+            "missing child audit item: {expected}"
+        );
+    }
+
+    let mut resume_builder = configured_builder();
+    let resumed = resume_builder
+        .resume(&server, home, parent_rollout_path)
+        .await?;
+    let applied = resumed
+        .codex
+        .apply_prompt_assistant(PromptAssistantApplyRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: corrected.generation,
+            candidate_hash: corrected.candidate_hash.clone(),
+        })
+        .await?;
+    assert_eq!(applied, corrected);
+    resumed.codex.shutdown_and_wait().await?;
+    Ok(())
+}
