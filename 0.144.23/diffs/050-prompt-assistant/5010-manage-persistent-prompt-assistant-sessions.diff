+#[test]
+fn recovery_keeps_a_b_a_workspace_histories_isolated() {
+    let parent_thread_id = codex_protocol::ThreadId::new();
+    let child_thread_id = codex_protocol::ThreadId::new();
+    let workspace_a = "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa";
+    let workspace_b = "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb";
+    let operations = [
+        (
+            workspace_a,
+            PromptAssistantOperation::Generate,
+            1,
+            "a one",
+            "A one",
+        ),
+        (
+            workspace_b,
+            PromptAssistantOperation::Generate,
+            2,
+            "b one",
+            "B one",
+        ),
+        (
+            workspace_a,
+            PromptAssistantOperation::Refine,
+            3,
+            "a two",
+            "A two",
+        ),
+    ];
+    let mut child_items = Vec::new();
+    let mut parent_items = Vec::new();
+    for (workspace_id, operation, generation, source, candidate) in operations {
+        let output = serde_json::json!({
+            "candidate": candidate,
+            "review": {
+                "intent_summary": "Preserve the workspace intent.",
+                "risk_level": "low",
+                "user_authorization": "high",
+                "status": "pass",
+                "rationale": "ready"
+            }
+        })
+        .to_string();
+        child_items.push(RolloutItem::EventMsg(EventMsg::UserMessage(
+            UserMessageEvent {
+                message: prompt::render_operation(
+                    operation,
+                    workspace_id,
+                    generation,
+                    "frozen context",
+                    source,
+                )
+                .expect("render operation"),
+                ..Default::default()
+            },
+        )));
+        child_items.push(RolloutItem::EventMsg(EventMsg::TurnComplete(
+            TurnCompleteEvent {
+                turn_id: format!("turn-{generation}"),
+                last_agent_message: Some(output),
+                error: None,
+                started_at: None,
+                completed_at: None,
+                duration_ms: None,
+                time_to_first_token_ms: None,
+            },
+        )));
+        parent_items.push(RolloutItem::PromptAssistantLifecycle(
+            PromptAssistantLifecycleItem {
+                parent_thread_id,
+                child_thread_id,
+                workspace_id: workspace_id.to_string(),
+                operation,
+                generation,
+                model: "hidden-specialist".to_string(),
+                reasoning_effort: None,
+                policy_hash: "policy-hash".to_string(),
+                status: PromptAssistantLifecycleStatus::Completed,
+                applied: false,
+                candidate_hash: Some(candidate_hash(candidate)),
+                usage: None,
+                error: None,
+            },
+        ));
+    }
+
+    let recovered = recover_workspaces(
+        parent_thread_id,
+        child_thread_id,
+        &parent_items,
+        &child_items,
+        "policy-hash",
+    );
+    let a = recovered
+        .iter()
+        .find(|workspace| workspace.workspace_id == workspace_a)
+        .expect("workspace A");
+    let b = recovered
+        .iter()
+        .find(|workspace| workspace.workspace_id == workspace_b)
+        .expect("workspace B");
+    let a_history = serde_json::to_string(a.history.raw_items()).expect("serialize A history");
+    let b_history = serde_json::to_string(b.history.raw_items()).expect("serialize B history");
+
+    assert!(a_history.contains("a one"));
+    assert!(a_history.contains("a two"));
+    assert!(!a_history.contains("b one"));
+    assert!(b_history.contains("b one"));
+    assert!(!b_history.contains("a one"));
+    assert_eq!(a.successful_turns, 2);
+    assert_eq!(b.successful_turns, 1);
+}
