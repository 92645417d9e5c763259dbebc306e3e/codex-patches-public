+use codex_protocol::ThreadId;
+use codex_protocol::openai_models::ReasoningEffort;
+use codex_protocol::prompt_assistant::PromptAssistantLifecycleItem;
+use codex_protocol::prompt_assistant::PromptAssistantLifecycleStatus;
+use codex_protocol::protocol::RolloutItem;
+use codex_protocol::protocol::TokenUsage;
+
+use crate::session::session::Session;
+
+use super::PromptAssistantError;
+use super::PromptAssistantRequest;
+use super::PromptAssistantResult;
+
+pub(super) async fn persist_result(
+    parent_session: &Session,
+    result: &PromptAssistantResult,
+    status: PromptAssistantLifecycleStatus,
+    applied: bool,
+    usage: Option<TokenUsage>,
+    error: Option<String>,
+) {
+    parent_session
+        .persist_rollout_items(&[RolloutItem::PromptAssistantLifecycle(
+            PromptAssistantLifecycleItem {
+                parent_thread_id: parent_session.thread_id(),
+                child_thread_id: result.child_thread_id,
+                workspace_id: result.workspace_id.clone(),
+                operation: result.operation,
+                generation: result.generation,
+                model: result.model.clone(),
+                reasoning_effort: result.reasoning_effort.clone(),
+                policy_hash: result.policy_hash.clone(),
+                status,
+                applied,
+                candidate_hash: Some(result.candidate_hash.clone()),
+                usage,
+                error,
+            },
+        )])
+        .await;
+}
+
+#[allow(clippy::too_many_arguments)]
+pub(super) async fn persist_error(
+    parent_session: &Session,
+    child_thread_id: ThreadId,
+    request: &PromptAssistantRequest,
+    generation: u64,
+    model: &str,
+    reasoning_effort: Option<ReasoningEffort>,
+    policy_hash: String,
+    usage: Option<TokenUsage>,
+    error: &PromptAssistantError,
+) {
+    let status = if matches!(error, PromptAssistantError::Cancelled) {
+        PromptAssistantLifecycleStatus::Cancelled
+    } else {
+        PromptAssistantLifecycleStatus::Failed
+    };
+    parent_session
+        .persist_rollout_items(&[RolloutItem::PromptAssistantLifecycle(
+            PromptAssistantLifecycleItem {
+                parent_thread_id: parent_session.thread_id(),
+                child_thread_id,
+                workspace_id: request.workspace_id.clone(),
+                operation: request.operation,
+                generation,
+                model: model.to_string(),
+                reasoning_effort,
+                policy_hash,
+                status,
+                applied: false,
+                candidate_hash: None,
+                usage,
+                error: Some(error.to_string()),
+            },
+        )])
+        .await;
+}
