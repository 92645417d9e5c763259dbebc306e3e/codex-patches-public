+use pretty_assertions::assert_eq;
+use serde_json::json;
+
+use super::*;
+
+#[test]
+fn output_contract_accepts_candidates_and_fail_closes_blocked_results() {
+    assert_eq!(
+        parse_output(
+            r#"{"candidate":"Do the bounded task.","review":{"intent_summary":"Perform one bounded task.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"Intent preserved."}}"#,
+        )
+        .expect("parse passing output"),
+        (
+            "Do the bounded task.".to_string(),
+            PromptAssistantReview {
+                intent_summary: "Perform one bounded task.".to_string(),
+                risk_level: GuardianRiskLevel::Low,
+                user_authorization: GuardianUserAuthorization::High,
+                status: PromptAssistantReviewStatus::Pass,
+                rationale: "Intent preserved.".to_string(),
+            },
+        )
+    );
+    assert_eq!(
+        parse_output(
+            r#"{"candidate":"","review":{"intent_summary":"Perform an unsafe action.","risk_level":"critical","user_authorization":"unknown","status":"blocked","rationale":"Cannot preserve safely."}}"#,
+        )
+        .expect("parse canonical blocked output")
+        .0,
+        ""
+    );
+    assert!(
+        parse_output(
+            r#"{"candidate":"unsafe","review":{"intent_summary":"Perform an unsafe action.","risk_level":"critical","user_authorization":"unknown","status":"blocked","rationale":"Cannot preserve safely."}}"#,
+        )
+        .is_err()
+    );
+    assert!(
+        parse_output(
+            r#"{"candidate":" ","review":{"intent_summary":"Perform an unsafe action.","risk_level":"critical","user_authorization":"unknown","status":"blocked","rationale":"Cannot preserve safely."}}"#,
+        )
+        .is_err()
+    );
+}
+
+#[test]
+fn output_contract_rejects_non_ascii_generated_fields() {
+    for output in [
+        r#"{"candidate":"ASCII candidate.","review":{"intent_summary":"ASCII intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"Contains \u2014 punctuation."}}"#,
+        r#"{"candidate":"\u8f93\u51fa\u4e2d\u6587","review":{"intent_summary":"ASCII intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII rationale."}}"#,
+        r#"{"candidate":"ASCII candidate.","review":{"intent_summary":"\u4e2d\u6587 intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII rationale."}}"#,
+        r#"{"candidate":"ASCII\u0000candidate.","review":{"intent_summary":"ASCII intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII rationale."}}"#,
+        r#"{"candidate":"ASCII candidate.","review":{"intent_summary":"ASCII\u001bintent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII rationale."}}"#,
+        r#"{"candidate":"ASCII candidate.","review":{"intent_summary":"ASCII intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII\u0007 rationale."}}"#,
+    ] {
+        assert!(
+            parse_output(output).is_err(),
+            "accepted non-ASCII output: {output}"
+        );
+    }
+
+    assert!(
+        parse_output(
+            r#"{"candidate":"First line.\n\tSecond line.","review":{"intent_summary":"ASCII intent.","risk_level":"low","user_authorization":"high","status":"pass","rationale":"ASCII rationale."}}"#,
+        )
+        .is_ok()
+    );
+}
+
+#[test]
+fn output_schema_requires_the_complete_front_review() {
+    let schema = output_schema();
+    assert_eq!(
+        schema["properties"]["review"]["required"],
+        json!([
+            "intent_summary",
+            "risk_level",
+            "user_authorization",
+            "status",
+            "rationale"
+        ])
+    );
+}
+
+#[test]
+fn operation_envelope_keeps_context_and_source_as_data() {
+    let rendered = render_operation(
+        PromptAssistantOperation::Translate,
+        "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
+        7,
+        "background",
+        "\u{5904}\u{7406}\u{8fd9}\u{4e2a}\u{4efb}\u{52a1}",
+    )
+    .expect("render operation");
+    let value: serde_json::Value = serde_json::from_str(&rendered).expect("operation JSON");
+
+    assert_eq!(value["parent_context"], "background");
+    assert_eq!(
+        value["source"],
+        "\u{5904}\u{7406}\u{8fd9}\u{4e2a}\u{4efb}\u{52a1}"
+    );
+    assert_eq!(value["generation"], 7);
+}
