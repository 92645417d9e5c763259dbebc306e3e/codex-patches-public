+#[tokio::test]
+async fn cancellation_changes_the_generation_before_stale_completion_can_commit() {
+    let manager = PromptAssistantSessionManager::default();
+    let cancel = CancellationToken::new();
+    {
+        let mut state = manager.state.lock().await;
+        state.next_generation = 4;
+        state
+            .workspaces
+            .insert(WORKSPACE_ID.to_string(), workspace());
+        state.active = Some(ActiveOperation {
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: 4,
+            cancel: cancel.clone(),
+        });
+    }
+
+    manager
+        .cancel(PromptAssistantCancelRequest {
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: 4,
+        })
+        .await
+        .expect("cancel active operation");
+
+    let state = manager.state.lock().await;
+    assert!(cancel.is_cancelled());
+    assert!(state.active.is_none());
+    assert_eq!(state.next_generation, 5);
