+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn persistent_prompt_assistant_isolated_workspaces_preserve_usage_and_rollouts() -> Result<()>
+{
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    let usages = [
+        TokenUsage {
+            input_tokens: 100,
+            cached_input_tokens: 60,
+            cache_write_input_tokens: 7,
+            output_tokens: 20,
+            reasoning_output_tokens: 12,
+            total_tokens: 120,
+        },
+        TokenUsage {
+            input_tokens: 80,
+            cached_input_tokens: 40,
+            cache_write_input_tokens: 5,
+            output_tokens: 15,
+            reasoning_output_tokens: 8,
+            total_tokens: 95,
+        },
+        TokenUsage {
+            input_tokens: 90,
+            cached_input_tokens: 70,
+            cache_write_input_tokens: 3,
+            output_tokens: 18,
+            reasoning_output_tokens: 9,
+            total_tokens: 108,
+        },
+        TokenUsage {
+            input_tokens: 95,
+            cached_input_tokens: 75,
+            cache_write_input_tokens: 2,
+            output_tokens: 17,
+            reasoning_output_tokens: 10,
+            total_tokens: 112,
+        },
+    ];
+    let responses = mount_sse_sequence(
+        &server,
+        vec![
+            successful_response("response-a1", "candidate A one", &usages[0]),
+            successful_response("response-b1", "candidate B one", &usages[1]),
+            successful_response("response-a2", "candidate A two", &usages[2]),
+            successful_response("response-a3", "candidate A two", &usages[3]),
+        ],
+    )
+    .await;
+    let test = configured_builder().build(&server).await?;
+
+    let a1 = test
+        .codex
+        .start_prompt_assistant(PromptAssistantRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            operation: PromptAssistantOperation::Generate,
+            source: "source A one".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+        })
+        .await?;
+    let b1 = test
+        .codex
+        .start_prompt_assistant(PromptAssistantRequest {
+            workspace_id: WORKSPACE_B.to_string(),
+            operation: PromptAssistantOperation::Generate,
+            source: "source B one".to_string(),
+            model: None,
+        })
+        .await?;
+    let a2 = test
+        .codex
+        .refine_prompt_assistant(PromptAssistantRefineRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: a1.generation,
+            instruction: "refine A two".to_string(),
+        })
+        .await?;
+    let a3 = test
+        .codex
+        .review_prompt_assistant(PromptAssistantReviewRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: a2.generation,
+            candidate_hash: a2.candidate_hash.clone(),
+        })
+        .await?;
+
+    assert_eq!(
+        [
+            a1.child_thread_id,
+            b1.child_thread_id,
+            a2.child_thread_id,
+            a3.child_thread_id,
+        ],
+        [a1.child_thread_id; 4]
+    );
+    assert_eq!(
+        [
+            a1.usage.clone(),
+            b1.usage.clone(),
+            a2.usage.clone(),
+            a3.usage.clone(),
+        ],
+        usages.clone().map(Some)
+    );
+
+    let captured = responses.requests();
+    assert_eq!(captured.len(), 4);
+    let expected_cache_key = format!("prompt-assistant:{}", test.session_configured.thread_id);
+    let child_thread_id = a1.child_thread_id.to_string();
+    for request in &captured {
+        let body = request.body_json();
+        assert_eq!(
+            body["prompt_cache_key"].as_str(),
+            Some(expected_cache_key.as_str())
+        );
+        assert_eq!(
+            body["client_metadata"]["thread_id"].as_str(),
+            Some(child_thread_id.as_str())
+        );
+        assert_eq!(body["instructions"], "selected hidden model instructions");
+        assert_eq!(body["tools"].as_array().map(Vec::len), Some(0));
+        assert!(body.to_string().contains("Codex Prompt Assistant"));
+    }
+    let b_request = captured[1].body_json().to_string();
+    assert!(!b_request.contains("source A one"));
+    assert!(!b_request.contains("candidate A one"));
+    let a_refine_request = captured[2].body_json().to_string();
+    assert!(a_refine_request.contains("source A one"));
+    assert!(a_refine_request.contains("candidate A one"));
+    assert!(!a_refine_request.contains("source B one"));
+    assert!(!a_refine_request.contains("candidate B one"));
+
+    let parent_rollout_path = test.codex.rollout_path().expect("parent rollout path");
+    test.codex.flush_rollout().await?;
+    test.codex.shutdown_and_wait().await?;
+    let child_rollout_path = find_thread_path_by_id_str(
+        test.codex_home_path(),
+        &a1.child_thread_id.to_string(),
+        /*state_db_ctx*/ None,
+    )
+    .await?
+    .expect("Prompt Assistant child rollout");
+    let (parent_items, _, parent_errors) =
+        RolloutRecorder::load_rollout_items(&parent_rollout_path).await?;
+    let (child_items, _, child_errors) =
+        RolloutRecorder::load_rollout_items(&child_rollout_path).await?;
+    assert_eq!((parent_errors, child_errors), (0, 0));
+    let lifecycle = parent_items
+        .iter()
+        .filter_map(|item| match item {
+            RolloutItem::PromptAssistantLifecycle(item)
+                if item.status == PromptAssistantLifecycleStatus::Completed =>
+            {
+                Some(item)
+            }
+            _ => None,
+        })
+        .collect::<Vec<_>>();
+    assert_eq!(lifecycle.len(), 4);
+    assert_eq!(
+        lifecycle
+            .iter()
+            .map(|item| item.usage.clone())
+            .collect::<Vec<_>>(),
+        usages.into_iter().map(Some).collect::<Vec<_>>()
+    );
+    let parent_text = std::fs::read_to_string(parent_rollout_path)?;
+    assert!(!parent_text.contains("source A one"));
+    assert!(!parent_text.contains("candidate A one"));
+    let child_text = std::fs::read_to_string(child_rollout_path)?;
+    for expected in [
+        "source A one",
+        "candidate A one",
+        "source B one",
+        "candidate B one",
+        "refine A two",
+        "candidate A two",
+        "token_count",
+    ] {
+        assert!(
+            child_text.contains(expected),
+            "missing child audit item: {expected}"
+        );
+    }
+    assert!(child_items.len() > lifecycle.len());
+    Ok(())
+}
