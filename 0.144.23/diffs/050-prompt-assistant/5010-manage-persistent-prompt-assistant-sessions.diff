+use pretty_assertions::assert_eq;
+
+use super::*;
+
+const WORKSPACE_ID: &str = "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa";
+
+#[tokio::test]
+async fn first_start_byte_progress_is_forwarded_with_workspace_generation_identity() {
+    let (tx_event, rx_event) = async_channel::unbounded();
+    for (byte_count, reset) in [(0, true), (137, false)] {
+        forward_progress_event(
+            tx_event.clone(),
+            WORKSPACE_ID,
+            /*generation*/ 9,
+            ResponseOutputBytesDeltaEvent {
+                thread_id: "child-thread".to_string(),
+                turn_id: "child-turn".to_string(),
+                request_id: "request".to_string(),
+                byte_count,
+                ttfb: Some(0.25),
+                output_tokens_per_second: None,
+                reset,
+            },
+        )
+        .await;
+
+        let event = rx_event.recv().await.expect("forwarded progress event");
+
+        assert_eq!(event.id, WORKSPACE_ID);
+        let EventMsg::PromptAssistantProgress(progress) = event.msg else {
+            panic!("expected projected Prompt Assistant progress");
+        };
+        assert_eq!(
+            progress,
+            PromptAssistantProgressEvent {
+                workspace_id: WORKSPACE_ID.to_string(),
+                generation: 9,
+                byte_count,
+                reset,
+            }
+        );
+    }
+}
