+#[derive(Clone, Debug, PartialEq)]
+pub(super) struct ReuseKey {
+    pub(super) model: String,
+    pub(super) provider_id: String,
+    pub(super) provider: codex_model_provider_info::ModelProviderInfo,
+    pub(super) reasoning_effort: Option<codex_protocol::openai_models::ReasoningEffort>,
+    pub(super) model_instructions: String,
+    pub(super) effective_policy: String,
+}
+
+impl ReuseKey {
+    pub(super) fn new(
+        config: &Config,
+        model: &str,
+        reasoning_effort: Option<codex_protocol::openai_models::ReasoningEffort>,
+        model_instructions: &str,
+        effective_policy: &str,
+    ) -> Self {
+        Self {
+            model: model.to_string(),
+            provider_id: config.model_provider_id.clone(),
+            provider: config.model_provider.clone(),
+            reasoning_effort,
+            model_instructions: model_instructions.to_string(),
+            effective_policy: effective_policy.to_string(),
+        }
+    }
+}
+
+pub(super) async fn spawn_trunk(
+    config: Config,
+    parent_session: Arc<Session>,
+    parent_turn: Arc<TurnContext>,
+    reuse_key: ReuseKey,
+    initial_history: Option<InitialHistory>,
+    manager_cancel: &CancellationToken,
+) -> Result<PromptAssistantTrunk, PromptAssistantError> {
+    let cancel = manager_cancel.child_token();
+    let (session, io) = Box::pin(run_isolated_prompt_assistant_thread(
+        config,
+        Arc::clone(&parent_session.services.auth_manager),
+        Arc::clone(&parent_session.services.models_manager),
+        parent_session,
+        parent_turn,
+        cancel.clone(),
+        initial_history,
+    ))
+    .await
+    .map_err(|err| PromptAssistantError::Failed(err.to_string()))?;
+
+    Ok(PromptAssistantTrunk {
+        session,
+        io,
+        cancel,
+        reuse_key,
+        base_history: ContextManager::new(),
+    })
+}
+
+pub(super) async fn submit_operation(
+    trunk: &PromptAssistantTrunk,
+    input: String,
+) -> Result<String, PromptAssistantError> {
+    trunk
+        .io
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: input,
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: Some(prompt::output_schema()),
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await
+        .map_err(|err| PromptAssistantError::Failed(err.to_string()))
+}
+
+pub(super) async fn wait_for_operation(
+    trunk: &PromptAssistantTrunk,
+    parent_session: &Session,
+    workspace_id: &str,
+    generation: u64,
+    expected_turn_id: &str,
+    operation_cancel: &CancellationToken,
+    manager_cancel: &CancellationToken,
+) -> Result<Option<String>, PromptAssistantError> {
+    let mut last_error: Option<ErrorEvent> = None;
+    loop {
+        tokio::select! {
+            _ = operation_cancel.cancelled() => {
+                interrupt_and_drain(&trunk.io, expected_turn_id).await?;
+                return Err(PromptAssistantError::Cancelled);
+            }
+            _ = manager_cancel.cancelled() => {
+                interrupt_and_drain(&trunk.io, expected_turn_id).await?;
+                return Err(PromptAssistantError::Cancelled);
+            }
+            event = trunk.io.next_event() => {
+                let event = event.map_err(|err| PromptAssistantError::Failed(err.to_string()))?;
+                if !event_matches_turn(&event, expected_turn_id) {
+                    continue;
+                }
+                match event.msg {
+                    EventMsg::TurnComplete(completed) => {
+                        if completed.last_agent_message.is_none()
+                            && let Some(error) = last_error
+                        {
+                            return Err(PromptAssistantError::Failed(error.message));
+                        }
+                        return Ok(completed.last_agent_message);
+                    }
+                    EventMsg::Error(error) => last_error = Some(error),
+                    EventMsg::TurnAborted(_) => return Err(PromptAssistantError::Cancelled),
+                    EventMsg::ResponseOutputBytesDelta(progress) => {
+                        forward_progress_event(
+                            parent_session.get_tx_event(),
+                            workspace_id,
+                            generation,
+                            progress,
+                        )
+                        .await;
+                    }
+                    _ => {}
+                }
+            }
+        }
+    }
+}
+
+async fn forward_progress_event(
+    tx_event: async_channel::Sender<Event>,
+    workspace_id: &str,
+    generation: u64,
+    progress: ResponseOutputBytesDeltaEvent,
+) {
+    let _ = tx_event
+        .send(project_progress_event(workspace_id, generation, progress))
+        .await;
+}
+
+fn project_progress_event(
+    workspace_id: &str,
+    generation: u64,
+    progress: ResponseOutputBytesDeltaEvent,
+) -> Event {
+    Event {
+        id: workspace_id.to_string(),
+        msg: EventMsg::PromptAssistantProgress(PromptAssistantProgressEvent {
+            workspace_id: workspace_id.to_string(),
+            generation,
+            byte_count: progress.byte_count,
+            reset: progress.reset,
+        }),
+    }
+}
+
+fn event_matches_turn(event: &Event, expected_turn_id: &str) -> bool {
+    if event.id != expected_turn_id {
+        return false;
+    }
+    match &event.msg {
+        EventMsg::TurnComplete(completed) => completed.turn_id == expected_turn_id,
+        EventMsg::TurnAborted(aborted) => aborted.turn_id.as_deref() == Some(expected_turn_id),
+        _ => true,
+    }
+}
+
+async fn interrupt_and_drain(
+    io: &SessionIo,
+    expected_turn_id: &str,
+) -> Result<(), PromptAssistantError> {
+    let _ = io.submit(Op::Interrupt).await;
+    tokio::time::timeout(INTERRUPT_DRAIN_TIMEOUT, async {
+        loop {
+            let event = io
+                .next_event()
+                .await
+                .map_err(|err| PromptAssistantError::Failed(err.to_string()))?;
+            if event_matches_turn(&event, expected_turn_id)
+                && matches!(
+                    event.msg,
+                    EventMsg::TurnAborted(_) | EventMsg::TurnComplete(_)
+                )
+            {
+                return Ok::<(), PromptAssistantError>(());
+            }
+        }
+    })
+    .await
+    .map_err(|_| PromptAssistantError::Failed("timed out draining cancelled operation".into()))??;
+    Ok(())
+}
+
+pub(super) async fn shutdown_trunk(trunk: &PromptAssistantTrunk) {
+    trunk.cancel.cancel();
+    let _ = trunk.io.shutdown_and_wait().await;
+}
