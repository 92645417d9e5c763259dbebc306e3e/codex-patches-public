+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn stale_cancel_does_not_cancel_the_active_generation() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    let response = successful_response("delayed-response", "candidate", &TokenUsage::default());
+    let delayed = mount_response_once(
+        &server,
+        sse_response(response).set_delay(Duration::from_secs(30)),
+    )
+    .await;
+    let test = configured_builder().build(&server).await?;
+    let codex = Arc::clone(&test.codex);
+    let start = tokio::spawn(async move {
+        codex
+            .start_prompt_assistant(PromptAssistantRequest {
+                workspace_id: WORKSPACE_A.to_string(),
+                operation: PromptAssistantOperation::Generate,
+                source: "delayed source".to_string(),
+                model: Some(HIDDEN_MODEL.to_string()),
+            })
+            .await
+    });
+    tokio::time::timeout(Duration::from_secs(5), async {
+        while delayed.requests().is_empty() {
+            tokio::time::sleep(Duration::from_millis(10)).await;
+        }
+    })
+    .await?;
+
+    let stale = test
+        .codex
+        .cancel_prompt_assistant(PromptAssistantCancelRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: 0,
+        })
+        .await;
+    assert!(matches!(stale, Err(PromptAssistantError::InvalidInput(_))));
+    assert!(!start.is_finished());
+    test.codex
+        .cancel_prompt_assistant(PromptAssistantCancelRequest {
+            workspace_id: WORKSPACE_A.to_string(),
+            generation: 1,
+        })
+        .await?;
+    assert!(matches!(start.await?, Err(PromptAssistantError::Cancelled)));
+
+    test.codex.shutdown_and_wait().await?;
+    Ok(())
+}
