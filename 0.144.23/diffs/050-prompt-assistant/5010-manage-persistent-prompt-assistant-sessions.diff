+#[test]
+fn concurrent_startup_seed_is_atomic_and_byte_exact() {
+    let codex_home = tempfile::tempdir().expect("codex home");
+    let start = std::sync::Barrier::new(8);
+    std::thread::scope(|scope| {
+        for _ in 0..8 {
+            scope.spawn(|| {
+                start.wait();
+                ensure_policy_file(codex_home.path()).expect("seed policy concurrently");
+            });
+        }
+    });
+
+    let path = codex_home.path().join(POLICY_RELATIVE_PATH);
