+use anyhow::Context;
+use anyhow::Result;
+use anyhow::ensure;
+use codex_protocol::protocol::GuardianRiskLevel;
+use codex_protocol::protocol::GuardianUserAuthorization;
+use serde::Deserialize;
+use serde::Serialize;
+use serde_json::Value;
+use serde_json::json;
+
+use super::PromptAssistantOperation;
+use super::PromptAssistantReview;
+use super::PromptAssistantReviewStatus;
+
+pub(super) const FIXED_INSTRUCTIONS: &str = include_str!("prompt.md");
+
+#[derive(Debug, Deserialize)]
+struct ModelOutput {
+    candidate: String,
+    review: ModelReview,
+}
+
+#[derive(Debug, Deserialize)]
+struct ModelReview {
+    intent_summary: String,
+    risk_level: GuardianRiskLevel,
+    user_authorization: GuardianUserAuthorization,
+    status: PromptAssistantReviewStatus,
+    rationale: String,
+}
+
+#[derive(Debug, Clone, Deserialize, Serialize)]
+pub(super) struct OperationEnvelope<'a> {
+    pub(super) operation: PromptAssistantOperation,
+    #[serde(borrow)]
+    pub(super) workspace_id: &'a str,
+    pub(super) generation: u64,
+    #[serde(borrow)]
+    pub(super) parent_context: &'a str,
+    #[serde(borrow)]
+    pub(super) source: &'a str,
+}
+
+pub(super) fn parse_operation_envelope(input: &str) -> Result<OperationEnvelope<'_>> {
+    serde_json::from_str(input).context("invalid Prompt Assistant operation envelope")
+}
+
+pub(super) fn output_schema() -> Value {
+    json!({
+        "type": "object",
+        "properties": {
+            "candidate": {
+                "type": "string",
+                "description": "The complete prompt candidate, or an empty string when blocked."
+            },
+            "review": {
+                "type": "object",
+                "properties": {
+                    "intent_summary": { "type": "string" },
+                    "risk_level": {
+                        "type": "string",
+                        "enum": ["low", "medium", "high", "critical"]
+                    },
+                    "user_authorization": {
+                        "type": "string",
+                        "enum": ["unknown", "low", "medium", "high"]
+                    },
+                    "status": {
+                        "type": "string",
+                        "enum": ["pass", "revised", "blocked"]
+                    },
+                    "rationale": { "type": "string" }
+                },
+                "required": [
+                    "intent_summary",
+                    "risk_level",
+                    "user_authorization",
+                    "status",
+                    "rationale"
+                ],
+                "additionalProperties": false
+            }
+        },
+        "required": ["candidate", "review"],
+        "additionalProperties": false
+    })
+}
+
+pub(super) fn render_operation(
+    operation: PromptAssistantOperation,
+    workspace_id: &str,
+    generation: u64,
+    parent_context: &str,
+    source: &str,
+) -> Result<String> {
+    Ok(serde_json::to_string(&OperationEnvelope {
+        operation,
+        workspace_id,
+        generation,
+        parent_context,
+        source,
+    })?)
+}
+
+pub(super) fn parse_output(output: &str) -> Result<(String, PromptAssistantReview)> {
+    let output: ModelOutput = serde_json::from_str(output)
+        .context("Prompt Assistant returned invalid structured output")?;
+    match output.review.status {
+        PromptAssistantReviewStatus::Pass | PromptAssistantReviewStatus::Revised => ensure!(
+            !output.candidate.trim().is_empty(),
+            "Prompt Assistant returned an empty candidate"
+        ),
+        PromptAssistantReviewStatus::Blocked => ensure!(
+            output.candidate.is_empty(),
+            "blocked Prompt Assistant output must not include an applicable candidate"
+        ),
+    }
+    ensure!(
+        is_printable_ascii_text(&output.candidate),
+        "Prompt Assistant candidate must contain only printable ASCII text"
+    );
+    ensure!(
+        !output.review.intent_summary.trim().is_empty(),
+        "Prompt Assistant returned an empty intent summary"
+    );
+    ensure!(
+        is_printable_ascii_text(&output.review.intent_summary),
+        "Prompt Assistant intent summary must contain only printable ASCII text"
+    );
+    ensure!(
+        !output.review.rationale.trim().is_empty(),
+        "Prompt Assistant returned an empty review rationale"
+    );
+    ensure!(
+        is_printable_ascii_text(&output.review.rationale),
+        "Prompt Assistant review rationale must contain only printable ASCII text"
+    );
+    Ok((
+        output.candidate,
+        PromptAssistantReview {
+            intent_summary: output.review.intent_summary,
+            risk_level: output.review.risk_level,
+            user_authorization: output.review.user_authorization,
+            status: output.review.status,
+            rationale: output.review.rationale,
+        },
+    ))
+}
+
+fn is_printable_ascii_text(text: &str) -> bool {
+    text.bytes()
+        .all(|byte| matches!(byte, b'\n' | b'\t' | b' '..=b'~'))
+}
+
