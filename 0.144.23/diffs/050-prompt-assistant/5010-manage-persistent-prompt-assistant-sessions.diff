+#[test]
+fn recovery_joins_compact_parent_lifecycle_to_child_transcript() {
+    let parent_thread_id = codex_protocol::ThreadId::new();
+    let child_thread_id = codex_protocol::ThreadId::new();
+    let workspace_id = "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa";
+    let candidate = "Use the bounded prompt.";
+    let output = serde_json::json!({
+        "candidate": candidate,
+        "review": {
+            "intent_summary": "Use the bounded prompt.",
+            "risk_level": "low",
+            "user_authorization": "high",
+            "status": "pass",
+            "rationale": "Intent preserved."
+        }
+    })
+    .to_string();
+    let envelope = prompt::render_operation(
+        PromptAssistantOperation::Generate,
+        workspace_id,
+        7,
+        "frozen context",
+        "source intent",
+    )
+    .expect("render operation");
+    let child_items = vec![
+        RolloutItem::EventMsg(EventMsg::UserMessage(UserMessageEvent {
+            message: envelope,
+            ..Default::default()
+        })),
+        RolloutItem::EventMsg(EventMsg::TurnComplete(TurnCompleteEvent {
+            turn_id: "turn-1".to_string(),
+            last_agent_message: Some(output),
+            error: None,
+            started_at: None,
+            completed_at: None,
+            duration_ms: None,
+            time_to_first_token_ms: None,
+        })),
+    ];
+    let usage = codex_protocol::protocol::TokenUsage {
+        input_tokens: 12,
+        cached_input_tokens: 8,
+        cache_write_input_tokens: 2,
+        output_tokens: 4,
+        reasoning_output_tokens: 1,
+        total_tokens: 16,
+    };
+    let parent_items = vec![RolloutItem::PromptAssistantLifecycle(
+        PromptAssistantLifecycleItem {
+            parent_thread_id,
+            child_thread_id,
+            workspace_id: workspace_id.to_string(),
+            operation: PromptAssistantOperation::Generate,
+            generation: 7,
+            model: "gpt-test".to_string(),
+            reasoning_effort: None,
+            policy_hash: "policy-hash".to_string(),
+            status: PromptAssistantLifecycleStatus::Completed,
+            applied: false,
+            candidate_hash: Some(candidate_hash(candidate)),
+            usage: Some(usage.clone()),
+            error: None,
+        },
+    )];
+
+    let recovered = recover_workspaces(
+        parent_thread_id,
+        child_thread_id,
+        &parent_items,
+        &child_items,
+        "policy-hash",
