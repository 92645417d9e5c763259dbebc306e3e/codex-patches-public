+pub(super) async fn latest_session_model(parent_session: &Session) -> Option<String> {
+    let parent_items = load_parent_items(parent_session).await?;
+    latest_session_lifecycle(parent_session.thread_id(), &parent_items, None, None)
+        .map(|lifecycle| lifecycle.model.clone())
+}
+
+async fn load_parent_items(parent_session: &Session) -> Option<Vec<RolloutItem>> {
+    parent_session
+        .services
+        .thread_store
+        .read_thread_for_resume(ReadThreadForResumeParams {
+            thread_id: parent_session.thread_id(),
+            include_archived: false,
+            history_window: ResumeHistoryWindow::Full,
+        })
+        .await
+        .ok()?
+        .history
+        .map(|history| history.items)
+}
+
+fn latest_session_lifecycle<'a>(
+    parent_thread_id: codex_protocol::ThreadId,
+    parent_items: &'a [RolloutItem],
+    expected_model: Option<&str>,
+    expected_policy_hash: Option<&str>,
+) -> Option<&'a codex_protocol::prompt_assistant::PromptAssistantLifecycleItem> {
+    parent_items.iter().rev().find_map(|item| match item {
+        RolloutItem::PromptAssistantLifecycle(lifecycle)
+            if lifecycle.parent_thread_id == parent_thread_id
+                && expected_model.is_none_or(|model| lifecycle.model == model)
+                && expected_policy_hash.is_none_or(|hash| lifecycle.policy_hash == hash) =>
+        {
+            Some(lifecycle)
+        }
+        _ => None,
+    })
+}
+
+struct CompletedChildOperation {
+    workspace_id: String,
+    operation: codex_protocol::prompt_assistant::PromptAssistantOperation,
+    generation: u64,
+    frozen_context: String,
+    source: String,
+    input: String,
+    output: String,
+    candidate: String,
+    review: super::PromptAssistantReview,
+}
+
+struct PendingChildOperation {
+    workspace_id: String,
+    operation: codex_protocol::prompt_assistant::PromptAssistantOperation,
+    generation: u64,
+    frozen_context: String,
+    source: String,
+    input: String,
+}
+
+pub(super) async fn recover_latest_session(
+    parent_session: &Session,
+    expected_model: &str,
+    expected_provider: &str,
+    expected_model_instructions: &str,
+    expected_policy_hash: &str,
+) -> Option<RecoveredSession> {
+    let store = &parent_session.services.thread_store;
+    let parent_items = load_parent_items(parent_session).await?;
+    let lifecycle = latest_session_lifecycle(
+        parent_session.thread_id(),
+        &parent_items,
+        Some(expected_model),
+        Some(expected_policy_hash),
+    )?;
+    let child = store
+        .read_thread_for_resume(ReadThreadForResumeParams {
+            thread_id: lifecycle.child_thread_id,
+            include_archived: false,
+            history_window: ResumeHistoryWindow::Full,
+        })
+        .await
+        .ok()?;
+    let child_history = child.history?;
+    let child_meta = child_history.items.iter().find_map(|item| match item {
+        RolloutItem::SessionMeta(meta_line) if meta_line.meta.id == child.thread_id => {
+            Some(&meta_line.meta)
+        }
+        _ => None,
+    })?;
+    if child_meta.source != SessionSource::Internal(InternalSessionSource::PromptAssistant)
+        || child_meta.parent_thread_id != Some(parent_session.thread_id())
+        || child_meta.model_provider.as_deref() != Some(expected_provider)
+        || child
+            .model
+            .as_deref()
+            .is_some_and(|model| model != expected_model)
+    {
+        return None;
+    }
+    let initial_history = InitialHistory::Resumed(ResumedHistory {
+        conversation_id: child.thread_id,
+        history: Arc::new(child_history.items.clone()),
+        rollout_path: child.rollout_path,
+    });
+    if initial_history
+        .get_base_instructions()
+        .is_some_and(|instructions| instructions.text != expected_model_instructions)
+    {
+        return None;
+    }
+    let workspaces = recover_workspaces(
+        parent_session.thread_id(),
+        child.thread_id,
+        &parent_items,
+        &child_history.items,
+        expected_policy_hash,
+    );
+    if workspaces.is_empty() {
+        return None;
+    }
+    Some(RecoveredSession {
+        child_thread_id: child.thread_id,
+        initial_history,
+        workspaces,
+    })
+}
+
+fn recover_workspaces(
+    parent_thread_id: codex_protocol::ThreadId,
+    child_thread_id: codex_protocol::ThreadId,
+    parent_items: &[RolloutItem],
+    child_items: &[RolloutItem],
+    expected_policy_hash: &str,
+) -> Vec<RecoveredWorkspace> {
+    let child_operations = completed_child_operations(child_items);
+    let mut recovered = HashMap::<String, RecoveredWorkspace>::new();
+    for lifecycle in parent_items.iter().filter_map(|item| match item {
+        RolloutItem::PromptAssistantLifecycle(lifecycle)
+            if lifecycle.parent_thread_id == parent_thread_id
+                && lifecycle.child_thread_id == child_thread_id
+                && lifecycle.policy_hash == expected_policy_hash =>
+        {
+            Some(lifecycle)
+        }
+        _ => None,
+    }) {
+        if lifecycle.status == PromptAssistantLifecycleStatus::Applied {
+            if let Some(workspace) = recovered.get_mut(&lifecycle.workspace_id)
+                && workspace.latest.generation == lifecycle.generation
+            {
+                workspace.applied_generation = Some(lifecycle.generation);
+            }
+            continue;
+        }
+        if !matches!(
+            lifecycle.status,
+            PromptAssistantLifecycleStatus::Completed | PromptAssistantLifecycleStatus::Blocked
+        ) {
+            continue;
+        }
+        let Some(hash) = lifecycle.candidate_hash.as_deref() else {
+            continue;
+        };
+        let Some(child_operation) = child_operations.iter().rev().find(|operation| {
+            operation.workspace_id == lifecycle.workspace_id
+                && operation.operation == lifecycle.operation
+                && operation.generation == lifecycle.generation
+                && candidate_hash(&operation.candidate) == hash
+        }) else {
+            continue;
+        };
+        let successful = child_operation.review.status != PromptAssistantReviewStatus::Blocked;
+        let entry = recovered
+            .entry(lifecycle.workspace_id.clone())
+            .or_insert_with(|| RecoveredWorkspace {
+                workspace_id: lifecycle.workspace_id.clone(),
+                frozen_context: child_operation.frozen_context.clone(),
+                successful_turns: 0,
+                successful_tokens: 0,
+                latest: PromptAssistantResult {
+                    workspace_id: lifecycle.workspace_id.clone(),
+                    child_thread_id,
+                    operation: lifecycle.operation,
+                    generation: lifecycle.generation,
+                    candidate: child_operation.candidate.clone(),
+                    candidate_hash: hash.to_string(),
+                    review: child_operation.review.clone(),
+                    model: lifecycle.model.clone(),
+                    reasoning_effort: lifecycle.reasoning_effort.clone(),
+                    usage: lifecycle.usage.clone(),
+                    policy_hash: lifecycle.policy_hash.clone(),
+                },
+                applied_generation: None,
+                history: ContextManager::new(),
+            });
+        if successful {
+            entry.successful_turns = entry.successful_turns.saturating_add(1);
+            entry.successful_tokens = entry
+                .successful_tokens
+                .saturating_add(approx_token_count(&child_operation.source))
+                .saturating_add(approx_token_count(&child_operation.candidate));
+            append_operation_history(&mut entry.history, child_operation);
+        }
+        if lifecycle.generation >= entry.latest.generation {
+            entry.latest = PromptAssistantResult {
+                workspace_id: lifecycle.workspace_id.clone(),
+                child_thread_id,
+                operation: lifecycle.operation,
+                generation: lifecycle.generation,
+                candidate: child_operation.candidate.clone(),
+                candidate_hash: hash.to_string(),
+                review: child_operation.review.clone(),
+                model: lifecycle.model.clone(),
+                reasoning_effort: lifecycle.reasoning_effort.clone(),
+                usage: lifecycle.usage.clone(),
+                policy_hash: lifecycle.policy_hash.clone(),
+            };
+        }
+    }
+    recovered.into_values().collect()
+}
+
+fn completed_child_operations(items: &[RolloutItem]) -> Vec<CompletedChildOperation> {
+    let mut pending_legacy = VecDeque::new();
+    let mut pending_by_turn = HashMap::new();
+    let mut completed = Vec::new();
+    for item in items {
+        match item {
+            RolloutItem::EventMsg(EventMsg::UserMessage(message)) => {
+                if let Some(pending) = pending_operation(&message.message) {
+                    pending_legacy.push_back(pending);
+                }
+            }
+            RolloutItem::EventMsg(EventMsg::ItemCompleted(event)) => {
+                if let TurnItem::UserMessage(message) = &event.item
+                    && let Some(input) = message.content.iter().find_map(|input| match input {
+                        UserInput::Text { text, .. } => Some(text.as_str()),
+                        _ => None,
+                    })
+                    && let Some(pending) = pending_operation(input)
+                {
+                    pending_by_turn.insert(event.turn_id.clone(), pending);
+                }
+            }
+            RolloutItem::EventMsg(EventMsg::TurnComplete(turn)) => {
+                let Some(pending) = pending_by_turn
+                    .remove(&turn.turn_id)
+                    .or_else(|| pending_legacy.pop_front())
+                else {
+                    continue;
+                };
+                let Some(output) = turn.last_agent_message.as_deref() else {
+                    continue;
+                };
+                let Ok((candidate, review)) = prompt::parse_output(output) else {
+                    continue;
+                };
+                completed.push(CompletedChildOperation {
+                    workspace_id: pending.workspace_id,
+                    operation: pending.operation,
+                    generation: pending.generation,
+                    frozen_context: pending.frozen_context,
+                    source: pending.source,
+                    input: pending.input,
+                    output: output.to_string(),
+                    candidate,
+                    review,
+                });
+            }
+            RolloutItem::EventMsg(EventMsg::TurnAborted(turn)) => {
+                if let Some(turn_id) = turn.turn_id.as_deref() {
+                    pending_by_turn.remove(turn_id);
+                } else {
+                    pending_legacy.pop_front();
+                }
+            }
+            _ => {}
+        }
+    }
+    completed
+}
+
+fn pending_operation(input: &str) -> Option<PendingChildOperation> {
+    let envelope = prompt::parse_operation_envelope(input).ok()?;
+    Some(PendingChildOperation {
+        workspace_id: envelope.workspace_id.to_string(),
+        operation: envelope.operation,
+        generation: envelope.generation,
+        frozen_context: envelope.parent_context.to_string(),
+        source: envelope.source.to_string(),
+        input: input.to_string(),
+    })
+}
+
+fn append_operation_history(history: &mut ContextManager, operation: &CompletedChildOperation) {
+    let items = [
+        ResponseItem::Message {
+            id: None,
+            role: "user".to_string(),
+            content: vec![ContentItem::InputText {
+                text: operation.input.clone(),
+            }],
+            phase: None,
+            internal_chat_message_metadata_passthrough: None,
+        },
+        ResponseItem::Message {
+            id: None,
+            role: "assistant".to_string(),
+            content: vec![ContentItem::OutputText {
+                text: operation.output.clone(),
+            }],
+            phase: Some(MessagePhase::FinalAnswer),
+            internal_chat_message_metadata_passthrough: None,
+        },
+    ];
+    history.record_items(items.iter(), TruncationPolicy::Tokens(10_000));
+}
