+#[test]
+fn canonical_source_owns_the_parent_scoped_cache_key() {
+    let parent_thread_id = ThreadId::new();
+    let source = SessionSource::Internal(InternalSessionSource::PromptAssistant);
+
+    assert!(is_prompt_assistant_source(&source));
+    assert_eq!(
+        prompt_cache_key_override(&source, Some(parent_thread_id)),
+        Some(format!("prompt-assistant:{parent_thread_id}"))
+    );
+    assert_eq!(prompt_cache_key_override(&source, None), None);
+    assert_eq!(
+        prompt_cache_key_override(&SessionSource::Cli, Some(parent_thread_id)),
+        None
+    );
+}
+
+#[test]
+fn dedicated_model_requires_the_canonical_internal_source() {
+    let model = codex_models_manager::PROMPT_ASSISTANT_MODEL_SLUG;
+    let allowed = SessionSource::Internal(InternalSessionSource::PromptAssistant);
+    let ordinary_subagent =
+        SessionSource::SubAgent(SubAgentSource::Other("prompt-assistant".to_string()));
+
+    assert!(model_allowed_for_source(model, &allowed));
+    assert!(!model_allowed_for_source(model, &SessionSource::Cli));
+    assert!(!model_allowed_for_source(model, &ordinary_subagent));
+    assert!(model_allowed_for_source("gpt-other", &SessionSource::Cli));
+}
