+#[tokio::test]
+async fn request_performance_snapshot_drives_ttfb_and_tps_status_items() {
+    let (mut chat, _rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    let usage = codex_app_server_protocol::TokenUsageBreakdown {
+        total_tokens: 15,
+        input_tokens: 10,
+        cached_input_tokens: 4,
+        cache_write_input_tokens: 0,
+        output_tokens: 5,
+        reasoning_output_tokens: 2,
+    };
+    chat.handle_server_notification(
+        ServerNotification::ThreadTokenUsageUpdated(
+            codex_app_server_protocol::ThreadTokenUsageUpdatedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                token_usage: codex_app_server_protocol::ThreadTokenUsage {
+                    total: usage.clone(),
+                    last: usage,
+                    model_context_window: Some(128_000),
+                },
+                request_performance: Some(codex_app_server_protocol::RequestPerformanceSnapshot {
+                    ttfb_ms: Some(125),
+                    output_tokens_per_second: Some(42.54),
+                }),
+            },
+        ),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(
+        chat.status_line_value_for_item(StatusLineItem::RequestTtfb),
+        Some("TTFB 125ms".to_string())
+    );
+    assert_eq!(
+        chat.status_line_value_for_item(StatusLineItem::RequestTps),
+        Some("TPS 42.5".to_string())
+    );
+
+    chat.handle_server_notification(
+        ServerNotification::ThreadTokenUsageUpdated(
+            codex_app_server_protocol::ThreadTokenUsageUpdatedNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-2".to_string(),
+                token_usage: codex_app_server_protocol::ThreadTokenUsage {
+                    total: codex_app_server_protocol::TokenUsageBreakdown {
+                        total_tokens: 0,
+                        input_tokens: 0,
+                        cached_input_tokens: 0,
+                        cache_write_input_tokens: 0,
+                        output_tokens: 0,
+                        reasoning_output_tokens: 0,
+                    },
+                    last: codex_app_server_protocol::TokenUsageBreakdown {
+                        total_tokens: 0,
+                        input_tokens: 0,
+                        cached_input_tokens: 0,
+                        cache_write_input_tokens: 0,
+                        output_tokens: 0,
+                        reasoning_output_tokens: 0,
+                    },
+                    model_context_window: Some(128_000),
+                },
+                request_performance: Some(codex_app_server_protocol::RequestPerformanceSnapshot {
+                    ttfb_ms: Some(200),
+                    output_tokens_per_second: None,
+                }),
+            },
+        ),
+        /*replay_kind*/ None,
+    );
+
+    assert_eq!(
+        chat.status_line_value_for_item(StatusLineItem::RequestTtfb),
+        Some("TTFB 200ms".to_string())
+    );
+    assert_eq!(
+        chat.status_line_value_for_item(StatusLineItem::RequestTps),
+        None
+    );
+}
