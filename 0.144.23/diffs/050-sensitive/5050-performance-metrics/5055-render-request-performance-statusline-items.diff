+        response_output_bytes_delta("request-1", 0, /*reset*/ true, /*ttfb*/ None),
+        /*replay_kind*/ None,
+    );
+    chat.handle_server_notification(
+        response_output_bytes_delta(
+            "request-1",
+            12,
+            /*reset*/ false,
+            /*ttfb*/ Some(0.125),
+        ),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(status_line_text(&chat), Some("TTFB 0.125s".to_string()));
+
+    chat.handle_server_notification(
+        thread_token_usage_updated(Some(
+            codex_app_server_protocol::RequestPerformanceSnapshot {
+                ttfb: None,
+                output_tokens_per_second: Some(42.54),
+            },
+        )),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(
+        status_line_text(&chat),
+        Some("TTFB 0.125s ▪ TPS 42.5".to_string())
+    );
+
+    chat.handle_server_notification(
+        thread_token_usage_updated(Some(
+            codex_app_server_protocol::RequestPerformanceSnapshot {
+                ttfb: Some(0.2),
+                output_tokens_per_second: None,
+            },
+        )),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(
+        status_line_text(&chat),
+        Some("TTFB 0.200s ▪ TPS 42.5".to_string()),
+        "a TTFB-only update must preserve the independently completed TPS"
+    );
+
+    chat.handle_server_notification(
+        thread_token_usage_updated(/*request_performance*/ None),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(
+        status_line_text(&chat),
+        Some("TTFB 0.200s ▪ TPS 42.5".to_string()),
+        "a usage update without performance data must not erase either lifecycle"
+    );
+
+    chat.handle_server_notification(
+        response_output_bytes_delta("request-2", 0, /*reset*/ true, /*ttfb*/ None),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(status_line_text(&chat), None);
+
+    chat.handle_server_notification(
+        thread_token_usage_updated(Some(
+            codex_app_server_protocol::RequestPerformanceSnapshot {
+                ttfb: Some(0.3),
+                output_tokens_per_second: Some(50.04),
+            },
+        )),
+        /*replay_kind*/ None,
+    );
+    assert_eq!(
+        status_line_text(&chat),
+        Some("TTFB 0.300s ▪ TPS 50.0".to_string()),
+        "a complete performance snapshot must still publish both values"
     );
-    assert!(drain_insert_history(&mut rx).is_empty());
 }
 
