+#[tokio::test]
+async fn response_stream_merges_raw_transport_bytes_before_completion() {
+    let (tx_response_bytes, rx_response_bytes) = tokio::sync::mpsc::unbounded_channel();
+    tx_response_bytes.send(7).expect("raw byte receiver open");
+    tx_response_bytes.send(11).expect("raw byte receiver open");
+    drop(tx_response_bytes);
+    let api_stream = futures::stream::iter([
+        Ok(ResponseEvent::Created),
+        Ok(ResponseEvent::Completed {
+            response_id: "resp-raw-bytes".to_string(),
+            token_usage: None,
+            end_turn: Some(true),
+        }),
+    ]);
+    let (mut stream, _) = super::map_response_events_with_timing(
+        /*upstream_request_id*/ None,
+        api_stream,
+        Some(rx_response_bytes),
+        test_session_telemetry(),
+        InferenceTraceAttempt::disabled(),
+        test_model_provider(),
+        /*performance*/ None,
+    );
+
+    let mut events = Vec::new();
+    while let Some(event) = stream.next().await {
+        events.push(event.expect("mapped response event"));
+    }
+
+    assert!(matches!(events[0], ResponseEvent::ResponseBytesDelta(7)));
+    assert!(matches!(events[1], ResponseEvent::ResponseBytesDelta(11)));
+    assert!(matches!(events[2], ResponseEvent::Created));
+    assert!(matches!(events[3], ResponseEvent::Completed { .. }));
+}
