+async fn emit_response_output_bytes(
+    sess: &Session,
+    turn_context: &TurnContext,
+    request_id: &str,
+    byte_count: usize,
+    reset: bool,
+) {
+    if byte_count == 0 && !reset {
+        return;
+    }
+    let _ = sess
+        .get_tx_event()
+        .send(Event {
+            id: turn_context.sub_id.clone(),
+            msg: EventMsg::ResponseOutputBytesDelta(ResponseOutputBytesDeltaEvent {
+                thread_id: sess.thread_id.to_string(),
+                turn_id: turn_context.sub_id.clone(),
+                request_id: request_id.to_string(),
+                byte_count: u64::try_from(byte_count).unwrap_or(u64::MAX),
+                reset,
+            }),
+        })
+        .await;
+}
