+#[tokio::test]
+async fn response_output_bytes_accumulate_live_and_reset_without_history() {
+    let (mut chat, mut rx, _ops) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.handle_server_notification(
+        ServerNotification::TurnStarted(TurnStartedNotification {
+            thread_id: "thread-1".to_string(),
+            turn: AppServerTurn {
+                id: "turn-1".to_string(),
+                items_view: codex_app_server_protocol::TurnItemsView::Full,
+                items: Vec::new(),
+                status: AppServerTurnStatus::InProgress,
+                error: None,
+                started_at: Some(0),
+                completed_at: None,
+                duration_ms: None,
+            },
+        }),
+        /*replay_kind*/ None,
+    );
+    drain_insert_history(&mut rx);
+
+    for byte_count in [12, 30] {
+        chat.handle_server_notification(
+            ServerNotification::ResponseOutputBytesDelta(
+                codex_app_server_protocol::ResponseOutputBytesDeltaNotification {
+                    thread_id: "thread-1".to_string(),
+                    turn_id: "turn-1".to_string(),
+                    byte_count,
+                    reset: false,
+                },
+            ),
+            /*replay_kind*/ None,
+        );
+    }
+
+    let status = chat
+        .bottom_pane
+        .status_widget()
+        .expect("status indicator should be visible");
+    assert_eq!(status.response_output_bytes(), Some(42));
+    assert!(drain_insert_history(&mut rx).is_empty());
+
+    chat.handle_server_notification(
+        ServerNotification::ResponseOutputBytesDelta(
+            codex_app_server_protocol::ResponseOutputBytesDeltaNotification {
+                thread_id: "thread-1".to_string(),
+                turn_id: "turn-1".to_string(),
+                byte_count: 0,
+                reset: true,
+            },
+        ),
+        /*replay_kind*/ None,
+    );
+    let status = chat
+        .bottom_pane
+        .status_widget()
+        .expect("status indicator should be visible");
+    assert_eq!(status.response_output_bytes(), None);
+    assert!(drain_insert_history(&mut rx).is_empty());
+}
