+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn v2_reasoning_fingerprint_keeps_upstream_tool_execution() -> anyhow::Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = start_mock_server().await;
+    let TestCodex { codex, .. } = test_codex()
+        .with_model_info_override("gpt-5.4", |model| {
+            model.multi_agent_version = Some(MultiAgentVersion::V2);
+        })
+        .build(&server)
+        .await?;
+    let plan_args = serde_json::json!({
+        "plan": [{"step": "v2 executes normally", "status": "in_progress"}]
+    })
+    .to_string();
+    let completed = |response_id: &str, reasoning_tokens: i64| {
+        serde_json::json!({
+            "type": "response.completed",
+            "response": {
+                "id": response_id,
+                "usage": {
+                    "input_tokens": 10,
+                    "input_tokens_details": { "cached_tokens": 7 },
+                    "output_tokens": 520,
+                    "output_tokens_details": { "reasoning_tokens": reasoning_tokens },
+                    "total_tokens": 530
+                }
+            }
+        })
+    };
+    let response_mock = mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-v2-tool"),
+                ev_reasoning_item("reasoning-v2", &[], &["v2 reasoning"]),
+                ev_function_call("plan-v2", "update_plan", &plan_args),
+                completed("resp-v2-tool", 516),
+            ]),
+            sse(vec![
+                ev_response_created("resp-v2-final"),
+                ev_assistant_message("message-v2-final", "v2 done"),
+                completed("resp-v2-final", 0),
+            ]),
+        ],
+    )
+    .await;
+
+    codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "keep v2 upstream".into(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+    wait_for_event(&codex, |event| matches!(event, EventMsg::TurnComplete(_))).await;
+
+    let requests = response_mock.requests();
+    assert_eq!(requests.len(), 2);
+    let follow_up = requests[1].body_json().to_string();
+    assert!(follow_up.contains("function_call_output"));
+    assert!(!follow_up.contains("Continue the same turn from the preserved reasoning chain"));
