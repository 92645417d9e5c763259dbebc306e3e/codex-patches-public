+const REASONING_CONTINUATION_FINGERPRINT_STEP: i64 = 518;
+const REASONING_CONTINUATION_MAX_ROUNDS: usize = 5;
+const REASONING_CONTINUATION_MARKER: &str = "Continue the same turn from the preserved reasoning chain. Unaccepted replies and tool calls have not taken effect; request any still-needed tool again.";
+
+fn reasoning_continuation_fingerprint_tier(reasoning_output_tokens: i64) -> Option<i64> {
+    if reasoning_output_tokens < REASONING_CONTINUATION_FINGERPRINT_STEP - 2
+        || (reasoning_output_tokens + 2) % REASONING_CONTINUATION_FINGERPRINT_STEP != 0
+    {
+        return None;
+    }
+    Some((reasoning_output_tokens + 2) / REASONING_CONTINUATION_FINGERPRINT_STEP)
+}
+
+fn reasoning_item_has_encrypted_content(item: &ResponseItem) -> bool {
+    matches!(
+        item,
+        ResponseItem::Reasoning {
+            encrypted_content: Some(_),
+            ..
+        }
+    )
+}
+
+fn response_item_is_deferred_tool_call_candidate(item: &ResponseItem) -> bool {
+    match item {
+        ResponseItem::FunctionCall { .. } | ResponseItem::CustomToolCall { .. } => true,
+        ResponseItem::ToolSearchCall {
+            call_id: Some(_),
+            execution,
+            ..
+        } => execution == "client",
+        _ => false,
     }
 }
 
+fn build_reasoning_continuation_input(
+    stable_original_input: &[ResponseItem],
+    round_response_items: Vec<ResponseItem>,
+) -> Vec<ResponseItem> {
+    let mut next_input = stable_original_input.to_vec();
+    next_input.extend(
+        round_response_items
+            .into_iter()
+            .filter(reasoning_item_has_encrypted_content),
+    );
+    next_input.push(ResponseItem::Message {
+        id: None,
+        role: "assistant".to_string(),
+        content: vec![ContentItem::OutputText {
+            text: REASONING_CONTINUATION_MARKER.to_string(),
+        }],
+        phase: Some(MessagePhase::Commentary),
+        internal_chat_message_metadata_passthrough: None,
+    });
+    next_input
+}
+
+fn continuation_notice_item(kind: ContinuationNoticeKind) -> TurnItem {
+    TurnItem::AgentMessage(codex_protocol::items::AgentMessageItem {
+        id: Uuid::new_v4().to_string(),
+        content: vec![codex_protocol::items::AgentMessageContent::Text {
+            text: kind.placeholder_text().to_string(),
+        }],
+        phase: Some(MessagePhase::Commentary),
+        memory_citation: None,
+        continuation_notice: Some(kind),
+        continuation_hidden: true,
+        continuation_instruction: false,
+    })
+}
+
+fn continuation_instruction_item() -> TurnItem {
+    TurnItem::AgentMessage(codex_protocol::items::AgentMessageItem {
+        id: Uuid::new_v4().to_string(),
+        content: vec![codex_protocol::items::AgentMessageContent::Text {
+            text: REASONING_CONTINUATION_MARKER.to_string(),
+        }],
+        phase: Some(MessagePhase::Commentary),
+        memory_citation: None,
+        continuation_notice: None,
+        continuation_hidden: false,
+        continuation_instruction: true,
+    })
+}
+
