+#[test]
+fn live_agent_peers_exclude_only_the_waiting_sender() {
+    let runtime = tokio::runtime::Builder::new_multi_thread()
+        .worker_threads(1)
+        .thread_stack_size(8 * 1024 * 1024)
+        .enable_all()
+        .build()
+        .expect("large-stack test runtime");
+    runtime.block_on(async {
+        let harness = AgentControlHarness::new().await;
+        let (root_thread_id, _root_thread) = harness.start_thread().await;
+        harness
+            .control
+            .register_session_root(root_thread_id, /*parent_thread_id*/ None);
+        let first_child = harness
+            .spawn_anonymous_child(root_thread_id, SpawnAgentOptions::default())
+            .await;
+        let second_child = harness
+            .spawn_anonymous_child(root_thread_id, SpawnAgentOptions::default())
+            .await;
+
+        let root_peer_ids = harness
+            .control
+            .list_live_agent_peers(root_thread_id)
+            .await
+            .expect("root peer snapshot")
+            .into_iter()
+            .filter_map(|metadata| metadata.agent_id)
+            .collect::<Vec<_>>();
+        assert_eq!(root_peer_ids.len(), 2);
+        assert!(root_peer_ids.contains(&first_child));
+        assert!(root_peer_ids.contains(&second_child));
+        assert!(!root_peer_ids.contains(&root_thread_id));
+
+        let child_peer_ids = harness
+            .control
+            .list_live_agent_peers(first_child)
+            .await
+            .expect("child peer snapshot")
+            .into_iter()
+            .filter_map(|metadata| metadata.agent_id)
+            .collect::<Vec<_>>();
+        assert_eq!(child_peer_ids.len(), 2);
+        assert!(child_peer_ids.contains(&root_thread_id));
+        assert!(child_peer_ids.contains(&second_child));
+        assert!(!child_peer_ids.contains(&first_child));
+    });
+}
