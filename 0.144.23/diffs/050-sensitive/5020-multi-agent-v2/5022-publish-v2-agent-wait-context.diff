+            id: WAIT_CALL_ID.to_string(),
+            tool: CollabAgentTool::Wait,
+            status: CollabAgentToolCallStatus::InProgress,
+            multi_agent_version: Some(MultiAgentVersion::V2),
+            sender_thread_id: thread.id.clone(),
+            receiver_thread_ids: Vec::new(),
+            prompt: None,
+            model: None,
+            reasoning_effort: None,
+            agents_states: HashMap::new(),
+        }
+    );
+
+    let wait_completed = timeout(DEFAULT_READ_TIMEOUT, async {
+        loop {
+            let notification = mcp
+                .read_stream_until_notification_message("item/completed")
+                .await?;
+            let notification: ItemCompletedNotification =
+                serde_json::from_value(notification.params.context("item/completed params")?)?;
+            if notification.item.id() == WAIT_CALL_ID {
+                return Ok::<ThreadItem, anyhow::Error>(notification.item);
+            }
+        }
+    })
+    .await??;
+    assert_eq!(
+        wait_completed,
+        ThreadItem::CollabAgentToolCall {
+            id: WAIT_CALL_ID.to_string(),
+            tool: CollabAgentTool::Wait,
+            status: CollabAgentToolCallStatus::Completed,
+            multi_agent_version: Some(MultiAgentVersion::V2),
+            sender_thread_id: thread.id,
+            receiver_thread_ids: Vec::new(),
+            prompt: None,
+            model: None,
+            reasoning_effort: None,
+            agents_states: HashMap::new(),
+        }
+    );
+
+    Ok(())
+}
