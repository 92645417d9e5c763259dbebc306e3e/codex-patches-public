+        mcp.read_stream_until_response_message(RequestId::Integer(turn_req)),
+    )
+    .await??;
+    let _: TurnStartResponse = to_response(turn_resp)?;
+
+    let wait_started = timeout(DEFAULT_READ_TIMEOUT, async {
+        loop {
+            let notification = mcp
+                .read_stream_until_notification_message("item/started")
+                .await?;
+            let notification: ItemStartedNotification =
+                serde_json::from_value(notification.params.context("item/started params")?)?;
+            if notification.item.id() == WAIT_CALL_ID {
+                return Ok::<ThreadItem, anyhow::Error>(notification.item);
+            }
+        }
+    })
+    .await??;
+    assert_eq!(
+        wait_started,
