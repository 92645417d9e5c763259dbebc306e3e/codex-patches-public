+    #[tokio::test]
+    async fn failed_after_bytes_clears_progress_before_retrying_the_next_generation() {
+        let (mut chat, _app_event_tx, mut events, _ops) =
+            make_chatwidget_manual_with_sender().await;
+        let parent_thread_id = ThreadId::new();
+        chat.thread_id = Some(parent_thread_id);
+        chat.apply_external_edit("original".to_string());
+        chat.start_prompt_assistant(
+            parent_thread_id,
+            PromptAssistantOperation::Generate,
+            "intent".to_string(),
+            "hidden-functional-model".to_string(),
+        );
+        let AppEvent::SubmitThreadOp {
+            op: AppCommand::PromptAssistantStart { workspace_id, .. },
+            ..
+        } = events.try_recv().expect("start event")
+        else {
+            panic!("expected prompt assistant start");
+        };
+        chat.handle_prompt_assistant_workspace_finished(
+            parent_thread_id,
+            workspace_id.clone(),
+            0,
+            Ok(workspace(parent_thread_id, &workspace_id)),
+        );
+
+        chat.handle_key_event(KeyEvent::new(KeyCode::Char('r'), KeyModifiers::NONE));
+        chat.handle_paste("first retry".to_string());
+        chat.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        let AppEvent::SubmitThreadOp {
+            op: first_retry, ..
+        } = events.try_recv().expect("first refine event")
+        else {
+            panic!("expected first refine op");
+        };
+        chat.prepare_prompt_assistant_operation(parent_thread_id, &first_retry);
+        chat.on_prompt_assistant_progress(workspace_id.clone(), 2, 64, false);
+        chat.handle_prompt_assistant_workspace_finished(
+            parent_thread_id,
+            workspace_id.clone(),
+            1,
+            Err("first retry failed".to_string()),
+        );
+        let state = chat.prompt_assistant.as_ref().expect("failed workspace");
+        assert_eq!(state.response_bytes, 0);
+        assert_eq!(state.progress_generation, None);
+
+        chat.handle_key_event(KeyEvent::new(KeyCode::Char('r'), KeyModifiers::NONE));
+        chat.handle_paste("second retry".to_string());
+        chat.handle_key_event(KeyEvent::new(KeyCode::Enter, KeyModifiers::NONE));
+        let AppEvent::SubmitThreadOp {
+            op: second_retry, ..
+        } = events.try_recv().expect("second refine event")
+        else {
+            panic!("expected second refine op");
+        };
+        chat.prepare_prompt_assistant_operation(parent_thread_id, &second_retry);
+        chat.on_prompt_assistant_progress(workspace_id.clone(), 3, 81, false);
+        assert_eq!(
+            chat.prompt_assistant
+                .as_ref()
+                .expect("retrying workspace")
+                .progress_generation,
+            Some(3)
+        );
+
+        let mut retried = workspace(parent_thread_id, &workspace_id);
+        retried.generation = 3;
+        retried.candidate = "retried candidate".to_string();
+        retried.candidate_hash = "sha256:retried".to_string();
+        chat.handle_prompt_assistant_workspace_finished(
+            parent_thread_id,
+            workspace_id,
+            1,
+            Ok(retried),
+        );
+        let state = chat.prompt_assistant.as_ref().expect("ready workspace");
+        assert_eq!(state.context.operation_generation, 3);
+        assert_eq!(state.progress_generation, None);
+        assert_eq!(state.response_bytes, 0);
+    }
