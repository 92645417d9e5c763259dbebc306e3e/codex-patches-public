+//! Prompt Assistant activation and app-server result routing.
+
+use codex_app_server_protocol::PromptAssistantApplyResponse;
+use codex_app_server_protocol::PromptAssistantCancelResponse;
+use codex_app_server_protocol::PromptAssistantOperation;
+use codex_app_server_protocol::PromptAssistantReviewDisposition;
+use codex_app_server_protocol::PromptAssistantWorkspace;
+use codex_protocol::ThreadId;
+use codex_protocol::openai_models::ModelPreset;
+use codex_protocol::openai_models::ModelVisibility;
+use uuid::Uuid;
+
+use super::ChatWidget;
+use crate::app_command::AppCommand;
+use crate::app_event::AppEvent;
+use crate::bottom_pane::SelectionItem;
+use crate::bottom_pane::SelectionViewParams;
+use crate::bottom_pane::custom_prompt_view::CustomPromptView;
+use crate::bottom_pane::popup_consts::standard_popup_hint_line;
+use crate::bottom_pane::prompt_assistant_view::PromptAssistantActionContext;
+use crate::bottom_pane::prompt_assistant_view::PromptAssistantCandidate;
+use crate::bottom_pane::prompt_assistant_view::PromptAssistantView;
+use crate::bottom_pane::prompt_assistant_view::PromptAssistantViewAction;
+use crate::bottom_pane::prompt_assistant_view::PromptAssistantViewHandle;
+
+const HIDDEN_MODEL_REQUIREMENT: &str = "Prompt Assistant requires a hidden catalog model";
+
+pub(super) struct PromptAssistantUiState {
+    parent_thread_id: ThreadId,
+    context: PromptAssistantActionContext,
+    handle: PromptAssistantViewHandle,
+    response_bytes: u64,
+    progress_generation: Option<u64>,
+}
+
+impl PromptAssistantUiState {
+    fn matches(&self, parent_thread_id: ThreadId, workspace_id: &str, generation: u64) -> bool {
+        self.parent_thread_id == parent_thread_id
+            && self.context.workspace_id == workspace_id
+            && self.context.operation_generation == generation
+    }
+
+    fn accept_progress(
+        &mut self,
+        workspace_id: &str,
+        generation: u64,
+        byte_count: u64,
+        reset: bool,
+    ) -> bool {
+        if self.context.workspace_id != workspace_id
+            || generation <= self.context.operation_generation
+            || self
+                .progress_generation
+                .is_some_and(|active_generation| active_generation != generation)
+        {
+            return false;
+        }
+
+        let response_bytes = if reset {
+            0
+        } else {
+            self.response_bytes.saturating_add(byte_count)
+        };
+        if !self
+            .handle
+            .set_response_bytes(&self.context, response_bytes)
+        {
+            return false;
+        }
+
+        self.progress_generation = Some(generation);
+        self.response_bytes = response_bytes;
+        true
+    }
+
+    fn reset_progress(&mut self) {
+        self.response_bytes = 0;
+        self.progress_generation = None;
+    }
+}
+
+impl ChatWidget {
+    pub(crate) fn prepare_prompt_assistant_operation(
+        &mut self,
+        parent_thread_id: ThreadId,
+        op: &AppCommand,
+    ) {
+        let (workspace_id, generation) = match op {
+            AppCommand::PromptAssistantStart { workspace_id, .. } => (workspace_id, 0),
+            AppCommand::PromptAssistantRefine {
+                workspace_id,
+                generation,
+                ..
+            }
+            | AppCommand::PromptAssistantReview {
+                workspace_id,
+                generation,
+                ..
+            } => (workspace_id, *generation),
+            _ => return,
+        };
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if state.matches(parent_thread_id, workspace_id, generation) {
+            state.reset_progress();
+        }
+    }
+
+    /// Open Prompt Assistant without consuming or replacing the underlying draft.
+    pub(crate) fn open_prompt_assistant(&mut self) {
+        self.bottom_pane
+            .flush_composer_paste_burst_before_snapshot();
+        let draft = self.composer_text_with_pending();
+        self.open_prompt_assistant_for_source(draft);
+    }
+
+    /// Open the transform flow for an inline `/prompt <draft>` source.
+    pub(crate) fn open_prompt_assistant_for_inline_draft(&mut self, draft: String) {
+        self.open_prompt_assistant_for_source(draft);
+    }
+
+    fn open_prompt_assistant_for_source(&mut self, draft: String) {
+        if self.active_side_conversation || self.blocks_direct_input {
+            return;
+        }
+        let Some(parent_thread_id) = self.thread_id else {
+            self.add_error_message(
+                "Prompt Assistant is unavailable before the session starts.".to_string(),
+            );
+            return;
+        };
+        if self.prompt_assistant.is_some() {
+            return;
+        }
+
+        if draft.trim().is_empty() {
+            let app_event_tx = self.app_event_tx.clone();
+            let view = CustomPromptView::new(
+                "Generate a prompt".to_string(),
+                "Describe the intended task and press Enter".to_string(),
+                String::new(),
+                Some("Prompt Assistant".to_string()),
+                Box::new(move |intent| {
+                    app_event_tx.send(AppEvent::OpenPromptAssistantModelPicker {
+                        parent_thread_id,
+                        operation: PromptAssistantOperation::Generate,
+                        input: intent,
+                    });
+                }),
+            );
+            self.bottom_pane.show_view(Box::new(view));
+            self.request_redraw();
+            return;
+        }
+
+        let translate_input = draft.clone();
+        let generate_input = draft;
+        self.bottom_pane.show_selection_view(SelectionViewParams {
+            title: Some("Prompt Assistant".to_string()),
+            subtitle: Some("Choose how to transform the current draft".to_string()),
+            footer_hint: Some(standard_popup_hint_line()),
+            items: vec![
+                SelectionItem {
+                    name: "Translate".to_string(),
+                    description: Some(
+                        "Translate the draft while preserving its meaning and constraints"
+                            .to_string(),
+                    ),
+                    actions: vec![Box::new(move |tx| {
+                        tx.send(AppEvent::OpenPromptAssistantModelPicker {
+                            parent_thread_id,
+                            operation: PromptAssistantOperation::Translate,
+                            input: translate_input.clone(),
+                        });
+                    })],
+                    dismiss_on_select: true,
+                    ..Default::default()
+                },
+                SelectionItem {
+                    name: "Generate".to_string(),
+                    description: Some(
+                        "Turn the draft into a complete, execution-ready prompt".to_string(),
+                    ),
+                    actions: vec![Box::new(move |tx| {
+                        tx.send(AppEvent::OpenPromptAssistantModelPicker {
+                            parent_thread_id,
+                            operation: PromptAssistantOperation::Generate,
+                            input: generate_input.clone(),
+                        });
+                    })],
+                    dismiss_on_select: true,
+                    ..Default::default()
+                },
+            ],
+            ..Default::default()
+        });
+        self.request_redraw();
+    }
+
+    pub(crate) fn open_prompt_assistant_model_picker(
+        &mut self,
+        parent_thread_id: ThreadId,
+        operation: PromptAssistantOperation,
+        input: String,
+    ) {
+        if self.thread_id != Some(parent_thread_id) || self.prompt_assistant.is_some() {
+            return;
+        }
+
+        let models =
+            prompt_assistant_models(self.model_catalog.try_list_models().unwrap_or_default());
+        let items = if models.is_empty() {
+            vec![SelectionItem {
+                name: "No hidden functional models available".to_string(),
+                description: Some(HIDDEN_MODEL_REQUIREMENT.to_string()),
+                is_disabled: true,
+                disabled_reason: Some("No eligible model is present in the catalog".to_string()),
+                ..Default::default()
+            }]
+        } else {
+            models
+                .into_iter()
+                .map(|preset| {
+                    let model = preset.model.clone();
+                    let request_input = input.clone();
+                    SelectionItem {
+                        name: preset.display_name,
+                        description: Some(format!("{} — {}", preset.model, preset.description)),
+                        search_value: Some(format!("{} {}", preset.model, preset.description)),
+                        actions: vec![Box::new(move |tx| {
+                            tx.send(AppEvent::StartPromptAssistant {
+                                parent_thread_id,
+                                operation,
+                                input: request_input.clone(),
+                                model: model.clone(),
+                            });
+                        })],
+                        dismiss_on_select: true,
+                        ..Default::default()
+                    }
+                })
+                .collect()
+        };
+
+        self.bottom_pane.show_selection_view(SelectionViewParams {
+            title: Some("Prompt Assistant model".to_string()),
+            subtitle: Some("Choose a hidden functional model".to_string()),
+            footer_hint: Some(standard_popup_hint_line()),
+            items,
+            is_searchable: true,
+            search_placeholder: Some("Search hidden models".to_string()),
+            ..Default::default()
+        });
+        self.request_redraw();
+    }
+
+    pub(crate) fn start_prompt_assistant(
+        &mut self,
+        parent_thread_id: ThreadId,
+        operation: PromptAssistantOperation,
+        input: String,
+        model: String,
+    ) {
+        if self.thread_id != Some(parent_thread_id) || self.prompt_assistant.is_some() {
+            return;
+        }
+
+        let workspace_id = Uuid::new_v4().to_string();
+        let context = PromptAssistantActionContext {
+            workspace_id: workspace_id.clone(),
+            operation_generation: 0,
+        };
+        let app_event_tx = self.app_event_tx.clone();
+        let callback_workspace_id = workspace_id.clone();
+        let view = PromptAssistantView::new(
+            self.composer_text_with_pending(),
+            context.clone(),
+            format!("{} ({model})", operation_label(operation)),
+            move |action| match action {
+                PromptAssistantViewAction::Apply {
+                    context,
+                    candidate_hash,
+                    candidate: _,
+                } => {
+                    app_event_tx.send(AppEvent::SubmitThreadOp {
+                        thread_id: parent_thread_id,
+                        op: AppCommand::prompt_assistant_apply(
+                            context.workspace_id,
+                            context.operation_generation,
+                            candidate_hash,
+                        ),
+                    });
+                }
+                PromptAssistantViewAction::Copy { candidate } => {
+                    app_event_tx.send(AppEvent::CopyPromptAssistantCandidate {
+                        parent_thread_id,
+                        workspace_id: callback_workspace_id.clone(),
+                        candidate,
+                    });
+                }
+                PromptAssistantViewAction::Refine {
+                    context,
+                    instruction,
+                } => {
+                    app_event_tx.send(AppEvent::SubmitThreadOp {
+                        thread_id: parent_thread_id,
+                        op: AppCommand::prompt_assistant_refine(
+                            context.workspace_id,
+                            context.operation_generation,
+                            instruction,
+                        ),
+                    });
+                }
+                PromptAssistantViewAction::Review {
+                    context,
+                    candidate_hash,
+                } => {
+                    app_event_tx.send(AppEvent::SubmitThreadOp {
+                        thread_id: parent_thread_id,
+                        op: AppCommand::prompt_assistant_review(
+                            context.workspace_id,
+                            context.operation_generation,
+                            candidate_hash,
+                        ),
+                    });
+                }
+                PromptAssistantViewAction::Cancel { context } => {
+                    app_event_tx.send(AppEvent::SubmitThreadOp {
+                        thread_id: parent_thread_id,
+                        op: AppCommand::prompt_assistant_cancel(
+                            context.workspace_id,
+                            context.operation_generation,
+                        ),
+                    });
+                }
+                PromptAssistantViewAction::Restore { original_draft: _ } => {
+                    app_event_tx.send(AppEvent::RestorePromptAssistant {
+                        parent_thread_id,
+                        workspace_id: callback_workspace_id.clone(),
+                    });
+                }
+            },
+        );
+        let handle = view.handle();
+        self.prompt_assistant = Some(PromptAssistantUiState {
+            parent_thread_id,
+            context,
+            handle,
+            response_bytes: 0,
+            progress_generation: None,
+        });
+        self.bottom_pane.show_view(Box::new(view));
+        self.app_event_tx.send(AppEvent::SubmitThreadOp {
+            thread_id: parent_thread_id,
+            op: AppCommand::prompt_assistant_start(workspace_id, operation, input, model),
+        });
+        self.request_redraw();
+    }
+
+    pub(crate) fn handle_prompt_assistant_workspace_finished(
+        &mut self,
+        parent_thread_id: ThreadId,
+        expected_workspace_id: String,
+        expected_generation: u64,
+        result: Result<PromptAssistantWorkspace, String>,
+    ) {
+        if self.thread_id != Some(parent_thread_id) {
+            return;
+        }
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if !state.matches(
+            parent_thread_id,
+            &expected_workspace_id,
+            expected_generation,
+        ) {
+            return;
+        }
+        let expected_context = state.context.clone();
+        let workspace = match result {
+            Ok(workspace) => workspace,
+            Err(error) => {
+                state.reset_progress();
+                state.handle.set_failed(&expected_context, error);
+                self.request_redraw();
+                return;
+            }
+        };
+        let returned_context = PromptAssistantActionContext {
+            workspace_id: workspace.workspace_id.clone(),
+            operation_generation: workspace.generation,
+        };
+        let progress_matches = state
+            .progress_generation
+            .is_none_or(|generation| generation == workspace.generation);
+        if workspace.thread_id != parent_thread_id.to_string()
+            || workspace.workspace_id != expected_workspace_id
+            || workspace.generation <= expected_generation
+            || !progress_matches
+        {
+            state.reset_progress();
+            state.handle.set_failed(
+                &expected_context,
+                "Prompt Assistant returned a stale or mismatched workspace".to_string(),
+            );
+            self.request_redraw();
+            return;
+        }
+
+        let candidate = candidate_from_workspace(&workspace);
+        if state
+            .handle
+            .complete_operation(&expected_context, returned_context.clone(), candidate)
+        {
+            state.context = returned_context;
+            state.reset_progress();
+        }
+        self.request_redraw();
+    }
+
+    pub(crate) fn handle_prompt_assistant_apply_finished(
+        &mut self,
+        parent_thread_id: ThreadId,
+        expected_workspace_id: String,
+        expected_generation: u64,
+        expected_candidate_hash: String,
+        result: Result<PromptAssistantApplyResponse, String>,
+    ) {
+        if self.thread_id != Some(parent_thread_id) {
+            return;
+        }
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if !state.matches(
+            parent_thread_id,
+            &expected_workspace_id,
+            expected_generation,
+        ) {
+            return;
+        }
+        let expected_context = state.context.clone();
+        let response = match result {
+            Ok(response) => response,
+            Err(error) => {
+                state.handle.set_failed(&expected_context, error);
+                self.request_redraw();
+                return;
+            }
+        };
+        if !response.applied
+            || response.workspace_id != expected_workspace_id
+            || response.generation != expected_generation
+            || response.candidate_hash != expected_candidate_hash
+        {
+            state.handle.set_failed(
+                &expected_context,
+                "Prompt Assistant rejected the selected candidate".to_string(),
+            );
+            self.request_redraw();
+            return;
+        }
+
+        if state.handle.finish_applied(&expected_context) {
+            let candidate = response.candidate;
+            self.prompt_assistant = None;
+            self.apply_external_edit(candidate);
+        }
+        self.request_redraw();
+    }
+
+    pub(crate) fn handle_prompt_assistant_cancel_finished(
+        &mut self,
+        parent_thread_id: ThreadId,
+        expected_workspace_id: String,
+        expected_generation: u64,
+        result: Result<PromptAssistantCancelResponse, String>,
+    ) {
+        if self.thread_id != Some(parent_thread_id) {
+            return;
+        }
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if !state.matches(
+            parent_thread_id,
+            &expected_workspace_id,
+            expected_generation,
+        ) {
+            return;
+        }
+        let response = match result {
+            Ok(response) => response,
+            Err(error) => {
+                let context = state.context.clone();
+                state.reset_progress();
+                state.handle.set_failed(&context, error);
+                self.request_redraw();
+                return;
+            }
+        };
+        if response.cancelled
+            && response.workspace_id == expected_workspace_id
+            && response.generation == expected_generation
+            && state.handle.finish_cancelled(&state.context)
+        {
+            self.prompt_assistant = None;
+            self.request_redraw();
+        }
+    }
+
+    pub(crate) fn restore_prompt_assistant(
+        &mut self,
+        parent_thread_id: ThreadId,
+        workspace_id: &str,
+    ) {
+        if self.prompt_assistant.as_ref().is_some_and(|state| {
+            state.parent_thread_id == parent_thread_id && state.context.workspace_id == workspace_id
+        }) {
+            self.prompt_assistant = None;
+        }
+    }
+
+    pub(crate) fn copy_prompt_assistant_candidate(
+        &mut self,
+        parent_thread_id: ThreadId,
+        workspace_id: String,
+        candidate: String,
+    ) {
+        self.copy_prompt_assistant_candidate_with(
+            parent_thread_id,
+            &workspace_id,
+            candidate,
+            crate::clipboard_copy::copy_to_clipboard,
+        );
+    }
+
+    fn copy_prompt_assistant_candidate_with(
+        &mut self,
+        parent_thread_id: ThreadId,
+        workspace_id: &str,
+        candidate: String,
+        copy_fn: impl FnOnce(&str) -> Result<Option<crate::clipboard_copy::ClipboardLease>, String>,
+    ) {
+        if self.thread_id != Some(parent_thread_id)
+            || !self.prompt_assistant.as_ref().is_some_and(|state| {
+                state.parent_thread_id == parent_thread_id
+                    && state.context.workspace_id == workspace_id
+            })
+        {
+            return;
+        }
+        match copy_fn(&candidate) {
+            Ok(lease) => self.clipboard_lease = lease,
+            Err(error) => tracing::warn!(error = %error, "Prompt Assistant copy failed"),
+        }
+        self.request_redraw();
+    }
+
+    pub(crate) fn on_prompt_assistant_progress(
+        &mut self,
+        workspace_id: String,
+        generation: u64,
+        byte_count: u64,
+        reset: bool,
+    ) {
+        let Some(state) = self.prompt_assistant.as_mut() else {
+            return;
+        };
+        if state.accept_progress(&workspace_id, generation, byte_count, reset) {
+            self.request_redraw();
+        }
+    }
+}
+
+fn operation_label(operation: PromptAssistantOperation) -> &'static str {
+    match operation {
+        PromptAssistantOperation::Translate => "translate",
+        PromptAssistantOperation::Generate => "generate",
+        PromptAssistantOperation::Refine => "refine",
+        PromptAssistantOperation::Review => "review",
+    }
+}
+
+fn prompt_assistant_models(models: Vec<ModelPreset>) -> Vec<ModelPreset> {
+    models
+        .into_iter()
+        .filter(|preset| prompt_assistant_visibility_is_eligible(preset.visibility))
+        .collect()
+}
+
+fn prompt_assistant_visibility_is_eligible(visibility: ModelVisibility) -> bool {
+    visibility == ModelVisibility::Hide
+}
+
+fn candidate_from_workspace(workspace: &PromptAssistantWorkspace) -> PromptAssistantCandidate {
+    let (apply_allowed, review_summary) = match workspace.review.as_ref() {
+        Some(review) => {
+            let disposition = match review.disposition {
+                PromptAssistantReviewDisposition::Pass => "Pass",
+                PromptAssistantReviewDisposition::Revised => "Revised",
+                PromptAssistantReviewDisposition::Blocked => "Blocked",
+            };
+            (
+                review.disposition != PromptAssistantReviewDisposition::Blocked,
+                Some(format!("{disposition}: {}", review.rationale)),
+            )
+        }
+        None => (true, None),
+    };
+    PromptAssistantCandidate {
+        text: workspace.candidate.clone(),
+        hash: workspace.candidate_hash.clone(),
+        apply_allowed,
+        review_summary,
+    }
+}
