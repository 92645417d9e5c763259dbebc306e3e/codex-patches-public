+    async fn shortcut_freezes_active_paste_bytes_and_preserves_draft_metadata_on_restore() {
+        let (mut chat, _app_event_tx, mut events, mut ops) =
+            make_chatwidget_manual_with_sender().await;
+        chat.thread_id = Some(ThreadId::new());
+        let large_paste = "x".repeat(1_005);
+        chat.handle_paste(large_paste.clone());
+        let image_path = std::path::PathBuf::from("/tmp/prompt-assistant-test-image.png");
+        chat.bottom_pane.attach_image(image_path.clone());
+        chat.handle_key_event(KeyEvent::new(KeyCode::Char('r'), KeyModifiers::NONE));
+        chat.handle_key_event(KeyEvent::new(KeyCode::Char('c'), KeyModifiers::NONE));
+        assert!(chat.bottom_pane.is_in_paste_burst());
+
+        chat.open_prompt_assistant();
+
+        assert!(!chat.bottom_pane.is_in_paste_burst());
+        let frozen = chat
+            .capture_thread_input_state()
+            .expect("thread input state")
+            .composer
+            .expect("composer state");
+        assert!(frozen.text.ends_with("rc"));
+        assert_eq!(frozen.pending_pastes.len(), 1);
+        assert_eq!(frozen.pending_pastes[0].1, large_paste);
+        assert_eq!(frozen.local_images.len(), 1);
+        assert_eq!(frozen.local_images[0].path, image_path);
+
+        chat.handle_key_event(KeyEvent::new(KeyCode::Esc, KeyModifiers::NONE));
+        let restored = chat
+            .capture_thread_input_state()
+            .expect("restored thread input state")
+            .composer
+            .expect("restored composer state");
+        assert_eq!(restored, frozen);
+        assert!(matches!(events.try_recv(), Err(TryRecvError::Empty)));
+        assert!(matches!(ops.try_recv(), Err(TryRecvError::Empty)));
+    }
