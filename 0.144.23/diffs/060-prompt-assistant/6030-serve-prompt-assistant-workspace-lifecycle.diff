+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn prompt_assistant_cancel_interrupts_an_inflight_start() -> Result<()> {
+    let server = start_mock_server().await;
+    let catalog = prompt_catalog();
+    mount_models_once(&server, catalog.clone()).await;
+    let delayed = mount_response_once(
+        &server,
+        sse_response(successful_response(
+            "delayed-response",
+            "candidate",
+            "pass",
+            &TokenUsage::default(),
+        ))
+        .set_delay(Duration::from_secs(30)),
+    )
+    .await;
+
+    let codex_home = TempDir::new()?;
+    write_models_cache_with_models(codex_home.path(), catalog.models)?;
+    write_config(codex_home.path(), &server.uri())?;
+    let mut mcp = TestAppServer::builder()
+        .with_codex_home(codex_home.path())
+        .without_auto_env()
+        .build()
+        .await?;
+    timeout(DEFAULT_TIMEOUT, mcp.initialize()).await??;
+    let thread_id = start_parent_thread(&mut mcp).await?;
+
+    let start_id = mcp
+        .send_prompt_assistant_start_request(PromptAssistantStartParams {
+            thread_id: thread_id.clone(),
+            operation: PromptAssistantStartOperation::Generate,
+            input: "delayed intent".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+            workspace_id: Some(WORKSPACE_ID.to_string()),
+        })
+        .await?;
+    let reset = read_prompt_progress(&mut mcp, &thread_id, WORKSPACE_ID, false).await?;
+    assert!(reset.reset);
+    timeout(DEFAULT_TIMEOUT, async {
+        while delayed.requests().is_empty() {
+            tokio::time::sleep(Duration::from_millis(10)).await;
+        }
+    })
+    .await?;
+
+    let stale_id = mcp
+        .send_prompt_assistant_cancel_request(PromptAssistantCancelParams {
+            thread_id: thread_id.clone(),
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: reset.generation.saturating_sub(1),
+        })
+        .await?;
+    let stale: JSONRPCError = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_error_message(RequestId::Integer(stale_id)),
+    )
+    .await??;
+    assert_eq!(stale.error.code, INVALID_REQUEST_ERROR_CODE);
+
+    let cancel_id = mcp
+        .send_prompt_assistant_cancel_request(PromptAssistantCancelParams {
+            thread_id,
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: reset.generation,
+        })
+        .await?;
+    let cancel_response: JSONRPCResponse = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(cancel_id)),
+    )
+    .await??;
+    let cancelled = to_response::<PromptAssistantCancelResponse>(cancel_response)?;
+    assert!(cancelled.cancelled);
+    assert_eq!(cancelled.generation, reset.generation);
+
+    let start_error: JSONRPCError = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_error_message(RequestId::Integer(start_id)),
+    )
+    .await??;
+    assert_eq!(start_error.error.code, INVALID_REQUEST_ERROR_CODE);
+    assert!(start_error.error.message.contains("was cancelled"));
+    Ok(())
+}
