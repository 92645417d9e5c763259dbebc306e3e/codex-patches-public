+use codex_app_server_protocol::PromptAssistantReviewDisposition;
+use codex_app_server_protocol::PromptAssistantReviewParams;
+use codex_app_server_protocol::PromptAssistantReviewResponse;
+use codex_app_server_protocol::PromptAssistantStartOperation;
+use codex_app_server_protocol::PromptAssistantStartParams;
+use codex_app_server_protocol::PromptAssistantStartResponse;
+use codex_app_server_protocol::PromptAssistantWorkspace;
+use codex_core::CodexThread;
+use codex_core::ThreadManager;
+use codex_core::prompt_assistant::PromptAssistantApplyRequest;
+use codex_core::prompt_assistant::PromptAssistantCancelRequest;
+use codex_core::prompt_assistant::PromptAssistantError;
+use codex_core::prompt_assistant::PromptAssistantOperation;
+use codex_core::prompt_assistant::PromptAssistantRefineRequest;
+use codex_core::prompt_assistant::PromptAssistantRequest;
+use codex_core::prompt_assistant::PromptAssistantResult;
+use codex_core::prompt_assistant::PromptAssistantReviewRequest;
+use codex_core::prompt_assistant::PromptAssistantReviewStatus;
+use codex_protocol::ThreadId;
+use uuid::Uuid;
+
+use crate::error_code::internal_error;
+use crate::error_code::invalid_request;
+
+#[derive(Clone)]
+pub(crate) struct PromptAssistantRequestProcessor {
+    thread_manager: Arc<ThreadManager>,
+}
+
+impl PromptAssistantRequestProcessor {
+    pub(crate) fn new(thread_manager: Arc<ThreadManager>) -> Self {
+        Self { thread_manager }
+    }
+
+    pub(crate) async fn start(
+        &self,
+        params: PromptAssistantStartParams,
+    ) -> Result<PromptAssistantStartResponse, JSONRPCErrorError> {
+        let (thread_id, thread) = self.loaded_thread(&params.thread_id).await?;
+        let result = thread
+            .start_prompt_assistant(PromptAssistantRequest {
+                workspace_id: params
+                    .workspace_id
+                    .unwrap_or_else(|| Uuid::now_v7().to_string()),
+                operation: operation_to_core(params.operation),
+                source: params.input,
+                model: params.model,
+            })
+            .await
+            .map_err(prompt_assistant_error)?;
+        Ok(PromptAssistantStartResponse {
+            workspace: workspace(thread_id, result),
+        })
+    }
+
+    pub(crate) async fn refine(
+        &self,
+        params: PromptAssistantRefineParams,
+    ) -> Result<PromptAssistantRefineResponse, JSONRPCErrorError> {
+        let (thread_id, thread) = self.loaded_thread(&params.thread_id).await?;
+        let result = thread
+            .refine_prompt_assistant(PromptAssistantRefineRequest {
+                workspace_id: params.workspace_id,
+                generation: params.generation,
+                instruction: params.instructions,
+            })
+            .await
+            .map_err(prompt_assistant_error)?;
+        Ok(PromptAssistantRefineResponse {
+            workspace: workspace(thread_id, result),
+        })
+    }
+
+    pub(crate) async fn review(
+        &self,
+        params: PromptAssistantReviewParams,
+    ) -> Result<PromptAssistantReviewResponse, JSONRPCErrorError> {
+        let (thread_id, thread) = self.loaded_thread(&params.thread_id).await?;
+        let result = thread
+            .review_prompt_assistant(PromptAssistantReviewRequest {
+                workspace_id: params.workspace_id,
+                generation: params.generation,
+                candidate_hash: params.candidate_hash,
+            })
+            .await
+            .map_err(prompt_assistant_error)?;
+        Ok(PromptAssistantReviewResponse {
+            workspace: workspace(thread_id, result),
+        })
+    }
+
+    pub(crate) async fn apply(
+        &self,
+        params: PromptAssistantApplyParams,
+    ) -> Result<PromptAssistantApplyResponse, JSONRPCErrorError> {
+        let (_, thread) = self.loaded_thread(&params.thread_id).await?;
+        let result = thread
+            .apply_prompt_assistant(PromptAssistantApplyRequest {
+                workspace_id: params.workspace_id,
+                generation: params.generation,
+                candidate_hash: params.candidate_hash,
+            })
+            .await
+            .map_err(prompt_assistant_error)?;
+        Ok(PromptAssistantApplyResponse {
+            workspace_id: result.workspace_id,
+            generation: result.generation,
+            candidate: result.candidate,
+            candidate_hash: result.candidate_hash,
+            applied: true,
+        })
+    }
+
+    pub(crate) async fn cancel(
+        &self,
+        params: PromptAssistantCancelParams,
+    ) -> Result<PromptAssistantCancelResponse, JSONRPCErrorError> {
+        let (_, thread) = self.loaded_thread(&params.thread_id).await?;
+        let workspace_id = params.workspace_id;
+        let generation = params.generation;
+        thread
+            .cancel_prompt_assistant(PromptAssistantCancelRequest {
+                workspace_id: workspace_id.clone(),
+                generation,
+            })
+            .await
+            .map_err(prompt_assistant_error)?;
+        Ok(PromptAssistantCancelResponse {
+            workspace_id,
+            generation,
+            cancelled: true,
+        })
+    }
+
+    async fn loaded_thread(
+        &self,
+        thread_id: &str,
+    ) -> Result<(ThreadId, Arc<CodexThread>), JSONRPCErrorError> {
+        let thread_id = ThreadId::from_string(thread_id)
+            .map_err(|err| invalid_request(format!("invalid thread id: {err}")))?;
+        let thread = self
+            .thread_manager
+            .get_thread(thread_id)
+            .await
+            .map_err(|_| invalid_request(format!("thread not found: {thread_id}")))?;
+        Ok((thread_id, thread))
+    }
+}
+
+fn workspace(thread_id: ThreadId, result: PromptAssistantResult) -> PromptAssistantWorkspace {
+    PromptAssistantWorkspace {
+        thread_id: thread_id.to_string(),
+        workspace_id: result.workspace_id,
+        child_thread_id: result.child_thread_id.to_string(),
+        operation: operation_to_api(result.operation),
+        model: result.model,
+        reasoning_effort: result.reasoning_effort,
+        generation: result.generation,
+        candidate: result.candidate,
+        candidate_hash: result.candidate_hash,
+        usage: result.usage.map(Into::into),
+        review: Some(ApiPromptAssistantReview {
+            disposition: match result.review.status {
+                PromptAssistantReviewStatus::Pass => PromptAssistantReviewDisposition::Pass,
+                PromptAssistantReviewStatus::Revised => PromptAssistantReviewDisposition::Revised,
+                PromptAssistantReviewStatus::Blocked => PromptAssistantReviewDisposition::Blocked,
+            },
+            rationale: result.review.rationale,
+        }),
+    }
+}
+
+fn operation_to_core(operation: PromptAssistantStartOperation) -> PromptAssistantOperation {
+    match operation {
+        PromptAssistantStartOperation::Translate => PromptAssistantOperation::Translate,
+        PromptAssistantStartOperation::Generate => PromptAssistantOperation::Generate,
+    }
+}
+
+fn operation_to_api(operation: PromptAssistantOperation) -> ApiPromptAssistantOperation {
+    match operation {
+        PromptAssistantOperation::Translate => ApiPromptAssistantOperation::Translate,
+        PromptAssistantOperation::Generate => ApiPromptAssistantOperation::Generate,
+        PromptAssistantOperation::Refine => ApiPromptAssistantOperation::Refine,
+        PromptAssistantOperation::Review => ApiPromptAssistantOperation::Review,
+    }
+}
+
+fn prompt_assistant_error(error: PromptAssistantError) -> JSONRPCErrorError {
+    match error {
+        PromptAssistantError::InvalidInput(_)
+        | PromptAssistantError::WorkspaceNotFound(_)
+        | PromptAssistantError::Cancelled
+        | PromptAssistantError::Blocked => invalid_request(error.to_string()),
+        PromptAssistantError::Failed(_) => internal_error(error.to_string()),
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use pretty_assertions::assert_eq;
+
+    use super::*;
+
+    #[test]
+    fn client_and_model_failures_use_distinct_json_rpc_error_classes() {
+        assert_eq!(
+            prompt_assistant_error(PromptAssistantError::InvalidInput("stale".into())).code,
+            crate::error_code::INVALID_REQUEST_ERROR_CODE
+        );
+        assert_eq!(
+            prompt_assistant_error(PromptAssistantError::Failed("upstream".into())).code,
+            crate::error_code::INTERNAL_ERROR_CODE
+        );
+    }
+}
