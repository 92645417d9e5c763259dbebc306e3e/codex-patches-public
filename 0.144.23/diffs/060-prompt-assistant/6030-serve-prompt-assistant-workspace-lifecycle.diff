+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn prompt_assistant_rpc_chain_preserves_progress_usage_and_validated_apply() -> Result<()> {
+    let server = start_mock_server().await;
+    let catalog = prompt_catalog();
+    mount_models_once(&server, catalog.clone()).await;
+    let usages = [
+        TokenUsage {
+            input_tokens: 100,
+            cached_input_tokens: 60,
+            cache_write_input_tokens: 7,
+            output_tokens: 20,
+            reasoning_output_tokens: 12,
+            total_tokens: 120,
+        },
+        TokenUsage {
+            input_tokens: 90,
+            cached_input_tokens: 70,
+            cache_write_input_tokens: 3,
+            output_tokens: 18,
+            reasoning_output_tokens: 9,
+            total_tokens: 108,
+        },
+        TokenUsage {
+            input_tokens: 95,
+            cached_input_tokens: 75,
+            cache_write_input_tokens: 2,
+            output_tokens: 17,
+            reasoning_output_tokens: 10,
+            total_tokens: 112,
+        },
+    ];
+    let responses = mount_sse_sequence(
+        &server,
+        vec![
+            successful_response("response-start", "candidate one", "pass", &usages[0]),
+            successful_response("response-refine", "candidate two", "revised", &usages[1]),
+            successful_response("response-review", "candidate two", "pass", &usages[2]),
+        ],
+    )
+    .await;
+
+    let codex_home = TempDir::new()?;
+    write_models_cache_with_models(codex_home.path(), catalog.models)?;
+    write_config(codex_home.path(), &server.uri())?;
+    let mut mcp = TestAppServer::builder()
+        .with_codex_home(codex_home.path())
+        .without_auto_env()
+        .build()
+        .await?;
+    timeout(DEFAULT_TIMEOUT, mcp.initialize()).await??;
+
+    let missing_thread = ThreadId::new().to_string();
+    let missing_id = mcp
+        .send_prompt_assistant_start_request(PromptAssistantStartParams {
+            thread_id: missing_thread,
+            operation: PromptAssistantStartOperation::Generate,
+            input: "intent".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+            workspace_id: Some(WORKSPACE_ID.to_string()),
+        })
+        .await?;
+    let missing: JSONRPCError = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_error_message(RequestId::Integer(missing_id)),
+    )
+    .await??;
+    assert_eq!(missing.error.code, INVALID_REQUEST_ERROR_CODE);
+    assert!(missing.error.message.contains("thread not found"));
+    assert!(responses.requests().is_empty());
+
+    let thread_id = start_parent_thread(&mut mcp).await?;
+    let start_id = mcp
+        .send_prompt_assistant_start_request(PromptAssistantStartParams {
+            thread_id: thread_id.clone(),
+            operation: PromptAssistantStartOperation::Generate,
+            input: "initial intent".to_string(),
+            model: Some(HIDDEN_MODEL.to_string()),
+            workspace_id: Some(WORKSPACE_ID.to_string()),
+        })
+        .await?;
+    let progress = read_prompt_progress(&mut mcp, &thread_id, WORKSPACE_ID, true).await?;
+    assert_eq!(progress.generation, 1);
+    assert!(!progress.reset);
+    let start_response: JSONRPCResponse = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(start_id)),
+    )
+    .await??;
+    let start = to_response::<PromptAssistantStartResponse>(start_response)?.workspace;
+    assert_eq!(start.operation, PromptAssistantOperation::Generate);
+    assert_eq!(start.usage, Some(usages[0].clone().into()));
+
+    let refine_id = mcp
+        .send_prompt_assistant_refine_request(PromptAssistantRefineParams {
+            thread_id: thread_id.clone(),
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: start.generation,
+            instructions: "make it more precise".to_string(),
+        })
+        .await?;
+    let refine_response: JSONRPCResponse = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(refine_id)),
+    )
+    .await??;
+    let refine = to_response::<PromptAssistantRefineResponse>(refine_response)?.workspace;
+    assert_eq!(refine.operation, PromptAssistantOperation::Refine);
+    assert_eq!(refine.usage, Some(usages[1].clone().into()));
+
+    let review_id = mcp
+        .send_prompt_assistant_review_request(PromptAssistantReviewParams {
+            thread_id: thread_id.clone(),
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: refine.generation,
+            candidate_hash: refine.candidate_hash.clone(),
+        })
+        .await?;
+    let review_response: JSONRPCResponse = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(review_id)),
+    )
+    .await??;
+    let review = to_response::<PromptAssistantReviewResponse>(review_response)?.workspace;
+    assert_eq!(review.operation, PromptAssistantOperation::Review);
+    assert_eq!(review.usage, Some(usages[2].clone().into()));
+    assert_eq!(
+        review.review.as_ref().map(|review| review.disposition),
+        Some(PromptAssistantReviewDisposition::Pass)
+    );
+
+    assert_eq!(start.workspace_id, refine.workspace_id);
+    assert_eq!(start.workspace_id, review.workspace_id);
+    assert_eq!(start.child_thread_id, refine.child_thread_id);
+    assert_eq!(start.child_thread_id, review.child_thread_id);
+    assert_eq!(start.model, HIDDEN_MODEL);
+    assert_eq!(start.model, refine.model);
+    assert_eq!(start.model, review.model);
+    assert_eq!(
+        [start.generation, refine.generation, review.generation],
+        [1, 2, 3]
+    );
+
+    let stale_apply_id = mcp
+        .send_prompt_assistant_apply_request(PromptAssistantApplyParams {
+            thread_id: thread_id.clone(),
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: refine.generation,
+            candidate_hash: refine.candidate_hash,
+        })
+        .await?;
+    let stale_apply: JSONRPCError = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_error_message(RequestId::Integer(stale_apply_id)),
+    )
+    .await??;
+    assert_eq!(stale_apply.error.code, INVALID_REQUEST_ERROR_CODE);
+    assert!(stale_apply.error.message.contains("generation or hash"));
+
+    let apply_id = mcp
+        .send_prompt_assistant_apply_request(PromptAssistantApplyParams {
+            thread_id,
+            workspace_id: WORKSPACE_ID.to_string(),
+            generation: review.generation,
+            candidate_hash: review.candidate_hash.clone(),
+        })
+        .await?;
+    let apply_response: JSONRPCResponse = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(apply_id)),
+    )
+    .await??;
+    let applied = to_response::<PromptAssistantApplyResponse>(apply_response)?;
+    assert!(applied.applied);
+    assert_eq!(applied.generation, review.generation);
+    assert_eq!(applied.candidate, review.candidate);
+    assert_eq!(applied.candidate_hash, review.candidate_hash);
+    assert_eq!(responses.requests().len(), 3);
+    Ok(())
+}
