+async fn start_parent_thread(mcp: &mut TestAppServer) -> Result<String> {
+    let request_id = mcp
+        .send_thread_start_request(ThreadStartParams {
+            model: Some("mock-model".to_string()),
+            ..Default::default()
+        })
+        .await?;
+    let response = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_response_message(RequestId::Integer(request_id)),
+    )
+    .await??;
+    let ThreadStartResponse { thread, .. } = to_response::<ThreadStartResponse>(response)?;
+    Ok(thread.id)
+}
+
+async fn read_prompt_progress(
+    mcp: &mut TestAppServer,
+    thread_id: &str,
+    workspace_id: &str,
+    require_nonzero: bool,
+) -> Result<PromptAssistantProgressNotification> {
+    let notification = timeout(
+        DEFAULT_TIMEOUT,
+        mcp.read_stream_until_matching_notification("Prompt Assistant progress", |notification| {
+            if notification.method != "promptAssistant/progress" {
+                return false;
+            }
+            let Some(params) = notification.params.as_ref() else {
+                return false;
+            };
+            params["threadId"] == thread_id
+                && params["workspaceId"] == workspace_id
+                && (!require_nonzero || params["byteCount"].as_u64().is_some_and(|bytes| bytes > 0))
+        }),
+    )
+    .await??;
+    Ok(serde_json::from_value(
+        notification.params.expect("progress params"),
+    )?)
+}
