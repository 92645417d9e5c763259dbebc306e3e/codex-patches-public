+
+const DEFAULT_TIMEOUT: Duration = Duration::from_secs(10);
+const HIDDEN_MODEL: &str = "hidden-prompt-specialist";
+const WORKSPACE_ID: &str = "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa";
+const INVALID_REQUEST_ERROR_CODE: i64 = -32600;
+
+fn completed_with_usage(response_id: &str, usage: &TokenUsage) -> Value {
+    serde_json::json!({
+        "type": "response.completed",
+        "response": {
+            "id": response_id,
+            "usage": {
+                "input_tokens": usage.input_tokens,
+                "input_tokens_details": {
+                    "cached_tokens": usage.cached_input_tokens,
+                    "cache_write_tokens": usage.cache_write_input_tokens
+                },
+                "output_tokens": usage.output_tokens,
+                "output_tokens_details": {
+                    "reasoning_tokens": usage.reasoning_output_tokens
+                },
+                "total_tokens": usage.total_tokens
+            }
+        }
+    })
+}
+
+fn successful_response(
+    response_id: &str,
+    candidate: &str,
+    disposition: &str,
+    usage: &TokenUsage,
+) -> String {
+    let output = serde_json::json!({
+        "candidate": candidate,
+        "review": {"status": disposition, "rationale": "Intent preserved."}
+    })
+    .to_string();
+    sse(vec![
+        ev_response_created(response_id),
+        ev_assistant_message(&format!("message-{response_id}"), &output),
+        completed_with_usage(response_id, usage),
+    ])
+}
+
+fn prompt_catalog() -> ModelsResponse {
+    let mut visible = codex_models_manager::model_info::model_info_from_slug("mock-model");
+    visible.priority = 0;
+    visible.visibility = ModelVisibility::List;
+    visible.enabled = true;
+    let mut hidden = visible.clone();
+    hidden.slug = HIDDEN_MODEL.to_string();
+    hidden.display_name = "Prompt specialist".to_string();
+    hidden.priority = 1;
+    hidden.visibility = ModelVisibility::Hide;
+    hidden.enabled = true;
+    hidden.base_instructions = "selected hidden model instructions".to_string();
+    ModelsResponse {
+        models: vec![visible, hidden],
+    }
+}
+
+fn write_config(codex_home: &Path, server_uri: &str) -> std::io::Result<()> {
+    std::fs::write(
+        codex_home.join("config.toml"),
+        format!(
+            r#"
+model = "mock-model"
+approval_policy = "never"
+sandbox_mode = "read-only"
