@@ -0,0 +1,227 @@
+use std::sync::Arc;
+
+use codex_app_server_protocol::JSONRPCErrorError;
+use codex_app_server_protocol::PromptAssistantApplyParams;
+use codex_app_server_protocol::PromptAssistantApplyResponse;
